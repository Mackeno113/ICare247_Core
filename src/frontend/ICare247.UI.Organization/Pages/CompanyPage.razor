@* File    : CompanyPage.razor
   Module  : ICare247.UI.Organization
   Purpose : Màn "Công ty" — master-detail. Trái: TreeList cây công ty (baseline lưới cây).
             Phải: form 1:1 theo section nghiệp vụ. Mọi text qua Loc.L (i18n bắt buộc). *@

@page "/m/organization/company"
@inherits LocalizedComponentBase
@inject CompanyApiService Api

<PageTitle>@Loc.L("organization.company.title", "Công ty")</PageTitle>

<div class="org-page">
    @* ── Toolbar mỏng — 1 CTA chính ────────────────────────────────────── *@
    <div class="org-toolbar">
        <h1 class="org-title">@Loc.L("organization.company.title", "Công ty")</h1>
        <button class="btn btn-primary" @onclick="NewCompany">+ @Loc.L("organization.company.add", "Thêm công ty")</button>
    </div>

    @if (_notice is not null)
    {
        <div class="org-notice">@_notice <button class="org-notice-x" @onclick="() => _notice = null">×</button></div>
    }

    <div class="org-body">
        @* ── Trái: cây công ty ─────────────────────────────────────────── *@
        <div class="org-tree-pane">
            <DxTreeList Data="_tree"
                        KeyFieldName="@nameof(CompanyTreeNode.Id)"
                        ParentKeyFieldName="@nameof(CompanyTreeNode.ChaId)"
                        SelectionMode="TreeListSelectionMode.Single"
                        SelectedDataItem="_selectedNode"
                        SelectedDataItemChanged="OnNodeSelected"
                        ShowSearchBox="true"
                        AutoExpandAllNodes="true"
                        TextWrapEnabled="true"
                        AllowColumnReorder="true"
                        ColumnResizeMode="TreeListColumnResizeMode.ColumnsContainer"
                        HighlightRowOnHover="true"
                        FocusedRowEnabled="true"
                        CssClass="org-tree">
                <Columns>
                    <DxTreeListDataColumn FieldName="@nameof(CompanyTreeNode.Ten)"
                                          Caption="@Loc.L("organization.company.col.ten", "Tên công ty")" MinWidth="200" />
                    <DxTreeListDataColumn FieldName="@nameof(CompanyTreeNode.Ma)"
                                          Caption="@Loc.L("organization.company.col.ma", "Mã")" Width="120px" />
                    <DxTreeListDataColumn FieldName="@nameof(CompanyTreeNode.CapTen)"
                                          Caption="@Loc.L("organization.company.col.cap", "Cấp")" Width="120px" />
                    <DxTreeListDataColumn FieldName="@nameof(CompanyTreeNode.TrangThai)"
                                          Caption="@Loc.L("organization.company.col.trangThai", "Trạng thái")" Width="130px">
                        <CellDisplayTemplate>
                            @{ var node = (CompanyTreeNode)context.DataItem; }
                            <span class="org-badge @(node.TrangThai == "HoatDong" ? "is-on" : "is-off")">
                                @StatusLabel(node.TrangThai)
                            </span>
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                </Columns>
            </DxTreeList>
        </div>

        @* ── Phải: form chi tiết 1:1 ───────────────────────────────────── *@
        <div class="org-detail-pane">
            @if (_edit is null)
            {
                <div class="org-empty">@Loc.L("organization.company.emptyHint", "Chọn một công ty trong cây hoặc bấm “Thêm công ty”.")</div>
            }
            else
            {
                @if (_errors.Count > 0)
                {
                    <div class="org-errors">
                        <ul>@foreach (var e in _errors) { <li>@Loc.L(e, e)</li> }</ul>
                    </div>
                }

                <h2 class="org-detail-title">
                    @(_editId is null
                        ? Loc.L("organization.company.newTitle", "Công ty mới")
                        : (string.IsNullOrWhiteSpace(_edit.Ten) ? Loc.L("organization.company.title", "Công ty") : _edit.Ten))
                </h2>

                <DxFormLayout CssClass="org-form">
                    @* ── Định danh ── *@
                    <DxFormLayoutGroup Caption="@Loc.L("organization.company.section.identity", "Định danh")" ColSpanMd="12">
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.ma", "Mã công ty")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.Ma" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.ten", "Tên công ty")" ColSpanMd="8">
                            <DxTextBox @bind-Text="_edit.Ten" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.tenVietTat", "Tên viết tắt")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.TenVietTat" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.cap", "Cấp công ty")" ColSpanMd="4">
                            <DxComboBox TData="LookupOption" TValue="long"
                                        Data="_options.CapCongTy" TextFieldName="@nameof(LookupOption.Text)"
                                        ValueFieldName="@nameof(LookupOption.Id)" @bind-Value="_edit.CapCongTyId"
                                        NullText="@Loc.L("common.lookup.choose", "— Chọn —")" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.maSoThue", "Mã số thuế")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.MaSoThue" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.congTyCha", "Công ty cha")" ColSpanMd="8">
                            <DxComboBox TData="CompanyTreeNode" TValue="long?"
                                        Data="ParentOptions" TextFieldName="@nameof(CompanyTreeNode.Ten)"
                                        ValueFieldName="@nameof(CompanyTreeNode.Id)" @bind-Value="_edit.CongTyChaId"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        NullText="@Loc.L("organization.company.rootHint", "(Gốc — không có công ty cha)")" />
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    @* ── Địa chỉ ── *@
                    <DxFormLayoutGroup Caption="@Loc.L("organization.company.section.address", "Địa chỉ")" ColSpanMd="12">
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.diaChi", "Số nhà, đường")" ColSpanMd="12">
                            <DxTextBox @bind-Text="_edit.DiaChi" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.phuongXa", "Phường / Xã")" ColSpanMd="6">
                            <DxComboBox TData="LookupOption" TValue="long?"
                                        Data="_phuongXaOptions" TextFieldName="@nameof(LookupOption.Text)"
                                        ValueFieldName="@nameof(LookupOption.Id)" @bind-Value="_edit.PhuongXaId"
                                        SearchMode="ListSearchMode.AutoSearch" TextChanged="OnPhuongXaSearch"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        NullText="@Loc.L("organization.company.phuongXaHint", "Gõ để tìm phường/xã…")" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.tinh", "Tỉnh / Thành phố")" ColSpanMd="6">
                            <DxTextBox Text="@TinhText" ReadOnly="true"
                                       NullText="@Loc.L("organization.company.tinhHint", "(Suy từ phường/xã)")" />
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    @* ── Liên hệ ── *@
                    <DxFormLayoutGroup Caption="@Loc.L("organization.company.section.contact", "Liên hệ")" ColSpanMd="12">
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.dienThoai", "Điện thoại")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.DienThoai" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.email", "Email")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.Email" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.website", "Website")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.Website" />
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    @* ── Pháp nhân & kế toán ── *@
                    <DxFormLayoutGroup Caption="@Loc.L("organization.company.section.legal", "Pháp nhân & kế toán")" ColSpanMd="12">
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.nguoiDaiDien", "Người đại diện")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.NguoiDaiDien" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.giamDoc", "Giám đốc")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.GiamDoc" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.keToanTruong", "Kế toán trưởng")" ColSpanMd="4">
                            <DxTextBox @bind-Text="_edit.KeToanTruong" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.nganHang", "Ngân hàng")" ColSpanMd="6">
                            <DxComboBox TData="LookupOption" TValue="long?"
                                        Data="_options.NganHang" TextFieldName="@nameof(LookupOption.Text)"
                                        ValueFieldName="@nameof(LookupOption.Id)" @bind-Value="_edit.NganHangId"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        NullText="@Loc.L("common.lookup.choose", "— Chọn —")" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.soTaiKhoan", "Số tài khoản")" ColSpanMd="6">
                            <DxTextBox @bind-Text="_edit.SoTaiKhoan" />
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    @* ── Trạng thái ── *@
                    <DxFormLayoutGroup Caption="@Loc.L("organization.company.section.status", "Trạng thái")" ColSpanMd="12">
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.trangThai", "Trạng thái")" ColSpanMd="4">
                            <DxComboBox TData="StatusOpt" TValue="string"
                                        Data="_statusOptions" TextFieldName="@nameof(StatusOpt.Label)"
                                        ValueFieldName="@nameof(StatusOpt.Code)" @bind-Value="_edit.TrangThai" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="@Loc.L("organization.company.field.logo", "Logo (sắp có)")" ColSpanMd="8">
                            <span class="org-soon">@Loc.L("organization.company.logoSoon", "Tải logo sẽ bổ sung ở đợt quản lý tệp đính kèm.")</span>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>

                @* ── Footer: 1 primary (Lưu) + secondary ── *@
                <div class="org-footer">
                    @if (_editId is not null)
                    {
                        <button class="btn btn-danger-ghost" @onclick="() => DeleteAsync(_editId!.Value)" disabled="@_saving">
                            @Loc.L("common.action.delete", "Xóa")
                        </button>
                    }
                    <span class="org-footer-spacer"></span>
                    <button class="btn btn-secondary" @onclick="CancelEdit" disabled="@_saving">@Loc.L("common.action.cancel", "Hủy")</button>
                    <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                        @(_saving ? Loc.L("common.action.saving", "Đang lưu…") : Loc.L("common.action.save", "Lưu"))
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<CompanyTreeNode> _tree = [];
    private CompanyFormOptions _options = new();
    private List<LookupOption> _phuongXaOptions = [];
    private readonly List<StatusOpt> _statusOptions = [];

    private CompanyTreeNode? _selectedNode;
    private CompanyInput? _edit;
    private long? _editId;
    private readonly List<string> _errors = [];
    private string? _notice;
    private bool _saving;

    /// <summary>Option công ty cha = mọi công ty trừ chính bản ghi đang sửa (chống tự làm cha).</summary>
    private IEnumerable<CompanyTreeNode> ParentOptions
        => _editId is null ? _tree : _tree.Where(c => c.Id != _editId);

    /// <summary>Tên tỉnh suy từ phường-xã đang chọn (Extra của option).</summary>
    private string TinhText
        => _phuongXaOptions.FirstOrDefault(p => p.Id == _edit?.PhuongXaId)?.Extra ?? "";

    protected override async Task OnInitializedAsync()
    {
        _statusOptions.Add(new StatusOpt("HoatDong", Loc.L("organization.company.status.active", "Đang hoạt động")));
        _statusOptions.Add(new StatusOpt("NgungHoatDong", Loc.L("organization.company.status.inactive", "Ngừng hoạt động")));

        _options = await Api.GetOptionsAsync();
        _phuongXaOptions = await Api.SearchPhuongXaAsync(null);
        await ReloadTreeAsync();
    }

    private async Task ReloadTreeAsync() => _tree = await Api.GetTreeAsync();

    private async Task OnNodeSelected(object? item)
    {
        var node = item as CompanyTreeNode;
        _selectedNode = node;
        _notice = null; _errors.Clear();
        if (node is null) { _edit = null; _editId = null; return; }

        var d = await Api.GetByIdAsync(node.Id);
        if (d is null) { _edit = null; _editId = null; return; }

        // Đảm bảo phường-xã đang chọn có trong list để combo hiển thị đúng nhãn + suy tỉnh.
        if (d.PhuongXaId is not null && _phuongXaOptions.All(p => p.Id != d.PhuongXaId))
            _phuongXaOptions.Insert(0, new LookupOption { Id = d.PhuongXaId.Value, Text = d.PhuongXaTen ?? "", Extra = d.TinhTen });

        _editId = d.Id;
        _edit = new CompanyInput
        {
            Ma = d.Ma, Ten = d.Ten, TenVietTat = d.TenVietTat,
            CongTyChaId = d.CongTyChaId, CapCongTyId = d.CapCongTyId, MaSoThue = d.MaSoThue,
            DiaChi = d.DiaChi, PhuongXaId = d.PhuongXaId, DienThoai = d.DienThoai, Email = d.Email, Website = d.Website,
            NguoiDaiDien = d.NguoiDaiDien, GiamDoc = d.GiamDoc, KeToanTruong = d.KeToanTruong,
            NganHangId = d.NganHangId, SoTaiKhoan = d.SoTaiKhoan, TrangThai = d.TrangThai
        };
    }

    private void NewCompany()
    {
        _selectedNode = null; _editId = null; _notice = null; _errors.Clear();
        _edit = new CompanyInput
        {
            // Mặc định cha = node đang chọn (nếu có) → thêm công ty con nhanh.
            CongTyChaId = _selectedNode?.Id,
            CapCongTyId = _options.CapCongTy.FirstOrDefault()?.Id ?? 0,
            TrangThai = "HoatDong"
        };
    }

    private void CancelEdit() { _edit = null; _editId = null; _selectedNode = null; _errors.Clear(); }

    private async Task OnPhuongXaSearch(string text)
    {
        if (string.IsNullOrWhiteSpace(text) || text.Length < 1) return;
        _phuongXaOptions = await Api.SearchPhuongXaAsync(text);
    }

    private async Task SaveAsync()
    {
        if (_edit is null) return;
        _saving = true; _errors.Clear(); _notice = null;
        try
        {
            var result = await Api.SaveAsync(_editId, _edit);
            if (!result.Success) { _errors.AddRange(result.Errors); return; }

            await ReloadTreeAsync();
            _notice = Loc.L("organization.company.saved", "Đã lưu công ty.");
            // Sau khi lưu → mở lại bản ghi vừa lưu.
            var savedId = result.Id ?? _editId;
            _selectedNode = _tree.FirstOrDefault(c => c.Id == savedId);
            if (_selectedNode is not null) await OnNodeSelected(_selectedNode);
        }
        finally { _saving = false; }
    }

    private async Task DeleteAsync(long id)
    {
        _saving = true; _notice = null; _errors.Clear();
        try
        {
            var result = await Api.DeleteAsync(id);
            if (!result.Success)
            {
                _notice = Loc.L(result.Reason ?? "organization.company.error.deleteBlocked",
                    "Không thể xóa — công ty còn phụ thuộc.");
                return;
            }
            await ReloadTreeAsync();
            CancelEdit();
            _notice = Loc.L("organization.company.deleted", "Đã xóa công ty.");
        }
        finally { _saving = false; }
    }

    private string StatusLabel(string code)
        => _statusOptions.FirstOrDefault(s => s.Code == code)?.Label ?? code;

    /// <summary>Option trạng thái (code bất biến + nhãn i18n).</summary>
    public sealed record StatusOpt(string Code, string Label);
}
