@* File    : TreeLookupBoxRenderer.razor
   Purpose : Render TreeLookupBox — dropdown popup dạng cây expand/collapse.
             Dùng cho Editor_Type = TreeLookupBox.
             Bảng nguồn phải có cột Parent_Column để build hierarchy.
             Hỗ trợ filter cascading khi ReloadTriggerField thay đổi.
   Lưu ý   : Popup TELEPORT ra <body> (icare.teleportPopup) như IcSelectBox — trong DraggableModal,
             popup neo theo dòng chảy DOM sẽ bị .dm-modal{overflow:hidden} cắt mất (bug đã gặp: nhìn
             như lookup rỗng dù API trả đủ dữ liệu). Mở popup bám mousedown trên CẢ ô nhập, không chỉ
             @onfocus — user bấm vào ô là phải bung cây, không bắt bấm đúng nút nhỏ bên phải. *@

@inject ILookupQueryService LookupQuerySvc
@inject IJSRuntime JS
@implements IAsyncDisposable
@inherits LocalizedComponentBase

<div class="treelookup-wrapper">
    @* ── EditBox — gõ trực tiếp để lọc (giống LookupBox) ── *@
    <div class="lookupbox-editbox @(State?.EffectiveReadOnly == true ? "readonly" : "")"
         @ref="_editboxRef"
         @onmousedown="OnEditboxMouseDown">
        <input type="text"
               class="lookupbox-search-input"
               placeholder="@Loc.L("common.lookup.choose", "-- Chọn --")"
               value="@_inputText"
               disabled="@(State?.EffectiveReadOnly == true)"
               @oninput="OnSearchInput"
               @onfocus="OnFocus"
               @onblur="OnInputBlur"
               @onkeydown="OnKeyDown" />
        @if (State?.EffectiveReadOnly != true && !string.IsNullOrEmpty(State?.ValueString))
        {
            <button class="lookupbox-clear" type="button" tabindex="-1"
                    @onmousedown="ClearValue"
                    @onmousedown:preventDefault @onmousedown:stopPropagation
                    title="@Loc.L("common.action.clear", "Xóa")">✕</button>
        }
        @* preventDefault để ô nhập không mất focus (blur sẽ đóng popup vừa mở); stopPropagation để
           không kích hoạt luôn OnEditboxMouseDown của ô bao ngoài ⇒ mở rồi đóng ngay. *@
        <button class="lookupbox-btn" type="button" tabindex="-1"
                @onmousedown="OnToggleMouseDown"
                @onmousedown:preventDefault @onmousedown:stopPropagation
                disabled="@(State?.EffectiveReadOnly == true)"
                title="@Loc.L("common.lookup.openTree", "Mở cây")">
            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 1v14M4 5h8M2 9h5M9 9h5" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
        </button>
    </div>

    @* ── Popup cây ── *@
    @if (_popupVisible)
    {
        <div class="lookupbox-popup treelookup-popup"
             @ref="_popupRef"
             style="width:@(State?.LookupConfig?.DropDownWidth ?? 500)px">

            @* Tree content *@
            @if (_loading)
            {
                <div class="popup-loading">⏳ @Loc.L("common.lookup.loadingData", "Đang tải dữ liệu...")</div>
            }
            else if (_loadError is not null)
            {
                <div class="popup-error">⚠ @_loadError</div>
            }
            else if (_rootNodes.Count == 0)
            {
                <div class="popup-empty">@Loc.L("common.lookup.noData", "Không có dữ liệu")</div>
            }
            else
            {
                <div class="treelookup-tree"
                     style="max-height:@(State?.LookupConfig?.DropDownHeight ?? 400)px; overflow-y:auto">
                    @{ var _nodeIdx = 0; }
                    @foreach (var node in GetDisplayNodes())
                    {
                        var isActive = _nodeIdx == _highlightIndex;
                        <div class="tree-node @(State?.ValueString == node.Value ? "selected" : "") @(isActive ? "highlight" : "")"
                             style="padding-left:@(node.Level * 16 + 8)px"
                             @onmousedown="() => SelectNode(node)"
                             @onmousedown:preventDefault="true">
                            @if (node.HasChildren)
                            {
                                <span class="tree-toggle"
                                      @onmousedown="() => ToggleNode(node)"
                                      @onmousedown:stopPropagation="true"
                                      @onmousedown:preventDefault="true">
                                    @(node.IsExpanded ? "▾" : "▸")
                                </span>
                            }
                            else
                            {
                                <span class="tree-leaf-indent">　</span>
                            }
                            <span class="tree-label">@((MarkupString)HighlightLabel(node.Label))</span>
                        </div>
                        _nodeIdx++;
                    }
                </div>
            }
        </div>
        <div class="lookupbox-overlay" @onmousedown="() => ClosePopupAsync()"></div>
    }
</div>

@code {
    [Parameter, EditorRequired] public FieldState?                                 State    { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange { get; set; }
    [Parameter]                 public EventCallback<string>                       OnBlur   { get; set; }
    [Parameter]                 public Dictionary<string, object?>                 Context  { get; set; } = [];

    private bool    _popupVisible;
    private bool    _loading;
    private string? _loadError;
    private string  _searchText = "";
    private string  _inputText  = "";   // text trong ô input: display value hoặc search term đang gõ
    private object? _lastTriggerValue;
    private int     _highlightIndex = -1; // index node đang highlight để chọn bằng Enter / phím ↑↓

    // Teleport popup ra <body>: giữ ref ô neo + popup để JS định vị fixed theo ô (xem đầu file).
    private ElementReference _editboxRef;
    private ElementReference _popupRef;
    private bool             _teleported;

    // ── Tree state ────────────────────────────────────────────────────────────

    private List<TreeNode> _rootNodes = [];
    private Dictionary<string, bool> _expandedState = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (State is null) return;

        var triggerField = State.LookupConfig?.ReloadTriggerField;
        var currentTriggerValue = !string.IsNullOrWhiteSpace(triggerField)
            && Context.TryGetValue(triggerField, out var tv) ? tv : null;

        var needsLoad = _rootNodes.Count == 0
            || (triggerField is not null && !Equals(_lastTriggerValue, currentTriggerValue));

        if (needsLoad)
        {
            _lastTriggerValue = currentTriggerValue;
            if (_rootNodes.Count > 0) await ClearValue();
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        if (State is null) return;
        _loading   = true;
        _loadError = null;

        try
        {
            // QueryTreeAsync trả flat list với __parentId được inject bởi repository
            var rows = await LookupQuerySvc.QueryTreeAsync(State.FieldId, Context);
            _rootNodes = BuildTree(rows, State.LookupConfig);
        }
        catch (Exception ex)
        {
            _loadError  = ex.Message;
            _rootNodes  = [];
        }
        finally { _loading = false; }

        // Có data → resolve TÊN hiển thị cho giá trị đang chọn (popup đóng) để ô khỏi hiện id thô
        // (vd "3" thay vì tên công ty cha). OnParametersSet chạy TRƯỚC khi tree về nên không tự
        // cập nhật được chỗ này — mirror LookupBoxRenderer.
        if (!_popupVisible)
            _inputText = GetSelectedDisplay();
    }

    // ── Build tree từ flat list ────────────────────────────────────────────────

    /// <summary>
    /// Dựng cây từ danh sách phẳng. Tên cột lấy từ <paramref name="cfg"/>; thiếu cấu hình thì BÁO LỖI
    /// thay vì dựng cây rỗng — trước đây Value_Column rỗng làm mọi node cùng khóa "" rồi ToDictionary
    /// ném "same key", user chỉ thấy lookup trống mà không biết vì sao.
    /// <para>
    /// Ba lớp phòng thủ để KHÔNG BAO GIỜ nuốt mất dữ liệu đã tải: khóa trùng thì bỏ qua bản sau, node
    /// tự trỏ chính mình / tạo vòng lặp thì coi như gốc, và nếu vẫn không tìm ra gốc nào (dữ liệu vòng
    /// tròn) thì trả phẳng toàn bộ. Có dữ liệu mà hiện "không có dữ liệu" là kiểu lỗi tốn nhiều giờ
    /// nhất để truy — thà cây phẳng còn hơn màn hình trống.
    /// </para>
    /// <para>Sự kiện theo sau: caller gán <c>_rootNodes</c>; <c>_loadError</c> (nếu có) hiện trong popup.</para>
    /// </summary>
    private List<TreeNode> BuildTree(
        IReadOnlyList<Dictionary<string, object?>> rows,
        FieldLookupConfigDto? cfg)
    {
        var valueCol   = cfg?.ValueColumn   ?? "";
        var displayCol = ExtractColumnKey(cfg?.DisplayColumn ?? "");

        if (rows.Count > 0 && string.IsNullOrWhiteSpace(valueCol))
        {
            _loadError = Loc.L("common.lookup.missingConfig",
                "Thiếu cấu hình cột lookup (Value_Column/Display_Column). Kiểm tra Ui_Field.Lookup_Source = 'dynamic' và Ui_Field_Lookup của field này.");
            return [];
        }

        var allNodes = rows.Select(r => new TreeNode
        {
            Value    = GetColStr(r, valueCol),
            Label    = GetColStr(r, displayCol),
            ParentId = r.TryGetValue("__parentId", out var pid) ? pid?.ToString() : null,
        }).ToList();

        // TryAdd thay ToDictionary: dữ liệu trùng khóa là lỗi cấu hình, không phải cớ để cả control chết.
        var byId = new Dictionary<string, TreeNode>(StringComparer.OrdinalIgnoreCase);
        foreach (var node in allNodes)
            if (!string.IsNullOrEmpty(node.Value)) byId.TryAdd(node.Value, node);

        // Build cha/con — bỏ qua node tự trỏ chính mình (Cha_Id = Id) để nó không tự loại mình khỏi gốc.
        foreach (var node in allNodes)
        {
            if (string.IsNullOrEmpty(node.ParentId)
                || string.Equals(node.ParentId, node.Value, StringComparison.OrdinalIgnoreCase)
                || !byId.TryGetValue(node.ParentId, out var parent))
                continue;

            parent.Children.Add(node);
            node.Parent = parent;
        }

        // Vòng lặp cha-con (A→B→A): cắt liên kết của node nào leo lên gặp lại chính nó → thành gốc.
        foreach (var node in allNodes)
        {
            var seen = new HashSet<TreeNode>();
            for (var p = node.Parent; p is not null; p = p.Parent)
            {
                if (!seen.Add(p) || ReferenceEquals(p, node))
                {
                    node.Parent?.Children.Remove(node);
                    node.Parent = null;
                    break;
                }
            }
        }

        // Root = node không có cha hợp lệ
        var roots = allNodes.Where(n => n.Parent is null).ToList();

        // Không ra gốc nào mà vẫn có dữ liệu ⇒ quan hệ cha-con hỏng: hiện phẳng, đừng hiện rỗng.
        // Phải cắt sạch liên kết trước khi trả, không thì mỗi node vừa là gốc vừa là con ⇒ render trùng.
        if (roots.Count == 0 && allNodes.Count > 0)
        {
            foreach (var n in allNodes) { n.Parent = null; n.Children.Clear(); }
            return allNodes;
        }

        return roots;
    }

    // ── Hiển thị tree (flatten + filter + collapse) ───────────────────────────

    private bool IsFilterActive =>
        _searchText.Length >= Math.Max(1, State?.LookupConfig?.FilterMinLength ?? 0);

    private List<TreeNode> GetDisplayNodes()
    {
        if (!string.IsNullOrWhiteSpace(_searchText) && IsFilterActive)
        {
            // Search mode: flatten toàn bộ, lọc contains, thêm ancestors để có ngữ cảnh
            var term     = _searchText.ToLower();
            var allNodes = new List<TreeNode>();
            foreach (var root in _rootNodes)
                FlattenAll(root, 0, allNodes);

            var matched  = allNodes.Where(n => n.Label.ToLower().Contains(term)).ToHashSet();
            var visible  = new HashSet<TreeNode>(matched);
            foreach (var n in matched)
            {
                var p = n.Parent;
                while (p is not null) { visible.Add(p); p = p.Parent; }
            }

            return allNodes.Where(n => visible.Contains(n)).ToList();
        }

        var result = new List<TreeNode>();
        foreach (var root in _rootNodes)
            FlattenVisible(root, 0, result);
        return result;
    }

    // Wrap phần text khớp bằng <mark> — trả về HTML string an toàn
    private string HighlightLabel(string label)
    {
        var escaped = System.Net.WebUtility.HtmlEncode(label);
        if (!IsFilterActive || string.IsNullOrWhiteSpace(_searchText))
            return escaped;

        var term = System.Net.WebUtility.HtmlEncode(_searchText);
        var idx  = escaped.IndexOf(term, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return escaped;

        return escaped[..idx]
             + "<mark>" + escaped.Substring(idx, term.Length) + "</mark>"
             + escaped[(idx + term.Length)..];
    }

    private void FlattenAll(TreeNode node, int level, List<TreeNode> result)
    {
        node.Level       = level;
        node.HasChildren = node.Children.Count > 0;
        node.IsExpanded  = true;
        result.Add(node);
        foreach (var child in node.Children)
            FlattenAll(child, level + 1, result);
    }

    private void FlattenVisible(TreeNode node, int level, List<TreeNode> result)
    {
        node.Level       = level;
        node.HasChildren = node.Children.Count > 0;
        node.IsExpanded  = _expandedState.TryGetValue(node.Value, out var exp) ? exp : true;
        result.Add(node);

        if (node.IsExpanded)
            foreach (var child in node.Children)
                FlattenVisible(child, level + 1, result);
    }

    // ── UI interactions ────────────────────────────────────────────────────────

    /// <summary>
    /// Bấm chuột vào ô nhập (vùng nào cũng được): mở cây. KHÔNG dựa mỗi <c>@onfocus</c> — ô đã giữ focus
    /// sẵn thì trình duyệt không phát focus lần nữa, user bấm lại thấy "không lên gì".
    /// Sự kiện theo sau: OpenPopupAsync (nếu đang đóng); đang mở thì để nguyên cho user gõ lọc tiếp.
    /// </summary>
    private async Task OnEditboxMouseDown()
    {
        if (State?.EffectiveReadOnly == true) return;
        if (_popupVisible) return;
        await OpenPopupAsync();
    }

    /// <summary>Nút biểu tượng cây: đang mở thì đóng, đang đóng thì mở.</summary>
    private async Task OnToggleMouseDown()
    {
        if (State?.EffectiveReadOnly == true) return;
        if (_popupVisible) await ClosePopupAsync();
        else               await OpenPopupAsync();
    }

    /// <summary>
    /// Input được focus (Tab tới, hoặc click đầu tiên): mở cây — cùng đường với OnEditboxMouseDown.
    /// Sự kiện theo sau: OpenPopupAsync.
    /// </summary>
    private async Task OnFocus()
    {
        if (State?.EffectiveReadOnly == true) return;
        if (_popupVisible) return;
        await OpenPopupAsync();
    }

    /// <summary>
    /// Mở popup: xóa display để user gõ lọc, nạp dữ liệu nếu chưa có.
    /// Sự kiện theo sau: OnAfterRenderAsync teleport popup ra body rồi định vị theo ô neo.
    /// </summary>
    private async Task OpenPopupAsync()
    {
        _inputText    = "";
        _searchText   = "";
        _popupVisible = true;
        if (_rootNodes.Count == 0 && !_loading)
            await LoadDataAsync();
    }

    /// <summary>
    /// Input mất focus: đóng popup, khôi phục display text của node đang chọn.
    /// Node/Toggle dùng onmousedown + preventDefault để chạy trước blur này.
    /// </summary>
    private async Task OnInputBlur() => await ClosePopupAsync();

    /// <summary>
    /// Đóng popup. Trả popup về đúng chỗ cũ trong DOM TRƯỚC khi ẩn — Blazor xóa node ở vị trí gốc,
    /// bỏ bước này thì diff trượt và popup thành rác nằm lại trong body.
    /// Sự kiện theo sau: _popupVisible = false, ô hiển thị lại tên node đang chọn.
    /// </summary>
    private async Task ClosePopupAsync()
    {
        await RestorePopupAsync();
        _popupVisible   = false;
        _searchText     = "";
        _inputText      = GetSelectedDisplay();
        _highlightIndex = -1;
    }

    /// <summary>Gỡ teleport (idempotent, nuốt lỗi JS vì có thể gọi lúc circuit/JS đã đóng).</summary>
    private async Task RestorePopupAsync()
    {
        if (!_teleported) return;
        _teleported = false;
        try { await JS.InvokeVoidAsync("icare.restorePopup", _popupRef); } catch { /* no-op */ }
    }

    /// <summary>
    /// Teleport popup ra &lt;body&gt; + định vị fixed theo ô neo, ngay sau khi popup được render.
    /// Bắt buộc trong DraggableModal: modal có overflow:hidden + kéo bằng transform nên popup nằm
    /// trong dòng chảy DOM sẽ bị cắt cụt hoặc mất hẳn.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_popupVisible || _teleported) return;
        try
        {
            await JS.InvokeVoidAsync("icare.teleportPopup", _editboxRef, _popupRef);
            _teleported = true;
        }
        catch { /* JS chưa sẵn → popup vẫn hiện tại chỗ, chỉ có nguy cơ bị cắt */ }
    }

    /// <summary>Component bị gỡ khi popup còn teleport → trả node về, tránh popup mồ côi dính lại trên body.</summary>
    public async ValueTask DisposeAsync()
    {
        await RestorePopupAsync();
        Dispose();
    }

    /// <summary>
    /// Khi State đổi từ bên ngoài mà popup đang đóng → sync display text.
    /// Sự kiện theo sau: _inputText phản ánh giá trị đang chọn.
    /// </summary>
    protected override void OnParametersSet()
    {
        if (!_popupVisible)
            _inputText = GetSelectedDisplay();
    }

    private void ToggleNode(TreeNode node)
    {
        var current = _expandedState.TryGetValue(node.Value, out var v) ? v : true;
        _expandedState[node.Value] = !current;
    }

    private async Task SelectNode(TreeNode node)
    {
        if (State is null) return;

        // Tree_Selectable_Level: giới hạn node được chọn. Node không hợp lệ → chỉ đóng/mở nhánh,
        // không gán giá trị (VD "leaf" = chỉ chọn Xã, bấm Tỉnh chỉ expand).
        var level = State.LookupConfig?.TreeSelectableLevel;
        var selectable = level switch
        {
            "leaf"   => !node.HasChildren,
            "branch" => node.HasChildren,
            _        => true   // "all" / null
        };
        if (!selectable)
        {
            if (node.HasChildren) ToggleNode(node);
            return;
        }

        State.Value = node.Value;
        await ClosePopupAsync();
        await OnChange.InvokeAsync((State.FieldCode, (object?)node.Value));
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    private async Task ClearValue()
    {
        if (State is null) return;
        State.Value     = null;
        _inputText      = "";
        _searchText     = "";
        _highlightIndex = -1;
        await OnChange.InvokeAsync((State.FieldCode, null));
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _inputText    = e.Value?.ToString() ?? "";
        _searchText   = _inputText;
        _popupVisible = true;
        // Highlight node hiển thị đầu tiên để Enter chọn ngay sau khi gõ
        _highlightIndex = GetDisplayNodes().Count > 0 ? 0 : -1;
    }

    /// <summary>
    /// Điều hướng cây bằng bàn phím trên danh sách node đang hiển thị:
    /// ↓/↑ di chuyển highlight, Enter chọn node đang highlight, Escape đóng popup.
    /// Sự kiện theo sau: SelectNode (Enter) hoặc ClosePopupAsync (Escape) hoặc cập nhật _highlightIndex.
    /// </summary>
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (State?.EffectiveReadOnly == true) return;

        var nodes = GetDisplayNodes();

        switch (e.Key)
        {
            case "ArrowDown":
                if (nodes.Count > 0)
                    _highlightIndex = Math.Min(_highlightIndex + 1, nodes.Count - 1);
                break;

            case "ArrowUp":
                if (nodes.Count > 0)
                    _highlightIndex = Math.Max(_highlightIndex - 1, 0);
                break;

            case "Enter":
                if (_highlightIndex >= 0 && _highlightIndex < nodes.Count)
                    await SelectNode(nodes[_highlightIndex]);
                break;

            case "Escape":
                await ClosePopupAsync();
                break;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string GetSelectedDisplay()
    {
        if (State is null) return "";
        var selectedVal = State.ValueString ?? "";
        // Tìm trong flat list toàn bộ nodes
        var allNodes = FlattenAllNodes(_rootNodes);
        var found = allNodes.FirstOrDefault(n =>
            string.Equals(n.Value, selectedVal, StringComparison.OrdinalIgnoreCase));
        return found?.Label ?? selectedVal;
    }

    private static IEnumerable<TreeNode> FlattenAllNodes(IEnumerable<TreeNode> nodes)
    {
        foreach (var n in nodes)
        {
            yield return n;
            foreach (var child in FlattenAllNodes(n.Children))
                yield return child;
        }
    }

    private static string GetColStr(Dictionary<string, object?> row, string col)
    {
        if (string.IsNullOrWhiteSpace(col)) return "";
        if (row.TryGetValue(col, out var v)) return v?.ToString() ?? "";
        // Case-insensitive fallback
        var key = row.Keys.FirstOrDefault(k =>
            k.Equals(col, StringComparison.OrdinalIgnoreCase));
        return key is not null ? row[key]?.ToString() ?? "" : "";
    }

    private static string ExtractColumnKey(string expr)
    {
        if (string.IsNullOrWhiteSpace(expr)) return expr;
        var m = System.Text.RegularExpressions.Regex.Match(
            expr.Trim(), @"\bAS\s+(\w+)\s*$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (m.Success) return m.Groups[1].Value;
        if (expr.Contains('('))
        {
            var last = expr.LastIndexOf(' ');
            if (last >= 0) return expr[(last + 1)..].Trim();
        }
        return expr.Trim();
    }

    // ── Inner model ───────────────────────────────────────────────────────────

    private sealed class TreeNode
    {
        public string           Value       { get; set; } = "";
        public string           Label       { get; set; } = "";
        public string?          ParentId    { get; set; }
        public TreeNode?        Parent      { get; set; }
        public List<TreeNode>   Children    { get; } = [];
        // display state (set mỗi lần flatten)
        public int              Level       { get; set; }
        public bool             HasChildren { get; set; }
        public bool             IsExpanded  { get; set; } = true;
    }
}
