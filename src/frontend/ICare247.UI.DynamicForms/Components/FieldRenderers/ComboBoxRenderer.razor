@* File    : ComboBoxRenderer.razor
   Purpose : Dynamic ComboBox (Editor_Type = ComboBox + LookupSource = dynamic) — nạp rows từ Table/TVF/SQL
             qua LookupQueryService, reload khi ReloadTriggerField đổi.
             WEB-UX-04: UI dùng control DÙNG CHUNG <IcSelectBox> (đồng nhất mọi dropdown); component này chỉ
             giữ data-logic (load + cascade). List lớn → IcSelectBox giới hạn render + gợi ý gõ (không virtualize). *@

@inject ILookupQueryService LookupQuerySvc
@inject LocalizationService Loc

<IcSelectBox TItem="LookupItem"
             Items="_items"
             TextOf="@(i => i.Label)"
             IsSelected="@(i => i.Value == State?.ValueString)"
             SelectedText="@SelectedLabel"
             OnSelect="SelectItem"
             OnClear="ClearValue"
             HeaderText="@State?.Label"
             Placeholder="@NullTextValue"
             HasError="@(State?.Errors.Count > 0)"
             Disabled="@(State?.EffectiveReadOnly ?? false)" />

@code {
    [Parameter, EditorRequired] public FieldState?                                 State    { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange { get; set; }
    [Parameter]                 public EventCallback<string>                       OnBlur   { get; set; }
    /// <summary>Context snapshot toàn form — truyền vào query để hỗ trợ cascading filter.</summary>
    [Parameter]                 public Dictionary<string, object?>                 Context  { get; set; } = [];

    private object?          _lastTriggerValue;
    private List<LookupItem> _items = [];

    private string NullTextValue => State?.Label is { Length: > 0 } lbl ? "-- " + lbl + " --" : Loc.L("common.combo.choose", "-- Chọn --");

    /// <summary>Nhãn của giá trị đang chọn (hiển thị khi đóng); không khớp → chính giá trị thô.</summary>
    private string SelectedLabel => _items.FirstOrDefault(i => i.Value == State?.ValueString)?.Label
                                    ?? State?.ValueString ?? "";

    protected override async Task OnParametersSetAsync()
    {
        if (State is null) return;

        // Reload khi trigger field (cascade) đổi giá trị.
        var triggerField        = State.LookupConfig?.ReloadTriggerField;
        var currentTriggerValue = !string.IsNullOrWhiteSpace(triggerField)
                                  && Context.TryGetValue(triggerField, out var tv) ? tv : null;
        var needsLoad = _items.Count == 0
            || (triggerField is not null && !Equals(_lastTriggerValue, currentTriggerValue));

        if (needsLoad)
        {
            var isCascade = triggerField is not null && !Equals(_lastTriggerValue, currentTriggerValue) && _items.Count > 0;
            _lastTriggerValue = currentTriggerValue;
            if (isCascade) await ClearValue();   // cha đổi → xóa lựa chọn cũ
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        if (State is null) return;
        try
        {
            State.DynamicRows = await LookupQuerySvc.QueryAsync(State.FieldId, Context);
            var valCol = State.LookupConfig?.ValueColumn   ?? "";
            var lblCol = State.LookupConfig?.DisplayColumn ?? "";
            _items = State.DynamicRows
                .Select(row => new LookupItem(GetColValue(row, valCol), GetColValue(row, lblCol)))
                .ToList();
        }
        catch { State.DynamicRows = []; _items = []; }   // lỗi tải → rỗng (IcSelectBox hiện "không có kết quả")
    }

    private async Task SelectItem(LookupItem item)
    {
        if (State is null) return;
        State.Value = item.Value;
        await OnChange.InvokeAsync((State.FieldCode, (object?)item.Value));
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    private async Task ClearValue()
    {
        if (State is null) return;
        State.Value = null;
        await OnChange.InvokeAsync((State.FieldCode, null));
    }

    private static string GetColValue(Dictionary<string, object?> row, string col)
    {
        if (string.IsNullOrWhiteSpace(col)) return "";
        var kv = row.FirstOrDefault(p => p.Key.Equals(col, StringComparison.OrdinalIgnoreCase));
        return kv.Value?.ToString() ?? "";
    }

    /// <summary>Typed wrapper cho một row lookup (Value/Label).</summary>
    private sealed record LookupItem(string Value, string Label);
}
