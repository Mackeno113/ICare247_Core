@* File    : LookupComboBoxRenderer.razor
   Purpose : Static select từ Sys_Lookup (Editor_Type = LookupComboBox / Select…). Data = State.Options
             (đã load sẵn qua LookupApiService). WEB-UX-04: UI dùng control DÙNG CHUNG <IcSelectBox> (đồng
             nhất mọi dropdown). Prop allowUserInput → IcSelectBox.AllowFreeText (nhận giá trị gõ tay). *@

@using System.Text.Json
@using System.Text.Json.Serialization
@inject LocalizationService Loc

<IcSelectBox TItem="LookupOptionDto"
             Items="@(State?.Options ?? [])"
             TextOf="@(o => o.Label)"
             IsSelected="@(o => o.ItemCode == State?.ValueString)"
             SelectedText="@SelectedLabel"
             OnSelect="SelectOption"
             OnClear="ClearValue"
             AllowFreeText="_props.AllowUserInput"
             OnFreeText="SetFreeText"
             HeaderText="@State?.Label"
             Placeholder="@NullTextValue"
             HasError="@(State?.Errors.Count > 0)"
             Disabled="@(State?.EffectiveReadOnly ?? false)" />

@code {
    [Parameter, EditorRequired] public FieldState?                                 State    { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange { get; set; }
    [Parameter]                 public EventCallback<string>                       OnBlur   { get; set; }

    private LookupComboBoxProps _props = new();

    private string NullTextValue => State?.Label is { Length: > 0 } lbl ? "-- " + lbl + " --" : Loc.L("common.combo.choose", "-- Chọn --");

    /// <summary>Nhãn của giá trị đang chọn; không khớp option (vd free-text) → chính giá trị thô.</summary>
    private string SelectedLabel => State?.Options.FirstOrDefault(o => o.ItemCode == State.ValueString)?.Label
                                    ?? State?.ValueString ?? "";

    protected override void OnParametersSet() => _props = LookupComboBoxProps.Parse(State?.ControlPropsJson);

    private async Task SelectOption(LookupOptionDto option)
    {
        if (State is null) return;
        State.Value = option.ItemCode;
        await OnChange.InvokeAsync((State.FieldCode, (object?)option.ItemCode));
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    /// <summary>allowUserInput: nhận chuỗi gõ tay làm giá trị (không có trong Sys_Lookup).</summary>
    private async Task SetFreeText(string text)
    {
        if (State is null) return;
        State.Value = text;
        await OnChange.InvokeAsync((State.FieldCode, (object?)text));
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    private async Task ClearValue()
    {
        if (State is null) return;
        State.Value = null;
        await OnChange.InvokeAsync((State.FieldCode, null));
    }

    /// <summary>Props từ Control_Props_Json. JSON: {"searchMode":"AutoSearch","allowUserInput":false,"clearButton":true}</summary>
    private sealed class LookupComboBoxProps
    {
        /// <summary>"AutoSearch" (default) | "None". (IcSelectBox luôn gõ-lọc; giữ prop để tương thích cấu hình.)</summary>
        [JsonPropertyName("searchMode")]   public string SearchMode     { get; set; } = "AutoSearch";
        /// <summary>Cho phép gõ giá trị ngoài danh sách → IcSelectBox.AllowFreeText.</summary>
        [JsonPropertyName("allowUserInput")] public bool AllowUserInput { get; set; }
        /// <summary>Hiện nút xóa. (IcSelectBox luôn cho xóa khi có giá trị; giữ prop để tương thích.)</summary>
        [JsonPropertyName("clearButton")]  public bool ClearButton      { get; set; } = true;

        public static LookupComboBoxProps Parse(string? json)
        {
            if (string.IsNullOrWhiteSpace(json)) return new();
            try
            {
                return JsonSerializer.Deserialize<LookupComboBoxProps>(json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
            }
            catch { return new(); }
        }
    }
}
