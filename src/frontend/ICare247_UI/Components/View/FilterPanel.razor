@* File    : FilterPanel.razor
   Purpose : Panel lọc trái của lưới nâng cao (Ui_View_Filter). Render control theo Control_Type,
             validate Required (thông báo i18n + focus ô lỗi đầu tiên), nút Tìm/Đặt lại.
             Bấm Tìm → raise OnSearch với map Filter_Code → giá trị thô (engine ép kiểu). *@

@using ICare247_UI.Services
@inherits LocalizedComponentBase

<div class="fp-panel @(Collapsed ? "fp-collapsed" : "")">
    <div class="fp-header">
        <span class="fp-title">@SearchLabelText</span>
        @if (Collapsible)
        {
            <button class="fp-toggle" type="button" title="@(Collapsed ? Loc.L("common.action.expand", "Mở") : Loc.L("common.action.collapse", "Thu gọn"))"
                    @onclick="() => Collapsed = !Collapsed">@(Collapsed ? "»" : "«")</button>
        }
    </div>

    @if (!Collapsed)
    {
        <div class="fp-body">
            @foreach (var f in VisibleFilters)
            {
                var flt = f;
                var hasErr = _errors.Contains(flt.FilterCode);
                <div class="fp-field fp-span-@(Math.Clamp((int)flt.ColSpan, 1, 4))">
                    <label class="fp-label" title="@flt.Tooltip">
                        @flt.DisplayLabel
                        @if (flt.IsRequired) { <span class="fp-req">*</span> }
                    </label>
                    @RenderControl(flt, hasErr)
                    @if (hasErr)
                    {
                        <span class="fp-err-msg">@RequiredMessage(flt.DisplayLabel)</span>
                    }
                </div>
            }
        </div>

        <div class="fp-actions">
            <button class="btn btn-primary fp-search" type="button" disabled="@_searching"
                    @onclick="DoSearchAsync">
                @(_searching ? SearchingText : SearchLabelText)
            </button>
            <button class="btn btn-light fp-reset" type="button" disabled="@_searching"
                    @onclick="DoReset">@ResetLabelText</button>
        </div>
    }
</div>

@code {
    /// <summary>Danh sách control lọc (đã resolve i18n) từ ViewMetadata.</summary>
    [Parameter] public List<ViewFilterDto> Filters { get; set; } = [];

    /// <summary>Nhãn nút Tìm (view-specific); null → key chung common.filter.search.</summary>
    [Parameter] public string? SearchLabel { get; set; }
    [Parameter] public string? ResetLabel { get; set; }
    [Parameter] public bool Collapsible { get; set; } = true;

    /// <summary>Bấm Tìm (đã validate) → trả map Filter_Code → giá trị thô.</summary>
    [Parameter] public EventCallback<IReadOnlyDictionary<string, string?>> OnSearch { get; set; }

    private readonly Dictionary<string, string?> _values = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, ElementReference> _refs = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _errors = new(StringComparer.OrdinalIgnoreCase);
    private bool _searching;
    private bool _initialized;

    public bool Collapsed { get; set; }

    private List<ViewFilterDto> VisibleFilters =>
        Filters.Where(f => f.IsVisible).OrderBy(f => f.OrderNo).ToList();

    private string SearchLabelText => string.IsNullOrWhiteSpace(SearchLabel)
        ? Loc.L("common.filter.search", "Tìm kiếm") : SearchLabel!;
    private string ResetLabelText => string.IsNullOrWhiteSpace(ResetLabel)
        ? Loc.L("common.filter.reset", "Đặt lại") : ResetLabel!;
    private string SearchingText => Loc.L("common.filter.searching", "Đang tìm…");

    /// <summary>Thông báo thiếu tham số (i18n template "{0} là bắt buộc").</summary>
    private string RequiredMessage(string label)
        => Loc.L("common.validation.required", "{0} là bắt buộc", label);

    protected override void OnParametersSet()
    {
        if (_initialized) return;
        _initialized = true;
        // Khởi tạo giá trị mặc định từ Default_Value.
        foreach (var f in Filters)
            _values[f.FilterCode] = f.DefaultValue;
    }

    /// <summary>Giá trị hiện tại của một filter (an toàn null).</summary>
    private string? ValueOf(string code) => _values.TryGetValue(code, out var v) ? v : null;

    private void SetValue(string code, string? value)
    {
        _values[code] = value;
        _errors.Remove(code); // gõ lại → xóa lỗi cũ của ô đó
    }

    /// <summary>Validate Required → nếu lỗi: đánh dấu + focus ô đầu tiên; ngược lại raise OnSearch.</summary>
    private async Task DoSearchAsync()
    {
        _errors.Clear();
        foreach (var f in VisibleFilters.Where(f => f.IsRequired))
            if (string.IsNullOrWhiteSpace(ValueOf(f.FilterCode)))
                _errors.Add(f.FilterCode);

        if (_errors.Count > 0)
        {
            // Focus ô lỗi đầu tiên theo thứ tự hiển thị.
            var first = VisibleFilters.First(f => _errors.Contains(f.FilterCode));
            if (_refs.TryGetValue(first.FilterCode, out var er))
                await er.FocusAsync();
            return;
        }

        _searching = true;
        try
        {
            // Chỉ gửi giá trị có nhập (bỏ rỗng → engine coi NULL = bỏ lọc).
            var payload = _values
                .Where(kv => !string.IsNullOrWhiteSpace(kv.Value))
                .ToDictionary(kv => kv.Key, kv => kv.Value, StringComparer.OrdinalIgnoreCase);
            await OnSearch.InvokeAsync(payload);
        }
        finally { _searching = false; }
    }

    /// <summary>Đặt lại về giá trị mặc định + xóa lỗi (không tự Tìm).</summary>
    private void DoReset()
    {
        _errors.Clear();
        foreach (var f in Filters)
            _values[f.FilterCode] = f.DefaultValue;
    }

    /// <summary>Render editor theo Control_Type. v1: Text/Number/Date/Checkbox native;
    /// Combo/Radio/MultiSelect tạm fallback text (load options đợt 2 cùng MultiSelect→IN).</summary>
    private RenderFragment RenderControl(ViewFilterDto f, bool hasErr) => builder =>
    {
        var css = "fp-input" + (hasErr ? " fp-input-err" : "");
        var type = f.ControlType.ToLowerInvariant() switch
        {
            "number" => "number",
            "date"   => "date",
            _        => "text"
        };

        if (f.ControlType.Equals("Checkbox", StringComparison.OrdinalIgnoreCase))
        {
            builder.OpenElement(0, "input");
            builder.AddAttribute(1, "type", "checkbox");
            builder.AddAttribute(2, "class", "fp-check");
            builder.AddAttribute(3, "checked", ValueOf(f.FilterCode) == "true");
            builder.AddAttribute(4, "onchange",
                EventCallback.Factory.Create<ChangeEventArgs>(this,
                    e => SetValue(f.FilterCode, (e.Value is true) ? "true" : null)));
            builder.AddElementReferenceCapture(5, er => _refs[f.FilterCode] = er);
            builder.CloseElement();
            return;
        }

        builder.OpenElement(10, "input");
        builder.AddAttribute(11, "type", type);
        builder.AddAttribute(12, "class", css);
        builder.AddAttribute(13, "placeholder", f.Placeholder ?? "");
        builder.AddAttribute(14, "title", f.Tooltip ?? "");
        builder.AddAttribute(15, "value", ValueOf(f.FilterCode) ?? "");
        builder.AddAttribute(16, "onchange",
            EventCallback.Factory.Create<ChangeEventArgs>(this,
                e => SetValue(f.FilterCode, e.Value?.ToString())));
        builder.AddElementReferenceCapture(17, er => _refs[f.FilterCode] = er);
        builder.CloseElement();
    };
}
