@* File    : DataView.razor
   Purpose : Lưới/cây hiển thị danh sách metadata-driven từ Ui_View. Chọn DxGrid (Grid) hoặc
             DxTreeList (TreeList) theo View_Type; render ô theo Render_Mode (Text/Boolean/Html). *@

@using System.Globalization
@using System.Dynamic
@using Ganss.Xss
@using ICare247_UI.Services
@inject NavigationManager Navigation
@inject GridLayoutService Layouts
@inject LocalizationService Loc
@implements IDisposable

@* Toolbar (Thêm/Refresh/Export…) dùng chung cho CẢ tree lẫn grid — trước đây chỉ nhánh grid có. *@
@if (ToolbarActions.Count > 0)
{
    <div class="dv-toolbar">
        @foreach (var a in ToolbarActions)
        {
            var act = a;
            <button class="btn btn-light dv-action" title="@(act.Tooltip ?? act.Label ?? act.ActionCode)"
                    @onclick="() => ExecuteActionAsync(act)">
                @if (!string.IsNullOrWhiteSpace(act.Icon)) { <span class="dv-action-icon">@act.Icon</span> }
                <span>@(act.Label ?? act.ActionCode)</span>
            </button>
        }
    </div>
}

@if (View.ViewType.Equals("TreeList", StringComparison.OrdinalIgnoreCase)
     && !string.IsNullOrWhiteSpace(View.KeyField) && !string.IsNullOrWhiteSpace(View.ParentField))
{
    @* VirtualScrollingEnabled + height ở .dv-treelist → header GHIM khi cuộn cây (bắt buộc mọi lưới data). *@
    @* ParentKeyFieldName = "__parentKey" (id cha THÔ backend emit riêng cho TreeList) — cột cha hiển thị
       đã bị auto-JOIN đổi thành TÊN nên không khớp Key_Field. LayoutAuto* → lưu/khôi phục layout per-user. *@
    <DxTreeList @ref="_tree"
                Data="_gridRows"
                KeyFieldName="@View.KeyField"
                ParentKeyFieldName="@ParentKeyAlias"
                LayoutAutoLoading="OnTreeLayoutLoading"
                LayoutAutoSaving="OnTreeLayoutSaving"
                ShowFilterRow="View.ShowFilterRow"
                FilterMenuButtonDisplayMode="TreeListFilterMenuButtonDisplayMode.Always"
                VirtualScrollingEnabled="true"
                CssClass="dv-treelist"
                TextWrapEnabled="true"
                AllowColumnReorder="true"
                ColumnResizeMode="TreeListColumnResizeMode.ColumnsContainer"
                HighlightRowOnHover="true"
                FocusedRowEnabled="true"
                RowDoubleClick="OnTreeRowDoubleClick">
        <Columns>
            @if (View.SelectionMode.Equals("multiple", StringComparison.OrdinalIgnoreCase))
            {
                @* Cột chọn ghim trái + khai báo đầu tiên → luôn ngoài cùng bên trái (baseline lưới). *@
                <DxTreeListSelectionColumn Width="44px" FixedPosition="TreeListColumnFixedPosition.Left" />
            }

            @* Cột STT — số thứ tự dòng hiển thị (VisibleIndex theo thứ tự cây). *@
            <DxTreeListDataColumn Caption="@Loc.L("common.column.stt", "STT")" Width="56px"
                                  AllowSort="false" FixedPosition="TreeListColumnFixedPosition.Left">
                <CellDisplayTemplate>
                    <span class="dv-stt">@(context.VisibleIndex + 1)</span>
                </CellDisplayTemplate>
            </DxTreeListDataColumn>

            @foreach (var col in DataColumns)
            {
                var c = col;
                <DxTreeListDataColumn Caption="@c.DisplayCaption" FieldName="@c.FieldName"
                                      Width="@c.Width" AllowSort="c.AllowSort"
                                      FilterRowEditorVisible="c.AllowFilter"
                                      FilterMenuButtonDisplayMode="TreeListFilterMenuButtonDisplayMode.Always">
                    <CellDisplayTemplate>
                        @RenderCell(AsRow(context.DataItem), c)
                    </CellDisplayTemplate>
                </DxTreeListDataColumn>
            }

            @* Cột Thao tác — Sửa mọi node; Xóa CHỈ ở node lá / cha không còn con (tránh mồ côi con + vi phạm FK). *@
            @if (HasRowActions)
            {
                <DxTreeListDataColumn Caption="@Loc.L("common.column.actions", "Thao tác")"
                                      Width="96px" AllowSort="false"
                                      FixedPosition="TreeListColumnFixedPosition.Right">
                    <CellDisplayTemplate>
                        @{ var trow = AsRow(context.DataItem); }
                        @if (View.AllowEdit)
                        {
                            <button class="btn-icon" title="@Loc.L("common.action.edit", "Sửa")"
                                    @onclick="() => OnEdit.InvokeAsync(trow)">✏️</button>
                        }
                        @if (View.AllowDelete && IsLeafOrChildless(trow))
                        {
                            <button class="btn-icon btn-icon-danger" title="@Loc.L("common.action.delete", "Xóa")"
                                    @onclick="() => DeleteRowAsync(trow)">🗑️</button>
                        }
                    </CellDisplayTemplate>
                </DxTreeListDataColumn>
            }
        </Columns>
    </DxTreeList>
}
else
{
    <DxGrid @ref="_grid"
            Data="_gridRows"
            LayoutAutoLoading="OnLayoutLoading"
            LayoutAutoSaving="OnLayoutSaving"
            ShowFilterRow="View.ShowFilterRow"
            ShowGroupPanel="View.ShowGroupPanel"
            VirtualScrollingEnabled="View.VirtualScroll"
            PageSize="@(View.PageSize < 1 ? 20 : View.PageSize)"
            PagerVisible="@(View.AllowPaging && !View.VirtualScroll)"
            PageSizeSelectorVisible="View.AllowPaging"
            PageSizeSelectorItems="@(new[] { 10, 20, 50 })"
            SelectionMode="@SelectionModeOf()"
            SelectedDataItems="SelectedDataItems"
            SelectedDataItemsChanged="SelectedDataItemsChanged"
            RowDoubleClick="OnRowDoubleClick"
            CssClass="dv-dxgrid"
            TextWrapEnabled="true"
            AllowColumnReorder="true"
            ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
            HighlightRowOnHover="true"
            FocusedRowEnabled="true">
        <Columns>
            @* Cột chọn (checkbox) — luôn ở ngoài cùng bên trái, baseline grid danh mục. *@
            <DxGridSelectionColumn Width="40px" FixedPosition="GridColumnFixedPosition.Left" />

            @* Cột STT — số thứ tự dòng hiển thị (đổi theo sort/paging). *@
            <DxGridCommandColumn Width="56px" Caption="@Loc.L("common.column.stt", "STT")" FixedPosition="GridColumnFixedPosition.Left"
                                 NewButtonVisible="false">
                <CellDisplayTemplate>
                    <span class="dv-stt">@(context.VisibleIndex + 1)</span>
                </CellDisplayTemplate>
            </DxGridCommandColumn>

            @foreach (var col in DataColumns)
            {
                var c = col;
                <DxGridDataColumn Caption="@c.DisplayCaption"
                                  FieldName="@c.FieldName"
                                  Width="@c.Width"
                                  MinWidth="@(c.MinWidth ?? 0)"
                                  FixedPosition="@FixedOf(c)"
                                  TextAlignment="@AlignOf(c)"
                                  AllowSort="c.AllowSort"
                                  AllowGroup="c.AllowGroup"
                                  SortIndex="@(c.SortIndex ?? -1)"
                                  SortOrder="@SortOrderOf(c)"
                                  FilterRowEditorVisible="c.AllowFilter"
                                  FilterRowOperatorType="@FilterOpOf(c)"
                                  FilterMenuButtonDisplayMode="GridFilterMenuButtonDisplayMode.Always">
                    <CellDisplayTemplate>
                        @RenderCell(AsRow(context.DataItem), c)
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            }

            @* Cột Thao tác — Sửa/Xóa theo dòng; tự ẩn nếu View không cho hoặc không có Edit_Form. *@
            @if (HasRowActions)
            {
                <DxGridCommandColumn Width="96px" Caption="@Loc.L("common.column.actions", "Thao tác")" FixedPosition="GridColumnFixedPosition.Right"
                                     NewButtonVisible="false">
                    <CellDisplayTemplate>
                        @{ var row = AsRow(context.DataItem); }
                        @if (View.AllowEdit)
                        {
                            <button class="btn-icon" title="@Loc.L("common.action.edit", "Sửa")"
                                    @onclick="() => OnEdit.InvokeAsync(row)">✏️</button>
                        }
                        @if (View.AllowDelete)
                        {
                            <button class="btn-icon btn-icon-danger" title="@Loc.L("common.action.delete", "Xóa")"
                                    @onclick="() => DeleteRowAsync(row)">🗑️</button>
                        }
                    </CellDisplayTemplate>
                </DxGridCommandColumn>
            }

        </Columns>
    </DxGrid>
}

@code {
    [Parameter] public ViewMetadataDto View { get; set; } = new();
    [Parameter] public List<Dictionary<string, object?>> Items { get; set; } = [];
    /// <summary>Double-click dòng → mở Sửa. Tham số = cả dòng (trang tự resolve khóa).</summary>
    [Parameter] public EventCallback<IDictionary<string, object?>> OnEdit { get; set; }
    [Parameter] public EventCallback<object?> OnDelete { get; set; }
    [Parameter] public EventCallback OnAdd { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<ViewActionDto> OnUnhandledAction { get; set; }

    /// <summary>Nút xuất tài liệu server-side theo mẫu (Export/Print + Engine=Server + Target=mã bộ mẫu).
    /// Payload gồm dòng đang chọn để trang gọi DocTemplateApiService.</summary>
    [Parameter] public EventCallback<ServerRenderRequest> OnServerRender { get; set; }

    /// <summary>Các dòng đang chọn (two-way) — chỉ có ý nghĩa khi Selection_Mode='multiple'.</summary>
    [Parameter] public IReadOnlyList<object> SelectedDataItems { get; set; } = [];
    [Parameter] public EventCallback<IReadOnlyList<object>> SelectedDataItemsChanged { get; set; }

    private IGrid? _grid;
    private DxTreeList? _tree;

    /// <summary>Alias cột id cha THÔ backend emit riêng cho TreeList (tránh auto-JOIN nuốt id).
    /// Dùng làm ParentKeyFieldName của cây + nguồn tính <see cref="_parentKeys"/>.</summary>
    private const string ParentKeyAlias = "__parentKey";

    /// <summary>Tập khóa (KeyField) đang LÀM CHA — mọi giá trị id cha (__parentKey) xuất hiện trong dữ liệu.
    /// Dùng để ẩn nút Xóa ở node còn con. Rebuild trong <see cref="BuildGridRows"/>.</summary>
    private readonly HashSet<string> _parentKeys = new(StringComparer.Ordinal);

    // ── Lưu/khôi phục layout lưới per-user (L0 localStorage + server) ──
    private CancellationTokenSource? _saveCts;

    /// <summary>Grid khởi tạo → nạp layout đã lưu của user (rỗng/hỏng → giữ mặc định Ui_View).</summary>
    private async Task OnLayoutLoading(GridPersistentLayoutEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(View.ViewCode)) return;
        var json = await Layouts.GetAsync(View.ViewCode);
        if (string.IsNullOrEmpty(json)) return;
        try { e.Layout = System.Text.Json.JsonSerializer.Deserialize<GridPersistentLayout>(json); }
        catch { /* JSON layout cũ/khác cấu trúc → bỏ qua, dùng mặc định */ }
    }

    /// <summary>User đổi layout → debounce 600ms (gộp nhiều thao tác) → lưu localStorage + server.</summary>
    private Task OnLayoutSaving(GridPersistentLayoutEventArgs e)
    {
        if (!string.IsNullOrWhiteSpace(View.ViewCode))
        {
            var json = System.Text.Json.JsonSerializer.Serialize(e.Layout);
            _saveCts?.Cancel();
            var cts = new CancellationTokenSource();
            _saveCts = cts;
            _ = DebouncedSaveAsync(json, cts.Token);
        }
        return Task.CompletedTask;
    }

    private async Task DebouncedSaveAsync(string json, CancellationToken token)
    {
        try { await Task.Delay(600, token); }
        catch (TaskCanceledException) { return; }
        if (token.IsCancellationRequested) return;
        await Layouts.SaveAsync(View.ViewCode, json);
    }

    public void Dispose() => _saveCts?.Cancel();

    // ── Lưu/khôi phục layout CÂY per-user (song song grid, dùng type TreeList*) ──
    /// <summary>TreeList khởi tạo → nạp layout đã lưu (rỗng/hỏng → giữ mặc định).</summary>
    private async Task OnTreeLayoutLoading(TreeListPersistentLayoutEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(View.ViewCode)) return;
        var json = await Layouts.GetAsync(View.ViewCode);
        if (string.IsNullOrEmpty(json)) return;
        try { e.Layout = System.Text.Json.JsonSerializer.Deserialize<TreeListPersistentLayout>(json); }
        catch { /* JSON layout cũ/khác cấu trúc → bỏ qua, dùng mặc định */ }
    }

    /// <summary>User đổi layout cây → debounce 600ms → lưu localStorage + server.</summary>
    private Task OnTreeLayoutSaving(TreeListPersistentLayoutEventArgs e)
    {
        if (!string.IsNullOrWhiteSpace(View.ViewCode))
        {
            var json = System.Text.Json.JsonSerializer.Serialize(e.Layout);
            _saveCts?.Cancel();
            var cts = new CancellationTokenSource();
            _saveCts = cts;
            _ = DebouncedSaveAsync(json, cts.Token);
        }
        return Task.CompletedTask;
    }

    /// <summary>Nút toolbar (Scope = Toolbar | Both), sắp theo Order_No.</summary>
    private List<ViewActionDto> ToolbarActions => View.Actions
        .Where(a => a.Scope.Equals("Toolbar", StringComparison.OrdinalIgnoreCase)
                 || a.Scope.Equals("Both", StringComparison.OrdinalIgnoreCase))
        .OrderBy(a => a.OrderNo)
        .ToList();

    /// <summary>Thực thi một action toolbar theo Action_Type / Action_Code.</summary>
    private async Task ExecuteActionAsync(ViewActionDto a)
    {
        switch (a.ActionType.ToLowerInvariant())
        {
            case "export":
                // Server-side (docx/pdf theo mẫu) → xuất qua Doc_Template; còn lại DxGrid client.
                if (await TryServerRenderAsync(a)) return;
                await ExportAsync(a.ExportFormat, a.ExportEngine);
                return;
            case "print":
                // Print theo mẫu (Target = mã bộ mẫu) → render server; nếu không có mẫu, để caller xử lý.
                if (await TryServerRenderAsync(a)) return;
                await OnUnhandledAction.InvokeAsync(a);
                return;
            case "navigate":
                if (!string.IsNullOrWhiteSpace(a.Target))
                    Navigation.NavigateTo(a.Target!);
                return;
            case "builtin":
                await ExecuteBuiltInAsync(a.ActionCode);
                return;
            default: // Event | Api → chưa wire
                await OnUnhandledAction.InvokeAsync(a);
                return;
        }
    }

    private async Task ExecuteBuiltInAsync(string code)
    {
        switch (code.ToLowerInvariant())
        {
            case "add":     await OnAdd.InvokeAsync(); break;
            case "refresh": await OnRefresh.InvokeAsync(); break;
            default:        break; // edit/delete/column-chooser ở row/grid, bỏ qua toolbar
        }
    }

    /// <summary>
    /// Nếu action là xuất theo mẫu server-side (Target = mã bộ mẫu + docx/pdf hoặc Engine='Server'),
    /// gom dòng đang chọn rồi phát <see cref="OnServerRender"/> để trang gọi render. Trả true nếu đã xử lý.
    /// </summary>
    private async Task<bool> TryServerRenderAsync(ViewActionDto a)
    {
        var fmt = (a.ExportFormat ?? "").ToLowerInvariant();
        var isServer = string.Equals(a.ExportEngine, "Server", StringComparison.OrdinalIgnoreCase)
                       || fmt is "pdf" or "docx";
        if (!isServer || string.IsNullOrWhiteSpace(a.Target)) return false;

        // Dòng đang chọn (tick checkbox) làm keyParams; lấy dòng đầu nếu chọn nhiều.
        // Sao sang Dictionary cụ thể (ExpandoObject/IDictionary không implement IReadOnlyDictionary).
        var sel = SelectedDataItems?.FirstOrDefault();
        var row = new Dictionary<string, object?>(AsRow(sel), StringComparer.OrdinalIgnoreCase);
        await OnServerRender.InvokeAsync(new ServerRenderRequest(
            a.Target!.Trim(), fmt is "docx" ? "docx" : "pdf", row, row.Count > 0));
        return true;
    }

    /// <summary>
    /// Export client qua DxGrid (giá trị thuần — DxGrid xuất theo FieldName, bỏ render template).
    /// docx/pdf theo mẫu đã tách sang <see cref="TryServerRenderAsync"/>; ở đây chỉ xlsx/csv.
    /// </summary>
    private async Task ExportAsync(string? format, string? engine)
    {
        if (_grid is null) return;

        var fmt = (format ?? "xlsx").ToLowerInvariant();
        var name = string.IsNullOrWhiteSpace(View.ExportFileName) ? View.ViewCode : View.ExportFileName!;

        // Server-side không có Target (mẫu) → không xuất được client, để caller thông báo.
        if (string.Equals(engine, "Server", StringComparison.OrdinalIgnoreCase) || fmt is "pdf" or "docx")
        {
            await OnUnhandledAction.InvokeAsync(new ViewActionDto
            {
                ActionType = "Export", ExportFormat = fmt, ExportEngine = "Server"
            });
            return;
        }

        if (fmt == "csv")
            await _grid.ExportToCsvAsync($"{name}.csv");
        else
            await _grid.ExportToXlsxAsync($"{name}.xlsx");
    }

    /// <summary>Cột Data hiển thị (Column_Kind='Data', Is_Visible), sắp theo Order_No.</summary>
    private List<ViewColumnDto> DataColumns => View.Columns
        .Where(c => c.IsVisible && c.ColumnKind.Equals("Data", StringComparison.OrdinalIgnoreCase))
        .Where(c => !string.IsNullOrWhiteSpace(c.FieldName))
        .OrderBy(c => c.OrderNo)
        .ToList();

    /// <summary>Hiện cột lệnh sửa/xóa khi View cho phép + có form sửa.</summary>
    private bool HasRowActions =>
        !string.IsNullOrWhiteSpace(View.EditFormCode) && (View.AllowEdit || View.AllowDelete);

    /// <summary>Double-click dòng → mở Sửa (truyền CẢ dòng; trang tự resolve khóa). Bỏ qua nếu View không cho sửa.</summary>
    private async Task OnRowDoubleClick(GridRowClickEventArgs e)
    {
        if (!View.AllowEdit || string.IsNullOrWhiteSpace(View.EditFormCode) || _grid is null) return;
        var item = _grid.GetDataItem(e.VisibleIndex);
        if (item is null) return;
        await OnEdit.InvokeAsync(AsRow(item));
    }

    /// <summary>Double-click node cây → mở Sửa (mirror grid). Bỏ qua nếu View không cho sửa.</summary>
    private async Task OnTreeRowDoubleClick(TreeListRowClickEventArgs e)
    {
        if (!View.AllowEdit || string.IsNullOrWhiteSpace(View.EditFormCode) || _tree is null) return;
        var item = _tree.GetDataItem(e.VisibleIndex);
        if (item is null) return;
        await OnEdit.InvokeAsync(AsRow(item));
    }

    /// <summary>True khi node là lá hoặc cha không còn con → được phép Xóa (khóa không xuất hiện
    /// làm ParentField của bất kỳ dòng nào). Node đang có con → ẩn nút Xóa (tránh mồ côi + FK).</summary>
    private bool IsLeafOrChildless(IDictionary<string, object?> row)
    {
        if (string.IsNullOrWhiteSpace(View.KeyField)) return true;
        var key = GetCell(row, View.KeyField!)?.ToString();
        return string.IsNullOrWhiteSpace(key) || !_parentKeys.Contains(key);
    }

    // Mặc định Multiple → cột chọn hiển thị checkbox (chuẩn grid danh mục); chỉ "single" mới đơn chọn.
    private GridSelectionMode SelectionModeOf() => View.SelectionMode?.ToLowerInvariant() switch
    {
        "single" => GridSelectionMode.Single,
        _        => GridSelectionMode.Multiple
    };

    /// <summary>Nút Xóa theo dòng → resolve khóa từ Key_Field rồi phát OnDelete (trang mở dialog xác nhận).</summary>
    private async Task DeleteRowAsync(IDictionary<string, object?> row)
    {
        if (string.IsNullOrWhiteSpace(View.KeyField)) return;
        var id = GetCell(row, View.KeyField!);
        if (id is null) return;
        await OnDelete.InvokeAsync(id);
    }

    // Dòng grid là ExpandoObject (IDictionary<string,object>) — nhận diện qua IDictionary.
    private static IDictionary<string, object?> AsRow(object? dataItem)
        => dataItem as IDictionary<string, object?> ?? new Dictionary<string, object?>();

    private static object? GetCell(IDictionary<string, object?> row, string col)
    {
        var hit = row.FirstOrDefault(kv => kv.Key.Equals(col, StringComparison.OrdinalIgnoreCase));
        return hit.Equals(default(KeyValuePair<string, object?>)) ? null : hit.Value;
    }

    /// <summary>Ghim cột theo Fixed_Position cấu hình (none/left/right → enum DevExpress).</summary>
    private static GridColumnFixedPosition FixedOf(ViewColumnDto c) => (c.FixedPosition ?? "").ToLowerInvariant() switch
    {
        "left"  => GridColumnFixedPosition.Left,
        "right" => GridColumnFixedPosition.Right,
        _       => GridColumnFixedPosition.None
    };

    /// <summary>
    /// Toán tử filter mặc định của ô filter row (Mức 1 — suy theo kiểu hiển thị/căn lề):
    /// text → Contains; boolean & cột canh phải (số) → Equal; còn lại để DevExpress tự chọn.
    /// User vẫn đổi được qua nút menu filter (FilterMenuButtonDisplayMode=Always).
    /// (Mức 2 metadata-driven theo Filter_Operator cấu hình — xem TASKS VIEW-3h.)
    /// </summary>
    private static GridFilterRowOperatorType FilterOpOf(ViewColumnDto c)
    {
        var rm = (c.RenderMode ?? "").ToLowerInvariant();
        if (rm == "boolean") return GridFilterRowOperatorType.Equal;
        if ((c.TextAlign ?? "").ToLowerInvariant() == "right") return GridFilterRowOperatorType.Equal;
        // date/datetime/time → Default (DevExpress tự cho editor ngày + toán tử ngày).
        return rm is "text" or "html" or "link" or "badge" or "template" or ""
            ? GridFilterRowOperatorType.Contains
            : GridFilterRowOperatorType.Default;
    }

    /// <summary>Sắp xếp mặc định theo Sort_Order cấu hình (asc/desc → enum; null = không sắp).</summary>
    private static GridColumnSortOrder SortOrderOf(ViewColumnDto c) => (c.SortOrder ?? "").ToLowerInvariant() switch
    {
        "asc"  => GridColumnSortOrder.Ascending,
        "desc" => GridColumnSortOrder.Descending,
        _      => GridColumnSortOrder.None
    };

    private static GridTextAlignment AlignOf(ViewColumnDto c) => (c.TextAlign ?? "").ToLowerInvariant() switch
    {
        "right"  => GridTextAlignment.Right,
        "center" => GridTextAlignment.Center,
        "left"   => GridTextAlignment.Left,
        _        => IsNumeric(c.RenderMode) ? GridTextAlignment.Right : GridTextAlignment.Left
    };

    private static bool IsNumeric(string renderMode) => false; // suy theo dữ liệu ở DisplayCell

    /// <summary>
    /// Render ô theo Render_Mode (Text/Boolean/Html/Image/Link/Badge) + áp conditional style
    /// (Style_Rule_Json) lên span bao ngoài.
    /// </summary>
    private RenderFragment RenderCell(IDictionary<string, object?> row, ViewColumnDto col) => builder =>
    {
        var value = GetCell(row, col.FieldName);
        var style = ResolveCellStyle(row, col);

        builder.OpenElement(0, "span");
        if (!string.IsNullOrEmpty(style))
            builder.AddAttribute(1, "style", style);

        var renderMode = col.RenderMode.ToLowerInvariant();

        // Template gộp nhiều token {Field} → render cả khi ô FieldName rỗng.
        if (renderMode == "template")
        {
            builder.AddContent(17, RenderTemplate(row, col.DisplayFormat));
        }
        else if (value is not null)
        {
            switch (renderMode)
            {
                case "date":
                    builder.AddContent(18, FormatValue(value, col.DisplayFormat ?? "dd/MM/yyyy"));
                    break;
                case "datetime":
                    builder.AddContent(19, FormatValue(value, col.DisplayFormat ?? "dd/MM/yyyy HH:mm"));
                    break;
                case "time":
                    builder.AddContent(20, FormatValue(value, col.DisplayFormat ?? @"hh\:mm"));
                    break;
                case "boolean":
                    var on = value is bool b ? b : bool.TryParse(value.ToString(), out var pb) && pb;
                    builder.AddContent(2, on ? "✓" : "");
                    break;
                case "html":
                    // SEC4-3: sanitize HTML trước khi render (bỏ <script>/on*/javascript: …) → chống stored-XSS
                    builder.AddContent(3, (MarkupString)_htmlSanitizer.Sanitize(value.ToString() ?? ""));
                    break;
                case "image":
                    var imgSrc = value.ToString() ?? "";
                    if (IsSafeUrl(imgSrc))
                    {
                        builder.OpenElement(4, "img");
                        builder.AddAttribute(5, "src", imgSrc);
                        builder.AddAttribute(6, "class", "dv-cell-img");
                        builder.AddAttribute(7, "alt", col.FieldName);
                        builder.CloseElement();
                    }
                    else
                    {
                        builder.AddContent(4, imgSrc); // src không an toàn → hiện text, không render <img>
                    }
                    break;
                case "link":
                    var href = value.ToString() ?? "";
                    if (IsSafeUrl(href))
                    {
                        builder.OpenElement(8, "a");
                        builder.AddAttribute(9, "href", href);
                        builder.AddAttribute(10, "target", "_blank");
                        builder.AddAttribute(11, "rel", "noopener");
                        builder.AddContent(12, href);
                        builder.CloseElement();
                    }
                    else
                    {
                        builder.AddContent(8, href); // SEC4-2: href không an toàn (vd javascript:) → render text thường
                    }
                    break;
                case "badge":
                    builder.OpenElement(13, "span");
                    builder.AddAttribute(14, "class", "dv-badge");
                    builder.AddContent(15, FormatValue(value, col.DisplayFormat));
                    builder.CloseElement();
                    break;
                default: // Text | Template (Template chưa render token — fallback text)
                    builder.AddContent(16, FormatValue(value, col.DisplayFormat));
                    break;
            }
        }

        builder.CloseElement();
    };

    // ── Conditional formatting (Style_Rule_Json — định dạng đơn giản client-eval) ──

    /// <summary>Cache rule đã parse theo từng cột (parse 1 lần / lần đổi metadata).</summary>
    private readonly Dictionary<string, List<StyleRule>> _rulesCache = new(StringComparer.OrdinalIgnoreCase);
    private int _rulesViewId = -1;

    /// <summary>
    /// Dữ liệu đưa vào DxGrid/DxTreeList — dạng <see cref="ExpandoObject"/> (mỗi dòng).
    /// DxGrid KHÔNG filter/sort được trên <c>Dictionary</c> (không suy ra kiểu cột);
    /// ExpandoObject là dạng dữ liệu động DevExpress hỗ trợ data-shaping đầy đủ.
    /// </summary>
    private List<ExpandoObject> _gridRows = [];

    /// <summary>Tham chiếu Items lần dựng gần nhất — chỉ dựng lại khi Items đổi (giữ ổn định selection).</summary>
    private object? _builtFromItems;

    protected override void OnParametersSet()
    {
        // CHỈ dựng lại _gridRows khi Items đổi (reference) — nếu dựng mỗi render sẽ tạo
        // ExpandoObject mới → DxGrid mất khớp dòng đang chọn (đếm sai, tick không ăn).
        if (!ReferenceEquals(Items, _builtFromItems))
        {
            BuildGridRows();
            _builtFromItems = Items;
        }

        // Parse lại rule chỉ khi đổi View.
        if (_rulesViewId == View.ViewId) return;
        _rulesViewId = View.ViewId;
        _rulesCache.Clear();
        foreach (var col in View.Columns)
        {
            if (string.IsNullOrWhiteSpace(col.StyleRuleJson)) continue;
            try
            {
                var rules = System.Text.Json.JsonSerializer.Deserialize<List<StyleRule>>(
                    col.StyleRuleJson!, JsonOpts);
                if (rules is { Count: > 0 }) _rulesCache[col.FieldName] = rules;
            }
            catch { /* JSON rule sai cú pháp → bỏ qua, không format */ }
        }
    }

    /// <summary>
    /// Chuyển từng dòng Dictionary → ExpandoObject; ÉP KIỂU theo Render_Mode cho cột ngày/giờ
    /// (server trả chuỗi JSON → parse sang DateTime/TimeSpan) để DxGrid hiện đúng editor lọc
    /// (date-picker) + sort theo ngày, không phải lọc chữ.
    /// </summary>
    private void BuildGridRows()
    {
        var types = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var c in View.Columns)
            if (!string.IsNullOrWhiteSpace(c.FieldName))
                types[c.FieldName] = c.RenderMode.ToLowerInvariant();

        var rows = new List<ExpandoObject>(Items.Count);
        foreach (var d in Items)
        {
            var e = new ExpandoObject();
            var ed = (IDictionary<string, object?>)e;
            foreach (var kv in d)
                ed[kv.Key] = types.TryGetValue(kv.Key, out var rm) ? ConvertCell(kv.Value, rm) : kv.Value;
            rows.Add(e);
        }
        _gridRows = rows;

        // Dựng lại tập khóa-cha cho luật xóa của tree — đọc id cha THÔ (__parentKey), KHÔNG dùng
        // View.ParentField (cột đó đã bị auto-JOIN đổi thành TÊN nên không khớp Key_Field id).
        _parentKeys.Clear();
        foreach (IDictionary<string, object?> r in _gridRows)
            if (r.TryGetValue(ParentKeyAlias, out var p) && p is not null)
            {
                var s = p.ToString();
                if (!string.IsNullOrWhiteSpace(s)) _parentKeys.Add(s);
            }
    }

    /// <summary>Ép kiểu giá trị ô theo render mode (date/datetime → DateTime; time → TimeSpan). Lỗi → giữ nguyên.</summary>
    private static object? ConvertCell(object? v, string renderMode)
    {
        if (v is null) return null;
        switch (renderMode)
        {
            case "date":
            case "datetime":
                if (v is DateTime) return v;
                return DateTime.TryParse(v.ToString(), CultureInfo.InvariantCulture,
                    DateTimeStyles.RoundtripKind, out var dt) ? dt : v;
            case "time":
                if (v is TimeSpan) return v;
                var s = v.ToString() ?? "";
                if (TimeSpan.TryParse(s, CultureInfo.InvariantCulture, out var t)) return t;
                return DateTime.TryParse(s, CultureInfo.InvariantCulture,
                    DateTimeStyles.RoundtripKind, out var d2) ? d2.TimeOfDay : v;
            default:
                return v;
        }
    }

    private static readonly System.Text.Json.JsonSerializerOptions JsonOpts =
        new(System.Text.Json.JsonSerializerDefaults.Web);

    /// <summary>Trả CSS inline cho ô nếu có rule conditional khớp (rule đầu khớp thắng).</summary>
    private string? ResolveCellStyle(IDictionary<string, object?> row, ViewColumnDto col)
    {
        if (!_rulesCache.TryGetValue(col.FieldName, out var rules)) return null;

        foreach (var r in rules)
        {
            if (r.When is null || r.Style is null || r.Style.Count == 0) continue;
            if (MatchCondition(row, r.When))
                return BuildCss(r.Style);
        }
        return null;
    }

    /// <summary>So khớp điều kiện rule với giá trị dòng theo toán tử (= != &gt; &gt;= &lt; &lt;=).</summary>
    private static bool MatchCondition(IDictionary<string, object?> row, RuleCondition cond)
    {
        if (string.IsNullOrWhiteSpace(cond.Field)) return false;
        var actual = GetCell(row, cond.Field!);
        var expected = cond.Value;

        var op = (cond.Op ?? "=").Trim();

        // Ưu tiên so sánh số nếu cả 2 vế là số.
        if (TryToDouble(actual, out var an) && TryToDouble(expected, out var en))
        {
            return op switch
            {
                "=" or "==" => an == en,
                "!=" or "<>" => an != en,
                ">"  => an > en,
                ">=" => an >= en,
                "<"  => an < en,
                "<=" => an <= en,
                _    => false
            };
        }

        // So sánh chuỗi (chỉ = / !=).
        var asStr = actual?.ToString() ?? "";
        var exStr = expected.ValueKind == System.Text.Json.JsonValueKind.String
            ? expected.GetString() ?? ""
            : expected.ToString();
        return op switch
        {
            "=" or "==" => asStr.Equals(exStr, StringComparison.OrdinalIgnoreCase),
            "!=" or "<>" => !asStr.Equals(exStr, StringComparison.OrdinalIgnoreCase),
            _ => false
        };
    }

    private static bool TryToDouble(object? value, out double d)
    {
        switch (value)
        {
            case null: d = 0; return false;
            case double db: d = db; return true;
            case long l:    d = l;  return true;
            case int i:     d = i;  return true;
            case decimal m: d = (double)m; return true;
        }
        return double.TryParse(value.ToString(), System.Globalization.NumberStyles.Any,
            CultureInfo.InvariantCulture, out d);
    }

    private static bool TryToDouble(System.Text.Json.JsonElement je, out double d)
    {
        d = 0;
        return je.ValueKind switch
        {
            System.Text.Json.JsonValueKind.Number => je.TryGetDouble(out d),
            System.Text.Json.JsonValueKind.String => double.TryParse(je.GetString(),
                System.Globalization.NumberStyles.Any, CultureInfo.InvariantCulture, out d),
            _ => false
        };
    }

    /// <summary>Dựng chuỗi CSS từ map style (color/background/fontWeight...).</summary>
    private static string BuildCss(Dictionary<string, string> style)
    {
        var sb = new System.Text.StringBuilder();
        foreach (var kv in style)
        {
            var prop = kv.Key.Trim().ToLowerInvariant() switch
            {
                "color"                  => "color",
                "background" or "bg"     => "background-color",
                "fontweight" or "font-weight" => "font-weight",
                "fontstyle" or "font-style"   => "font-style",
                "textalign" or "text-align"   => "text-align",
                _ => null
            };
            if (prop is not null) sb.Append(prop).Append(':').Append(kv.Value).Append(';');
        }
        return sb.ToString();
    }

    private sealed class StyleRule
    {
        public RuleCondition? When { get; set; }
        public Dictionary<string, string>? Style { get; set; }
    }

    private sealed class RuleCondition
    {
        public string? Field { get; set; }
        public string? Op { get; set; }
        public System.Text.Json.JsonElement Value { get; set; }
    }

    /// <summary>
    /// SEC4-3: sanitizer dùng chung cho cột renderMode "html" — cấu hình mặc định Ganss.Xss
    /// (giữ tag/attr an toàn, loại <c>&lt;script&gt;</c>, handler <c>on*</c>, URL <c>javascript:</c>…).
    /// Tái dùng 1 instance (Sanitize thread-safe; WASM đơn luồng).
    /// </summary>
    private static readonly HtmlSanitizer _htmlSanitizer = new();

    /// <summary>
    /// SEC4-2: chỉ cho phép URL an toàn cho cột link/image — chặn scheme thực thi mã
    /// (<c>javascript:</c>, <c>data:</c>, <c>vbscript:</c>). Cho phép tương đối + http(s)/mailto/tel.
    /// </summary>
    private static bool IsSafeUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url)) return false;
        var u = url.TrimStart();
        if (u.StartsWith('/') || u.StartsWith('#') || u.StartsWith('?') || u.StartsWith('.'))
            return true; // đường dẫn tương đối
        return u.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
            || u.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
            || u.StartsWith("mailto:", StringComparison.OrdinalIgnoreCase)
            || u.StartsWith("tel:", StringComparison.OrdinalIgnoreCase);
    }

    private static string FormatValue(object value, string? fmt)
    {
        if (!string.IsNullOrWhiteSpace(fmt))
        {
            switch (value)
            {
                case long l:     return l.ToString(fmt, CultureInfo.CurrentCulture);
                case int i:      return i.ToString(fmt, CultureInfo.CurrentCulture);
                case decimal d:  return d.ToString(fmt, CultureInfo.CurrentCulture);
                case double db:  return db.ToString(fmt, CultureInfo.CurrentCulture);
                case DateTime dt2: return dt2.ToString(fmt, CultureInfo.CurrentCulture);
                case TimeSpan tsp: return tsp.ToString(fmt, CultureInfo.CurrentCulture);
                case string s when DateTime.TryParse(
                        s, CultureInfo.InvariantCulture, DateTimeStyles.RoundtripKind, out var dt):
                    return dt.ToString(fmt, CultureInfo.CurrentCulture);
            }
        }
        return value.ToString() ?? "";
    }

    /// <summary>Render template chèn token: thay "{Field}" bằng giá trị ô tương ứng (vd "{Ma} - {Ten}").</summary>
    private static string RenderTemplate(IDictionary<string, object?> row, string? template)
    {
        if (string.IsNullOrEmpty(template)) return "";
        return System.Text.RegularExpressions.Regex.Replace(template, @"\{(\w+)\}", m =>
        {
            var v = GetCell(row, m.Groups[1].Value);
            return v?.ToString() ?? "";
        });
    }
}
