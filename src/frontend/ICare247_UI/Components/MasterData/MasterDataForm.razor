@* File    : MasterDataForm.razor
   Purpose : Form Thêm/Sửa 1 bản ghi danh mục — tái dùng FieldRenderer + lưới responsive .fields-grid.
             Load metadata form (FormApi), prefill khi Sửa, validate server-side khi Lưu (POST/PUT). *@

@using ICare247_UI.Models
@using ICare247_UI.Components
@inject FormApiService        FormApi
@inject MasterDataApiService  MasterApi
@inject LookupApiService      LookupApi
@inject AttachmentApiService  AttachmentApi
@inject IJSRuntime            JS
@inherits LocalizedComponentBase

@if (_loading)
{
    <div class="md-form-loading"><div class="spinner"></div><span>@Loc.L("masterdata.form.loading", "Đang tải form…")</span></div>
}
else if (_error is not null)
{
    <div class="error-banner"><strong>⚠ @Loc.L("common.label.error", "Lỗi:")</strong> @_error</div>
}
else
{
    <div class="md-form">
        @if (ShowTitle)
        {
            <h3 class="md-form-title">@(IsEditMode ? Loc.L("common.action.update", "Cập nhật") : Loc.L("common.action.create", "Thêm mới")) — @_formName</h3>
        }

        @* Toast lỗi: ghim sticky đầu body (dưới tiêu đề đã neo) + căn phải → luôn thấy khi cuộn. *@
        @if (_formError is not null || _formMessages.Count > 0)
        {
            <div class="md-form-alert">
                <div class="result-invalid md-form-alert-toast">
                    <button type="button" class="md-form-alert-close"
                            title="@Loc.L("common.action.close", "Đóng")" @onclick="DismissError">✕</button>
                    @if (_formError is not null)
                    {
                        <div class="md-form-alert-title">@_formError</div>
                    }
                    @if (_formMessages.Count > 0)
                    {
                        <ul class="md-form-banner-list">
                            @foreach (var m in _formMessages) { <li>@m</li> }
                        </ul>
                    }
                </div>
            </div>
        }

        @{
            // Gom field theo section (mirror FormRunner). Field không thuộc section nào → nhóm orphan.
            // NOTE: không dùng biến tên 'section' vì @section là Razor directive.
            var sections = _form?.Sections ?? [];
            var sectionGroups = sections
                .Select(sec => new
                {
                    Name   = sec.SectionName,
                    Fields = _fieldStates.Where(fs => sec.Fields.Any(f => f.FieldCode == fs.FieldCode)).ToList()
                })
                .Where(g => g.Fields.Count > 0)
                .ToList();

            var orphanFields = _fieldStates
                .Where(fs => !sections.Any(s => s.Fields.Any(f => f.FieldCode == fs.FieldCode)))
                .ToList();

            // Số nhóm thực có nội dung. ≤1 → render phẳng (không khung group).
            var groupCount = sectionGroups.Count + (orphanFields.Count > 0 ? 1 : 0);
            var useGroups  = groupCount > 1;
        }

        <div class="form-body">
        @if (useGroups)
        {
            @foreach (var grp in sectionGroups)
            {
                <div class="section-card">
                    @if (!string.IsNullOrWhiteSpace(grp.Name))
                    {
                        <div class="section-title">@grp.Name</div>
                    }
                    <div class="fields-grid" style="--form-cols:@_formColumns">
                        @foreach (var fs in grp.Fields)
                        {
                            <FieldRenderer State="fs"
                                           OnChange="OnFieldChanged"
                                           OnBlur="OnFieldBlur"
                                           Context="BuildContext()"
                                           DebugMode="false" />
                        }
                    </div>
                </div>
            }
            @if (orphanFields.Count > 0)
            {
                <div class="section-card">
                    <div class="section-title">@Loc.L("masterdata.form.otherFields", "Các field khác")</div>
                    <div class="fields-grid" style="--form-cols:@_formColumns">
                        @foreach (var fs in orphanFields)
                        {
                            <FieldRenderer State="fs"
                                           OnChange="OnFieldChanged"
                                           OnBlur="OnFieldBlur"
                                           Context="BuildContext()"
                                           DebugMode="false" />
                        }
                    </div>
                </div>
            }
        }
        else
        {
            @* Chỉ 1 nhóm → render field phẳng, không bọc card group *@
            <div class="fields-grid" style="--form-cols:@_formColumns">
                @foreach (var fs in _fieldStates)
                {
                    <FieldRenderer State="fs"
                                   OnChange="OnFieldChanged"
                                   OnBlur="OnFieldBlur"
                                   Context="BuildContext()"
                                   DebugMode="false" />
                }
            </div>
        }
        </div>

        <div class="md-form-footer">
            <button class="btn btn-secondary" @onclick="Cancel" disabled="@_saving">@Loc.L("common.action.cancel", "Hủy")</button>
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_saving">
                @(_saving ? Loc.L("common.action.saving", "Đang lưu…") : "💾 " + Loc.L("common.action.save", "Lưu"))
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public string FormCode { get; set; } = "";
    /// <summary>PK bản ghi: null = Thêm mới, có giá trị = Sửa.</summary>
    [Parameter] public object? Id { get; set; }
    /// <summary>Phát khi lưu thành công — tham số = PK (mới hoặc cũ).</summary>
    [Parameter] public EventCallback<object?> OnSaved { get; set; }
    /// <summary>Phát khi user bấm Hủy.</summary>
    [Parameter] public EventCallback OnCancelled { get; set; }
    /// <summary>Hiện tiêu đề h3 trong form. Đặt false khi popup đã có thanh tiêu đề riêng (DraggableModal).</summary>
    [Parameter] public bool ShowTitle { get; set; } = true;
    /// <summary>Phát bề rộng modal hài hòa theo số cột form (vd "460px") sau khi load metadata —
    /// để popup chứa form (DraggableModal) thu hẹp khi form 1 cột, rộng dần khi nhiều cột.</summary>
    [Parameter] public EventCallback<string> OnWidthResolved { get; set; }

    /// <summary>Giá trị đổ sẵn khi Thêm mới (prefill từ panel lọc — ADR-030), key = Field_Code.</summary>
    [Parameter] public IReadOnlyDictionary<string, object?>? InitialValues { get; set; }

    /// <summary>Field_Code khóa (read-only) khi prefill — không cho sửa lại giá trị đổ sẵn.</summary>
    [Parameter] public IReadOnlyCollection<string>? LockedFields { get; set; }

    private bool IsEditMode => Id is not null;

    private List<FieldState> _fieldStates = [];
    /// <summary>Metadata form giữ lại để nhóm field theo section khi render (mirror FormRunner).</summary>
    private FormMetadataDto? _form;
    private string _formName = "";
    /// <summary>Số cột lưới nền form (Ui_Form.Columns, 1..4). Đẩy vào CSS var --form-cols.</summary>
    private int _formColumns = 4;
    private bool   _loading  = true;
    private bool   _saving;
    private string? _error;       // lỗi load
    private string? _formError;   // dòng tóm tắt lỗi hiển thị đầu form (vd "Có N lỗi cần sửa")
    private List<string> _formMessages = [];  // lỗi CẤP FORM (field_name rỗng / không khớp field) — banner

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true; _error = null; _formError = null; _formMessages.Clear();
        try
        {
            var form = await FormApi.GetFormAsync(FormCode);
            if (form is null) { _error = Loc.L("masterdata.form.notfound", "Form '{0}' không tồn tại.", FormCode); return; }
            _form = form;
            _formName = form.FormName.Length > 0 ? form.FormName : form.FormCode;
            _formColumns = Math.Clamp(form.Columns ?? 4, 1, 4);
            // Báo bề rộng modal phù hợp số cột (popup chứa form tự co/giãn cho hài hòa).
            await OnWidthResolved.InvokeAsync(ModalWidthForColumns(_formColumns));

            // Build field states. GIỮ field ảo (Is_Virtual): chúng là field cha cascade (VD Tỉnh/
            // Ngân hàng) — phải render để user chọn + có trong context để bơm @param cho lookup con.
            // Field ảo KHÔNG map cột DB nên bị loại ở bước Lưu (SaveAsync), không phải ở đây.
            _fieldStates = form.Fields
                .Select(f => new FieldState
                {
                    FieldId      = f.FieldId,
                    FieldCode    = f.FieldCode.Length > 0 ? f.FieldCode : $"field_{f.FieldId}",
                    FieldType    = NormalizeFieldType(f.FieldType, f.LookupSource),
                    Label        = f.Label.Length > 0 ? f.Label : f.FieldCode,
                    IsVisible    = f.IsVisible,
                    IsReadOnly   = f.IsReadOnly,
                    IsRequired   = f.IsRequired,
                    LockOnEdit   = f.LockOnEdit,
                    IsVirtual    = f.IsVirtual,
                    IsEditMode   = IsEditMode,
                    ColSpan      = f.ColSpan > 0 ? f.ColSpan : (byte)1,
                    LookupSource = f.LookupSource,
                    LookupCode   = f.LookupSource == "static"  ? f.LookupCode   : null,
                    LookupConfig = f.LookupSource == "dynamic" ? f.LookupConfig : null,
                    ControlPropsJson = f.ControlPropsJson,
                }).ToList();

            await LoadLookupOptionsAsync();

            // Prefill khi Sửa
            if (IsEditMode && Id is not null)
            {
                var record = await MasterApi.GetByIdAsync(FormCode, Id);
                if (record is not null)
                {
                    foreach (var fs in _fieldStates)
                    {
                        var hit = record.FirstOrDefault(
                            kv => kv.Key.Equals(fs.FieldCode, StringComparison.OrdinalIgnoreCase));
                        if (!hit.Equals(default(KeyValuePair<string, object?>)))
                            fs.Value = hit.Value;
                    }
                }
            }
            // Prefill khi Thêm mới — đổ giá trị từ panel lọc (ADR-030); LockedFields → khóa read-only.
            else if (!IsEditMode && InitialValues is not null && InitialValues.Count > 0)
            {
                var init = new Dictionary<string, object?>(InitialValues, StringComparer.OrdinalIgnoreCase);
                var locked = LockedFields is null
                    ? new HashSet<string>(StringComparer.OrdinalIgnoreCase)
                    : new HashSet<string>(LockedFields, StringComparer.OrdinalIgnoreCase);
                foreach (var fs in _fieldStates)
                {
                    if (init.TryGetValue(fs.FieldCode, out var val) && val is not null)
                    {
                        fs.Value = val;
                        if (locked.Contains(fs.FieldCode)) fs.IsReadOnly = true;
                    }
                }
            }
        }
        catch (Exception ex) { _error = ApiErrorLocalizer.Describe(Loc, ex); }
        finally { _loading = false; }
    }

    private Task OnFieldChanged((string Code, object? Value) args)
    {
        var fs = _fieldStates.FirstOrDefault(f => f.FieldCode == args.Code);
        if (fs is not null) { fs.Value = args.Value; fs.Errors.Clear(); }
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnFieldBlur(string fieldCode) => Task.CompletedTask;

    private async Task SaveAsync()
    {
        _saving = true; _formError = null; _formMessages.Clear();
        foreach (var fs in _fieldStates) fs.Errors.Clear();
        try
        {
            // Gửi mọi field ĐANG HIỂN THỊ (IsVisible), TRỪ field ảo (Is_Virtual — không map cột DB,
            // chỉ để lọc cascade). Field hiển thị nhưng bị khóa (read-only / LockOnEdit) vẫn gửi —
            // không sửa được nên giá trị không đổi, vô hại. Field ẩn (IsVisible=false) không gửi.
            var values = _fieldStates
                .Where(fs => fs.IsVisible && !fs.IsVirtual)
                .ToDictionary(fs => fs.FieldCode, fs => fs.Value);

            var result = await MasterApi.SaveAsync(FormCode, Id, values);

            if (result.Success)
            {
                // Đa-tệp-khi-thêm-mới: gắn các tệp đã upload (treo) vào record vừa có Id.
                await LinkPendingAttachmentsAsync(result.Id);
                await OnSaved.InvokeAsync(result.Id);
                return;
            }

            // Map lỗi: khớp field → tô đỏ ô; lỗi cấp form (field_name rỗng / không khớp field) → banner.
            foreach (var err in result.Errors)
            {
                var fs = string.IsNullOrEmpty(err.FieldCode)
                    ? null
                    : _fieldStates.FirstOrDefault(
                        f => f.FieldCode.Equals(err.FieldCode, StringComparison.OrdinalIgnoreCase));
                if (fs is not null) fs.Errors.Add(err.Message);
                else _formMessages.Add(err.Message);
            }

            var fieldErrorCount = result.Errors.Count - _formMessages.Count;
            _formError = fieldErrorCount > 0
                ? Loc.L("masterdata.form.haserrors", "Có {0} lỗi cần sửa trước khi lưu.", fieldErrorCount)
                : (_formMessages.Count == 0 ? Loc.L("common.msg.saveFailed", "Lưu thất bại.") : null);

            // Trỏ chuột + cuộn tới field lỗi ĐẦU TIÊN (theo thứ tự hiển thị) — icare.focusField
            // focus phần tử id="field_{FieldCode}" mà FieldRenderer đã bọc sẵn.
            var firstErr = _fieldStates.FirstOrDefault(f => f.Errors.Count > 0);
            if (firstErr is not null)
                await JS.InvokeVoidAsync("icare.focusField", firstErr.FieldCode);
        }
        catch (Exception ex) { _formError = ApiErrorLocalizer.Describe(Loc, ex); }
        finally { _saving = false; }
    }

    /// <summary>Đóng toast lỗi (giữ nguyên highlight đỏ ở từng field để user vẫn biết ô nào sai).</summary>
    private void DismissError()
    {
        _formError = null;
        _formMessages.Clear();
    }

    private async Task Cancel() => await OnCancelled.InvokeAsync();

    // ── Helpers (mirror FormRunner) ──────────────────────────────────────────

    /// <summary>Gắn các đính kèm đã upload "treo" (đa-tệp-khi-thêm-mới) vào record vừa tạo.</summary>
    private async Task LinkPendingAttachmentsAsync(object? newId)
    {
        if (newId is null || !long.TryParse(newId.ToString(), out var oid) || oid <= 0) return;

        foreach (var fs in _fieldStates.Where(f => f.FieldType == "attachment"))
        {
            var ids = ExtractPendingIds(fs.Value);
            if (ids.Count == 0) continue;
            try { await AttachmentApi.LinkAsync(FormCode, oid, fs.FieldCode, ids); }
            catch { /* best-effort: tệp treo có job dọn — không chặn đóng form */ }
        }
    }

    /// <summary>Trích danh sách Id treo từ giá trị field (renderer đặt List&lt;long&gt; khi thêm mới đa tệp).</summary>
    private static List<long> ExtractPendingIds(object? value) => value switch
    {
        List<long> l => l,
        IEnumerable<long> e => e.ToList(),
        _ => [],
    };

    private Dictionary<string, object?> BuildContext()
    {
        var ctx = _fieldStates.ToDictionary(f => f.FieldCode, f => f.Value);
        // Khóa dành riêng (prefix __, không trùng field code) cho control Attachment tự suy bảng chủ + Id record.
        ctx["__ownerTable"] = FormCode;
        ctx["__ownerId"] = Id;
        return ctx;
    }

    private async Task LoadLookupOptionsAsync()
    {
        var codes = _fieldStates
            .Where(fs => !string.IsNullOrWhiteSpace(fs.LookupCode))
            .Select(fs => fs.LookupCode!)
            .Distinct(StringComparer.OrdinalIgnoreCase).ToList();
        if (codes.Count == 0) return;

        var map = await LookupApi.GetOptionsBatchAsync(codes);
        foreach (var fs in _fieldStates)
            if (!string.IsNullOrWhiteSpace(fs.LookupCode) && map.TryGetValue(fs.LookupCode, out var opts))
                fs.Options = opts;
    }

    /// <summary>Bề rộng modal hài hòa theo số cột form: 1 cột hẹp, nhiều cột rộng dần.</summary>
    private static string ModalWidthForColumns(int cols) => cols switch
    {
        1 => "480px",
        2 => "680px",
        3 => "900px",
        _ => "1080px"
    };

    private static string NormalizeFieldType(string dbType, string? lookupSource)
        => dbType.ToLower() switch
        {
            "textbox" or "text"                                  => "text",
            "textarea" or "memo"                                 => "textarea",
            "numberedit" or "number" or "numericbox"             => "number",
            "dateedit" or "date" or "datepicker"                 => "date",
            "datetimeedit" or "datetime" or "datetimepicker"     => "datetime",
            "checkbox" or "bool"                                 => "bool",
            "toggleswitch" or "toggle"                           => "switch",
            "combobox" => lookupSource == "dynamic" ? "combobox" : "select",
            "select" or "lookupedit" or "dropdown" or "multiselect"
                or "radiogroup" or "lookupcombobox"              => "select",
            "lookupbox"                                          => "fklookup",
            "treelookupbox" or "treelookup"                      => "treelookup",
            "attachmentbox" or "attachment" or "fileupload"      => "attachment",
            _                                                    => "text"
        };
}
