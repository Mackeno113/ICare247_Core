@* File    : ConfirmDeleteDialog.razor
   Purpose : Dialog xác nhận xóa cứng. Mở dialog → soft-check usage:
             - Nếu đang bị tham chiếu: cảnh báo đỏ + liệt kê bảng.cột + số dòng + nhãn "dữ liệu cũ",
               ẨN nút Xóa (chặn).
             - Nếu sạch: cho xóa vĩnh viễn. *@

@using ICare247_UI.Services
@inject MasterDataApiService MasterApi
@inherits LocalizedComponentBase

<div class="md-modal-backdrop" @onclick="Cancel">
    <div class="md-modal md-modal-sm" @onclick:stopPropagation="true">
        <div class="md-modal-header">⚠️ @Loc.L("delete.confirm.title", "Xác nhận xóa")</div>
        <div class="md-modal-body">
            @if (_checking)
            {
                <div class="md-form-loading"><div class="spinner"></div><span>@Loc.L("delete.checking", "Đang kiểm tra tham chiếu…")</span></div>
            }
            else if (_error is not null)
            {
                <div class="result-invalid">@_error</div>
            }
            else if (_blocked.Count > 0)
            {
                <div class="result-invalid">
                    <strong>❌ @Loc.L("delete.blocked.title", "Không thể xóa.")</strong> @Loc.L("delete.blocked.usedAt", "Bản ghi đang được sử dụng tại:")
                    <ul>
                        @foreach (var u in _blocked)
                        {
                            <li>
                                <code>@u.Schema.@u.Table.@u.Column</code> → @Loc.L("delete.blocked.rows", "{0} dòng", u.RowCount)
                                @if (u.IsLegacy) { <span class="md-legacy-tag">@Loc.L("delete.blocked.legacy", "[dữ liệu cũ]")</span> }
                            </li>
                        }
                    </ul>
                    @Loc.L("delete.blocked.removeFirst", "Gỡ các tham chiếu này trước khi xóa.")
                </div>
            }
            else
            {
                <p>@((MarkupString)Loc.L("delete.confirm.body", "Bạn chắc chắn xóa <strong>vĩnh viễn</strong> bản ghi này? Hành động không thể hoàn tác."))</p>
            }
        </div>
        <div class="md-modal-footer">
            <button class="btn btn-secondary" @onclick="Cancel">@(_blocked.Count > 0 ? Loc.L("common.action.understood", "Đã hiểu") : Loc.L("common.action.cancel", "Hủy"))</button>
            @if (!_checking && _error is null && _blocked.Count == 0)
            {
                <button class="btn btn-danger" @onclick="ConfirmAsync" disabled="@_deleting">
                    @(_deleting ? Loc.L("delete.deleting", "Đang xóa…") : "🗑️ " + Loc.L("delete.confirm.permanent", "Xóa vĩnh viễn"))
                </button>
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string FormCode { get; set; } = "";
    [Parameter] public object Id { get; set; } = default!;
    /// <summary>Phát khi xóa thành công.</summary>
    [Parameter] public EventCallback OnDeleted { get; set; }
    /// <summary>Phát khi đóng dialog (hủy hoặc đã hiểu).</summary>
    [Parameter] public EventCallback OnClosed { get; set; }

    private bool _checking = true;
    private bool _deleting;
    private string? _error;
    private List<ReferenceUsageDto> _blocked = [];

    protected override async Task OnInitializedAsync()
    {
        try { _blocked = await MasterApi.GetUsageAsync(FormCode, Id); }
        catch (Exception ex) { _error = ex.Message; }
        finally { _checking = false; }
    }

    private async Task ConfirmAsync()
    {
        _deleting = true; _error = null;
        try
        {
            var result = await MasterApi.DeleteAsync(FormCode, Id);
            if (result.Success) { await OnDeleted.InvokeAsync(); return; }
            // Race: vừa có tham chiếu mới (server enforce) → hiển thị danh sách
            _blocked = result.BlockedBy;
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _deleting = false; }
    }

    private async Task Cancel() => await OnClosed.InvokeAsync();
}
