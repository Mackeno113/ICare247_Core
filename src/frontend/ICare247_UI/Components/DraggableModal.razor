@* File    : DraggableModal.razor
   Purpose : Popup dùng chung theo quy tắc thiết kế ICare247:
             - Kéo di chuyển bằng cách giữ chuột/chạm trên THANH TIÊU ĐỀ.
             - CHỈ đóng khi bấm nút (✕/Escape) — KHÔNG đóng khi click nền.
             - BeforeClose (tùy chọn): parent chặn đóng khi form đang dirty (WEB-UX-03).
             Bọc nội dung qua ChildContent; phát OnClose khi được phép đóng. *@

@implements IAsyncDisposable
@inject IJSRuntime JS
@inject LocalizationService Loc

@* @onkeydown ở backdrop bắt Escape (keydown bubble từ input con). Dropdown teleport ra body
   nằm ngoài cây này nên Escape của chúng không lọt vào đây. *@
<div class="md-modal-backdrop" @onkeydown="OnKeyDown">
    <div class="md-modal dm-modal" @ref="_panel" style="@WidthStyle">
        <div class="md-modal-header dm-header" @ref="_handle">
            <span class="dm-title">@Title</span>
            <button class="dm-close" type="button" @onclick="CloseAsync" aria-label="@Loc.L("common.action.close", "Đóng")">✕</button>
        </div>
        <div class="md-modal-body dm-body">
            @ChildContent
        </div>
    </div>
</div>

@code {
    /// <summary>Tiêu đề hiển thị trên thanh kéo.</summary>
    [Parameter] public string? Title { get; set; }
    /// <summary>Bề rộng tùy chọn, vd "560px". Bỏ trống = mặc định CSS (.md-modal 720px).</summary>
    [Parameter] public string? Width { get; set; }
    /// <summary>Nội dung trong popup (form, v.v.).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Phát khi popup THỰC SỰ đóng (sau khi qua <see cref="BeforeClose"/> nếu có).</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>
    /// Chốt chặn trước khi đóng (tùy chọn). Parent trả false để HỦY đóng (vd form dirty → hỏi xác nhận,
    /// user chọn tiếp tục sửa). Null = đóng luôn như cũ (không phá popup khác đang dùng DraggableModal).
    /// Áp cho CẢ nút ✕ lẫn phím Escape.
    /// </summary>
    [Parameter] public Func<Task<bool>>? BeforeClose { get; set; }

    private ElementReference _panel;
    private ElementReference _handle;
    private bool _dragInit;

    private string? WidthStyle => string.IsNullOrWhiteSpace(Width) ? null : $"width:{Width}";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _dragInit) return;
        _dragInit = true;
        // JS chưa sẵn (prerender) → bỏ qua; popup vẫn dùng được, chỉ không kéo.
        try { await JS.InvokeVoidAsync("icare.enableDrag", _handle, _panel); }
        catch { /* no-op */ }
    }

    /// <summary>Escape → thử đóng (qua cùng chốt chặn BeforeClose như nút ✕).</summary>
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") await CloseAsync();
    }

    /// <summary>Đóng: nếu có BeforeClose thì hỏi trước; false → không đóng. Ngược lại phát OnClose.</summary>
    private async Task CloseAsync()
    {
        if (BeforeClose is not null && !await BeforeClose())
            return;
        await OnClose.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("icare.disableDrag", _handle); }
        catch { /* circuit đã đóng → bỏ qua */ }
    }
}
