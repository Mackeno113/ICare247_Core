@* File    : NumericBoxRenderer.razor
   Purpose : Render DxSpinEdit từ FieldState + ControlPropsJson.
             EditorType "NumericBox" — số nguyên hoặc số thập phân.
             Props: minValue, maxValue, decimals, spinStep, allowNull.
             Dùng decimal? để hỗ trợ cả số nguyên lẫn thập phân + cho phép null. *@

@using System.Globalization
@using System.Text.Json
@using System.Text.Json.Serialization
@using DevExpress.Blazor
@inject IJSRuntime JS

<div @onfocusout="HandleLostFocus">
    <DxSpinEdit @bind-Value="BoundValue"
                MinValue="@((decimal)_props.MinValue)"
                MaxValue="@((decimal)_props.MaxValue)"
                Increment="@((decimal)_props.SpinStep)"
                DisplayFormat="@_displayFormat"
                Culture="@_culture"

                NullText="@NullTextValue"
                CssClass="@CssClassValue"
                Width="100%"
                InputId="@($"field_{State!.FieldCode}")"

                ReadOnly="@(State?.EffectiveReadOnly ?? false)" />
</div>

@code {
    // ── Parameters ───────────────────────────────────────────────────────────────
    [Parameter, EditorRequired]
    public FieldState? State { get; set; }

    [Parameter]
    public EventCallback<(string Code, object? Value)> OnChange { get; set; }

    [Parameter]
    public EventCallback<string> OnBlur { get; set; }

    // ── Private state ────────────────────────────────────────────────────────────
    private NumericBoxProps _props = new();
    private decimal? _localValue;
    private string      _displayFormat = "N0";
    private CultureInfo _culture       = CultureInfo.GetCultureInfo("en-US");

    /// <summary>
    /// Backing property cho @bind-Value — phát event async khi giá trị thay đổi.
    /// </summary>
    private decimal? BoundValue
    {
        get => _localValue;
        set => _ = HandleValueChangedAsync(value);
    }

    // ── Computed ─────────────────────────────────────────────────────────────────

    /// <summary>NullText: format gợi ý hoặc label fallback.</summary>
    private string NullTextValue => State?.Label is { Length: > 0 } lbl ? lbl + "..." : "";

    /// <summary>CSS class thêm dx-has-error khi field có lỗi validation.</summary>
    private string CssClassValue => State?.Errors.Count > 0 ? "field-dx dx-has-error" : "field-dx";

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        _props = NumericBoxProps.Parse(State?.ControlPropsJson);

        // DisplayFormat luôn dùng N (phân cách hàng nghìn + số thập phân) — cả blur lẫn edit state.
        // CultureInfo theo locale field: "vi" → vi-VN (9.999,05), "" → en-US (9,999.05).
        // TODO: mặc định theo system config khi CC-config-number-format hoàn thiện.
        var culture   = _props.Locale == "vi"
            ? CultureInfo.GetCultureInfo("vi-VN")
            : CultureInfo.GetCultureInfo("en-US");
        _displayFormat = $"N{_props.Decimals}";
        _culture       = culture;

        // Parse giá trị hiện tại từ State.Value (có thể là nhiều kiểu)
        _localValue = State?.Value switch
        {
            decimal d                                          => d,
            int     i                                          => (decimal)i,
            long    l                                          => (decimal)l,
            double  db                                         => (decimal)db,
            string  s when decimal.TryParse(s, out var parsed) => parsed,
            null when !_props.AllowNull                        => 0m,
            _                                                  => null
        };
    }

    // ── Lifecycle (after render) ─────────────────────────────────────────────────

    /// <summary>
    /// Đăng ký JS formatter real-time sau khi DOM sẵn sàng.
    /// Guard el._icareNumFmt trong JS tránh duplicate listener khi re-render.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (State is not null)
            await JS.InvokeVoidAsync("icare.setupNumericInput", $"field_{State.FieldCode}", _props.Locale);
    }

    // ── Handlers ─────────────────────────────────────────────────────────────────

    private async Task HandleValueChangedAsync(decimal? value)
    {
        if (State is null) return;
        _localValue = value;
        State.Value = value;
        await OnChange.InvokeAsync((State.FieldCode, (object?)value));
    }

    private async Task HandleLostFocus(FocusEventArgs _)
    {
        if (State is null) return;
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    // ── Inner types ──────────────────────────────────────────────────────────────

    /// <summary>
    /// Props từ Control_Props_Json cho NumericBox.
    /// JSON mẫu: {"minValue":0,"maxValue":999999,"decimals":2,"spinStep":0.5,"allowNull":false}
    /// </summary>
    private sealed class NumericBoxProps
    {
        [JsonPropertyName("minValue")]
        public double MinValue { get; set; } = 0;

        [JsonPropertyName("maxValue")]
        public double MaxValue { get; set; } = 999999;

        /// <summary>Số chữ số thập phân hiển thị — 0 = số nguyên.</summary>
        [JsonPropertyName("decimals")]
        public int Decimals { get; set; } = 0;

        /// <summary>Bước nhảy khi bấm mũi tên spin.</summary>
        [JsonPropertyName("spinStep")]
        public double SpinStep { get; set; } = 1;

        /// <summary>Cho phép để trống (null) — false = bắt buộc có giá trị, mặc định 0.</summary>
        [JsonPropertyName("allowNull")]
        public bool AllowNull { get; set; } = false;

        /// <summary>
        /// Locale format số: "vi" → chuẩn VN (9.999,05) | "" → quốc tế en-US (9,999.05) [default].
        /// Luôn hiển thị phân cách hàng nghìn — locale chỉ quyết định ký tự separator.
        /// TODO: mặc định theo system config khi CC-config-number-format hoàn thiện.
        /// </summary>
        [JsonPropertyName("locale")]
        public string Locale { get; set; } = "";

        public static NumericBoxProps Parse(string? json)
        {
            if (string.IsNullOrWhiteSpace(json)) return new();
            try
            {
                // NumberHandling: ConfigStudio (DevExpress TextEdit) lưu prop number dưới dạng
                // chuỗi (vd "2"). AllowReadingFromString để parse "2" -> int/double thay vì throw.
                return JsonSerializer.Deserialize<NumericBoxProps>(json,
                    new JsonSerializerOptions
                    {
                        PropertyNameCaseInsensitive = true,
                        NumberHandling = JsonNumberHandling.AllowReadingFromString
                    }) ?? new();
            }
            catch { return new(); }
        }
    }
}
