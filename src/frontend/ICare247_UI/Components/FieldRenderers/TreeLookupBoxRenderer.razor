@* File    : TreeLookupBoxRenderer.razor
   Purpose : Render TreeLookupBox — dropdown popup dạng cây expand/collapse.
             Dùng cho Editor_Type = TreeLookupBox.
             Bảng nguồn phải có cột Parent_Column để build hierarchy.
             Hỗ trợ filter cascading khi ReloadTriggerField thay đổi. *@

@inject ILookupQueryService LookupQuerySvc
@inherits LocalizedComponentBase

<div class="treelookup-wrapper">
    @* ── EditBox — gõ trực tiếp để lọc (giống LookupBox) ── *@
    <div class="lookupbox-editbox @(State?.EffectiveReadOnly == true ? "readonly" : "")">
        <input type="text"
               class="lookupbox-search-input"
               placeholder="@Loc.L("common.lookup.choose", "-- Chọn --")"
               value="@_inputText"
               disabled="@(State?.EffectiveReadOnly == true)"
               @oninput="OnSearchInput"
               @onfocus="OnFocus"
               @onblur="OnInputBlur"
               @onkeydown="OnKeyDown" />
        @if (State?.EffectiveReadOnly != true && !string.IsNullOrEmpty(State?.ValueString))
        {
            <button class="lookupbox-clear" @onclick="ClearValue" @onclick:stopPropagation title="@Loc.L("common.action.clear", "Xóa")">✕</button>
        }
        <button class="lookupbox-btn" @onclick="TogglePopup"
                disabled="@(State?.EffectiveReadOnly == true)"
                title="@Loc.L("common.lookup.openTree", "Mở cây")">
            <svg viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 1v14M4 5h8M2 9h5M9 9h5" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
        </button>
    </div>

    @* ── Popup cây ── *@
    @if (_popupVisible)
    {
        <div class="lookupbox-popup treelookup-popup"
             style="width:@(State?.LookupConfig?.DropDownWidth ?? 500)px">

            @* Tree content *@
            @if (_loading)
            {
                <div class="popup-loading">⏳ @Loc.L("common.lookup.loadingData", "Đang tải dữ liệu...")</div>
            }
            else if (_loadError is not null)
            {
                <div class="popup-error">⚠ @_loadError</div>
            }
            else if (_rootNodes.Count == 0)
            {
                <div class="popup-empty">@Loc.L("common.lookup.noData", "Không có dữ liệu")</div>
            }
            else
            {
                <div class="treelookup-tree"
                     style="max-height:@(State?.LookupConfig?.DropDownHeight ?? 400)px; overflow-y:auto">
                    @{ var _nodeIdx = 0; }
                    @foreach (var node in GetDisplayNodes())
                    {
                        var isActive = _nodeIdx == _highlightIndex;
                        <div class="tree-node @(State?.ValueString == node.Value ? "selected" : "") @(isActive ? "highlight" : "")"
                             style="padding-left:@(node.Level * 16 + 8)px"
                             @onmousedown="() => SelectNode(node)"
                             @onmousedown:preventDefault="true">
                            @if (node.HasChildren)
                            {
                                <span class="tree-toggle"
                                      @onmousedown="() => ToggleNode(node)"
                                      @onmousedown:stopPropagation="true"
                                      @onmousedown:preventDefault="true">
                                    @(node.IsExpanded ? "▾" : "▸")
                                </span>
                            }
                            else
                            {
                                <span class="tree-leaf-indent">　</span>
                            }
                            <span class="tree-label">@((MarkupString)HighlightLabel(node.Label))</span>
                        </div>
                        _nodeIdx++;
                    }
                </div>
            }
        </div>
        <div class="lookupbox-overlay" @onclick="ClosePopup"></div>
    }
</div>

@code {
    [Parameter, EditorRequired] public FieldState?                                 State    { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange { get; set; }
    [Parameter]                 public EventCallback<string>                       OnBlur   { get; set; }
    [Parameter]                 public Dictionary<string, object?>                 Context  { get; set; } = [];

    private bool    _popupVisible;
    private bool    _loading;
    private string? _loadError;
    private string  _searchText = "";
    private string  _inputText  = "";   // text trong ô input: display value hoặc search term đang gõ
    private object? _lastTriggerValue;
    private int     _highlightIndex = -1; // index node đang highlight để chọn bằng Enter / phím ↑↓

    // ── Tree state ────────────────────────────────────────────────────────────

    private List<TreeNode> _rootNodes = [];
    private Dictionary<string, bool> _expandedState = [];

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (State is null) return;

        var triggerField = State.LookupConfig?.ReloadTriggerField;
        var currentTriggerValue = !string.IsNullOrWhiteSpace(triggerField)
            && Context.TryGetValue(triggerField, out var tv) ? tv : null;

        var needsLoad = _rootNodes.Count == 0
            || (triggerField is not null && !Equals(_lastTriggerValue, currentTriggerValue));

        if (needsLoad)
        {
            _lastTriggerValue = currentTriggerValue;
            if (_rootNodes.Count > 0) await ClearValue();
            await LoadDataAsync();
        }
    }

    private async Task LoadDataAsync()
    {
        if (State is null) return;
        _loading   = true;
        _loadError = null;

        try
        {
            // QueryTreeAsync trả flat list với __parentId được inject bởi repository
            var rows = await LookupQuerySvc.QueryTreeAsync(State.FieldId, Context);
            _rootNodes = BuildTree(rows, State.LookupConfig);
        }
        catch (Exception ex)
        {
            _loadError  = ex.Message;
            _rootNodes  = [];
        }
        finally { _loading = false; }
    }

    // ── Build tree từ flat list ────────────────────────────────────────────────

    private List<TreeNode> BuildTree(
        IReadOnlyList<Dictionary<string, object?>> rows,
        FieldLookupConfigDto? cfg)
    {
        var valueCol   = cfg?.ValueColumn   ?? "";
        var displayCol = ExtractColumnKey(cfg?.DisplayColumn ?? "");

        var allNodes = rows.Select(r => new TreeNode
        {
            Value    = GetColStr(r, valueCol),
            Label    = GetColStr(r, displayCol),
            ParentId = r.TryGetValue("__parentId", out var pid) ? pid?.ToString() : null,
        }).ToList();

        var byId = allNodes.ToDictionary(n => n.Value, StringComparer.OrdinalIgnoreCase);

        // Build cha/con
        foreach (var node in allNodes)
        {
            if (!string.IsNullOrEmpty(node.ParentId)
                && byId.TryGetValue(node.ParentId, out var parent))
            {
                parent.Children.Add(node);
                node.Parent = parent;
            }
        }

        // Root = node không có cha hợp lệ
        return allNodes.Where(n => n.Parent is null).ToList();
    }

    // ── Hiển thị tree (flatten + filter + collapse) ───────────────────────────

    private bool IsFilterActive =>
        _searchText.Length >= Math.Max(1, State?.LookupConfig?.FilterMinLength ?? 0);

    private List<TreeNode> GetDisplayNodes()
    {
        if (!string.IsNullOrWhiteSpace(_searchText) && IsFilterActive)
        {
            // Search mode: flatten toàn bộ, lọc contains, thêm ancestors để có ngữ cảnh
            var term     = _searchText.ToLower();
            var allNodes = new List<TreeNode>();
            foreach (var root in _rootNodes)
                FlattenAll(root, 0, allNodes);

            var matched  = allNodes.Where(n => n.Label.ToLower().Contains(term)).ToHashSet();
            var visible  = new HashSet<TreeNode>(matched);
            foreach (var n in matched)
            {
                var p = n.Parent;
                while (p is not null) { visible.Add(p); p = p.Parent; }
            }

            return allNodes.Where(n => visible.Contains(n)).ToList();
        }

        var result = new List<TreeNode>();
        foreach (var root in _rootNodes)
            FlattenVisible(root, 0, result);
        return result;
    }

    // Wrap phần text khớp bằng <mark> — trả về HTML string an toàn
    private string HighlightLabel(string label)
    {
        var escaped = System.Net.WebUtility.HtmlEncode(label);
        if (!IsFilterActive || string.IsNullOrWhiteSpace(_searchText))
            return escaped;

        var term = System.Net.WebUtility.HtmlEncode(_searchText);
        var idx  = escaped.IndexOf(term, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return escaped;

        return escaped[..idx]
             + "<mark>" + escaped.Substring(idx, term.Length) + "</mark>"
             + escaped[(idx + term.Length)..];
    }

    private void FlattenAll(TreeNode node, int level, List<TreeNode> result)
    {
        node.Level       = level;
        node.HasChildren = node.Children.Count > 0;
        node.IsExpanded  = true;
        result.Add(node);
        foreach (var child in node.Children)
            FlattenAll(child, level + 1, result);
    }

    private void FlattenVisible(TreeNode node, int level, List<TreeNode> result)
    {
        node.Level       = level;
        node.HasChildren = node.Children.Count > 0;
        node.IsExpanded  = _expandedState.TryGetValue(node.Value, out var exp) ? exp : true;
        result.Add(node);

        if (node.IsExpanded)
            foreach (var child in node.Children)
                FlattenVisible(child, level + 1, result);
    }

    // ── UI interactions ────────────────────────────────────────────────────────

    private async Task TogglePopup()
    {
        if (State?.EffectiveReadOnly == true) return;
        _popupVisible = !_popupVisible;

        if (_popupVisible)
        {
            _searchText = "";
            if (_rootNodes.Count == 0 && !_loading)
                await LoadDataAsync();
        }
        else
        {
            // Đóng → khôi phục display text của node đang chọn
            _inputText  = GetSelectedDisplay();
            _searchText = "";
        }
    }

    /// <summary>
    /// Input được focus: xóa display để user gõ tìm kiếm, mở popup, load data nếu chưa có.
    /// Sự kiện theo sau: _popupVisible = true, _inputText rỗng để gõ filter.
    /// </summary>
    private async Task OnFocus()
    {
        if (State?.EffectiveReadOnly == true) return;
        _inputText    = "";
        _searchText   = "";
        _popupVisible = true;
        if (_rootNodes.Count == 0 && !_loading)
            await LoadDataAsync();
    }

    /// <summary>
    /// Input mất focus: đóng popup, khôi phục display text của node đang chọn.
    /// Node/Toggle dùng onmousedown + preventDefault để chạy trước blur này.
    /// </summary>
    private void OnInputBlur()
    {
        _popupVisible   = false;
        _searchText     = "";
        _inputText      = GetSelectedDisplay();
        _highlightIndex = -1;
    }

    private void ClosePopup()
    {
        _popupVisible   = false;
        _searchText     = "";
        _inputText      = GetSelectedDisplay();
        _highlightIndex = -1;
    }

    /// <summary>
    /// Khi State đổi từ bên ngoài mà popup đang đóng → sync display text.
    /// Sự kiện theo sau: _inputText phản ánh giá trị đang chọn.
    /// </summary>
    protected override void OnParametersSet()
    {
        if (!_popupVisible)
            _inputText = GetSelectedDisplay();
    }

    private void ToggleNode(TreeNode node)
    {
        var current = _expandedState.TryGetValue(node.Value, out var v) ? v : true;
        _expandedState[node.Value] = !current;
    }

    private async Task SelectNode(TreeNode node)
    {
        if (State is null) return;
        State.Value = node.Value;
        ClosePopup();
        await OnChange.InvokeAsync((State.FieldCode, (object?)node.Value));
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    private async Task ClearValue()
    {
        if (State is null) return;
        State.Value     = null;
        _inputText      = "";
        _searchText     = "";
        _highlightIndex = -1;
        await OnChange.InvokeAsync((State.FieldCode, null));
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _inputText    = e.Value?.ToString() ?? "";
        _searchText   = _inputText;
        _popupVisible = true;
        // Highlight node hiển thị đầu tiên để Enter chọn ngay sau khi gõ
        _highlightIndex = GetDisplayNodes().Count > 0 ? 0 : -1;
    }

    /// <summary>
    /// Điều hướng cây bằng bàn phím trên danh sách node đang hiển thị:
    /// ↓/↑ di chuyển highlight, Enter chọn node đang highlight, Escape đóng popup.
    /// Sự kiện theo sau: SelectNode (Enter) hoặc ClosePopup (Escape) hoặc cập nhật _highlightIndex.
    /// </summary>
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (State?.EffectiveReadOnly == true) return;

        var nodes = GetDisplayNodes();

        switch (e.Key)
        {
            case "ArrowDown":
                if (nodes.Count > 0)
                    _highlightIndex = Math.Min(_highlightIndex + 1, nodes.Count - 1);
                break;

            case "ArrowUp":
                if (nodes.Count > 0)
                    _highlightIndex = Math.Max(_highlightIndex - 1, 0);
                break;

            case "Enter":
                if (_highlightIndex >= 0 && _highlightIndex < nodes.Count)
                    await SelectNode(nodes[_highlightIndex]);
                break;

            case "Escape":
                ClosePopup();
                break;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private string GetSelectedDisplay()
    {
        if (State is null) return "";
        var selectedVal = State.ValueString ?? "";
        // Tìm trong flat list toàn bộ nodes
        var allNodes = FlattenAllNodes(_rootNodes);
        var found = allNodes.FirstOrDefault(n =>
            string.Equals(n.Value, selectedVal, StringComparison.OrdinalIgnoreCase));
        return found?.Label ?? selectedVal;
    }

    private static IEnumerable<TreeNode> FlattenAllNodes(IEnumerable<TreeNode> nodes)
    {
        foreach (var n in nodes)
        {
            yield return n;
            foreach (var child in FlattenAllNodes(n.Children))
                yield return child;
        }
    }

    private static string GetColStr(Dictionary<string, object?> row, string col)
    {
        if (string.IsNullOrWhiteSpace(col)) return "";
        if (row.TryGetValue(col, out var v)) return v?.ToString() ?? "";
        // Case-insensitive fallback
        var key = row.Keys.FirstOrDefault(k =>
            k.Equals(col, StringComparison.OrdinalIgnoreCase));
        return key is not null ? row[key]?.ToString() ?? "" : "";
    }

    private static string ExtractColumnKey(string expr)
    {
        if (string.IsNullOrWhiteSpace(expr)) return expr;
        var m = System.Text.RegularExpressions.Regex.Match(
            expr.Trim(), @"\bAS\s+(\w+)\s*$",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        if (m.Success) return m.Groups[1].Value;
        if (expr.Contains('('))
        {
            var last = expr.LastIndexOf(' ');
            if (last >= 0) return expr[(last + 1)..].Trim();
        }
        return expr.Trim();
    }

    // ── Inner model ───────────────────────────────────────────────────────────

    private sealed class TreeNode
    {
        public string           Value       { get; set; } = "";
        public string           Label       { get; set; } = "";
        public string?          ParentId    { get; set; }
        public TreeNode?        Parent      { get; set; }
        public List<TreeNode>   Children    { get; } = [];
        // display state (set mỗi lần flatten)
        public int              Level       { get; set; }
        public bool             HasChildren { get; set; }
        public bool             IsExpanded  { get; set; } = true;
    }
}
