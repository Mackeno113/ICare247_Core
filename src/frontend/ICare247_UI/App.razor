@*
    Router bọc trong CascadingAuthenticationState để AuthorizeView / MainLayout đọc được
    trạng thái đăng nhập (JwtAuthenticationStateProvider). Bảo vệ route: MainLayout tự
    redirect về /login khi chưa đăng nhập (màn auth dùng AuthLayout nên không bị chặn).
*@
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly"
            AdditionalAssemblies="new[] { typeof(ICare247.UI.Organization.DependencyInjection).Assembly }">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
