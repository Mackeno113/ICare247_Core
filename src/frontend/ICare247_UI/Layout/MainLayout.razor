@inherits LayoutComponentBase
@implements IDisposable
@inject AppState AppState
@inject NavigationManager Nav
@inject LocalizationService Loc
@inject IAuthService Auth
@inject AuthenticationStateProvider AuthProvider

@*
    MainLayout — Shell ERP responsive + đa ngôn ngữ + bảo vệ đăng nhập.
    - Chưa đăng nhập → tự điều hướng về /login (màn auth dùng AuthLayout nên không vào đây).
    - Desktop: sidebar dọc cố định + topbar + nội dung.
    - Mobile (<= 768px): sidebar off-canvas, mở bằng nút ☰, tự đóng khi điều hướng.
    Token màu/kích thước lấy từ wwwroot/css/tokens.css (KHÔNG hardcode màu).
*@

@if (!_authChecked)
{
    <div class="app-auth-loading">@Loc.L("common.app.loading", "Đang tải...")</div>
}
else if (_authed)
{
    <div class="app-shell @(_navOpen ? "app-shell--nav-open" : "")">
        <aside class="app-sidebar">
            <div class="app-brand">
                <span class="app-brand__logo">IC</span>
                <span class="app-brand__name">ICare247</span>
            </div>
            <NavMenu />
        </aside>

        <div class="app-backdrop" @onclick="CloseNav"></div>

        <div class="app-body">
            <header class="app-topbar">
                <button type="button" class="app-navtoggle" @onclick="ToggleNav" aria-label="@Loc.L("common.app.openmenu", "Mở menu")">☰</button>
                <div class="app-company">
                    @* TODO(phase-org): thay bằng DxComboBox chọn công ty từ AppState/API *@
                    <span class="app-company__label">@Loc.L("common.app.company", "Công ty"):</span>
                    <span class="app-company__value">@Loc.L("common.app.nocompany", "— chưa chọn —")</span>
                </div>
                <div class="app-topbar__spacer"></div>
                <div class="app-lang">
                    <LanguageSwitcher />
                </div>
                <div class="app-user">
                    <span class="app-user__avatar" title="@_userName">@_avatar</span>
                    <span class="app-user__name">@_userName</span>
                    <button type="button" class="app-user__logout" @onclick="HandleLogout"
                            title="@Loc.L("common.app.logout", "Đăng xuất")">⎋</button>
                </div>
            </header>

            <main class="app-content">
                @Body
            </main>
        </div>
    </div>
}

@code {
    // Trạng thái mở sidebar trên mobile.
    private bool _navOpen;

    // Trạng thái xác thực.
    private bool _authChecked;
    private bool _authed;
    private string _userName = "";
    private string _avatar = "U";

    /// <summary>
    /// Khởi tạo: lắng nghe điều hướng + đổi ngôn ngữ + đổi trạng thái auth; nạp i18n;
    /// gắn token đã lưu rồi kiểm tra đăng nhập. Sự kiện theo sau: chưa đăng nhập → về /login.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        Loc.OnChanged += OnLanguageChanged;
        AuthProvider.AuthenticationStateChanged += OnAuthStateChanged;

        // Nguồn i18n riêng của host (chuỗi trang/feature hand-coded). Phải đăng ký TRƯỚC
        // InitializeAsync để overlay ngôn ngữ gộp luôn file json của host. Sự kiện theo sau:
        // lần nạp overlay kế tiếp merge thêm wwwroot/i18n/{lang}.json.
        Loc.RegisterSource("i18n");

        await Loc.InitializeAsync();
        await Auth.InitializeAsync();      // nạp token + gắn header Bearer
        await CheckAuthAsync();
    }

    /// <summary>Kiểm tra trạng thái đăng nhập hiện tại; chưa đăng nhập → điều hướng /login.</summary>
    private async Task CheckAuthAsync()
    {
        var state = await AuthProvider.GetAuthenticationStateAsync();
        var identity = state.User.Identity;
        _authed = identity?.IsAuthenticated ?? false;
        _userName = identity?.Name ?? "";
        _avatar = string.IsNullOrEmpty(_userName) ? "U" : char.ToUpperInvariant(_userName[0]).ToString();
        _authChecked = true;

        if (!_authed)
            Nav.NavigateTo("login");

        StateHasChanged();
    }

    /// <summary>Đăng xuất rồi về màn đăng nhập.</summary>
    private async Task HandleLogout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("login");
    }

    /// <summary>Mở/đóng sidebar. Sự kiện theo sau: shell thêm/bỏ class --nav-open.</summary>
    private void ToggleNav() => _navOpen = !_navOpen;

    /// <summary>Đóng sidebar.</summary>
    private void CloseNav() => _navOpen = false;

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    /// <summary>Khi trạng thái auth đổi (login/logout) → kiểm tra lại để cập nhật shell.</summary>
    private void OnAuthStateChanged(Task<AuthenticationState> _) => InvokeAsync(CheckAuthAsync);

    /// <summary>Đóng sidebar khi đổi trang để không che nội dung.</summary>
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_navOpen) { _navOpen = false; StateHasChanged(); }
    }

    /// <summary>Hủy đăng ký sự kiện khi component bị loại bỏ.</summary>
    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Loc.OnChanged -= OnLanguageChanged;
        AuthProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
