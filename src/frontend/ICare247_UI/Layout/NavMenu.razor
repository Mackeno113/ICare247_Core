@implements IDisposable
@inject NavigationManager Nav
@inject LocalizationService Loc
@inject NavigationApiService NavApi

@*
    NavMenu — điều hướng dọc dạng accordion, ĐỆ QUY (cây sâu tùy ý — ADR-023 §5).
    - Nguồn dữ liệu: API /me/navigation (đã lọc theo quyền). Rỗng/lỗi → fallback AppNav tĩnh.
    - Dựng cây từ node phẳng: node gốc Loai=Menu → "nhóm" (overline caption); con bên dưới
      vẽ ĐỆ QUY: node có con → cụm thu/mở (collapsible), node có route lá → liên kết.
    - Node nhóm rỗng (không con, không route) bị BỎ (vd Menu chưa gắn màn) — không vẽ link hỏng.
    - Tiêu đề qua Loc.L(key, base vi): key suy từ cấu trúc; base là Ten/Title.
    - Tự vẽ lại khi đổi ngôn ngữ; tự bung nhánh chứa URL hiện tại.
*@

<nav class="nav-menu">
    @* Ô lọc menu — gõ tới đâu lọc tới đó theo nhãn ĐÃ DỊCH (ngôn ngữ giao diện hiện tại). *@
    <div class="nav-filter">
        <span class="nav-filter__icon"><Icon Name="search" Size="16" StrokeWidth="2" /></span>
        <input class="nav-filter__input" type="search" autocomplete="off"
               placeholder="@Loc.L("nav.filter.placeholder", "Lọc menu…")"
               aria-label="@Loc.L("nav.filter.placeholder", "Lọc menu…")"
               value="@_filter" @oninput="OnFilterInput" />
        @if (HasFilter)
        {
            <button type="button" class="nav-filter__clear" @onclick="ClearFilter"
                    title="@Loc.L("common.action.clear", "Xóa")"
                    aria-label="@Loc.L("common.action.clear", "Xóa")">
                <Icon Name="x" Size="14" StrokeWidth="2" />
            </button>
        }
    </div>

    @{ var top = FilteredTop(); }
    @foreach (var item in top)
    {
        <NavLink class="nav-item" href="@item.Href" Match="@(item.Href == "" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
            <span class="nav-item__icon"><Icon Name="@item.Icon" /></span>
            <span class="nav-item__label">@Loc.L(item.TitleKey, item.Title)</span>
        </NavLink>
    }

    @{ var sections = FilteredSections(); }
    @foreach (var section in sections)
    {
        <div class="nav-section">
            <div class="nav-section__label">@Loc.L(section.TitleKey, section.Title)</div>
            @* Con của nhóm vẽ ĐỆ QUY từ cấp 0 — cụm con lồng cụm con sâu tùy ý. *@
            @foreach (var child in FilteredChildren(section.Children))
            {
                @RenderNode(child, 0)
            }
        </div>
    }

    @{ var bottom = FilteredBottom(); }
    @if (bottom.Count > 0)
    {
        <div class="nav-sep"></div>
        @foreach (var item in bottom)
        {
            <NavLink class="nav-item nav-item--muted" href="@item.Href" title="@Loc.L(item.TitleKey, item.Title)">
                <span class="nav-item__icon"><Icon Name="@item.Icon" /></span>
                <span class="nav-item__label">@Loc.L(item.TitleKey, item.Title)</span>
            </NavLink>
        }
    }

    @if (HasFilter && top.Count == 0 && sections.Count == 0 && bottom.Count == 0)
    {
        <div class="nav-empty">@Loc.L("nav.filter.empty", "Không có mục phù hợp")</div>
    }
</nav>

@code {
    // ── View-model: cây menu sau khi dựng (từ API hoặc AppNav) ──────────────
    // Mục đơn cấp gốc (Tổng quan / Công cụ Dev) — không vào cây đệ quy.
    private sealed record VmItem(string Key, string TitleKey, string Title, string Icon, string Href);
    // 1 node trong cây đệ quy: IsGroup=true → cụm thu/mở (có Children); false → liên kết lá (có Href).
    private sealed record VmNode(string Key, string TitleKey, string Title, string Icon, string Href, bool IsGroup, List<VmNode> Children);
    // Nhóm gốc (overline caption) — con là cây node đệ quy.
    private sealed record VmSection(string Key, string TitleKey, string Title, List<VmNode> Children);

    private List<VmItem> _top = new();
    private List<VmSection> _sections = new();
    private List<VmItem> _bottom = new();

    // Tập khóa node đang mở (multi-expand cho cây sâu) + đường dẫn URL hiện tại (tô đậm nhánh).
    private readonly HashSet<string> _expanded = new(StringComparer.Ordinal);
    private string _currentPath = "";

    // Chuỗi lọc menu (so khớp với nhãn ĐÃ DỊCH theo ngôn ngữ giao diện hiện tại).
    private string _filter = "";
    private bool HasFilter => _filter.Length > 0;

    /// <summary>Sidebar đang thu nhỏ về rail icon (do MainLayout truyền xuống).</summary>
    [Parameter] public bool Collapsed { get; set; }

    /// <summary>Yêu cầu MainLayout bung lại sidebar (khi bấm cụm lúc đang thu gọn).</summary>
    [Parameter] public EventCallback OnExpand { get; set; }

    /// <summary>
    /// Khởi tạo: nạp menu theo quyền từ API (rỗng/lỗi → AppNav), bung nhánh chứa URL,
    /// lắng nghe đổi URL + đổi ngôn ngữ.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        var nodes = await NavApi.GetNavigationAsync();
        if (nodes.Count > 0) BuildFromApi(nodes);
        else BuildFromAppNav();

        SyncFromUri();
        ExpandActivePath();
        Nav.LocationChanged += OnLocationChanged;
        Loc.OnChanged += OnLanguageChanged;
    }

    // ── Dựng VM từ API (node phẳng → cây đệ quy) ────────────────────────────
    private void BuildFromApi(IReadOnlyList<MeNavNode> nodes)
    {
        // Chỉ hiện ở sidebar: ViTriHienThi Sidebar/Ca2.
        bool OnSidebar(MeNavNode n) => n.ViTriHienThi is "Sidebar" or "Ca2";
        var vis = nodes.Where(OnSidebar).ToList();

        string Href(string? duongDan) => (duongDan ?? "").TrimStart('/');

        // Con trực tiếp của 1 node (theo ChaMa), đã sắp theo Thứ tự.
        List<MeNavNode> ChildrenOf(string? ma) =>
            vis.Where(n => n.ChaMa == ma).OrderBy(n => n.ThuTu).ToList();

        // Dựng 1 node + toàn bộ con (đệ quy). Trả null nếu là nhóm rỗng / lá không route → bỏ.
        // moduleSlug = slug của cụm tổ tiên gần nhất (để suy key màn theo quy ước nav.screen.{module}.{man}).
        VmNode? BuildNode(MeNavNode n, string moduleSlug)
        {
            var slug = NavKeys.Slug(n.Ma);
            var kids = ChildrenOf(n.Ma)
                .Select(c => BuildNode(c, slug))
                .Where(c => c is not null).Select(c => c!).ToList();
            var href = Href(n.DuongDan);

            // Nhóm không con & không route → không có gì để mở/đi → bỏ (tránh link hỏng).
            if (kids.Count == 0 && href.Length == 0) return null;

            var isGroup = kids.Count > 0;
            var titleKey = isGroup ? NavKeys.Module(slug) : NavKeys.Screen(moduleSlug, slug);
            var icon = n.Icon ?? (isGroup ? "circle" : "dot");
            return new VmNode(n.Ma, titleKey, n.Ten, icon, href, isGroup, kids);
        }

        // Mục đơn cấp gốc (Loai=ManHinh, không cha): Tổng quan + Công cụ Dev.
        foreach (var n in vis.Where(n => n.ChaMa is null && n.Loai == "ManHinh").OrderBy(n => n.ThuTu))
        {
            var item = new VmItem(n.Ma, NavKeys.Root(n.Ma), n.Ten, n.Icon ?? "circle", Href(n.DuongDan));
            if (n.Ma is "devtools" || (n.DuongDan ?? "").StartsWith("/dev")) _bottom.Add(item);
            else _top.Add(item);
        }

        // Nhóm gốc (Loai=Menu, không cha) → overline caption; con vẽ đệ quy bên dưới.
        foreach (var grp in vis.Where(n => n.ChaMa is null && n.Loai == "Menu").OrderBy(n => n.ThuTu))
        {
            var grpKey = grp.Ma.StartsWith("group.") ? grp.Ma["group.".Length..] : grp.Ma;
            var children = ChildrenOf(grp.Ma)
                .Select(c => BuildNode(c, NavKeys.Slug(grpKey)))
                .Where(c => c is not null).Select(c => c!).ToList();
            if (children.Count > 0)
                _sections.Add(new VmSection(grp.Ma, NavKeys.Group(grpKey), grp.Ten, children));
        }
    }

    // ── Dựng VM từ AppNav (fallback tĩnh khi API rỗng/lỗi) ──────────────────
    private void BuildFromAppNav()
    {
        _top.Add(new VmItem("dashboard", "nav.dashboard", "Tổng quan", "layout-grid", ""));

        foreach (var group in AppNav.Groups)
        {
            var children = AppNav.Modules.Where(m => m.Group == group.Key).Select(m =>
                new VmNode(
                    m.Key, NavKeys.Module(m.Key), m.Title, m.Icon, $"m/{m.Key}", true,
                    m.Screens.Select(s => new VmNode(
                        s.Key,
                        NavKeys.Screen(m.Key, s.Key), s.Title, "dot",
                        string.IsNullOrEmpty(s.Route) ? $"m/{m.Key}/{s.Key}" : s.Route.TrimStart('/'),
                        false, new List<VmNode>())).ToList()))
                .ToList();
            if (children.Count > 0)
                _sections.Add(new VmSection(group.Key, NavKeys.Group(group.Key), group.Title, children));
        }

        _bottom.Add(new VmItem("devtools", "nav.devtools", "Công cụ (Dev)", "wrench", "dev/forms"));
        _bottom.Add(new VmItem("i18ntools", "nav.i18ntools", "Tra cứu i18n", "languages", "dev/i18n"));
    }

    // ── Render đệ quy 1 node (cụm thu/mở hoặc liên kết lá) ───────────────────
    /// <summary>Vẽ 1 node theo cấp sâu (depth) — thụt lề tăng dần qua biến CSS --nav-depth.</summary>
    private RenderFragment RenderNode(VmNode node, int depth) =>@<text>
        @if (node.IsGroup)
        {
            var isOpen = IsOpen(node);
            var isActive = IsActivePath(node);
            <div class="nav-group @(isActive ? "nav-group--active" : "")">
                <button type="button" class="nav-group__header" style="@($"--nav-depth:{depth}")"
                        @onclick="() => ToggleNode(node)" title="@Loc.L(node.TitleKey, node.Title)">
                    <span class="nav-item__icon"><Icon Name="@node.Icon" /></span>
                    <span class="nav-group__title">@Loc.L(node.TitleKey, node.Title)</span>
                    <span class="nav-group__caret @(isOpen ? "nav-group__caret--open" : "")">
                        <Icon Name="chevron-right" Size="14" StrokeWidth="2" />
                    </span>
                </button>
                @if (isOpen)
                {
                    <div class="nav-group__items">
                        @foreach (var child in FilteredChildren(node.Children))
                        {
                            @RenderNode(child, depth + 1)
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <NavLink class="nav-subitem" href="@node.Href" style="@($"--nav-depth:{depth}")"
                     title="@Loc.L(node.TitleKey, node.Title)">
                <span class="nav-item__icon nav-subitem__icon"><Icon Name="@node.Icon" Size="16" /></span>
                <span class="nav-item__label">@Loc.L(node.TitleKey, node.Title)</span>
            </NavLink>
        }
    </text>;

    // ── Lọc menu ────────────────────────────────────────────────────────────
    /// <summary>Cập nhật chuỗi lọc khi gõ. Sự kiện theo sau: danh sách render lọc lại + nhánh tự bung.</summary>
    private void OnFilterInput(ChangeEventArgs e) => _filter = (e.Value?.ToString() ?? "").Trim();

    /// <summary>Xóa chuỗi lọc, hiện lại toàn bộ menu.</summary>
    private void ClearFilter() => _filter = "";

    /// <summary>Khớp lọc: rỗng = nhận hết; ngược lại so chứa, không phân biệt hoa thường.</summary>
    private bool Match(string label) =>
        !HasFilter || label.Contains(_filter, StringComparison.CurrentCultureIgnoreCase);

    /// <summary>Nhãn đã dịch của 1 node (để lọc/hiển thị).</summary>
    private string Label(VmNode n) => Loc.L(n.TitleKey, n.Title);

    /// <summary>Node khớp lọc nếu chính nó khớp HOẶC có hậu duệ khớp.</summary>
    private bool NodeMatches(VmNode n) => Match(Label(n)) || n.Children.Any(NodeMatches);

    /// <summary>Mở cụm khi: đang lọc (bung mọi nhánh có kết quả) HOẶC nằm trong tập đang mở.</summary>
    private bool IsOpen(VmNode n) => HasFilter || _expanded.Contains(n.Key);

    /// <summary>Con khớp lọc (giữ nguyên thứ tự); không lọc → giữ tất cả.</summary>
    private List<VmNode> FilteredChildren(List<VmNode> nodes) =>
        !HasFilter ? nodes : nodes.Where(NodeMatches).ToList();

    private List<VmItem> FilteredTop() =>
        _top.Where(i => Match(Loc.L(i.TitleKey, i.Title))).ToList();

    private List<VmItem> FilteredBottom() =>
        _bottom.Where(i => Match(Loc.L(i.TitleKey, i.Title))).ToList();

    /// <summary>Nhóm còn hiện nếu có con khớp lọc; loại bỏ nhóm rỗng.</summary>
    private List<VmSection> FilteredSections()
    {
        if (!HasFilter) return _sections;
        return _sections.Where(s => s.Children.Any(NodeMatches)).ToList();
    }

    // ── Trạng thái active / bung theo URL ───────────────────────────────────
    /// <summary>Route lá khớp URL hiện tại (đúng hệt hoặc là tiền tố segment).</summary>
    private bool PathMatches(string href) =>
        href.Length > 0 &&
        (string.Equals(_currentPath, href, StringComparison.OrdinalIgnoreCase) ||
         _currentPath.StartsWith(href + "/", StringComparison.OrdinalIgnoreCase));

    /// <summary>Node nằm trên nhánh đang xem nếu chính nó hoặc một hậu duệ khớp URL.</summary>
    private bool IsActivePath(VmNode n) => PathMatches(n.Href) || n.Children.Any(IsActivePath);

    /// <summary>Tự bung mọi cụm tổ tiên của màn đang xem (giữ các cụm khác nguyên trạng).</summary>
    private void ExpandActivePath()
    {
        void Walk(IEnumerable<VmNode> nodes)
        {
            foreach (var n in nodes.Where(n => n.IsGroup && IsActivePath(n)))
            {
                _expanded.Add(n.Key);
                Walk(n.Children);
            }
        }
        foreach (var s in _sections) Walk(s.Children);
    }

    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        SyncFromUri();
        ExpandActivePath();
        StateHasChanged();
    }

    private void SyncFromUri() => _currentPath = Nav.ToBaseRelativePath(Nav.Uri);

    /// <summary>
    /// Bấm cụm. Sự kiện theo sau: đang thu gọn → bung lại sidebar + mở cụm vừa bấm (+ điều hướng nếu có route);
    /// ngược lại toggle (đóng nếu đang mở; mở + điều hướng nếu đang đóng và có route).
    /// </summary>
    private async Task ToggleNode(VmNode node)
    {
        if (Collapsed)
        {
            await OnExpand.InvokeAsync();
            _expanded.Add(node.Key);
            if (node.Href.Length > 0) Nav.NavigateTo(node.Href);
            return;
        }

        if (!_expanded.Remove(node.Key))
        {
            _expanded.Add(node.Key);
            if (node.Href.Length > 0) Nav.NavigateTo(node.Href);
        }
    }

    /// <summary>Hủy đăng ký sự kiện khi component bị loại bỏ.</summary>
    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Loc.OnChanged -= OnLanguageChanged;
    }
}
