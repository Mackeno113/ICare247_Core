@* File    : ViewPage.razor
   Purpose : Màn hiển thị danh sách metadata-driven từ Ui_View (route /view/{ViewCode}).
             Gọi api/v1/views/{code}/info + /data; render DataView (Grid/TreeList). *@

@page "/view/{ViewCode}"
@using ICare247_UI.Services
@using ICare247_UI.Components.View
@using ICare247_UI.Components.MasterData
@inject ViewApiService ViewApi
@inject CacheAdminApiService Cache
@inject PermissionState Perms
@inject MasterDataApiService MasterApi
@inherits LocalizedComponentBase

<PageTitle>@(_view?.Title ?? _view?.ViewCode ?? ViewCode) — View</PageTitle>

<div class="page-container">
    @if (_loading)
    {
        <div class="md-form-loading"><div class="spinner"></div><span>@Loc.L("view.loading", "Đang tải View…")</span></div>
    }
    else if (_error is not null)
    {
        <div class="error-banner"><strong>⚠ @Loc.L("common.label.error", "Lỗi:")</strong> @_error</div>
    }
    else if (_view is not null)
    {
        <div class="md-list-header">
            <div>
                <h2>@(_view.Title ?? _view.ViewCode)</h2>
            </div>
            <div class="md-list-header__actions" style="display:flex; gap:8px; align-items:center;">
                @if (_isSuperAdmin)
                {
                    <button class="btn btn-secondary" disabled="@_clearingCache" @onclick="ClearCacheAsync"
                            title="@Loc.L("view.cache.clear.tip", "Xóa cache cấu hình màn + combobox, rồi tải lại")">
                        ↻ @Loc.L("view.cache.clear", "Xóa cache")
                    </button>
                }
                @if (_selected.Count > 0 && _view.AllowDelete && !string.IsNullOrWhiteSpace(_view.EditFormCode))
                {
                    <button class="btn btn-danger" @onclick="() => _showBulkDelete = true">
                        🗑️ @Loc.L("view.bulkDelete.btn", "Xóa đã chọn ({0})", _selected.Count)
                    </button>
                }
                @if (_view.AllowAdd && !string.IsNullOrWhiteSpace(_view.EditFormCode))
                {
                    <button class="btn btn-secondary" @onclick="() => _showImport = true"
                            title="@Loc.L("import.btn.tip", "Nhập dữ liệu từ file Excel theo template")">
                        ⬆ @Loc.L("import.btn", "Import Excel")
                    </button>
                    <button class="btn btn-primary" @onclick="OpenAdd">+ @Loc.L("common.action.create", "Thêm mới")</button>
                }
            </div>
        </div>

        <div class="@(_view.HasFilterPanel ? "dv-with-filter" : "")">
            @if (_view.HasFilterPanel)
            {
                <FilterPanel ViewCode="ViewCode" Filters="_view.Filters" SearchLabel="_view.SearchLabel"
                             ResetLabel="_view.ResetLabel" Collapsible="_view.FilterCollapsible"
                             OnSearch="OnFilterSearchAsync" OnValuesChanged="OnFilterValuesChanged" />
            }
            <div class="dv-grid-area">
                <DataView View="_view" Items="_items" OnEdit="OpenEdit" OnDelete="OpenDelete"
                          OnAdd="OpenAdd" OnRefresh="ReloadDataAsync" OnUnhandledAction="OnUnhandledAction"
                          SelectedDataItems="_selected" SelectedDataItemsChanged="OnSelectionChanged" />

                @if (_notice is not null)
                {
                    <div class="md-list-notice">@_notice</div>
                }

                <div class="md-list-footer">@Loc.L("view.footer.count", "Hiển thị {0} / {1} bản ghi", _items.Count, _total)</div>
            </div>
        </div>
    }
</div>

@* ── Popup Thêm/Sửa ngay trên màn lưới — đóng/Lưu xong ở nguyên màn này ── *@
@if (_showForm && _view is not null && !string.IsNullOrWhiteSpace(_view.EditFormCode))
{
    <DraggableModal Title="@FormTitle" Width="@_formWidth" OnClose="CloseForm">
        <MasterDataForm FormCode="@(_view.EditFormCode!)" Id="_editId" ShowTitle="false"
                        InitialValues="_prefillValues" LockedFields="_prefillLocked"
                        OnSaved="OnFormSaved" OnCancelled="CloseForm"
                        OnWidthResolved="(w) => _formWidth = w" />
    </DraggableModal>
}

@* ── Dialog xác nhận xóa (qua Edit_Form của View) ── *@
@if (_deleteId is not null && _view is not null && !string.IsNullOrWhiteSpace(_view.EditFormCode))
{
    <ConfirmDeleteDialog FormCode="@(_view.EditFormCode!)" Id="_deleteId"
                         OnDeleted="OnRecordDeleted" OnClosed="() => _deleteId = null" />
}

@* ── Xác nhận xóa nhiều (các dòng đã tick checkbox) ── *@
@if (_showBulkDelete && _view is not null)
{
    <DraggableModal Title="@Loc.L("view.bulkDelete.title", "Xóa nhiều bản ghi")" Width="460px"
                    OnClose="() => _showBulkDelete = false">
        <div class="md-form">
            <p>@((MarkupString)Loc.L("view.bulkDelete.confirm", "Xóa <strong>{0}</strong> bản ghi đã chọn? Bản ghi đang được tham chiếu sẽ được giữ lại.", _selected.Count))</p>
            <div class="md-form-footer">
                <button class="btn btn-secondary" disabled="@_bulkBusy" @onclick="() => _showBulkDelete = false">
                    @Loc.L("common.action.cancel", "Hủy")
                </button>
                <button class="btn btn-danger" disabled="@_bulkBusy" @onclick="BulkDeleteAsync">
                    @(_bulkBusy ? Loc.L("delete.deleting", "Đang xóa…") : "🗑️ " + Loc.L("delete.confirm.permanent", "Xóa vĩnh viễn"))
                </button>
            </div>
        </div>
    </DraggableModal>
}

@* ── Trợ lý Import Excel (tải template → preview → commit) ── *@
@if (_showImport && _view is not null)
{
    <DraggableModal Title="@($"{Loc.L("import.btn", "Import Excel")} — {_view.Title ?? _view.ViewCode}")"
                    Width="760px" OnClose="() => _showImport = false">
        <ImportWizard ViewCode="ViewCode" OnClose="() => _showImport = false" OnCommitted="OnImported" />
    </DraggableModal>
}

@code {
    [Parameter] public string ViewCode { get; set; } = "";

    private ViewMetadataDto? _view;
    private List<Dictionary<string, object?>> _items = [];
    private int _total;
    private bool _loading = true;
    private bool _clearingCache;
    private bool _isSuperAdmin;
    private string? _error;
    private string? _notice;

    /// <summary>Giá trị panel lọc lần Tìm gần nhất — để Refresh chạy lại đúng bộ lọc (nguồn SP/SQL).</summary>
    private IReadOnlyDictionary<string, string?> _lastFilters = new Dictionary<string, string?>();

    /// <summary>Giá trị panel lọc HIỆN TẠI (cập nhật mỗi khi đổi) — dùng để prefill khi Thêm mới (ADR-030).</summary>
    private IReadOnlyDictionary<string, string?> _currentFilters = new Dictionary<string, string?>();

    /// <summary>Prefill cho form Thêm mới: Field_Code → giá trị (đổ từ panel khi mở Thêm).</summary>
    private Dictionary<string, object?>? _prefillValues;
    /// <summary>Field_Code khóa read-only khi prefill (Default_Lock=1).</summary>
    private HashSet<string>? _prefillLocked;

    // ── Trạng thái popup Thêm/Sửa + dialog Xóa (inline trên màn lưới) ──
    private bool    _showForm;
    private object? _editId;     // null = Thêm, có giá trị = Sửa
    private object? _deleteId;
    private string? _formWidth;  // bề rộng modal Thêm/Sửa theo số cột form (MasterDataForm phát ra)

    // ── Chọn nhiều dòng (checkbox) + xóa hàng loạt ──
    private IReadOnlyList<object> _selected = [];
    private bool _showBulkDelete;
    private bool _bulkBusy;

    // ── Import Excel (trợ lý tải template → preview → commit) ──
    private bool _showImport;

    /// <summary>Import ghi xong ≥1 dòng → nạp lại dữ liệu lưới (không đóng modal để người dùng xem kết quả).</summary>
    private async Task OnImported() => await ReloadDataAsync();

    /// <summary>Cập nhật danh sách dòng đang tick (DxGrid SelectedDataItems = ExpandoObject).</summary>
    private void OnSelectionChanged(IReadOnlyList<object> items) => _selected = items;

    /// <summary>Tiêu đề thanh popup: "Thêm mới / Cập nhật — {Tên màn đã i18n}" (không lòi mã Form).</summary>
    private string FormTitle =>
        $"{(_editId is null ? Loc.L("common.action.create", "Thêm mới") : Loc.L("common.action.update", "Cập nhật"))} — {_view?.Title ?? _view?.ViewCode}";

    protected override async Task OnParametersSetAsync() => await InitAsync();

    private async Task InitAsync()
    {
        _loading = true; _error = null;
        try
        {
            _isSuperAdmin = await Perms.IsSuperAdminAsync();
            _view = await ViewApi.GetInfoAsync(ViewCode);
            if (_view is null) { _error = Loc.L("view.notfound", "Không tìm thấy View '{0}'.", ViewCode); return; }

            // Nguồn SP/SQL có panel lọc: chỉ tải khi Auto_Search_On_Load (tránh SP nặng) — ngược lại chờ bấm Tìm.
            if (_view.HasFilterPanel && !_view.AutoSearchOnLoad)
            {
                _items = []; _total = 0;
            }
            else
            {
                await ReloadDataAsync();
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    /// <summary>
    /// Xóa cache màn này (View metadata server) + cache combobox client, rồi nạp lại cấu hình + dữ liệu.
    /// Dùng khi cấu hình/danh mục đã đổi ở DB nhưng màn vẫn hiện bản cũ.
    /// </summary>
    private async Task ClearCacheAsync()
    {
        _clearingCache = true; _notice = null;
        var res = await Cache.InvalidateViewAsync(ViewCode);
        Cache.ClearClientLookupCache();
        await InitAsync();              // GET lại view info (cache đã xóa) + dữ liệu
        _clearingCache = false;
        _notice = res.Ok
            ? Loc.L("view.cache.cleared", "Đã xóa cache và tải lại.")
            : (res.Error ?? Loc.L("view.cache.clear.err", "Xóa cache thất bại."));
    }

    /// <summary>Tải lại dữ liệu: nguồn query → chạy lại bộ lọc gần nhất; nguồn Table → SELECT + search LIKE.</summary>
    private async Task ReloadDataAsync()
    {
        if (_view!.IsQuerySource)
        {
            await RunSearchAsync(_lastFilters);
            return;
        }

        // Tải TOÀN BỘ bản ghi 1 lần (pageSize tối đa) rồi để DxGrid tự phân trang/cuộn ảo phía
        // client theo Page_Size cấu hình. Nếu chỉ lấy đúng Page_Size (vd 20) thì lưới chỉ có 1
        // trang server trong bộ nhớ → không cuộn/sang trang xem hết được phần dữ liệu còn lại.
        var result = await ViewApi.GetDataAsync(ViewCode, search: null, page: 1, pageSize: int.MaxValue);
        _items = result?.Items ?? [];
        _total = result?.TotalCount ?? 0;
    }

    /// <summary>Panel lọc bấm Tìm (đã validate Required client-side) → thực thi SP/SQL.</summary>
    private async Task OnFilterSearchAsync(IReadOnlyDictionary<string, string?> values)
    {
        _lastFilters = values;
        await RunSearchAsync(values);
    }

    /// <summary>Gọi endpoint /search; tham số sai/thiếu (400) → hiện thông báo thay vì vỡ trang.</summary>
    private async Task RunSearchAsync(IReadOnlyDictionary<string, string?> values)
    {
        _notice = null;
        try
        {
            var result = await ViewApi.SearchAsync(ViewCode, values);
            _items = result?.Items ?? [];
            _total = result?.TotalCount ?? 0;
        }
        catch (HttpRequestException ex)
        {
            _items = []; _total = 0;
            _notice = ex.Message;
        }
    }

    /// <summary>Panel lọc đổi giá trị → ghi nhận để prefill khi Thêm mới (không chạy Tìm).</summary>
    private void OnFilterValuesChanged(IReadOnlyDictionary<string, string?> values) => _currentFilters = values;

    /// <summary>Mở popup Thêm mới (Edit_Form của View) — đổ giá trị panel lọc vào field theo Default_To_Field.</summary>
    private void OpenAdd()
    {
        if (string.IsNullOrWhiteSpace(_view?.EditFormCode)) return;
        BuildPrefill();
        _editId = null;
        _showForm = true;
    }

    /// <summary>
    /// Dựng map prefill từ giá trị panel hiện tại: với mỗi filter có Default_To_Field + đang có giá trị →
    /// đổ vào field đó; Default_Lock=1 → khóa read-only. Chỉ áp cho View có panel lọc.
    /// </summary>
    private void BuildPrefill()
    {
        _prefillValues = null;
        _prefillLocked = null;
        if (_view is null || !_view.HasFilterPanel) return;

        var values = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
        var locked = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var f in _view.Filters)
        {
            if (string.IsNullOrWhiteSpace(f.DefaultToField)) continue;
            if (!_currentFilters.TryGetValue(f.FilterCode, out var raw) || string.IsNullOrWhiteSpace(raw)) continue;
            values[f.DefaultToField!] = raw;
            if (f.DefaultLock) locked.Add(f.DefaultToField!);
        }
        if (values.Count > 0) { _prefillValues = values; _prefillLocked = locked; }
    }

    /// <summary>Double-click dòng → mở popup Sửa: resolve khóa từ Key_Field.</summary>
    private void OpenEdit(IDictionary<string, object?> row)
    {
        if (string.IsNullOrWhiteSpace(_view?.EditFormCode) || string.IsNullOrWhiteSpace(_view.KeyField)) return;
        var hit = row.FirstOrDefault(kv => kv.Key.Equals(_view.KeyField, StringComparison.OrdinalIgnoreCase));
        var id = hit.Value;
        if (id is null) return;
        _editId = id;
        _showForm = true;
    }

    /// <summary>Xóa: mở dialog xác nhận (soft-check tham chiếu) ngay trên màn lưới.</summary>
    private void OpenDelete(object? id)
    {
        if (string.IsNullOrWhiteSpace(_view?.EditFormCode) || id is null) return;
        _deleteId = id;
    }

    /// <summary>Đóng popup Thêm/Sửa (Hủy hoặc nút ✕).</summary>
    private void CloseForm()
    {
        _showForm = false;
        _editId = null;
        _formWidth = null;   // reset để lần mở sau tính lại theo form tương ứng
    }

    /// <summary>Lưu thành công → đóng popup + nạp lại dữ liệu lưới (ở nguyên màn này).</summary>
    private async Task OnFormSaved(object? _)
    {
        CloseForm();
        await ReloadDataAsync();
    }

    /// <summary>Xóa thành công → đóng dialog + nạp lại dữ liệu lưới.</summary>
    private async Task OnRecordDeleted()
    {
        _deleteId = null;
        await ReloadDataAsync();
    }

    /// <summary>
    /// Xóa hàng loạt các dòng đã tick: resolve khóa từ Key_Field rồi gọi xóa từng bản ghi.
    /// Bản ghi đang bị tham chiếu (server chặn) được đếm riêng, không làm hỏng cả mẻ.
    /// </summary>
    private async Task BulkDeleteAsync()
    {
        if (_view is null || string.IsNullOrWhiteSpace(_view.EditFormCode) || string.IsNullOrWhiteSpace(_view.KeyField))
            return;

        _bulkBusy = true; _notice = null;
        int deleted = 0, blocked = 0, failed = 0;
        try
        {
            foreach (var item in _selected.ToList())
            {
                // ExpandoObject = IDictionary<string, object?> tại runtime (object? = object).
                if (item is not IDictionary<string, object?> row) { failed++; continue; }
                var hit = row.FirstOrDefault(kv => kv.Key.Equals(_view.KeyField, StringComparison.OrdinalIgnoreCase));
                if (hit.Value is null) { failed++; continue; }

                try
                {
                    var res = await MasterApi.DeleteAsync(_view.EditFormCode!, hit.Value);
                    if (res.Success) deleted++; else blocked++;
                }
                catch { failed++; }
            }
        }
        finally
        {
            _bulkBusy = false;
            _showBulkDelete = false;
            _selected = [];
            await ReloadDataAsync();
            _notice = Loc.L("view.bulkDelete.result", "Đã xóa {0} bản ghi. Bị tham chiếu (giữ lại): {1}. Lỗi: {2}.", deleted, blocked, failed);
        }
    }

    /// <summary>Action chưa hỗ trợ client (print/event/api/export server-side) → hiện thông báo.</summary>
    private void OnUnhandledAction(ViewActionDto a)
    {
        _notice = a.ActionType.Equals("Export", StringComparison.OrdinalIgnoreCase)
            ? Loc.L("view.action.exportUnsupported", "Xuất {0} server-side (pdf/docx) chưa hỗ trợ — sẽ bổ sung sau.", a.ExportFormat ?? "")
            : Loc.L("view.action.unsupported", "Action '{0}' ({1}) chưa được hỗ trợ ở runtime.", a.ActionType, a.ActionCode);
    }
}
