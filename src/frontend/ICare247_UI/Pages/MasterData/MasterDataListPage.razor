@* File    : MasterDataListPage.razor
   Purpose : Màn List danh mục — Thêm/Sửa/Xóa. Form Thêm/Sửa render Popup (modal inline)
             hoặc Tab (điều hướng routed page) theo Ui_Form.Display_Mode. *@

@page "/master/{FormCode}"
@using ICare247_UI.Services
@using ICare247_UI.Components.MasterData
@inject MasterDataApiService MasterApi
@inject CacheAdminApiService Cache
@inject PermissionState Perms
@inject NavigationManager Nav
@inject ToastService Toast
@inherits LocalizedComponentBase

<PageTitle>@(_info?.FormCode ?? FormCode) — @Loc.L("masterdata.list.pageTitle", "Danh mục")</PageTitle>

<div class="page-container">
    @if (_loading)
    {
        <div class="md-form-loading"><div class="spinner"></div><span>@Loc.L("masterdata.list.loading", "Đang tải danh mục…")</span></div>
    }
    else if (_error is not null)
    {
        <div class="error-banner"><strong>⚠ @Loc.L("common.label.error", "Lỗi:")</strong> @_error</div>
    }
    else if (_info is not null)
    {
        <div class="md-list-header">
            <div>
                <h2>@Loc.L("masterdata.list.manage", "Quản lý: {0}", FormCode)</h2>
                <span class="md-list-sub">@Loc.L("masterdata.list.subtitle", "Bảng {0}.{1} · chế độ {2}", _info.SchemaName, _info.TableName, _info.DisplayMode)</span>
            </div>
            <div style="display:flex; gap:8px; align-items:center;">
                @if (_isSuperAdmin)
                {
                    <button class="btn btn-secondary" disabled="@_clearingCache" @onclick="ClearCacheAsync"
                            title="@Loc.L("masterdata.cache.clear.tip", "Xóa cache cấu hình form + combobox, rồi tải lại")">
                        ↻ @Loc.L("masterdata.cache.clear", "Xóa cache")
                    </button>
                }
                @if (_perm.Them)
                {
                    <button class="btn btn-primary" @onclick="() => OpenForm(null)">+ @Loc.L("common.action.create", "Thêm mới")</button>
                }
            </div>
        </div>

        <div class="md-list-toolbar">
            <input class="md-search" placeholder="@Loc.L("common.search.placeholder", "🔍 Tìm kiếm…")" value="@_search"
                   @onchange="OnSearchChanged" />
            <label class="md-active-filter">
                <input type="checkbox" checked="@_activeOnly" @onchange="OnActiveToggled" />
                @Loc.L("masterdata.list.activeOnly", "Chỉ Active")
            </label>
        </div>

        <MasterDataGrid Columns="_listColumns"
                        Items="_items"
                        PkColumn="@_info.PkColumn"
                        Config="_gridConfig"
                        CanEdit="_perm.Sua"
                        CanDelete="_perm.Xoa"
                        OnEdit="(id) => OpenForm(id)"
                        OnDelete="OpenDelete" />

        <div class="md-list-footer">@Loc.L("view.footer.count", "Hiển thị {0} / {1} bản ghi", _items.Count, _total)</div>
    }
</div>

@* ── Popup form (chỉ khi Display_Mode = Popup) — kéo được, chỉ đóng bằng nút ── *@
@if (_showPopup && _info is not null)
{
    <DraggableModal Title="@PopupTitle" Width="@_formWidth" OnClose="CloseForm" BeforeClose="ConfirmCloseIfDirtyAsync">
        <MasterDataForm @ref="_form" FormCode="@FormCode" Id="_editId" ShowTitle="false"
                        OnSaved="OnFormSaved" OnCancelled="CancelFormAsync"
                        OnWidthResolved="(w) => _formWidth = w" />
    </DraggableModal>
}

@* Hộp thoại "Bỏ thay đổi?" khi đóng form còn thay đổi chưa lưu (WEB-UX-03). *@
<ConfirmDialog @ref="_confirm" />

@* ── Confirm delete dialog ── *@
@if (_deleteId is not null && _info is not null)
{
    <ConfirmDeleteDialog FormCode="@FormCode" Id="_deleteId"
                         OnDeleted="OnRecordDeleted" OnClosed="() => _deleteId = null" />
}

@code {
    [Parameter] public string FormCode { get; set; } = "";

    private MasterDataFormInfoDto? _info;
    private List<MasterDataColumnDto> _listColumns = [];
    private List<Dictionary<string, object?>> _items = [];
    private int _total;
    private bool _loading = true;
    private bool _clearingCache;
    private bool _isSuperAdmin;
    private string? _error;

    private string? _search;
    private bool _activeOnly;

    // Cờ quyền cho form này (Form = FormCode). Chưa cấu hình → cho phép hết.
    private PermFlags _perm = PermFlags.All;

    // Cấu hình lưới DxGrid — default an toàn; sau này nạp per-form từ metadata.
    private readonly MasterDataGridConfig _gridConfig = new();

    private bool _showPopup;
    private object? _editId;
    private object? _deleteId;
    private string? _formWidth;  // bề rộng modal theo số cột form (MasterDataForm phát ra)
    private MasterDataForm? _form;      // ref form để hỏi IsDirty khi đóng
    private ConfirmDialog?  _confirm;   // hộp thoại "Bỏ thay đổi?"

    /// <summary>Tiêu đề thanh popup: "Thêm mới / Cập nhật — {FormCode}".</summary>
    private string PopupTitle =>
        $"{(_editId is null ? Loc.L("common.action.create", "Thêm mới") : Loc.L("common.action.update", "Cập nhật"))} — {FormCode}";

    protected override async Task OnParametersSetAsync() => await InitAsync();

    /// <summary>Xóa cache cấu hình form (server) + cache combobox client, rồi nạp lại form + danh sách.</summary>
    private async Task ClearCacheAsync()
    {
        _clearingCache = true;
        await Cache.InvalidateFormAsync(FormCode);
        Cache.ClearClientLookupCache();
        await InitAsync();
        _clearingCache = false;
    }

    private async Task InitAsync()
    {
        _loading = true; _error = null;
        try
        {
            _info = await MasterApi.GetInfoAsync(FormCode);
            if (_info is null) { _error = Loc.L("masterdata.list.notfound", "Không tìm thấy form danh mục '{0}'.", FormCode); return; }

            await Perms.EnsureLoadedAsync();
            _perm = Perms.ForTarget("Form", FormCode);
            _isSuperAdmin = await Perms.IsSuperAdminAsync();

            // Cột lưới = Show_In_List; fallback toàn bộ cột nếu chưa cấu hình cờ nào
            _listColumns = _info.Columns.Where(c => c.ShowInList).ToList();
            if (_listColumns.Count == 0) _listColumns = _info.Columns.ToList();

            await ReloadListAsync();
        }
        catch (Exception ex) { _error = ApiErrorLocalizer.Describe(Loc, ex); }
        finally { _loading = false; }
    }

    private async Task ReloadListAsync()
    {
        // Tải toàn bộ bản ghi 1 lần (page=1, pageSize tối đa) rồi để DxGrid tự phân trang/
        // cuộn phía client. Không phân trang server: pager + bộ chọn pageSize của lưới lật
        // trên đám dòng đã nạp sẵn nên xem được hết dữ liệu, không bị kẹt ở trang đầu.
        var result = await MasterApi.GetListAsync(FormCode, _search, _activeOnly ? true : null,
                                                  page: 1, pageSize: int.MaxValue);
        _items = result.Items;
        _total = result.TotalCount;
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        await ReloadListAsync();
    }

    private async Task OnActiveToggled(ChangeEventArgs e)
    {
        _activeOnly = e.Value is bool b && b;
        await ReloadListAsync();
    }

    /// <summary>Mở form Thêm (id null) / Sửa — Popup inline hoặc điều hướng Tab theo Display_Mode.</summary>
    private void OpenForm(object? id)
    {
        if (_info is null) return;

        if (_info.DisplayMode.Equals("Tab", StringComparison.OrdinalIgnoreCase))
        {
            var url = id is null
                ? $"/master/{Uri.EscapeDataString(FormCode)}/edit"
                : $"/master/{Uri.EscapeDataString(FormCode)}/edit/{Uri.EscapeDataString(id.ToString() ?? "")}";
            Nav.NavigateTo(url);
            return;
        }

        _editId = id;
        _showPopup = true;
    }

    private void CloseForm() { _showPopup = false; _editId = null; _formWidth = null; }

    /// <summary>
    /// Chốt chặn đóng modal (✕/Escape): form còn thay đổi chưa lưu → hỏi "Bỏ thay đổi?".
    /// Trả true = cho đóng (sạch hoặc user đồng ý bỏ); false = giữ lại tiếp tục sửa.
    /// </summary>
    private async Task<bool> ConfirmCloseIfDirtyAsync()
    {
        if (_form is null || !_form.IsDirty) return true;
        if (_confirm is null) return true;
        return await _confirm.ShowAsync(
            Loc.L("form.discard.title", "Bỏ thay đổi?"),
            Loc.L("form.discard.msg", "Bạn có thay đổi chưa lưu. Đóng form sẽ mất các thay đổi này."),
            Loc.L("form.discard.confirm", "Bỏ & đóng"),
            Loc.L("form.discard.cancel", "Tiếp tục sửa"));
    }

    /// <summary>Nút Hủy trong form → đi qua cùng chốt chặn dirty như ✕/Escape rồi mới đóng.</summary>
    private async Task CancelFormAsync()
    {
        if (await ConfirmCloseIfDirtyAsync())
            CloseForm();
    }

    /// <summary>
    /// Lưu thành công → đóng popup + toast + nạp lại danh sách. Tách 2 trạng thái: DB lưu xong nhưng
    /// làm mới danh sách lỗi → CẢNH BÁO (không phải "lưu thất bại").
    /// </summary>
    private async Task OnFormSaved(object? _)
    {
        CloseForm();
        try
        {
            await ReloadListAsync();
            Toast.Success(Loc.L("common.msg.saved", "Đã lưu."));
        }
        catch (Exception ex)
        {
            Toast.Warning(Loc.L("common.msg.savedButReloadFailed",
                "Đã lưu, nhưng làm mới danh sách lỗi — hãy tải lại trang. ({0})", ex.Message));
        }
    }

    private void OpenDelete(object? id) => _deleteId = id;

    private async Task OnRecordDeleted()
    {
        _deleteId = null;
        await ReloadListAsync();
    }
}
