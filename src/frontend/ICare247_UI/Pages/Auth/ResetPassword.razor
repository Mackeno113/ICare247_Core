@* File    : ResetPassword.razor
   Purpose : Màn đặt lại mật khẩu bằng token (?token=...). Backend STUB (chưa hỗ trợ thật) —
             trả 501 → hiện thông báo "đang hoàn thiện". Motif "thiết bị khóa + chấm bi".
             Checklist 4 điều kiện mật khẩu kiểm tra client-side. *@

@page "/reset-password"
@layout AuthLayout
@inherits LocalizedComponentBase
@inject HttpClient Http
@inject NavigationManager Nav
@using System.Net.Http.Json
@using System.Text.RegularExpressions

<PageTitle>@Loc.L("auth.reset.title", "Đặt lại mật khẩu") — ICare247</PageTitle>

<AuthShell>
    <FormContent>
        <div class="auth-brand-row">
            <span class="auth-logo">◆</span>
            <span class="auth-logo-text">ICare<span class="accent">247</span></span>
        </div>

        <h1 class="auth-title">@Loc.L("auth.reset.heading", "Đặt lại mật khẩu")</h1>
        <p class="auth-subtitle">@Loc.L("auth.reset.sub", "Tạo mật khẩu mới cho tài khoản của bạn.")</p>

        @if (_notice is not null)
        {
            <div class="auth-alert @_noticeKind"><span>@(_noticeKind == "info" ? "ℹ" : "⚠")</span><span>@_notice</span></div>
        }

        <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
            <AuthInput Id="newpass"
                       Type="password"
                       Label="@Loc.L("auth.reset.new", "Mật khẩu mới")"
                       Icon="🔒"
                       Autocomplete="new-password"
                       @bind-Value="_password" />

            <ul class="auth-checklist">
                <li class="@(HasMinLength ? "ok" : null)"><span class="dot">✓</span>@Loc.L("auth.reset.rule.len", "Ít nhất 8 ký tự")</li>
                <li class="@(HasUpper ? "ok" : null)"><span class="dot">✓</span>@Loc.L("auth.reset.rule.upper", "Có chữ in hoa")</li>
                <li class="@(HasDigit ? "ok" : null)"><span class="dot">✓</span>@Loc.L("auth.reset.rule.digit", "Có chữ số")</li>
                <li class="@(HasSpecial ? "ok" : null)"><span class="dot">✓</span>@Loc.L("auth.reset.rule.special", "Có ký tự đặc biệt")</li>
            </ul>

            <AuthInput Id="confirm"
                       Type="password"
                       Label="@Loc.L("auth.reset.confirm", "Xác nhận mật khẩu")"
                       Icon="🔒"
                       Autocomplete="new-password"
                       Invalid="@(!string.IsNullOrEmpty(_confirm) && !IsMatch)"
                       @bind-Value="_confirm" />

            <AuthButton Busy="_busy" Disabled="!CanSubmit"
                        BusyText="@Loc.L("auth.reset.submitting", "Đang xử lý...")">
                @Loc.L("auth.reset.submit", "Đặt lại mật khẩu")
            </AuthButton>
        </form>

        <p class="auth-foot">
            <a class="auth-link" href="login">@Loc.L("auth.reset.back", "← Quay lại đăng nhập")</a>
        </p>
    </FormContent>

    <BrandContent>
        <BrandPanel Motif="reset"
                    Eyebrow="@Loc.L("auth.brand.eyebrow.security", "AN TOÀN TÀI KHOẢN")"
                    Headline="@Loc.L("auth.reset.brand.headline", "Mật khẩu mạnh, tài khoản an toàn.")"
                    Sub="@Loc.L("auth.reset.brand.sub", "Sau khi đặt lại, mọi phiên đăng nhập cũ sẽ bị thu hồi trên các thiết bị.")" />
    </BrandContent>
</AuthShell>

@code {
    private string? _password;
    private string? _confirm;
    private bool _busy;
    private string? _notice;
    private string _noticeKind = "info";
    private string? _token;

    private bool HasMinLength => (_password?.Length ?? 0) >= 8;
    private bool HasUpper => _password?.Any(char.IsUpper) ?? false;
    private bool HasDigit => _password?.Any(char.IsDigit) ?? false;
    private bool HasSpecial => _password?.Any(c => !char.IsLetterOrDigit(c)) ?? false;
    private bool IsMatch => !string.IsNullOrEmpty(_password) && _password == _confirm;
    private bool CanSubmit => HasMinLength && HasUpper && HasDigit && HasSpecial && IsMatch;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        // Lấy token từ query string (?token=...) — gửi kèm khi đặt lại.
        var query = new Uri(Nav.Uri).Query;
        var m = Regex.Match(query, @"[?&]token=([^&]+)");
        _token = m.Success ? Uri.UnescapeDataString(m.Groups[1].Value) : null;
    }

    /// <summary>Gửi yêu cầu đặt lại. Backend hiện STUB → 501 → hiện thông báo đang hoàn thiện.</summary>
    private async Task HandleSubmit()
    {
        if (!CanSubmit) return;
        _busy = true;
        _notice = null;
        try
        {
            var resp = await Http.PostAsJsonAsync("api/v1/auth/reset-password",
                new { token = _token ?? "", newPassword = _password });

            if (resp.IsSuccessStatusCode)
            {
                _noticeKind = "info";
                _notice = Loc.L("auth.reset.done", "Đặt lại mật khẩu thành công. Vui lòng đăng nhập lại.");
            }
            else
            {
                _noticeKind = "info";
                _notice = Loc.L("auth.reset.pending", "Tính năng đặt lại mật khẩu qua email đang được hoàn thiện. Vui lòng liên hệ quản trị viên.");
            }
        }
        catch
        {
            _noticeKind = "error";
            _notice = Loc.L("auth.reset.error", "Không kết nối được máy chủ. Vui lòng thử lại.");
        }
        finally
        {
            _busy = false;
        }
    }
}
