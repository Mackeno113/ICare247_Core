@* File    : ForgotPassword.razor
   Purpose : Màn quên mật khẩu — gửi yêu cầu đặt lại (backend STUB, chưa gửi mail thật).
             Motif "khiên + radar" (design-login-hitech). Banner chống dò email. *@

@page "/forgot-password"
@layout AuthLayout
@inherits LocalizedComponentBase
@inject IAuthService Auth

<PageTitle>@Loc.L("auth.forgot.title", "Quên mật khẩu") — ICare247</PageTitle>

<AuthShell>
    <FormContent>
        <div class="auth-brand-row">
            <span class="auth-logo">◆</span>
            <span class="auth-logo-text">ICare<span class="accent">247</span></span>
        </div>

        <h1 class="auth-title">@Loc.L("auth.forgot.heading", "Quên mật khẩu")</h1>
        <p class="auth-subtitle">@Loc.L("auth.forgot.sub", "Nhập tên đăng nhập hoặc email. Nếu tài khoản tồn tại, chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu.")</p>

        @if (_sent)
        {
            <div class="auth-alert info">
                <span>✓</span>
                <span>@Loc.L("auth.forgot.sent", "Nếu tài khoản tồn tại, hướng dẫn đặt lại mật khẩu đã được gửi. Vui lòng kiểm tra email.")</span>
            </div>
        }
        else
        {
            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault>
                <AuthInput Id="account"
                           Label="@Loc.L("auth.forgot.account", "Tên đăng nhập hoặc email")"
                           Icon="✉"
                           Placeholder="@Loc.L("auth.forgot.account.ph", "Nhập tên đăng nhập hoặc email")"
                           @bind-Value="_account" />

                <AuthButton Busy="_busy" BusyText="@Loc.L("auth.forgot.submitting", "Đang gửi...")">
                    @Loc.L("auth.forgot.submit", "Gửi hướng dẫn")
                </AuthButton>
            </form>
        }

        <p class="auth-foot">
            <a class="auth-link" href="login">@Loc.L("auth.forgot.back", "← Quay lại đăng nhập")</a>
        </p>
    </FormContent>

    <BrandContent>
        <BrandPanel Motif="forgot"
                    Eyebrow="@Loc.L("auth.brand.eyebrow.security", "AN TOÀN TÀI KHOẢN")"
                    Headline="@Loc.L("auth.forgot.brand.headline", "Bảo vệ tài khoản của bạn.")"
                    Sub="@Loc.L("auth.forgot.brand.sub", "Quy trình đặt lại mật khẩu an toàn, không tiết lộ tài khoản nào tồn tại trong hệ thống.")" />
    </BrandContent>
</AuthShell>

@code {
    private string? _account;
    private bool _busy;
    private bool _sent;

    /// <summary>Gửi yêu cầu. Sự kiện theo sau: luôn hiện banner thành công (chống dò tài khoản).</summary>
    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_account)) return;
        _busy = true;
        await Auth.RequestPasswordResetAsync(_account!);
        _busy = false;
        _sent = true;
    }
}
