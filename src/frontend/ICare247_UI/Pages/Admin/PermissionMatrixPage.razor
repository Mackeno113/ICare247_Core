@page "/m/administration/permissions"
@inject AdminPermissionApiService Api
@inject LocalizationService Loc

@*
    PermissionMatrixPage — màn Phân quyền (bespoke, ADR-023).
    2 view theo vai trò đang chọn:
    · "Chức năng" — DxTreeList cây chức năng (HT_ChucNang) + cột "Tất cả" + 5 cột Xem/Thêm/Sửa/Xóa/In.
      Cascade 2 chiều: tick cha → toàn bộ con; trạng thái CHA suy từ con (indeterminate), KHÔNG lưu cứng.
    · "Phạm vi công ty" — cây TC_CongTy checkbox WYSIWYG (HT_VaiTro_CongTy): tick cha auto-tick nhánh,
      bỏ tick tự do, lưu đúng những gì tick. User thuộc vai trò KẾ THỪA ĐỘNG các công ty này.
    - 1 CTA "Lưu" duy nhất → lưu view đang mở (PUT permissions hoặc PUT companies).
*@

<PageTitle>@Loc.L("admin.perm.title", "Phân quyền") — ICare247</PageTitle>

<div class="perm-toolbar">
    <span class="perm-title">@Loc.L("admin.perm.title", "Phân quyền")</span>
    <span class="perm-sep">·</span>
    <label class="perm-rolelabel">@Loc.L("admin.perm.role", "Vai trò"):</label>
    <select class="perm-roleselect" @onchange="OnRoleChanged">
        @foreach (var r in _roles)
        {
            <option value="@r.Id" selected="@(r.Id == _roleId)">@r.Ten</option>
        }
    </select>
    <span class="perm-sep">·</span>
    <div class="perm-viewtabs">
        <button class="perm-viewtab @(_view == ViewMode.Functions ? "perm-viewtab--active" : null)"
                @onclick="() => _view = ViewMode.Functions">@Loc.L("admin.perm.view.functions", "Chức năng")</button>
        <button class="perm-viewtab @(_view == ViewMode.Companies ? "perm-viewtab--active" : null)"
                @onclick="OpenCompaniesViewAsync">@Loc.L("admin.perm.view.companies", "Phạm vi công ty")</button>
    </div>
    <span class="perm-spacer"></span>
    @if (_saved)
    {
        <span class="perm-saved">@Loc.L("admin.perm.saved", "Đã lưu")</span>
    }
    <button class="perm-btn-primary" disabled="@(_roleId is null || _saving)" @onclick="SaveAsync">
        @(_saving ? Loc.L("common.btn.saving", "Đang lưu…") : Loc.L("common.btn.save", "Lưu"))
    </button>
</div>

@if (_view == ViewMode.Companies)
{
    @if (_companiesLoading)
    {
        <div class="perm-empty">@Loc.L("common.app.loading", "Đang tải...")</div>
    }
    else if (_companyItems.Count == 0)
    {
        <div class="perm-empty">@Loc.L("admin.perm.companies.empty", "Chưa có công ty nào (tạo ở màn Công ty).")</div>
    }
    else
    {
        <div class="perm-cohint">@Loc.L("admin.perm.companies.hint", "User thuộc vai trò này được truy cập các công ty tick bên dưới (kế thừa động — sửa là áp ngay). Tick công ty cha sẽ tick cả nhánh con, bỏ tick từng công ty tùy ý. Công ty tạo sau này không tự có quyền.")</div>
        <div class="perm-cotree">
            <IcCompanyPicker Mode="IcPickerMode.MultiCheck" Items="_companyItems"
                             SelectedIds="_selectedCompanyIds" SelectedIdsChanged="OnCompaniesChanged" />
        </div>
    }
}
else if (_loading)
{
    <div class="perm-empty">@Loc.L("common.app.loading", "Đang tải...")</div>
}
else if (_nodes.Count == 0)
{
    <div class="perm-empty">@Loc.L("admin.perm.empty", "Chưa có chức năng nào (cần chạy seed HT_ChucNang).")</div>
}
else
{
    @* VirtualScrollingEnabled (thay ShowAllRows) + height ở .perm-tree → DevExpress tách header ra
       ngoài vùng cuộn = GHIM tiêu đề khi cuộn cây. ShowAllRows render hết dòng, header trôi theo. *@
    <DxTreeList Data="_nodes" KeyFieldName="Id" ParentKeyFieldName="ChaId"
                AutoExpandAllNodes="true" VirtualScrollingEnabled="true" HighlightRowOnHover="true"
                CssClass="perm-tree">
        <Columns>
            <DxTreeListDataColumn Caption="@Loc.L("admin.perm.func", "Chức năng")" FieldName="Ten" />

            @* Cột "Tất cả": tick 1 ô = bật/tắt cả 5 quyền của dòng (+cascade). Header = master toàn bảng. *@
            <DxTreeListDataColumn Width="92px">
                <HeaderCaptionTemplate>
                    <div class="perm-head" @onclick:stopPropagation="true">
                        <span>@Loc.L("admin.perm.all", "Tất cả")</span>
                        <DxCheckBox T="bool?" AllowIndeterminateState="true" AllowIndeterminateStateByClick="false"
                                    Checked="@MasterAllState()" CheckedChanged="@((bool? v) => OnMasterAll(v))"
                                    CssClass="perm-chk" />
                    </div>
                </HeaderCaptionTemplate>
                <CellDisplayTemplate>
                    @{ var na = (PermNode)context.DataItem; }
                    <div class="perm-cell">
                        <DxCheckBox T="bool?" AllowIndeterminateState="true" AllowIndeterminateStateByClick="false"
                                    Checked="@RowAllState(na)" CheckedChanged="@((bool? v) => OnRowAll(na, v))"
                                    CssClass="perm-chk" />
                    </div>
                </CellDisplayTemplate>
            </DxTreeListDataColumn>

            @foreach (var col in Cols)
            {
                var c = col;
                <DxTreeListDataColumn Width="84px">
                    <HeaderCaptionTemplate>
                        <div class="perm-head" @onclick:stopPropagation="true">
                            <span>@Loc.L(c.Key, c.Def)</span>
                            <DxCheckBox T="bool?" AllowIndeterminateState="true" AllowIndeterminateStateByClick="false"
                                        Checked="@ColHeaderState(c.Get)" CheckedChanged="@((bool? v) => OnColHeader(c.Set, v))"
                                        CssClass="perm-chk" />
                        </div>
                    </HeaderCaptionTemplate>
                    <CellDisplayTemplate>
                        @{ var n = (PermNode)context.DataItem; }
                        <div class="perm-cell">
                            <DxCheckBox T="bool?" AllowIndeterminateState="true"
                                        AllowIndeterminateStateByClick="false"
                                        Checked="@CellState(n, c.Get)"
                                        CheckedChanged="@((bool? v) => OnCell(n, c.Set, v))"
                                        CssClass="perm-chk" />
                        </div>
                    </CellDisplayTemplate>
                </DxTreeListDataColumn>
            }
        </Columns>
    </DxTreeList>
}

@code {
    private enum ViewMode { Functions, Companies }

    private List<RoleVm> _roles = new();
    private List<PermNode> _nodes = new();
    private Dictionary<long, List<PermNode>> _childrenByParent = new();
    private long? _roleId;
    private bool _loading;
    private bool _saving;
    private bool _saved;

    // ── Phạm vi công ty (HT_VaiTro_CongTy) — cây WYSIWYG do IcCompanyPicker đảm nhiệm ──
    private ViewMode _view = ViewMode.Functions;
    private List<IcPickerItem> _companyItems = new();
    private HashSet<long> _selectedCompanyIds = new();
    private bool _companiesLoading;

    // 5 cột thao tác (Duyệt → workflow, không có ở đây). Caption qua Loc.L(key, def).
    private List<(string Key, string Def, Func<PermNode, bool> Get, Action<PermNode, bool> Set)> Cols => new()
    {
        ("admin.perm.view",   "Xem",  n => n.Xem,  (n, v) => n.Xem = v),
        ("admin.perm.add",    "Thêm", n => n.Them, (n, v) => n.Them = v),
        ("admin.perm.edit",   "Sửa",  n => n.Sua,  (n, v) => n.Sua = v),
        ("admin.perm.delete", "Xóa",  n => n.Xoa,  (n, v) => n.Xoa = v),
        ("admin.perm.print",  "In",   n => n.InAn, (n, v) => n.InAn = v),
    };

    /// <summary>Khởi tạo: nạp vai trò, chọn vai trò đầu rồi nạp ma trận quyền.</summary>
    protected override async Task OnInitializedAsync()
    {
        _roles = await Api.GetRolesAsync();
        if (_roles.Count > 0)
        {
            _roleId = _roles[0].Id;
            await LoadPermissionsAsync();
        }
    }

    private async Task OnRoleChanged(ChangeEventArgs e)
    {
        if (long.TryParse(e.Value?.ToString(), out var id))
        {
            _roleId = id;
            _saved = false;
            _companyItems = new();
            await LoadPermissionsAsync();
            if (_view == ViewMode.Companies) await LoadCompaniesAsync();
        }
    }

    /// <summary>Mở view Phạm vi công ty — nạp cây lần đầu cho vai trò đang chọn.</summary>
    private async Task OpenCompaniesViewAsync()
    {
        _view = ViewMode.Companies;
        if (_companyItems.Count == 0) await LoadCompaniesAsync();
    }

    /// <summary>Nạp cây công ty của vai trò → map sang node picker (cây + cascade do IcCompanyPicker lo).</summary>
    private async Task LoadCompaniesAsync()
    {
        if (_roleId is null) return;
        _companiesLoading = true;
        var companies = await Api.GetRoleCompaniesAsync(_roleId.Value);
        _companyItems = companies.Select(c => new IcPickerItem(c.Id, c.Ma, c.Ten, c.ParentId)).ToList();
        _selectedCompanyIds = companies.Where(c => c.DaGan).Select(c => c.Id).ToHashSet();
        _companiesLoading = false;
    }

    /// <summary>Nhận tập tick mới từ picker (cascade WYSIWYG xử lý trong component).</summary>
    private void OnCompaniesChanged(IReadOnlyCollection<long> ids)
    {
        _saved = false;
        _selectedCompanyIds = new HashSet<long>(ids);
    }

    private async Task LoadPermissionsAsync()
    {
        if (_roleId is null) return;
        _loading = true;
        _nodes = await Api.GetPermissionsAsync(_roleId.Value);
        _childrenByParent = _nodes.Where(n => n.ChaId is not null)
            .GroupBy(n => n.ChaId!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());
        _loading = false;
    }

    private List<PermNode> Children(PermNode n)
        => _childrenByParent.TryGetValue(n.Id, out var c) ? c : new();

    private List<PermNode> Roots() => _nodes.Where(n => n.ChaId is null).ToList();

    private static bool? Combine(IEnumerable<bool?> states)
    {
        var list = states.ToList();
        if (list.Count == 0) return false;
        if (list.All(s => s == true)) return true;
        if (list.All(s => s == false)) return false;
        return null;
    }

    /// <summary>Trạng thái ô: lá = cờ của nó; cha = suy từ con (all bật→true · all tắt→false · lẫn→null).</summary>
    private bool? CellState(PermNode n, Func<PermNode, bool> get)
    {
        var kids = Children(n);
        return kids.Count == 0 ? get(n) : Combine(kids.Select(k => CellState(k, get)));
    }

    /// <summary>Trạng thái cột "Tất cả" của 1 dòng = gộp 5 quyền của dòng đó.</summary>
    private bool? RowAllState(PermNode n) => Combine(Cols.Select(c => CellState(n, c.Get)));

    /// <summary>Trạng thái checkbox header 1 cột = gộp cột đó trên mọi node gốc.</summary>
    private bool? ColHeaderState(Func<PermNode, bool> get) => Combine(Roots().Select(r => CellState(r, get)));

    /// <summary>Trạng thái ô master = gộp toàn bộ 5 cột trên mọi node gốc.</summary>
    private bool? MasterAllState() => Combine(Cols.Select(c => ColHeaderState(c.Get)));

    private void SetCascade(PermNode n, Action<PermNode, bool> set, bool val)
    {
        set(n, val);
        foreach (var ch in Children(n)) SetCascade(ch, set, val);
    }

    /// <summary>Tick/bỏ 1 ô → áp xuống toàn bộ con (cha tự suy lại khi vẽ lại).</summary>
    private void OnCell(PermNode n, Action<PermNode, bool> set, bool? v)
    {
        SetCascade(n, set, v == true);
        _saved = false;
    }

    /// <summary>Cột "Tất cả" của 1 dòng → bật/tắt cả 5 quyền (+cascade con).</summary>
    private void OnRowAll(PermNode n, bool? v)
    {
        foreach (var c in Cols) SetCascade(n, c.Set, v == true);
        _saved = false;
    }

    /// <summary>Checkbox header 1 cột → bật/tắt cột đó cho mọi node.</summary>
    private void OnColHeader(Action<PermNode, bool> set, bool? v)
    {
        foreach (var r in Roots()) SetCascade(r, set, v == true);
        _saved = false;
    }

    /// <summary>Ô master → bật/tắt toàn bộ 5 cột cho mọi node.</summary>
    private void OnMasterAll(bool? v)
    {
        foreach (var r in Roots())
            foreach (var c in Cols) SetCascade(r, c.Set, v == true);
        _saved = false;
    }

    /// <summary>Lưu view đang mở: ma trận chức năng hoặc phạm vi công ty (1 CTA duy nhất).</summary>
    private async Task SaveAsync()
    {
        if (_roleId is null) return;
        _saving = true;
        _saved = false;
        _saved = _view == ViewMode.Companies
            ? await Api.SaveRoleCompaniesAsync(_roleId.Value, _selectedCompanyIds.ToList())
            : await Api.SaveAsync(_roleId.Value, _nodes);
        _saving = false;
    }
}
