@page "/m/administration/menu"
@inject MenuAdminApiService Api
@inject ViewApiService ViewApi
@inject LocalizationService Loc

@*
    MenuBuilderPage — màn Quản lý menu (Menu Builder).
    - Trái: DxTreeList cây node (HT_ChucNang). Bấm 1 dòng → đổ chi tiết (chỉ đọc) sang panel phải.
      Cột Thứ tự có nút ▲▼ đổi vị trí trong cùng cấp (gọi lại API Update — KHÔNG endpoint mới).
    - Phải: panel CHI TIẾT chỉ đọc (không nút Lưu / Thêm). Nút "Sửa" mở popup.
    - Popup thêm/sửa: Loại node = Nhóm | View. Module chọn từ HT_PhanHe; Icon chọn từ bộ Lucide;
      Đường dẫn server tự suy theo loại, cho phép TÙY CHỈNH khi mặc định sai.
    - Ghi: POST/PUT/DELETE /api/v1/admin/menu (Data DB tenant). Server invalidate cache menu.
*@

<PageTitle>@Loc.L("admin.menu.title", "Quản lý menu") — ICare247</PageTitle>

<div class="mb-toolbar">
    <span class="mb-title">@Loc.L("admin.menu.title", "Quản lý menu")</span>
    <span class="mb-sep">·</span>
    <span class="mb-sub">@Loc.L("admin.menu.sub", "Cấu hình cây menu trỏ tới các View đã cấu hình")</span>
    <span class="mb-spacer"></span>
    <button class="mb-btn mb-btn--primary" @onclick="OpenCreate">+ @Loc.L("admin.menu.new", "Thêm node")</button>
    <button class="mb-btn" @onclick="ReloadAsync">↻ @Loc.L("common.btn.refresh", "Làm mới")</button>
</div>

<div class="mb-layout">
    <div class="mb-tree">
        @if (_loading)
        {
            <div class="mb-empty">@Loc.L("common.app.loading", "Đang tải...")</div>
        }
        else if (_nodes.Count == 0)
        {
            <div class="mb-empty">@Loc.L("admin.menu.empty", "Chưa có node nào.")</div>
        }
        else
        {
            <DxTreeList Data="_nodes" KeyFieldName="Id" ParentKeyFieldName="ChaId"
                        AutoExpandAllNodes="true" ShowAllRows="true" HighlightRowOnHover="true"
                        FocusedRowEnabled="true" FocusedRowChanged="OnRowFocused"
                        ShowFilterRow="true"
                        FilterMenuButtonDisplayMode="TreeListFilterMenuButtonDisplayMode.Always"
                        AllowColumnReorder="true"
                        ColumnResizeMode="TreeListColumnResizeMode.ColumnsContainer"
                        CssClass="mb-treelist">
                <Columns>
                    <DxTreeListDataColumn Caption="@Loc.L("admin.menu.col.name", "Tên")" FieldName="Ten"
                                          FilterRowOperatorType="TreeListFilterRowOperatorType.Contains" />
                    <DxTreeListDataColumn Caption="@Loc.L("admin.menu.col.kind", "Loại")" FieldName="LoaiText" Width="90px"
                                          FilterRowOperatorType="TreeListFilterRowOperatorType.Contains">
                        <CellDisplayTemplate>
                            @{ var n = (MenuNodeVm)context.DataItem; }
                            <span class="mb-badge @(n.Loai == "Menu" ? "mb-badge--group" : "mb-badge--screen")">
                                @KindLabel(n)
                            </span>
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                    <DxTreeListDataColumn Caption="@Loc.L("admin.menu.col.module", "Phân hệ")" FieldName="ModuleText" Width="110px"
                                          FilterRowOperatorType="TreeListFilterRowOperatorType.Contains">
                        <CellDisplayTemplate>
                            @{ var n = (MenuNodeVm)context.DataItem; }
                            <span>@(n.ModuleText)</span>
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                    <DxTreeListDataColumn Caption="@Loc.L("admin.menu.col.route", "Đường dẫn")" FieldName="DuongDan"
                                          FilterRowOperatorType="TreeListFilterRowOperatorType.Contains">
                        <CellDisplayTemplate>
                            @{ var n = (MenuNodeVm)context.DataItem; }
                            @if (!string.IsNullOrWhiteSpace(n.DuongDan))
                            {
                                <a href="@n.DuongDan" target="_blank" rel="noopener"
                                   title="@Loc.L("admin.menu.route.open", "Mở trong tab mới")">@n.DuongDan</a>
                            }
                            else { <span>—</span> }
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                    <DxTreeListDataColumn Caption="@Loc.L("admin.menu.col.active", "Bật")" FieldName="KichHoat" Width="70px">
                        <CellDisplayTemplate>
                            @{ var n = (MenuNodeVm)context.DataItem; }
                            <span>@(n.KichHoat ? "✓" : "—")</span>
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                    <DxTreeListDataColumn Caption="@Loc.L("admin.menu.col.order", "Thứ tự")" FieldName="ThuTu" Width="120px">
                        <CellDisplayTemplate>
                            @{ var n = (MenuNodeVm)context.DataItem; }
                            <div class="mb-order">
                                <button class="mb-arrow" title="@Loc.L("admin.menu.move.up", "Lên")"
                                        disabled="@(_busyMove || IsFirst(n))" @onclick="() => MoveAsync(n, true)">▲</button>
                                <button class="mb-arrow" title="@Loc.L("admin.menu.move.down", "Xuống")"
                                        disabled="@(_busyMove || IsLast(n))" @onclick="() => MoveAsync(n, false)">▼</button>
                            </div>
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                    <DxTreeListDataColumn Caption="" Width="104px">
                        <CellDisplayTemplate>
                            @{ var n = (MenuNodeVm)context.DataItem; }
                            <button class="mb-act" @onclick="() => OpenEdit(n)">@Loc.L("common.btn.edit", "Sửa")</button>
                            @if (!n.LaHeThong)
                            {
                                <button class="mb-act mb-act--danger" @onclick="() => _confirmDelete = n">@Loc.L("common.btn.delete", "Xóa")</button>
                            }
                        </CellDisplayTemplate>
                    </DxTreeListDataColumn>
                </Columns>
            </DxTreeList>
        }
    </div>

    <div class="mb-detail">
        @if (_selected is null)
        {
            <div class="mb-empty">@Loc.L("admin.menu.detail.none", "Chọn một dòng để xem chi tiết.")</div>
        }
        else
        {
            <div class="mb-detail__head">
                <span class="mb-detail__title">@_selected.Ten</span>
                <button class="mb-btn mb-btn--primary" @onclick="() => OpenEdit(_selected)">
                    @Loc.L("common.btn.edit", "Sửa")
                </button>
            </div>

            <dl class="mb-dl">
                <dt>@Loc.L("admin.menu.col.kind", "Loại")</dt>
                <dd>@KindLabel(_selected)</dd>

                <dt>@Loc.L("admin.menu.f.code", "Mã")</dt>
                <dd><code>@_selected.Ma</code></dd>

                <dt>@Loc.L("admin.menu.col.module", "Phân hệ")</dt>
                <dd>@ModuleLabel(_selected.Module)</dd>

                <dt>@Loc.L("admin.menu.col.route", "Đường dẫn")</dt>
                <dd>
                    @if (!string.IsNullOrWhiteSpace(_selected.DuongDan))
                    {
                        <a href="@_selected.DuongDan" target="_blank" rel="noopener"
                           title="@Loc.L("admin.menu.route.open", "Mở trong tab mới")">@_selected.DuongDan</a>
                    }
                    else { <span>—</span> }
                </dd>

                <dt>@Loc.L("admin.menu.f.icon", "Icon")</dt>
                <dd>
                    @if (!string.IsNullOrEmpty(_selected.Icon))
                    {
                        <span class="mb-icon-inline"><Icon Name="@_selected.Icon" Size="16" /> @_selected.Icon</span>
                    }
                    else { <span>—</span> }
                </dd>

                <dt>@Loc.L("admin.menu.col.order", "Thứ tự")</dt>
                <dd>@_selected.ThuTu</dd>

                <dt>@Loc.L("admin.menu.col.active", "Trạng thái")</dt>
                <dd>@(_selected.KichHoat ? Loc.L("admin.menu.on", "Đang bật") : Loc.L("admin.menu.off", "Đang tắt"))</dd>

                @if (_selected.LaHeThong)
                {
                    <dt>@Loc.L("admin.menu.f.system", "Hệ thống")</dt>
                    <dd>@Loc.L("admin.menu.systemnode.short", "Node nền tảng (không xóa)")</dd>
                }
            </dl>
        }
    </div>
</div>

@* ─────────────────────────── Popup thêm/sửa node ─────────────────────────── *@
@if (_popupOpen)
{
    <div class="mb-modal__root">
        <div class="mb-modal__backdrop" @onclick="ClosePopup"></div>
        @if (_dragging)
        {
            <div class="mb-drag-capture" @onpointermove="OnDragMove" @onpointerup="OnDragEnd" @onpointerleave="OnDragEnd"></div>
        }
        <div class="mb-modal" style="@ModalDragStyle">
            <div class="mb-modal__head">
                <h3 class="mb-drag-handle" @onpointerdown="OnDragStart" title="@Loc.L("admin.menu.drag.hint", "Kéo tiêu đề để di chuyển")">
                    @(_editingId is null
                        ? Loc.L("admin.menu.form.new", "Thêm node mới")
                        : Loc.L("admin.menu.form.edit", "Sửa node #{0}", _editingId))
                </h3>
                <button class="mb-iconbtn" @onclick="ClosePopup" title="@Loc.L("common.btn.close", "Đóng")">
                    <Icon Name="x" Size="18" />
                </button>
            </div>

            <div class="mb-modal__body">
                @if (_editingSystem)
                {
                    <div class="mb-note mb-note--warn">
                        @Loc.L("admin.menu.systemnode", "Node hệ thống — chỉ sửa được Bật/tắt & Thứ tự, không xóa.")
                    </div>
                }

                <label class="mb-label">@Loc.L("admin.menu.f.kind", "Loại node")</label>
                <select class="mb-input" value="@_kind" @onchange="OnKindChanged" disabled="@_editingSystem">
                    <option value="Group">@Loc.L("admin.menu.kind.group", "Nhóm (không mở màn)")</option>
                    <option value="View">@Loc.L("admin.menu.kind.view", "Mở View")</option>
                    <option value="Form" disabled>@Loc.L("admin.menu.kind.form", "Mở Form (sắp có)")</option>
                </select>

                @if (_kind == "View")
                {
                    <label class="mb-label">@Loc.L("admin.menu.f.view", "View (đọc từ cấu hình)")</label>
                    <DxComboBox TData="ComboOpt" TValue="ComboOpt" Data="@_viewOpts"
                                Value="@_viewSel" ValueChanged="@OnViewSelChanged"
                                SearchMode="ListSearchMode.AutoSearch"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                NullText="@Loc.L("admin.menu.f.view.pick", "— Chọn View —")"
                                CssClass="mb-combo" Width="100%" />
                }

                <label class="mb-label">@Loc.L("admin.menu.f.name", "Tên hiển thị *")</label>
                <input class="mb-input" @bind="_ten" @bind:event="oninput"
                       placeholder="@Loc.L("admin.menu.f.name.ph", "VD: Khách hàng")" />

                @if (_editingId is not null)
                {
                    <label class="mb-label">@Loc.L("admin.menu.f.i18nkey", "Khóa i18n (dịch tên menu)")</label>
                    @if (!string.IsNullOrEmpty(_navKey))
                    {
                        <div class="mb-keybox"><code>@_navKey</code></div>
                        <p class="mb-help">
                            @Loc.L("admin.menu.f.i18nkey.help", "Tên trên menu được dịch theo khóa này; \"Tên hiển thị\" ở trên là bản gốc (tiếng Việt) dùng khi chưa có bản dịch.")
                        </p>

                        @if (TransLangs.Any())
                        {
                            <label class="mb-label">@Loc.L("admin.menu.f.trans", "Bản dịch tên theo ngôn ngữ")</label>
                            @foreach (var l in TransLangs)
                            {
                                <div class="mb-transrow">
                                    <span class="mb-translang">@l.Name</span>
                                    <input class="mb-input" @bind="_trans[l.Code]"
                                           placeholder="@_ten" />
                                </div>
                            }
                            <p class="mb-help">
                                @Loc.L("admin.menu.f.trans.help", "Để trống = dùng bản gốc tiếng Việt. Bản dịch lưu khi bấm Lưu.")
                            </p>
                        }
                    }
                    else
                    {
                        <div class="mb-keybox mb-keybox--muted">
                            @Loc.L("admin.menu.f.i18nkey.none", "Không suy được khóa cho node này.")
                        </div>
                    }
                }

                <label class="mb-label">@Loc.L("admin.menu.f.parent", "Node cha")</label>
                @* Dropdown chứa cây node (DxTreeList) — chọn cha trực quan theo phân cấp ── *@
                <DxDropDownBox Value="_parentNode" ValueChanged="@((object? v) => OnParentValueChanged(v))"
                               QueryDisplayText="ParentDisplayText"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                               NullText="@Loc.L("admin.menu.f.parent.root", "— Gốc (không cha) —")"
                               CssClass="mb-combo" Width="100%">
                    <DropDownBodyTemplate Context="dd">
                        <div class="mb-parenttree">
                            @if (_parentTreeNodes.Count == 0)
                            {
                                <div class="mb-parenttree__empty">@Loc.L("admin.menu.f.parent.none", "Không có node cha khả dụng.")</div>
                            }
                            else
                            {
                                <DxTreeList Data="_parentTreeNodes" KeyFieldName="Id" ParentKeyFieldName="ChaId"
                                            SelectionMode="TreeListSelectionMode.Single"
                                            SelectedDataItem="_parentNode"
                                            SelectedDataItemChanged="@((object item) => OnParentTreePicked(item, dd))"
                                            AutoExpandAllNodes="true" ShowFilterRow="true"
                                            FilterMenuButtonDisplayMode="TreeListFilterMenuButtonDisplayMode.Never"
                                            CssClass="mb-parenttree__list">
                                    <Columns>
                                        <DxTreeListDataColumn FieldName="Ten" Caption="@Loc.L("admin.menu.col.name", "Tên")"
                                                              FilterRowOperatorType="TreeListFilterRowOperatorType.Contains" />
                                    </Columns>
                                </DxTreeList>
                            }
                        </div>
                    </DropDownBodyTemplate>
                </DxDropDownBox>

                @* ── Đường dẫn: server tự suy, cho phép tùy chỉnh ── *@
                <label class="mb-label">@Loc.L("admin.menu.col.route", "Đường dẫn")</label>
                <p class="mb-help">
                    @Loc.L("admin.menu.f.route.help", "Đường dẫn là URL điều hướng khi bấm node trên menu. Mặc định hệ thống tự suy theo loại node: node Nhóm không có đường dẫn; node View trỏ /view/{mã}. Chỉ bật tùy chỉnh khi mặc định không đúng (vd node nhóm trỏ tới trang tĩnh /m/...).")
                </p>
                <div class="mb-routebox">
                    <span class="mb-route-default">@Loc.L("admin.menu.f.route.default", "Mặc định:")
                        <code>@(string.IsNullOrEmpty(DerivedRoute()) ? Loc.L("admin.menu.f.route.empty", "(không có)") : DerivedRoute())</code>
                    </span>
                    <label class="mb-check mb-check--inline">
                        <input type="checkbox" checked="@_overridePath" @onchange="OnToggleOverride" />
                        @Loc.L("admin.menu.f.route.override", "Tùy chỉnh đường dẫn")
                    </label>
                </div>
                @if (_overridePath)
                {
                    <input class="mb-input" @bind="_duongDan" @bind:event="oninput"
                           placeholder="@Loc.L("admin.menu.f.route.ph", "VD: /m/organization")" />
                }

                <div class="mb-row">
                    <div class="mb-col">
                        <label class="mb-label">@Loc.L("admin.menu.col.module", "Phân hệ")</label>
                        <DxComboBox TData="ComboOpt" TValue="ComboOpt" Data="@_moduleOpts"
                                    Value="@_moduleSel" ValueChanged="@OnModuleSelChanged"
                                    SearchMode="ListSearchMode.AutoSearch"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                    NullText="@Loc.L("admin.menu.f.module.none", "— Không —")"
                                    CssClass="mb-combo" Width="100%" />
                    </div>
                    <div class="mb-col mb-col--narrow">
                        <label class="mb-label">@Loc.L("admin.menu.f.order", "Thứ tự")</label>
                        <input class="mb-input" type="number" @bind="_thuTu" />
                    </div>
                </div>

                <label class="mb-label">@Loc.L("admin.menu.f.icon", "Icon")</label>
                <div class="mb-iconpick">
                    <button type="button" title="@Loc.L("admin.menu.f.icon.none", "Không icon")"
                            class="mb-iconchip mb-iconchip--none @(string.IsNullOrEmpty(_icon) ? "is-sel" : "")"
                            @onclick="() => _icon = string.Empty">
                        <Icon Name="x" Size="16" />
                    </button>
                    @foreach (var ic in IconNames)
                    {
                        <button type="button" title="@ic"
                                class="mb-iconchip @(_icon == ic ? "is-sel" : "")"
                                @onclick="() => _icon = ic">
                            <Icon Name="@ic" Size="18" />
                        </button>
                    }
                </div>
                <p class="mb-help">
                    @Loc.L("admin.menu.f.icon.help", "Danh sách icon đọc từ bộ icon dùng chung (Icon.razor). Thiếu icon? Kỹ thuật thêm vào src/frontend/ICare247.UI.Shared/Components/Icon.razor.")
                </p>

                <label class="mb-check">
                    <input type="checkbox" @bind="_kichHoat" />
                    @Loc.L("admin.menu.f.active", "Kích hoạt (hiển thị trên menu)")
                </label>

                @if (_status is not null)
                {
                    <div class="mb-note @(_statusErr ? "mb-note--err" : "mb-note--ok")">@_status</div>
                }
            </div>

            <div class="mb-modal__foot">
                @if (_editingId is not null && !_editingSystem)
                {
                    <button class="mb-btn mb-btn--danger" disabled="@_saving" @onclick="RequestDeleteFromPopup">
                        @Loc.L("common.btn.delete", "Xóa")
                    </button>
                }
                <span class="mb-spacer"></span>
                <button class="mb-btn" @onclick="ClosePopup">@Loc.L("common.btn.cancel", "Hủy")</button>
                <button class="mb-btn mb-btn--primary" disabled="@_saving" @onclick="SaveAsync">
                    @(_saving ? Loc.L("common.btn.saving", "Đang lưu…") : Loc.L("common.btn.save", "Lưu"))
                </button>
            </div>
        </div>
    </div>
}

@* ─────────────────────── Dialog xác nhận xóa node ─────────────────────── *@
@if (_confirmDelete is not null)
{
    <div class="mb-modal__root">
        <div class="mb-modal__backdrop" @onclick="() => _confirmDelete = null"></div>
        <div class="mb-modal mb-modal--sm">
            <div class="mb-modal__head">
                <h3>⚠️ @Loc.L("admin.menu.del.title", "Xác nhận xóa node")</h3>
                <button class="mb-iconbtn" @onclick="() => _confirmDelete = null" title="@Loc.L("common.btn.close", "Đóng")">
                    <Icon Name="x" Size="18" />
                </button>
            </div>
            <div class="mb-modal__body">
                <p>@((MarkupString)Loc.L("admin.menu.del.body", "Bạn chắc chắn xóa node <strong>{0}</strong>? Hành động không thể hoàn tác.", _confirmDelete.Ten))</p>
                @if (_delStatus is not null)
                {
                    <div class="mb-note mb-note--err">@_delStatus</div>
                }
            </div>
            <div class="mb-modal__foot">
                <span class="mb-spacer"></span>
                <button class="mb-btn" disabled="@_deleting" @onclick="() => _confirmDelete = null">
                    @Loc.L("common.btn.cancel", "Hủy")
                </button>
                <button class="mb-btn mb-btn--danger" disabled="@_deleting" @onclick="ConfirmDeleteAsync">
                    @(_deleting ? Loc.L("delete.deleting", "Đang xóa…") : Loc.L("admin.menu.del.confirm", "Xóa node"))
                </button>
            </div>
        </div>
    </div>
}

@code {
    // ── Bộ chọn icon đọc thẳng từ "từ điển" Icon.razor (single source) — không gõ tay ──
    private static IReadOnlyList<string> IconNames => Icon.RegisteredNames;

    private List<MenuNodeVm> _nodes = new();
    private List<ViewListItemDto> _views = new();
    private List<ModuleOption> _modules = new();
    private bool _loading = true, _saving, _busyMove;
    private MenuNodeVm? _selected;

    // ── Popup state ──
    private bool _popupOpen;
    private string? _status; private bool _statusErr;

    // ── Xác nhận xóa node ──
    private MenuNodeVm? _confirmDelete;
    private bool _deleting;
    private string? _delStatus;

    // ── Kéo di chuyển popup (drag bằng tiêu đề) ──
    private bool _dragging;
    private double _dragX, _dragY;          // độ dời hiện tại so với vị trí giữa
    private double _dragOX, _dragOY;        // toạ độ con trỏ lúc bắt đầu kéo
    private double _dragBX, _dragBY;        // độ dời tại thời điểm bắt đầu kéo

    private string ModalDragStyle =>
        (_dragX == 0 && _dragY == 0) ? "" : $"transform:translate({(int)_dragX}px,{(int)_dragY}px)";

    private void ResetDrag() { _dragging = false; _dragX = 0; _dragY = 0; }

    private void OnDragStart(PointerEventArgs e)
    {
        _dragging = true;
        _dragOX = e.ClientX; _dragOY = e.ClientY;
        _dragBX = _dragX; _dragBY = _dragY;
    }

    private void OnDragMove(PointerEventArgs e)
    {
        if (!_dragging) return;
        _dragX = _dragBX + (e.ClientX - _dragOX);
        _dragY = _dragBY + (e.ClientY - _dragOY);
    }

    private void OnDragEnd(PointerEventArgs e) => _dragging = false;
    private long? _editingId;
    private bool _editingSystem;
    private string _kind = "Group";
    private string _ten = "";
    private long? _parentId;
    private string? _objectCode;
    private string _icon = "";
    private string? _module;
    private int _thuTu;
    private bool _kichHoat = true;
    private bool _overridePath;
    private string _duongDan = "";
    private string? _navKey;  // khóa i18n suy ra của node đang sửa (read-only)
    private Dictionary<string, string> _trans = new();      // lang → bản dịch (đang sửa)
    private Dictionary<string, string> _transOrig = new();  // bản gốc để biết thay đổi

    /// <summary>Các ngôn ngữ cần nhập bản dịch (mọi ngôn ngữ trừ ngôn ngữ gốc — gốc = ô "Tên hiển thị").</summary>
    private IEnumerable<LanguageInfo> TransLangs
        => Loc.Available.Where(l => l.Code != LocalizationService.BaseLanguage);

    // Nguồn combobox (ComboOpt) là kiểu public top-level — xem MenuBuilderModels.cs.
    // Materialize 1 lần (tham chiếu ổn định) — DxComboBox không reset lựa chọn giữa các lần render.
    private List<ComboOpt> _viewOpts = new();
    private List<ComboOpt> _moduleOpts = new();

    // ── Node cha = cây (DxDropDownBox + DxTreeList). Nguồn cây + node đang chọn. ──
    private List<MenuNodeVm> _parentTreeNodes = new();
    private MenuNodeVm? _parentNode;

    // Item ĐANG CHỌN (bind nguyên object — KHÔNG dùng ValueField để tránh reflection theo tên-trường,
    // vốn fail với kiểu app → trước đây Module bind ra null). Hiển thị qua ToString()=Display.
    private ComboOpt? _viewSel;
    private ComboOpt? _moduleSel;

    private void BuildViewOpts() => _viewOpts = _views.Select(v =>
        new ComboOpt(v.ViewCode, string.IsNullOrWhiteSpace(v.Title) ? v.ViewCode : $"{v.Title} ({v.ViewCode})")).ToList();
    private void BuildModuleOpts() => _moduleOpts = _modules.Select(m => new ComboOpt(m.Ma, $"{m.Ma} — {m.Ten}")).ToList();

    /// <summary>Dựng nguồn cây node cha (loại trừ chính node + nhánh con để chống vòng lặp).</summary>
    private void BuildParentTree() => _parentTreeNodes = ParentOptions().ToList();

    /// <summary>Đồng bộ item đang chọn từ giá trị nguyên thủy hiện tại (gọi khi mở popup).</summary>
    private void SyncCombosFromValues()
    {
        _viewSel   = string.IsNullOrEmpty(_objectCode) ? null : _viewOpts.FirstOrDefault(o => o.Code == _objectCode);
        _moduleSel = string.IsNullOrEmpty(_module)     ? null : _moduleOpts.FirstOrDefault(o => o.Code == _module);
        _parentNode = _parentId is { } pid ? _nodes.FirstOrDefault(n => n.Id == pid) : null;
    }

    /// <summary>Text hiển thị trong ô dropdown node cha = tên node đang chọn (rỗng → NullText).</summary>
    private string ParentDisplayText(DropDownBoxQueryDisplayTextContext ctx)
        => (ctx.Value as MenuNodeVm)?.Ten ?? string.Empty;

    /// <summary>Đổi giá trị từ ô dropdown (vd nút xóa → null).</summary>
    private void OnParentValueChanged(object? v)
    {
        _parentNode = v as MenuNodeVm;
        _parentId = _parentNode?.Id;
    }

    /// <summary>Chọn 1 node trên cây → gán cha + đóng dropdown.</summary>
    private void OnParentTreePicked(object item, DropDownBoxTemplateContext dd)
    {
        _parentNode = item as MenuNodeVm;
        _parentId = _parentNode?.Id;
        dd.DropDownBox.HideDropDown();
    }

    private void OnViewSelChanged(ComboOpt? o)
    {
        _viewSel = o;
        _objectCode = o?.Code;
        // Gợi ý Tên hiển thị từ View nếu đang trống.
        if (!string.IsNullOrEmpty(_objectCode) && string.IsNullOrWhiteSpace(_ten))
        {
            var v = _views.FirstOrDefault(x => x.ViewCode == _objectCode);
            if (v is not null) _ten = string.IsNullOrWhiteSpace(v.Title) ? v.ViewCode : v.Title!;
        }
    }

    private void OnModuleSelChanged(ComboOpt? o) { _moduleSel = o; _module = o?.Code; }

    protected override async Task OnInitializedAsync()
    {
        _views = await ViewApi.GetListAsync(pageSize: 200);
        _modules = await Api.GetModulesAsync();
        BuildViewOpts();
        BuildModuleOpts();
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _loading = true;
        _nodes = await Api.GetTreeAsync();
        // Gán nhãn phân hệ đầy đủ để cột lọc/sắp khớp đúng text hiển thị.
        foreach (var n in _nodes) n.ModuleText = ModuleLabel(n.Module);
        // Giữ lại lựa chọn chi tiết nếu node còn tồn tại.
        if (_selected is not null)
            _selected = _nodes.FirstOrDefault(n => n.Id == _selected.Id);
        _loading = false;
    }

    private void OnRowFocused(TreeListFocusedRowChangedEventArgs e)
        => _selected = e.DataItem as MenuNodeVm;

    // ── Mở popup ──
    private void OpenCreate()
    {
        _editingId = null; _editingSystem = false;
        _kind = "Group"; _ten = ""; _parentId = _selected?.Id; _objectCode = null;
        _icon = ""; _module = null; _thuTu = 0; _kichHoat = true;
        _overridePath = false; _duongDan = "";
        _navKey = null; _trans = new(); _transOrig = new();
        BuildParentTree();
        SyncCombosFromValues();
        ResetDrag();
        _status = null; _popupOpen = true;
    }

    private async Task OpenEdit(MenuNodeVm? n)
    {
        if (n is null) return;
        _editingId = n.Id;
        _editingSystem = n.LaHeThong;
        _kind = n.LoaiDoiTuong switch { "View" => "View", "Form" => "Form", _ => "Group" };
        _ten = n.Ten;
        _parentId = n.ChaId;
        _objectCode = n.DoiTuong;
        _icon = n.Icon ?? "";
        _module = n.Module;
        _thuTu = n.ThuTu;
        _kichHoat = n.KichHoat;
        // Bật tùy chỉnh khi đường dẫn hiện tại khác đường dẫn server tự suy.
        var derived = DerivedRouteFor(_kind, _objectCode);
        _overridePath = !string.IsNullOrWhiteSpace(n.DuongDan) && n.DuongDan != derived;
        _duongDan = n.DuongDan ?? "";
        _navKey = NavKeyOf(n);

        // Nạp bản dịch hiện có theo khóa i18n cho các ngôn ngữ (ngoài gốc).
        _trans = new(); _transOrig = new();
        foreach (var l in TransLangs) _trans[l.Code] = "";
        if (!string.IsNullOrEmpty(_navKey))
        {
            var map = await Loc.GetTranslationsAsync(_navKey);
            foreach (var l in TransLangs)
                if (map.TryGetValue(l.Code, out var v)) _trans[l.Code] = v;
        }
        _transOrig = new(_trans);

        BuildParentTree();
        SyncCombosFromValues();
        ResetDrag();
        _status = null; _popupOpen = true;
    }

    // ── Suy khóa i18n của node — KHỚP logic dựng menu trong NavMenu.BuildFromApi ──
    private string? NavKeyOf(MenuNodeVm n)
    {
        var parent = n.ChaId is { } c ? _nodes.FirstOrDefault(x => x.Id == c) : null;

        // Dùng NavKeys.* (tự ASCII-hóa đoạn khóa) → khớp 100% với NavMenu lúc dịch thật.

        // Gốc + ManHinh (Tổng quan, Công cụ Dev…) → nav.{ma}
        if (parent is null && n.Loai == "ManHinh") return NavKeys.Root(n.Ma);

        // Gốc + Menu (nhóm) → nav.group.{key}
        if (parent is null && n.Loai == "Menu") return NavKeys.Group(n.Ma);

        // Cha là nhóm gốc + bản thân là Menu → phân hệ → nav.module.{key}
        var parentIsRootGroup = parent is not null && parent.ChaId is null && parent.Loai == "Menu";
        if (parentIsRootGroup && n.Loai == "Menu")
            return NavKeys.Module(ModKeyOf(n));

        // Dưới một phân hệ → màn → nav.screen.{module}.{screen}
        if (parent is not null)
        {
            var dot = n.Ma.IndexOf('.');
            var screenKey = dot >= 0 ? n.Ma[(dot + 1)..] : n.Ma;
            return NavKeys.Screen(ModKeyOf(parent), screenKey);
        }
        return null;
    }

    private static string ModKeyOf(MenuNodeVm mod)
    {
        var seg = (mod.DuongDan ?? "").TrimStart('/').Split('/', StringSplitOptions.RemoveEmptyEntries);
        return seg.Length >= 2 && seg[0] == "m" ? seg[1] : mod.Ma;
    }

    private void ClosePopup() { _popupOpen = false; _status = null; }

    private void OnKindChanged(ChangeEventArgs e)
    {
        _kind = e.Value?.ToString() ?? "Group";
        if (_kind == "Group") { _objectCode = null; _viewSel = null; }
    }

    private void OnToggleOverride(ChangeEventArgs e)
    {
        _overridePath = e.Value is true;
        // Bật lần đầu mà chưa có giá trị → gợi ý từ mặc định để admin chỉnh.
        if (_overridePath && string.IsNullOrWhiteSpace(_duongDan))
            _duongDan = DerivedRoute();
    }

    /// <summary>Đường dẫn server sẽ tự suy theo loại hiện chọn trong popup.</summary>
    private string DerivedRoute() => DerivedRouteFor(_kind, _objectCode);

    private static string DerivedRouteFor(string kind, string? objectCode) => kind switch
    {
        "View" => string.IsNullOrEmpty(objectCode) ? "" : $"/view/{objectCode}",
        "Form" => string.IsNullOrEmpty(objectCode) ? "" : $"/master/{objectCode}",
        _ => ""
    };

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_ten))
        { SetStatus(Loc.L("admin.menu.err.name", "Tên node là bắt buộc."), true); return; }
        if (_kind == "View" && string.IsNullOrEmpty(_objectCode))
        { SetStatus(Loc.L("admin.menu.err.view", "Cần chọn View."), true); return; }
        if (_overridePath)
        {
            var r = _duongDan.Trim();
            if (string.IsNullOrEmpty(r) || !r.StartsWith('/'))
            { SetStatus(Loc.L("admin.menu.err.route", "Đường dẫn tùy chỉnh phải bắt đầu bằng '/'."), true); return; }
        }

        _saving = true; _status = null;
        var body = new MenuNodePayload
        {
            NodeKind = _kind, Ten = _ten.Trim(), ParentId = _parentId,
            ObjectCode = _kind == "Group" ? null : _objectCode,
            DuongDan = _overridePath ? _duongDan.Trim() : null,
            Module = string.IsNullOrWhiteSpace(_module) ? null : _module,
            Icon = string.IsNullOrWhiteSpace(_icon) ? null : _icon.Trim(),
            ThuTu = _thuTu, KichHoat = _kichHoat
        };

        var res = _editingId is null
            ? await Api.CreateAsync(body)
            : await Api.UpdateAsync(_editingId.Value, body);
        _saving = false;

        if (res.Ok)
        {
            // Lưu bản dịch đã thay đổi (chỉ khi sửa node có khóa i18n).
            if (_editingId is not null && !string.IsNullOrEmpty(_navKey))
            {
                foreach (var l in TransLangs)
                {
                    var val = _trans.TryGetValue(l.Code, out var v) ? v : "";
                    var orig = _transOrig.TryGetValue(l.Code, out var o) ? o : "";
                    if (val != orig)
                        await Loc.SaveTranslationAsync(_navKey, l.Code, val.Trim());
                }
            }
            await ReloadAsync();
            _popupOpen = false;
        }
        else
        {
            SetStatus(res.Error ?? Loc.L("admin.menu.err.save", "Lưu thất bại."), true);
        }
    }

    /// <summary>Nút "Xóa" trong popup → mở dialog xác nhận (không xóa ngay).</summary>
    private void RequestDeleteFromPopup()
    {
        _delStatus = null;
        _confirmDelete = _editingId is { } id ? _nodes.FirstOrDefault(n => n.Id == id) : null;
    }

    /// <summary>Xóa thật sau khi người dùng xác nhận trong dialog.</summary>
    private async Task ConfirmDeleteAsync()
    {
        if (_confirmDelete is null) return;
        _deleting = true; _delStatus = null;
        var id = _confirmDelete.Id;
        var res = await Api.DeleteAsync(id);
        _deleting = false;

        if (res.Ok)
        {
            if (_selected?.Id == id) _selected = null;
            if (_editingId == id) _popupOpen = false;
            _confirmDelete = null;
            await ReloadAsync();
        }
        else
        {
            _delStatus = res.Error ?? Loc.L("admin.menu.err.delete", "Xóa thất bại.");
        }
    }

    private void SetStatus(string msg, bool err) { _status = msg; _statusErr = err; }

    // ── Đổi thứ tự: hoán vị trong cùng cấp, gán lại ThuTu tuần tự rồi ghi qua Update ──
    private List<MenuNodeVm> Siblings(MenuNodeVm n)
        => _nodes.Where(x => x.ChaId == n.ChaId).OrderBy(x => x.ThuTu).ThenBy(x => x.Id).ToList();

    private bool IsFirst(MenuNodeVm n) { var s = Siblings(n); return s.Count > 0 && s[0].Id == n.Id; }
    private bool IsLast(MenuNodeVm n) { var s = Siblings(n); return s.Count > 0 && s[^1].Id == n.Id; }

    private async Task MoveAsync(MenuNodeVm n, bool up)
    {
        if (_busyMove) return;
        var siblings = Siblings(n);
        var idx = siblings.FindIndex(x => x.Id == n.Id);
        var swapIdx = up ? idx - 1 : idx + 1;
        if (idx < 0 || swapIdx < 0 || swapIdx >= siblings.Count) return;

        (siblings[idx], siblings[swapIdx]) = (siblings[swapIdx], siblings[idx]);

        _busyMove = true;
        // Gán lại ThuTu = 1..N theo thứ tự mới; chỉ ghi node có ThuTu thay đổi.
        for (int i = 0; i < siblings.Count; i++)
        {
            var want = i + 1;
            if (siblings[i].ThuTu != want)
            {
                siblings[i].ThuTu = want;
                await Api.UpdateAsync(siblings[i].Id, PayloadFromVm(siblings[i]));
            }
        }
        _busyMove = false;
        await ReloadAsync();
    }

    /// <summary>Dựng payload từ VM hiện có — GIỮ nguyên DuongDan (override) để không mất route khi ghi lại.</summary>
    private static MenuNodePayload PayloadFromVm(MenuNodeVm n) => new()
    {
        NodeKind = n.LoaiDoiTuong switch { "View" => "View", "Form" => "Form", _ => "Group" },
        Ten = n.Ten,
        ParentId = n.ChaId,
        ObjectCode = n.DoiTuong,
        DuongDan = n.DuongDan,
        Module = n.Module,
        Icon = n.Icon,
        ThuTu = n.ThuTu,
        KichHoat = n.KichHoat
    };

    // ── Helpers cây cha (loại trừ chính node + nhánh con để chống vòng lặp) ──
    private IEnumerable<MenuNodeVm> ParentOptions()
    {
        if (_editingId is null) return _nodes;
        var banned = DescendantsAndSelf(_editingId.Value);
        return _nodes.Where(n => !banned.Contains(n.Id));
    }

    private HashSet<long> DescendantsAndSelf(long id)
    {
        var set = new HashSet<long> { id };
        bool added = true;
        while (added)
        {
            added = false;
            foreach (var n in _nodes)
                if (n.ChaId is { } c && set.Contains(c) && set.Add(n.Id)) added = true;
        }
        return set;
    }

    private string KindLabel(MenuNodeVm n) => n.LoaiDoiTuong switch
    {
        "View" => Loc.L("admin.menu.kind.view.short", "View"),
        "Form" => Loc.L("admin.menu.kind.form.short", "Form"),
        _ => Loc.L("admin.menu.kind.group.short", "Nhóm")
    };

    private string ModuleLabel(string? ma)
    {
        if (string.IsNullOrEmpty(ma)) return "—";
        var m = _modules.FirstOrDefault(x => x.Ma == ma);
        return m is null ? ma : $"{m.Ma} — {m.Ten}";
    }
}

