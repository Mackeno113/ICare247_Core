@* File    : Home.razor
   Purpose : Trang công cụ Dev — danh sách form chạy thử, hoặc nhập Form_Code thủ công.
   Lưu ý   : Đổi route "/" → "/dev/forms" khi dựng shell end-user (Dashboard chiếm "/"). *@

@page "/dev/forms"
@inject FormApiService FormApi
@inject ApiSettings Settings
@inject NavigationManager Nav
@inherits LocalizedComponentBase

<PageTitle>ICare247 UI</PageTitle>

<div class="page-container page-narrow">
    <div class="page-header">
        <h1>🚀 @Loc.L("dev.forms.title", "ICare247 — Runtime Check")</h1>
        <p class="subtitle">@Loc.L("dev.forms.subtitle", "Test cấu hình UI form trực tiếp từ metadata")</p>
        <div class="api-badge">
            API: <strong>@Settings.BaseUrl</strong>
            &nbsp;|&nbsp; Tenant: <strong>@Settings.TenantId</strong>
            &nbsp;|&nbsp; Lang: <strong>@Settings.LangCode</strong>
        </div>
    </div>

    @* ── Nhập Form Code thủ công ──────────────────── *@
    <div class="card">
        <h3>@Loc.L("dev.forms.runByCode", "Chạy form theo mã")</h3>
        <div class="input-row">
            <input type="text" class="code-input"
                   placeholder="@Loc.L("dev.forms.codePlaceholder", "Nhập Form_Code (VD: NHAN_VIEN_CREATE)")"
                   @bind="_manualCode"
                   @onkeydown="OnKeyDown" />
            <button class="btn btn-primary" @onclick="RunManual"
                    disabled="@string.IsNullOrWhiteSpace(_manualCode)">
                ▶ @Loc.L("common.action.run", "Chạy")
            </button>
        </div>
        @if (_manualError is not null)
        {
            <p class="error-text">@_manualError</p>
        }
    </div>

    @* ── Danh sách form từ API ─────────────────────── *@
    <div class="card">
        <div class="card-header-row">
            <h3>@Loc.L("dev.forms.listTitle", "Danh sách form")</h3>
            <button class="btn btn-secondary" @onclick="LoadForms" disabled="@_loading">
                @(_loading ? Loc.L("common.state.loading", "Đang tải...") : "⟳ " + Loc.L("common.action.refresh", "Tải lại"))
            </button>
        </div>

        @if (_loadError is not null)
        {
            <div class="error-banner">
                ⚠ @Loc.L("dev.forms.loadError", "Không tải được danh sách:") @_loadError
                <br /><small>@Loc.L("dev.forms.checkBackend", "Kiểm tra backend đang chạy tại") <code>@Settings.BaseUrl</code></small>
            </div>
        }
        else if (_loading)
        {
            <div class="loading">@Loc.L("dev.forms.connecting", "Đang kết nối API...")</div>
        }
        else if (_forms.Count == 0)
        {
            <div class="empty-state">@Loc.L("dev.forms.empty", "Không có form nào. Thêm form qua ConfigStudio WPF trước.")</div>
        }
        else
        {
            <table class="forms-table">
                <thead>
                    <tr>
                        <th>@Loc.L("dev.forms.col.code", "Form Code")</th>
                        <th>@Loc.L("dev.forms.col.platform", "Platform")</th>
                        <th>@Loc.L("dev.forms.col.table", "Bảng")</th>
                        <th>@Loc.L("dev.forms.col.fields", "Fields")</th>
                        <th>@Loc.L("dev.forms.col.version", "Version")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in _forms)
                    {
                        <tr>
                            <td><code>@f.FormCode</code></td>
                            <td><span class="badge">@f.Platform</span></td>
                            <td>@f.TableName</td>
                            <td>@f.FieldCount</td>
                            <td>v@f.Version</td>
                            <td>
                                <button class="btn btn-sm"
                                        @onclick="() => RunForm(f.FormCode)">
                                    ▶ @Loc.L("common.action.run", "Chạy")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<FormListItemDto> _forms      = [];
    private bool                  _loading    = true;
    private string?               _loadError;
    private string                _manualCode = "";
    private string?               _manualError = null;

    protected override async Task OnInitializedAsync()
        => await LoadForms();

    private async Task LoadForms()
    {
        _loading   = true;
        _loadError = null;
        try
        {
            _forms = await FormApi.GetFormsListAsync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _forms     = [];
        }
        finally { _loading = false; }
    }

    private void RunForm(string code)
        => Nav.NavigateTo($"/form/{Uri.EscapeDataString(code)}");

    private void RunManual()
    {
        var code = _manualCode.Trim();
        if (string.IsNullOrWhiteSpace(code)) return;
        Nav.NavigateTo($"/form/{Uri.EscapeDataString(code)}");
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") RunManual();
    }
}
