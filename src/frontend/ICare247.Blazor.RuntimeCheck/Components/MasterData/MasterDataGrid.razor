@* File    : MasterDataGrid.razor
   Purpose : Lưới danh mục dựng trên DevExpress DxGrid — cấu hình qua MasterDataGridConfig
             (cấp lưới) + MasterDataColumnDto (cấp cột). Dữ liệu động (Dictionary) đọc qua
             CellDisplayTemplate; sort/filter/group dựa trên FieldName = ColumnCode. *@

@using System.Globalization
@using ICare247.Blazor.RuntimeCheck.Services

<DxGrid Data="Items"
        ShowFilterRow="Config.ShowFilterRow"
        ShowGroupPanel="Config.ShowGroupPanel"
        VirtualScrollingEnabled="Config.VirtualScrolling"
        PageSize="Config.PageSize"
        PagerVisible="@(Config.PagerVisible && !Config.VirtualScrolling)"
        PageSizeSelectorVisible="Config.PageSizeSelector"
        PageSizeSelectorItems="@(new[] { 10, 20, 50 })"
        SelectionMode="@SelectionMode()"
        CssClass="md-dxgrid"
        TextWrapEnabled="false">
    <Columns>
        @if (Config.SelectionMode.Equals("multiple", StringComparison.OrdinalIgnoreCase))
        {
            <DxGridSelectionColumn Width="44px" />
        }

        @foreach (var col in Columns)
        {
            var c = col; // capture biến vòng lặp cho template
            <DxGridDataColumn Caption="@(c.Label.Length > 0 ? c.Label : c.ColumnCode)"
                              FieldName="@c.ColumnCode"
                              Width="@c.Width"
                              TextAlignment="AlignOf(c)"
                              AllowSort="c.AllowSort"
                              AllowGroup="c.AllowGroup"
                              FilterRowCellVisible="c.AllowFilter">
                <CellDisplayTemplate>
                    @DisplayCell(GetCell(AsRow(context.DataItem), c.ColumnCode), c)
                </CellDisplayTemplate>
            </DxGridDataColumn>
        }

        <DxGridCommandColumn Width="110px" Caption="Thao tác">
            <CellDisplayTemplate>
                @{
                    var pk = GetCell(AsRow(context.DataItem), PkColumn);
                }
                <button class="btn-icon" title="Sửa" @onclick="() => OnEdit.InvokeAsync(pk)">✏️</button>
                <button class="btn-icon btn-icon-danger" title="Xóa" @onclick="() => OnDelete.InvokeAsync(pk)">🗑️</button>
            </CellDisplayTemplate>
        </DxGridCommandColumn>
    </Columns>

    <TotalSummary>
        @if (Config.ShowCountSummary && _firstColName is not null)
        {
            <DxGridSummaryItem SummaryType="GridSummaryItemType.Count"
                               FieldName="@_firstColName"
                               FooterColumnName="@_firstColName" />
        }
    </TotalSummary>
</DxGrid>

@code {
    [Parameter] public List<MasterDataColumnDto> Columns { get; set; } = [];
    [Parameter] public List<Dictionary<string, object?>> Items { get; set; } = [];
    [Parameter] public string PkColumn { get; set; } = "";
    [Parameter] public MasterDataGridConfig Config { get; set; } = new();
    [Parameter] public EventCallback<object?> OnEdit { get; set; }
    [Parameter] public EventCallback<object?> OnDelete { get; set; }

    /// <summary>Cột đầu tiên (đặt summary đếm vào footer cột này).</summary>
    private string? _firstColName => Columns.Count > 0 ? Columns[0].ColumnCode : null;

    /// <summary>Map chuỗi cấu hình → enum chọn dòng của DxGrid.
    /// "none" map về Single + không thêm cột chọn → không có checkbox, không chọn khi click.</summary>
    private GridSelectionMode SelectionMode() => Config.SelectionMode?.ToLowerInvariant() switch
    {
        "multiple" => GridSelectionMode.Multiple,
        _          => GridSelectionMode.Single
    };

    /// <summary>Ép DataItem (object) của DxGrid về dòng dữ liệu động.</summary>
    private static Dictionary<string, object?> AsRow(object? dataItem)
        => dataItem as Dictionary<string, object?> ?? [];

    private static bool IsBool(MasterDataColumnDto c)
        => c.NetType.Equals("bool", StringComparison.OrdinalIgnoreCase);

    private static bool IsNumeric(MasterDataColumnDto c)
        => c.NetType.ToLowerInvariant() is "int" or "long" or "short" or "byte"
           or "decimal" or "double" or "float";

    /// <summary>Căn lề: ưu tiên cấu hình Align, không có → suy theo NetType.</summary>
    private static GridTextAlignment AlignOf(MasterDataColumnDto c)
        => (c.Align ?? "").ToLowerInvariant() switch
        {
            "right"  => GridTextAlignment.Right,
            "center" => GridTextAlignment.Center,
            "left"   => GridTextAlignment.Left,
            _        => IsBool(c) ? GridTextAlignment.Center
                      : IsNumeric(c) ? GridTextAlignment.Right
                      : GridTextAlignment.Left
        };

    private static object? GetCell(Dictionary<string, object?> row, string col)
    {
        var hit = row.FirstOrDefault(kv => kv.Key.Equals(col, StringComparison.OrdinalIgnoreCase));
        return hit.Equals(default(KeyValuePair<string, object?>)) ? null : hit.Value;
    }

    /// <summary>Hiển thị 1 ô: bool → ✓; có DisplayFormat → format theo kiểu; còn lại → thô.</summary>
    private static string DisplayCell(object? value, MasterDataColumnDto col)
    {
        if (value is null) return "";

        if (IsBool(col))
        {
            var on = value is bool b ? b : bool.TryParse(value.ToString(), out var pb) && pb;
            return on ? "✓" : "";
        }

        var fmt = col.DisplayFormat;
        if (!string.IsNullOrWhiteSpace(fmt))
        {
            switch (value)
            {
                case long l:    return l.ToString(fmt, CultureInfo.CurrentCulture);
                case int i:     return i.ToString(fmt, CultureInfo.CurrentCulture);
                case decimal d: return d.ToString(fmt, CultureInfo.CurrentCulture);
                case double db: return db.ToString(fmt, CultureInfo.CurrentCulture);
                case string s when DateTime.TryParse(
                        s, CultureInfo.InvariantCulture, DateTimeStyles.RoundtripKind, out var dt):
                    return dt.ToString(fmt, CultureInfo.CurrentCulture);
            }
        }
        return value.ToString() ?? "";
    }
}
