@namespace ICare247.UI.Shared.Components.Pickers
@inherits LocalizedComponentBase
@inject IDiaBanPickerSource DiaBan

@*
    IcAddressBlock — cụm địa chỉ composite dùng chung (spec 31 §4.2):
    [Địa chỉ chi tiết ......... full-width]
    [Tỉnh/Thành ⌄]  [Xã/Phường ⌄ + tìm]
    · Chỉ LƯU 2 giá trị: DiaChi + PhuongXaId. Tỉnh là bộ lọc/suy ra — KHÔNG lưu trùng.
    · WEB-UX-04: Tỉnh + Xã dùng CHUNG control IcSelectBox (chuẩn "Cấp công ty" — gõ-thẳng-lọc, ✓ soft-blue,
      teleport). Tỉnh = client (danh mục ~34), Xã = server (tìm theo tỉnh, cap 200). Địa chỉ = DxTextBox.
    · Đổi Tỉnh → xóa Xã/Phường đang chọn.
*@

<div class="iab-root">
    <div class="iab-field iab-field--full">
        <span>@Loc.L("common.address.detail", "Địa chỉ chi tiết")</span>
        <DxTextBox Text="@DiaChi"
                   TextChanged="@(v => DiaChiChanged.InvokeAsync(v))"
                   BindValueMode="BindValueMode.OnLostFocus"
                   NullText="@Loc.L("common.address.detail.hint", "Số nhà, đường, thôn/xóm…")"
                   ReadOnly="@Disabled" MaxLength="500"
                   CssClass="field-dx" Width="100%" />
    </div>

    <div class="iab-row">
        <div class="iab-field">
            <span>@Loc.L("common.address.province", "Tỉnh/Thành phố")</span>
            <IcSelectBox TItem="IcPickerItem"
                         Items="_tinhList"
                         TextOf="@(t => t.Ten)"
                         IsSelected="@(t => t.Id == _tinhId)"
                         SelectedText="@(SelectedTinh?.Ten)"
                         OnSelect="SelectTinhAsync"
                         Placeholder="@Loc.L("common.address.province.placeholder", "— Chọn tỉnh/thành —")"
                         Disabled="@Disabled" />
        </div>

        <div class="iab-field">
            <span>@Loc.L("common.address.ward", "Xã/Phường")</span>
            <IcSelectBox TItem="IcPickerItem"
                         SearchFunc="SearchXaAsync"
                         TextOf="@(x => x.Ten)"
                         IsSelected="@(x => x.Id == PhuongXaId)"
                         SelectedText="@(_xaSelected?.Ten)"
                         OnSelect="SelectXaAsync"
                         OnClear="ClearXaAsync"
                         Placeholder="@Loc.L("common.address.ward.placeholder", "— Chọn xã/phường —")"
                         Disabled="@(Disabled || _tinhId is null)" />
        </div>
    </div>
</div>

@code {
    /// <summary>Địa chỉ chi tiết (số nhà, đường…).</summary>
    [Parameter] public string? DiaChi { get; set; }
    [Parameter] public EventCallback<string?> DiaChiChanged { get; set; }

    /// <summary>Xã/Phường đã chọn — giá trị DUY NHẤT lưu DB cùng DiaChi (tỉnh suy ra).</summary>
    [Parameter] public long? PhuongXaId { get; set; }
    [Parameter] public EventCallback<long?> PhuongXaIdChanged { get; set; }

    [Parameter] public bool Disabled { get; set; }

    private IReadOnlyList<IcPickerItem> _tinhList = [];
    private long? _tinhId;
    private IcPickerItem? _xaSelected;

    /// <summary>Tỉnh đang chọn (suy từ _tinhId) — hiển thị + đánh dấu ✓.</summary>
    private IcPickerItem? SelectedTinh => _tinhList.FirstOrDefault(t => t.Id == _tinhId);

    /// <summary>Nạp danh sách tỉnh; có sẵn PhuongXaId → resolve tên xã + suy tỉnh để chọn sẵn.</summary>
    protected override async Task OnInitializedAsync()
    {
        _tinhList = await DiaBan.GetTinhThanhAsync();
        await ResolvePhuongXaAsync();
    }

    /// <summary>Cha đổi PhuongXaId từ ngoài (reset form, nạp bản ghi khác) → resolve lại hiển thị.</summary>
    protected override async Task OnParametersSetAsync()
    {
        if (PhuongXaId != _xaSelected?.Id) await ResolvePhuongXaAsync();
    }

    private async Task ResolvePhuongXaAsync()
    {
        if (PhuongXaId is { } id)
        {
            _xaSelected = await DiaBan.GetPhuongXaAsync(id);
            _tinhId = _xaSelected?.ParentId ?? _tinhId;
        }
        else
        {
            _xaSelected = null;
        }
    }

    /// <summary>Chọn tỉnh: xóa xã đang chọn (giá trị lưu là xã — tỉnh chỉ là bộ lọc).</summary>
    private async Task SelectTinhAsync(IcPickerItem tinh)
    {
        _tinhId = tinh.Id;
        if (_xaSelected is not null)
        {
            _xaSelected = null;
            await PhuongXaIdChanged.InvokeAsync(null);
        }
    }

    /// <summary>Hàm tìm xã theo tỉnh cho IcSelectBox (server, debounce). Chưa chọn tỉnh → rỗng.</summary>
    private Task<IReadOnlyList<IcPickerItem>> SearchXaAsync(string keyword, CancellationToken ct)
        => _tinhId is { } tinhId
            ? DiaBan.SearchPhuongXaAsync(tinhId, keyword, ct)
            : Task.FromResult<IReadOnlyList<IcPickerItem>>([]);

    /// <summary>Chọn xã → bắn PhuongXaIdChanged (form cha giữ giá trị lưu).</summary>
    private async Task SelectXaAsync(IcPickerItem xa)
    {
        _xaSelected = xa;
        if (xa.Id != PhuongXaId) await PhuongXaIdChanged.InvokeAsync(xa.Id);
    }

    /// <summary>Xóa xã đang chọn.</summary>
    private async Task ClearXaAsync()
    {
        if (_xaSelected is null && PhuongXaId is null) return;
        _xaSelected = null;
        await PhuongXaIdChanged.InvokeAsync(null);
    }
}
