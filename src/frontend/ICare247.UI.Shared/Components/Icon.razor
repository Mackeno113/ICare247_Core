@*
    Icon — icon nét đơn sắc dùng chung toàn app (bộ Lucide, bổ sung Tabler khi thiếu).
    - Tô bằng currentColor → tự đổi màu theo ngữ cảnh (hover/active/disabled).
    - viewBox 24, fill none, không bóng/màu → đồng bộ phong cách Linear/Vercel.
    - Tra theo Name (tên icon, KHÔNG phải khóa nghiệp vụ). Thiếu tên → chấm tròn để không vỡ layout.
    - Thêm icon mới = (1) thêm 1 case vào switch bên dưới (dán path từ lucide.dev, giữ stroke-width
      tương đối) + (2) thêm đúng tên đó vào mảng RegisteredNames ở khối @code. Hai nơi phải đồng bộ:
      switch để VẼ, RegisteredNames để các bộ CHỌN icon (vd màn Quản lý menu) liệt kê được.
*@

<svg class="@($"app-icon {CssClass}".Trim())" viewBox="0 0 24 24" fill="none" stroke="currentColor"
     stroke-width="@StrokeWidth" stroke-linecap="round" stroke-linejoin="round"
     width="@Size" height="@Size" aria-hidden="true" focusable="false">
    @switch (Name)
    {
        case "layout-grid":
            <rect x="3" y="3" width="7" height="7" rx="1.5" />
            <rect x="14" y="3" width="7" height="7" rx="1.5" />
            <rect x="3" y="14" width="7" height="7" rx="1.5" />
            <rect x="14" y="14" width="7" height="7" rx="1.5" />
            break;

        case "building":
            <path d="M4 21V5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v16" />
            <path d="M14 9h5a1 1 0 0 1 1 1v11" />
            <path d="M3 21h18" />
            <path d="M7.5 8h3M7.5 12h3M7.5 16h3" />
            break;

        case "users":
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            break;

        case "clock":
            <circle cx="12" cy="12" r="9" />
            <path d="M12 7v5l3.5 2" />
            break;

        case "package":
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
            <path d="m3.3 7 8.7 5 8.7-5" />
            <path d="M12 22V12" />
            break;

        case "credit-card":
            <rect x="2.5" y="5" width="19" height="14" rx="2" />
            <path d="M2.5 10h19" />
            <path d="M6 15h4" />
            break;

        case "bar-chart":
            <path d="M3 3v18h18" />
            <path d="M8 17v-6" />
            <path d="M13 17V7" />
            <path d="M18 17v-9" />
            break;

        case "sliders":
            <path d="M21 4h-7M10 4H3" />
            <path d="M21 12h-9M8 12H3" />
            <path d="M21 20h-5M12 20H3" />
            <path d="M14 2v4M8 10v4M16 18v4" />
            break;

        case "wrench":
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
            break;

        case "chevron-right":
            <path d="m9 6 6 6-6 6" />
            break;

        case "dot":
            <circle cx="12" cy="12" r="2.5" fill="currentColor" stroke="none" />
            break;

        case "chevrons-left":
            <path d="m11 17-5-5 5-5" />
            <path d="m18 17-5-5 5-5" />
            break;

        case "languages":
            <path d="m5 8 6 6" />
            <path d="m4 14 6-6 2-3" />
            <path d="M2 5h12" />
            <path d="M7 2h1" />
            <path d="m22 22-5-10-5 10" />
            <path d="M14 18h6" />
            break;

        @* ── Bổ sung dùng chung (toolbar/form) ── *@
        case "plus":
            <path d="M12 5v14M5 12h14" />
            break;

        case "search":
            <circle cx="11" cy="11" r="7" />
            <path d="m21 21-4.3-4.3" />
            break;

        case "x":
            <path d="M18 6 6 18M6 6l12 12" />
            break;

        case "pencil":
            <path d="M12 20h9" />
            <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
            break;

        case "trash":
            <path d="M3 6h18" />
            <path d="M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2" />
            <path d="M19 6v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V6" />
            <path d="M10 11v6M14 11v6" />
            break;

        default:
            <circle cx="12" cy="12" r="3.5" />
            break;
    }
</svg>

@code {
    /// <summary>
    /// Danh sách tên icon ĐÃ ĐĂNG KÝ (khớp 1-1 với các case trong &lt;svg&gt; ở trên).
    /// Đây là "từ điển icon" dùng chung — bộ chọn icon (vd màn Quản lý menu) đọc từ đây
    /// thay vì hard-code. THÊM ICON MỚI: dán &lt;path&gt; từ lucide.dev thành 1 case ở trên,
    /// rồi thêm đúng tên đó vào mảng này (giữ 2 nơi đồng bộ).
    /// </summary>
    public static readonly IReadOnlyList<string> RegisteredNames = new[]
    {
        "layout-grid", "building", "users", "clock", "package", "credit-card",
        "bar-chart", "sliders", "wrench", "chevron-right", "chevrons-left",
        "dot", "languages", "plus", "search", "x", "pencil", "trash"
    };

    /// <summary>Tên icon (kiểu Lucide), vd "building", "users", "plus". Không tìm thấy → chấm tròn.</summary>
    [Parameter, EditorRequired] public string Name { get; set; } = "";

    /// <summary>Cạnh icon tính bằng px (rộng = cao). Mặc định 18.</summary>
    [Parameter] public int Size { get; set; } = 18;

    /// <summary>Độ dày nét. Mặc định 1.75 (đồng bộ Lucide).</summary>
    [Parameter] public double StrokeWidth { get; set; } = 1.75;

    /// <summary>Class CSS phụ thêm vào svg (vd để chỉnh màu/căn lề tại nơi dùng).</summary>
    [Parameter] public string? CssClass { get; set; }
}
