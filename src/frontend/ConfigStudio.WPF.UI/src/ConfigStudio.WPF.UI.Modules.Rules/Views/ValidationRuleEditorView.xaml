<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Rules.Views.ValidationRuleEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: Header + Toolbar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Button Command="{Binding BackCommand}" ToolTip="Quay lại Field Config"
                            Width="30" Height="30" Background="Transparent" BorderBrush="Transparent">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" />
                    </Button>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Validation Rules — {0}">
                                    <Binding Path="FieldCode" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="12" Opacity="0.6"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Field #{0} · Form #{1} · {2} rules">
                                    <Binding Path="FieldId" />
                                    <Binding Path="FormId" />
                                    <Binding Path="Rules.Count" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!-- Dirty indicator -->
                    <TextBlock Text="•" Foreground="Orange" FontSize="20"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"
                               ToolTip="Có thay đổi chưa lưu" />
                </StackPanel>

                <!-- Toolbar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <dx:SimpleButton Command="{Binding AddRuleCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" VerticalAlignment="Center" />
                            <TextBlock Text="Thêm Rule" Margin="6,0,0,0" />
                        </StackPanel>
                    </dx:SimpleButton>

                    <Button Command="{Binding MoveUpCommand}" ToolTip="Di chuyển lên"
                            Width="30" Height="30" Background="Transparent" BorderBrush="Transparent">
                        <TextBlock Text="↑" FontSize="14" VerticalAlignment="Center" />
                    </Button>
                    <Button Command="{Binding MoveDownCommand}" ToolTip="Di chuyển xuống"
                            Width="30" Height="30" Background="Transparent" BorderBrush="Transparent">
                        <TextBlock Text="↓" FontSize="14" VerticalAlignment="Center" />
                    </Button>

                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="4,4" />

                    <dx:SimpleButton Command="{Binding OpenExpressionBuilderCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{}{ }" VerticalAlignment="Center" />
                            <TextBlock Text="Expression Builder" Margin="6,0,0,0" />
                        </StackPanel>
                    </dx:SimpleButton>

                    <!-- Right: Save All -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="16,0,0,0">
                        <dx:SimpleButton Command="{Binding SaveAllCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" VerticalAlignment="Center" />
                                <TextBlock Text="Lưu tất cả" Margin="6,0,0,0" />
                            </StackPanel>
                        </dx:SimpleButton>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: GridControl + Edit Panel
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- GridControl -->
            <Border Grid.Column="0" BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                <dxg:GridControl ItemsSource="{Binding Rules}"
                                 SelectedItem="{Binding SelectedRule, Mode=TwoWay}"
                                 AutoPopulateColumns="False">
                    <dxg:GridControl.View>
                        <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                       AllowPerPixelScrolling="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn Header="#" FieldName="OrderNo" Width="40" />
                        <dxg:GridColumn Header="Loại Rule" FieldName="RuleTypeCode" Width="120" />
                        <dxg:GridColumn Header="Expression" FieldName="ExpressionPreview" Width="*" />
                        <dxg:GridColumn Header="Error Key" FieldName="ErrorKey" Width="150" />
                        <dxg:GridColumn Header="Severity" FieldName="Severity" Width="90" />
                        <dxg:GridColumn Header="Active" FieldName="IsActive" Width="65" />
                        <dxg:GridColumn Header="" Width="90" AllowEditing="False" AllowSorting="False">
                            <dxg:GridColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.EditRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                CommandParameter="{Binding Row}"
                                                ToolTip="Sửa rule" Width="30" Height="30"
                                                Background="Transparent" BorderBrush="Transparent">
                                            <TextBlock Text="✎" />
                                        </Button>
                                        <Button Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                CommandParameter="{Binding Row}"
                                                Foreground="#EF4444"
                                                ToolTip="Xóa rule" Width="30" Height="30"
                                                Background="Transparent" BorderBrush="Transparent">
                                            <TextBlock Text="🗑" />
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </dxg:GridColumn.CellTemplate>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </Border>

            <!-- Edit Panel -->
            <Border Grid.Column="1" Width="320" Margin="8,0,0,0"
                    BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6"
                    Padding="16"
                    Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Chi tiết Rule"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}"
                               Margin="0,0,0,16" />

                    <dxe:ComboBoxEdit NullText="Loại Rule"
                                      ItemsSource="{Binding RuleTypeOptions}"
                                      EditValue="{Binding EditRuleType}"
                                      Margin="0,0,0,12" />

                    <dxe:ComboBoxEdit NullText="Severity"
                                      ItemsSource="{Binding SeverityOptions}"
                                      EditValue="{Binding EditSeverity}"
                                      Margin="0,0,0,12" />

                    <dxe:TextEdit NullText="Error Key (i18n)"
                                  EditValue="{Binding EditErrorKey, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,0,12" />

                    <dxe:TextEdit NullText="Expression Preview"
                                  EditValue="{Binding EditExpressionPreview, UpdateSourceTrigger=PropertyChanged}"
                                  IsReadOnly="True"
                                  Margin="0,0,0,16" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelEditCommand}"
                                Content="Hủy" Margin="0,0,8,0"
                                Background="Transparent" BorderBrush="Transparent" />
                        <dx:SimpleButton Command="{Binding SaveRuleCommand}"
                                         Content="Áp dụng" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6"
                Background="#EEF5FF" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🛡" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock FontSize="12" Opacity="0.6" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} rules · Field: {1}">
                            <Binding Path="Rules.Count" />
                            <Binding Path="FieldCode" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
