<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FormEditDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:conv="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True"
             MinWidth="900" MinHeight="620"
             d:DesignWidth="960" d:DesignHeight="660"
             mc:Ignorable="d">

    <!-- Prism dialog window size -->
    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="Width"      Value="960" />
            <Setter Property="Height"     Value="680" />
            <Setter Property="ResizeMode" Value="CanResize" />
            <Setter Property="Title"      Value="{Binding Title}" />
        </Style>
    </prism:Dialog.WindowStyle>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisConverter x:Key="InvBoolToVis" />

        <!-- Label trong form edit -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Opacity"    Value="0.65" />
            <Setter Property="Margin"     Value="0,0,0,4" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <!-- Container cho từng field (label + input) -->
        <Style x:Key="FieldGroupStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <!-- Readonly value display -->
        <Style x:Key="ReadonlyValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="FontFamily"   Value="Consolas" />
            <Setter Property="Foreground"   Value="#64748B" />
            <Setter Property="Background"   Value="#F8FAFC" />
            <Setter Property="Padding"      Value="8,6" />
        </Style>

        <!-- Tab header badge -->
        <Style x:Key="TabBadgeStyle" TargetType="Border">
            <Setter Property="Background"   Value="#DBEAFE" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding"      Value="6,1" />
            <Setter Property="Margin"       Value="5,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- Action button trong DataGrid cell -->
        <Style x:Key="InlineBtnStyle" TargetType="Button">
            <Setter Property="Width"           Value="28" />
            <Setter Property="Height"          Value="26" />
            <Setter Property="Margin"          Value="2,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Foreground"      Value="#475569" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E1ECFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InlineDeleteBtnStyle" TargetType="Button" BasedOn="{StaticResource InlineBtnStyle}">
            <Setter Property="Foreground" Value="#EF4444" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"    />   <!-- TabControl -->
            <RowDefinition Height="Auto" />   <!-- Validation summary -->
            <RowDefinition Height="Auto" />   <!-- Toolbar Lưu / Hủy -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: 2 Tabs — Thông tin cơ bản | Sections & Fields
             ═══════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="0" BorderThickness="0" Background="Transparent" Padding="16,12,16,0">

            <!-- ── TAB 1: Thông tin cơ bản ─────────────────────── -->
            <TabItem Header="Thông tin cơ bản">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Cột trái -->
                        <StackPanel Grid.Column="0">

                            <!-- Form Code -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}">
                                <DockPanel>
                                    <TextBlock Text="Form Code *" Style="{StaticResource FieldLabelStyle}"
                                               DockPanel.Dock="Left" />
                                    <!-- Checking spinner -->
                                    <TextBlock DockPanel.Dock="Right" Text="⏳ Đang kiểm tra..."
                                               FontSize="11" Opacity="0.5" VerticalAlignment="Center"
                                               Visibility="{Binding IsCheckingCode, Converter={StaticResource BoolToVis}}" />
                                </DockPanel>
                                <dxe:TextEdit EditValue="{Binding FormCode, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="VD: PATIENT_INTAKE"
                                              CharacterCasing="Upper" />
                                <!-- Inline error -->
                                <TextBlock Text="{Binding FormCodeError}" FontSize="11"
                                           Foreground="#EF4444" Margin="0,3,0,0"
                                           Visibility="{Binding HasFormCodeError, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>

                            <!-- Tên Form -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}">
                                <TextBlock Text="Tên Form *" Style="{StaticResource FieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Nhập tên hiển thị..." />
                            </StackPanel>

                            <!-- Platform -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}">
                                <TextBlock Text="Platform *" Style="{StaticResource FieldLabelStyle}" />
                                <dxe:ComboBoxEdit ItemsSource="{Binding PlatformOptions}"
                                                  EditValue="{Binding Platform}" />
                            </StackPanel>

                            <!-- Layout Engine -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}">
                                <TextBlock Text="Layout Engine" Style="{StaticResource FieldLabelStyle}" />
                                <dxe:ComboBoxEdit ItemsSource="{Binding LayoutEngineOptions}"
                                                  EditValue="{Binding LayoutEngine}" />
                            </StackPanel>

                            <!-- Is Active -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}" Orientation="Horizontal">
                                <dxe:CheckEdit IsChecked="{Binding IsActive}"
                                               Content="Kích hoạt (Is Active)" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Cột phải -->
                        <StackPanel Grid.Column="2">

                            <!-- Business Table -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}">
                                <TextBlock Text="Business Table *" Style="{StaticResource FieldLabelStyle}" />
                                <!-- NOTE: dùng ComboBoxEdit, phase2 nâng cấp lên SearchLookUpEdit -->
                                <dxe:ComboBoxEdit ItemsSource="{Binding TableOptions}"
                                                  EditValue="{Binding SelectedTable, Mode=TwoWay}"
                                                  DisplayMember="DisplayText"
                                                  NullText="Chọn bảng dữ liệu..." />
                            </StackPanel>

                            <!-- Description -->
                            <StackPanel Style="{StaticResource FieldGroupStyle}">
                                <TextBlock Text="Mô tả" Style="{StaticResource FieldLabelStyle}" />
                                <dxe:MemoEdit EditValue="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Nhập mô tả form..."
                                              Height="80" AcceptsReturn="True" />
                            </StackPanel>

                            <!-- Version + Checksum — readonly, chỉ hiện trong edit mode -->
                            <StackPanel Visibility="{Binding IsCreateMode, Converter={StaticResource InvBoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Style="{StaticResource FieldGroupStyle}">
                                        <TextBlock Text="Version" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding Version}" Style="{StaticResource ReadonlyValueStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Style="{StaticResource FieldGroupStyle}">
                                        <TextBlock Text="Checksum" Style="{StaticResource FieldLabelStyle}" />
                                        <TextBlock Text="{Binding Checksum}" Style="{StaticResource ReadonlyValueStyle}"
                                                   FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- ── TAB 2: Sections & Fields ────────────────────── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Sections &amp; Fields" FontSize="12" FontWeight="Medium" />
                        <Border Style="{StaticResource TabBadgeStyle}">
                            <TextBlock FontSize="11" Foreground="#1D4ED8" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0}s / {1}f">
                                        <Binding Path="Sections.Count" />
                                        <Binding Path="SelectedSectionFields" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" MinWidth="180" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ── Sections panel (trái) ─────────────── -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Section toolbar -->
                        <Border Grid.Row="0" Padding="8,6" BorderBrush="#E2EAFF" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock Text="Sections" FontSize="12" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Style="{StaticResource InlineBtnStyle}"
                                            Command="{Binding AddSectionCommand}"
                                            ToolTip="Thêm Section" Content="＋" FontSize="15" />
                                    <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                            Command="{Binding RemoveSectionCommand}"
                                            ToolTip="Xóa Section đang chọn" Content="✕" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Sections ListBox -->
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Sections}"
                                 SelectedItem="{Binding SelectedSection, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="▶" FontSize="10"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"
                                                   Opacity="0.4" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Code}" FontSize="12"
                                                       FontWeight="Medium" />
                                            <TextBlock FontSize="10" Opacity="0.5">
                                                <TextBlock.Text>
                                                    <MultiBinding StringFormat="{}{0} fields">
                                                        <Binding Path="Children.Count" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding"       Value="8,4" />
                                    <Setter Property="Cursor"        Value="Hand" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </Grid>

                    <!-- Splitter -->
                    <GridSplitter Grid.Column="1" Width="4"
                                  HorizontalAlignment="Stretch"
                                  Background="#E2EAFF" />

                    <!-- ── Fields panel (phải) ─────────────────── -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Fields toolbar -->
                        <Border Grid.Row="0" Padding="8,6" BorderBrush="#E2EAFF" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="Fields — {0}">
                                            <Binding Path="SelectedSection.Code" FallbackValue="(chưa chọn section)" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Style="{StaticResource InlineBtnStyle}"
                                            Command="{Binding MoveFieldUpCommand}"
                                            ToolTip="Dời lên" Content="↑" />
                                    <Button Style="{StaticResource InlineBtnStyle}"
                                            Command="{Binding MoveFieldDownCommand}"
                                            ToolTip="Dời xuống" Content="↓" />
                                    <Button Style="{StaticResource InlineBtnStyle}"
                                            Command="{Binding AddFieldCommand}"
                                            ToolTip="Thêm Field" Content="＋" FontSize="15"
                                            IsEnabled="{Binding HasSelectedSection}" />
                                    <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                            Command="{Binding RemoveFieldCommand}"
                                            ToolTip="Xóa Field đang chọn" Content="✕" FontSize="12" />
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Fields DataGrid -->
                        <dxg:GridControl Grid.Row="1"
                                         ItemsSource="{Binding SelectedSectionFields}"
                                         SelectedItem="{Binding SelectedField, Mode=TwoWay}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView ShowGroupPanel="False"
                                               AllowEditing="False"
                                               AllowPerPixelScrolling="True"
                                               NavigationStyle="Row" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="#"          FieldName="SortOrder"   Width="45" />
                                <dxg:GridColumn Header="Field Code" FieldName="Code"        Width="160" />
                                <dxg:GridColumn Header="Tên hiển thị" FieldName="DisplayName" Width="*" />
                                <dxg:GridColumn Header="Editor"     FieldName="EditorType"  Width="110" />

                                <!-- Actions -->
                                <dxg:GridColumn Header="" Width="90" AllowSorting="False" AllowEditing="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                        Margin="4,0">
                                                <!-- Mở Field Config -->
                                                <Button Style="{StaticResource InlineBtnStyle}"
                                                        Command="{Binding DataContext.OpenFieldConfigCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Cấu hình field"
                                                        Content="⚙" />
                                                <!-- Xóa field -->
                                                <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                                        Command="{Binding DataContext.RemoveFieldCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Xóa field"
                                                        Content="✕" FontSize="11" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>

                        <!-- Placeholder khi chưa chọn section -->
                        <Border Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding HasSelectedSection, Converter={StaticResource InvBoolToVis}}">
                            <TextBlock Text="← Chọn section để xem fields" FontSize="13" Opacity="0.4" />
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: Validation Summary
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="16,0" Padding="12,8"
                Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="1" CornerRadius="4"
                Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="⚠" Foreground="#DC2626"
                           Margin="0,0,8,0" VerticalAlignment="Top" FontSize="14" />
                <TextBlock Text="{Binding ValidationSummary}" Foreground="#991B1B"
                           FontSize="12" TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Toolbar Lưu / Hủy
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="16,10" BorderBrush="#E2EAFF" BorderThickness="0,1,0,0"
                Background="{DynamicResource ShellContentBackgroundBrush}">
            <DockPanel>
                <!-- Dirty indicator -->
                <TextBlock DockPanel.Dock="Left" Text="● Có thay đổi chưa lưu"
                           FontSize="11" Foreground="#D97706" VerticalAlignment="Center"
                           Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />

                <!-- Buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <dx:SimpleButton Content="Hủy"
                                     Command="{Binding CancelCommand}"
                                     Margin="0,0,8,0" Height="34" Padding="20,0" />
                    <dx:SimpleButton Content="💾 Lưu"
                                     Command="{Binding SaveCommand}"
                                     Height="34" Padding="24,0"
                                     IsEnabled="{Binding IsCheckingCode, Converter={StaticResource InvBoolToVis}}" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
