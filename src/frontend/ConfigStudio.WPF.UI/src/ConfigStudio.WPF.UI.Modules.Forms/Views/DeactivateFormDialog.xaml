<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.DeactivateFormDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="420"
             mc:Ignorable="d">

    <UserControl.Resources>

        <!-- Nút hủy: outline trắng -->
        <Style x:Key="BtnCancel" TargetType="Button">
            <Setter Property="Padding"         Value="20,6" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Foreground"      Value="#374151" />
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F4F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nút xác nhận: đỏ -->
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Padding"         Value="20,6" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="Medium" />
            <Setter Property="Foreground"      Value="White" />
            <Setter Property="Background"      Value="#EF4444" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#DC2626" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#B91C1C" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Border Background="White"
            BorderBrush="#E2E8F0"
            BorderThickness="1"
            CornerRadius="6"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ── Header ─────────────────────────────────────────── -->
            <Border Grid.Row="0" Background="#EF4444" Padding="20,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="16" Foreground="White"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="Vô hiệu hóa Form"
                               FontSize="15" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- ── Body ───────────────────────────────────────────── -->
            <StackPanel Grid.Row="1" Margin="20,18,20,14">

                <!-- Mô tả -->
                <TextBlock FontSize="13" Foreground="#374151" TextWrapping="Wrap">
                    <Run Text="Bạn sắp vô hiệu hóa form " />
                    <Run FontWeight="Bold" Text="{Binding FormCode, Mode=OneWay}" />
                    <Run Text=" — " /><Run FontStyle="Italic" Text="{Binding FormName, Mode=OneWay}" /><Run Text="." />
                </TextBlock>

                <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#6B7280" TextWrapping="Wrap"
                           Text="Form sẽ bị ẩn khỏi runtime. Dữ liệu không bị xóa và có thể khôi phục bất kỳ lúc nào." />

                <!-- Impact box -->
                <Border Margin="0,14,0,0" Background="#FEF3C7" BorderBrush="#F59E0B"
                        BorderThickness="1" CornerRadius="5" Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Ảnh hưởng" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#92400E" Margin="0,0,0,6" />

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="▪ " Foreground="#92400E" FontSize="12" />
                            <TextBlock FontSize="12" Foreground="#78350F">
                                <Run FontWeight="Bold" Text="{Binding SectionCount, Mode=OneWay}" />
                                <Run Text=" section" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="▪ " Foreground="#92400E" FontSize="12" />
                            <TextBlock FontSize="12" Foreground="#78350F">
                                <Run FontWeight="Bold" Text="{Binding FieldCount, Mode=OneWay}" />
                                <Run Text=" field" />
                            </TextBlock>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="▪ " Foreground="#92400E" FontSize="12" />
                            <TextBlock FontSize="12" Foreground="#78350F">
                                <Run FontWeight="Bold" Text="{Binding EventCount, Mode=OneWay}" />
                                <Run Text=" event" />
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- ── Footer ─────────────────────────────────────────── -->
            <Border Grid.Row="2" Background="#F8FAFC" BorderBrush="#E2E8F0"
                    BorderThickness="0,1,0,0" Padding="20,10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Hủy"
                            Style="{StaticResource BtnCancel}"
                            Margin="0,0,8,0"
                            Command="{Binding CancelCommand}" />
                    <Button Content="Vô hiệu hóa"
                            Style="{StaticResource BtnDanger}"
                            Command="{Binding ConfirmCommand}" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</UserControl>
