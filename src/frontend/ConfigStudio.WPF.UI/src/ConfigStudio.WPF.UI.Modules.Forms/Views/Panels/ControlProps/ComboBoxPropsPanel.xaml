<!-- File    : ComboBoxPropsPanel.xaml
     Module  : Forms / Views / Panels / ControlProps
     Layer   : Presentation
     Purpose : Panel cấu hình cho Editor_Type = ComboBox (dynamic) và LookupComboBox (static).
               Gồm 3 section: Nguồn dữ liệu | Tìm kiếm | Hiển thị.
               DataContext được kế thừa từ FieldConfigView → FieldConfigViewModel. -->
<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.Panels.ControlProps.ComboBoxPropsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="680">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <StackPanel>

        <!-- ══════════════════════════════════════════════════════
             SECTION 1 — Nguồn dữ liệu
             LookupComboBox → Sys_Lookup; ComboBox → Table/TVF/SQL
             ══════════════════════════════════════════════════════ -->

        <!-- ── Nguồn dữ liệu: Sys_Lookup (chỉ LookupComboBox) ─── -->
        <Border Visibility="{Binding IsLookupEditor, Converter={StaticResource BoolToVis}}"
                Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Nguồn dữ liệu — Sys_Lookup" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,14" />

                <TextBlock Text="Lookup Code" FontSize="11" FontWeight="SemiBold"
                           Foreground="#64748B" Margin="0,0,0,6" />
                <dxe:ComboBoxEdit ItemsSource="{Binding AvailableLookupCodes}"
                                  EditValue="{Binding LookupCode, UpdateSourceTrigger=PropertyChanged}"
                                  IsTextEditable="True"
                                  Height="32" Margin="0,0,0,4"
                                  NullText="VD: GENDER, MARITAL_STATUS" />
                <TextBlock FontSize="11" Foreground="#64748B" Opacity="0.75" TextWrapping="Wrap"
                           Margin="0,0,0,12">
                    <Run Text="Mã danh mục trong Sys_Lookup. VD: " />
                    <Run Text="GENDER" FontFamily="Consolas" Foreground="#1D4ED8" />
                </TextBlock>

                <!-- Preview options -->
                <TextBlock Text="Xem trước options:" FontSize="11" Foreground="#64748B"
                           Margin="0,0,0,6"
                           Visibility="{Binding LookupPreviewItems.Count, Converter={StaticResource BoolToVis}}" />
                <ItemsControl ItemsSource="{Binding LookupPreviewItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Border Background="#DBEAFE" CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding ItemCode}" FontFamily="Consolas" FontSize="11"
                                               Foreground="#1D4ED8" />
                                </Border>
                                <TextBlock Text="{Binding Label}" FontSize="12" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ── Nguồn dữ liệu: Dynamic — Table/TVF/SQL (chỉ ComboBox) ─── -->
        <Border Visibility="{Binding IsComboBoxEditor, Converter={StaticResource BoolToVis}}"
                Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Nguồn dữ liệu — Dynamic" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,14" />

                <!-- Mode selector -->
                <TextBlock Text="Chế độ truy vấn" FontSize="11" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <RadioButton Content="Bảng / View"
                                 IsChecked="{Binding IsTableMode, Mode=OneWay}"
                                 GroupName="CbQueryMode" Margin="0,0,16,0"
                                 Command="{Binding SetQueryModeCommand}"
                                 CommandParameter="table" />
                    <RadioButton Content="Function (TVF)"
                                 IsChecked="{Binding IsFunctionMode, Mode=OneWay}"
                                 GroupName="CbQueryMode" Margin="0,0,16,0"
                                 Command="{Binding SetQueryModeCommand}"
                                 CommandParameter="function" />
                    <RadioButton Content="SQL tùy chỉnh"
                                 IsChecked="{Binding IsSqlMode, Mode=OneWay}"
                                 GroupName="CbQueryMode"
                                 Command="{Binding SetQueryModeCommand}"
                                 CommandParameter="custom_sql" />
                </StackPanel>

                <!-- Value + Display — chung 3 mode -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cột Value (lưu vào DB)" FontSize="11"
                                   Foreground="#64748B" Margin="0,0,0,3" />
                        <dxe:TextEdit Text="{Binding FkValueField, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32" NullText="VD: PhongBan_Code" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cột Display (hiển thị)" FontSize="11"
                                   Foreground="#64748B" Margin="0,0,0,3" />
                        <dxe:TextEdit Text="{Binding FkDisplayField, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32" NullText="VD: Ten_PhongBan" />
                    </StackPanel>
                </Grid>

                <!-- Panel: Bảng / View -->
                <StackPanel Visibility="{Binding IsTableMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Tên bảng hoặc View" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkTableName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32" Margin="0,0,0,10"
                                  NullText="VD: DM_PhongBan  hoặc  vw_PhongBan_Full" />
                    <TextBlock Text="Filter SQL / WHERE (tùy chọn)" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkFilterSql, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32" Margin="0,0,0,2"
                                  NullText="VD: Is_Active = 1 AND Tenant_Id = @TenantId" />
                    <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,2,0,0">
                        <Run Text="Tham số hệ thống: " />
                        <Run Text="@TenantId  @Today  @CurrentUser" FontFamily="Consolas" Foreground="#059669" />
                    </TextBlock>
                </StackPanel>

                <!-- Panel: Function (TVF) -->
                <StackPanel Visibility="{Binding IsFunctionMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Tên Function (TVF)" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkFunctionName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32" Margin="0,0,0,4" FontFamily="Consolas"
                                  NullText="VD: fn_GetPhongBanHieuLuc" />
                </StackPanel>

                <!-- Panel: SQL tùy chỉnh -->
                <StackPanel Visibility="{Binding IsSqlMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="SELECT SQL tùy chỉnh" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkSelectSql, UpdateSourceTrigger=PropertyChanged}"
                                  Height="80" AcceptsReturn="True" Margin="0,0,0,4"
                                  FontFamily="Consolas" FontSize="11"
                                  NullText="SELECT id, name FROM ... WHERE Tenant_Id = @TenantId" />
                </StackPanel>

                <!-- Order By -->
                <TextBlock Text="Sắp xếp (ORDER BY)" FontSize="11" Foreground="#64748B" Margin="0,12,0,3" />
                <dxe:TextEdit Text="{Binding FkOrderBy, UpdateSourceTrigger=PropertyChanged}"
                              Height="32" NullText="VD: Ten_PhongBan ASC" />
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             SECTION 2 — Tìm kiếm (cả ComboBox lẫn LookupComboBox)
             ══════════════════════════════════════════════════════ -->
        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Tìm kiếm" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,14" />

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Chế độ tìm kiếm" FontSize="11" Foreground="#64748B" Margin="0,0,0,6" FontWeight="SemiBold" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding SearchModeOptions}"
                                          EditValue="{Binding CbSearchMode}"
                                          IsTextEditable="False" Height="32" />
                        <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,4,0,0"
                                   Text="None = tắt  |  AutoFilter = lọc  |  AutoSearch = tìm" />
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Visibility="{Binding ShowSearchFilterCondition, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Điều kiện so khớp" FontSize="11" Foreground="#64748B" Margin="0,0,0,6" FontWeight="SemiBold" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding SearchFilterConditionOptions}"
                                          EditValue="{Binding CbSearchFilterCondition}"
                                          IsTextEditable="False" Height="32" />
                        <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,4,0,0"
                                   Text="Contains | StartsWith | Equals" />
                    </StackPanel>
                </Grid>

                <dxe:CheckEdit Content="Cho phép nhập text tự do (AllowUserInput)"
                               IsChecked="{Binding CbAllowUserInput}"
                               FontSize="12" Margin="0,0,0,4" />
                <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75"
                           Text="Khi bật: user có thể nhập giá trị không có trong list." />
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             SECTION 3 — Hiển thị
             ══════════════════════════════════════════════════════ -->
        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Hiển thị" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,14" />

                <!-- NullText key -->
                <TextBlock Text="Placeholder key (NullText)" FontSize="11" Foreground="#64748B"
                           Margin="0,0,0,3" FontWeight="SemiBold" />
                <dxe:TextEdit Text="{Binding CbNullTextKey, UpdateSourceTrigger=PropertyChanged}"
                              Height="32" Margin="0,0,0,2"
                              NullText="VD: nhanvien.placeholder.phong_ban" />
                <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,0,0,12"
                           Text="I18n key cho text hiển thị khi chưa chọn giá trị." />

                <!-- DropDownWidthMode + ClearButton -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Chiều rộng dropdown" FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,6" FontWeight="SemiBold" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding DropDownWidthModeOptions}"
                                          EditValue="{Binding CbDropDownWidthMode}"
                                          IsTextEditable="False" Height="32" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Nút xóa (Clear)" FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,6" FontWeight="SemiBold" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding ClearButtonModeOptions}"
                                          EditValue="{Binding CbClearButton}"
                                          IsTextEditable="False" Height="32" />
                    </StackPanel>
                </Grid>

                <!-- Group + Disabled field (chỉ ComboBox dynamic) -->
                <StackPanel Visibility="{Binding IsComboBoxEditor, Converter={StaticResource BoolToVis}}">
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Group theo field (tùy chọn)" FontSize="11" Foreground="#64748B"
                                       Margin="0,0,0,3" FontWeight="SemiBold" />
                            <dxe:TextEdit Text="{Binding CbGroupFieldName, UpdateSourceTrigger=PropertyChanged}"
                                          Height="32" NullText="VD: LoaiPhongBan" />
                            <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,3,0,0"
                                       Text="Tên field để nhóm items trong dropdown." />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Field disable item (tùy chọn)" FontSize="11" Foreground="#64748B"
                                       Margin="0,0,0,3" FontWeight="SemiBold" />
                            <dxe:TextEdit Text="{Binding CbDisabledFieldName, UpdateSourceTrigger=PropertyChanged}"
                                          Height="32" NullText="VD: Is_Active (bool)" />
                            <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,3,0,0"
                                       Text="Tên field bool để vô hiệu hóa từng item." />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
