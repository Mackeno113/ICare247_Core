<!-- File    : TreePickerPropsPanel.xaml
     Module  : Forms / Views / Panels / ControlProps
     Layer   : Presentation
     Purpose : Panel cấu hình cho Editor_Type = TreePicker (dropdown cây phân cấp).
               Gồm 4 section: Nguồn dữ liệu | Cấu hình cây | Cascading Reload | Diễn giải.
               DataContext được kế thừa từ FieldConfigView → FieldConfigViewModel. -->
<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.Panels.ControlProps.TreePickerPropsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="680">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <StackPanel>

        <!-- ══════════════════════════════════════════════════════
             SECTION 1 — Nguồn dữ liệu
             ══════════════════════════════════════════════════════ -->
        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Nguồn dữ liệu" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,14" />

                <!-- Mode selector -->
                <TextBlock Text="Chế độ truy vấn" FontSize="11" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                    <RadioButton Content="Bảng / View"
                                 IsChecked="{Binding IsTableMode, Mode=OneWay}"
                                 GroupName="TpQueryMode" Margin="0,0,16,0"
                                 Command="{Binding SetQueryModeCommand}"
                                 CommandParameter="table" />
                    <RadioButton Content="Function (TVF)"
                                 IsChecked="{Binding IsFunctionMode, Mode=OneWay}"
                                 GroupName="TpQueryMode" Margin="0,0,16,0"
                                 Command="{Binding SetQueryModeCommand}"
                                 CommandParameter="function" />
                    <RadioButton Content="SQL tùy chỉnh"
                                 IsChecked="{Binding IsSqlMode, Mode=OneWay}"
                                 GroupName="TpQueryMode"
                                 Command="{Binding SetQueryModeCommand}"
                                 CommandParameter="custom_sql" />
                </StackPanel>

                <!-- Value + Display — chung 3 mode -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cột Value — FK lưu vào DB" FontSize="11"
                                   Foreground="#64748B" Margin="0,0,0,3" FontWeight="SemiBold" />
                        <dxe:TextEdit Text="{Binding FkValueField, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32" NullText="VD: PhongBan_Id" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Cột Display (hiển thị)" FontSize="11"
                                   Foreground="#64748B" Margin="0,0,0,3" FontWeight="SemiBold" />
                        <dxe:TextEdit Text="{Binding FkDisplayField, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32" NullText="VD: Ten_PhongBan" />
                    </StackPanel>
                </Grid>

                <!-- Panel: Bảng / View -->
                <StackPanel Visibility="{Binding IsTableMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Tên bảng hoặc View" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkTableName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32" Margin="0,0,0,2"
                                  NullText="VD: DM_PhongBan  hoặc  vw_PhongBan_Tree" />
                    <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,0,0,10"
                               Text="Bảng hoặc View — phải có cột ParentId để build cây." />
                    <TextBlock Text="Filter SQL / WHERE (tùy chọn)" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkFilterSql, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32" Margin="0,0,0,2"
                                  NullText="VD: Is_Active = 1 AND Tenant_Id = @TenantId" />
                    <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,2,0,0">
                        <Run Text="Tham số hệ thống tự động: " />
                        <Run Text="@TenantId  @Today  @CurrentUser" FontFamily="Consolas" Foreground="#059669" />
                    </TextBlock>
                </StackPanel>

                <!-- Panel: Function (TVF) -->
                <StackPanel Visibility="{Binding IsFunctionMode, Converter={StaticResource BoolToVis}}">
                    <Border Background="#FFF7ED" CornerRadius="6" Padding="10,6"
                            Margin="0,0,0,10" BorderBrush="#FED7AA" BorderThickness="1">
                        <TextBlock FontSize="10" Foreground="#92400E" TextWrapping="Wrap">
                            <Run Text="⚡ TVF: " />
                            <Run Text="SELECT ... FROM fn_Tên(@P1, @P2)" FontFamily="Consolas" />
                            <LineBreak />
                            <Run Text="Kết quả phải có cột ParentId để build cây phân cấp." />
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Tên Function (TVF)" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkFunctionName, UpdateSourceTrigger=PropertyChanged}"
                                  Height="32" Margin="0,0,0,12" FontFamily="Consolas"
                                  NullText="VD: fn_GetPhongBanTree" />

                    <!-- Function params -->
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="Tham số hàm (theo thứ tự)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#374151" DockPanel.Dock="Left" VerticalAlignment="Center" />
                        <Button Content="+ Thêm" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Height="26" Padding="10,0" FontSize="11"
                                Foreground="#1D4ED8" Background="Transparent"
                                BorderBrush="#1D4ED8" BorderThickness="1" Cursor="Hand"
                                Command="{Binding AddFunctionParamCommand}" />
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding FkFunctionParams}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FFFBEB" CornerRadius="4"
                                        BorderBrush="#FDE68A" BorderThickness="1"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="28" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="@Tên tham số" FontSize="10"
                                                       Foreground="#64748B" Margin="0,0,0,2" />
                                            <dxe:TextEdit Height="28" FontFamily="Consolas" FontSize="11"
                                                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                          NullText="VD: NgayHieuLuc" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Nguồn" FontSize="10"
                                                       Foreground="#64748B" Margin="0,0,0,2" />
                                            <dxe:ComboBoxEdit Height="28" IsTextEditable="False"
                                                              ItemsSource="{Binding DataContext.FunctionParamSourceTypes,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              EditValue="{Binding SourceType}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Field / System key" FontSize="10"
                                                       Foreground="#64748B" Margin="0,0,0,2" />
                                            <dxe:TextEdit Height="28" FontFamily="Consolas" FontSize="11"
                                                          Text="{Binding FieldRef, UpdateSourceTrigger=PropertyChanged}"
                                                          NullText="VD: NgayVaoLam" />
                                        </StackPanel>
                                        <Button Grid.Column="5" Content="✕" Width="24" Height="24"
                                                FontSize="12" Foreground="#EF4444"
                                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.RemoveFunctionParamCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Panel: SQL tùy chỉnh -->
                <StackPanel Visibility="{Binding IsSqlMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="SELECT SQL tùy chỉnh" FontSize="11"
                               Foreground="#64748B" Margin="0,0,0,3" />
                    <dxe:TextEdit Text="{Binding FkSelectSql, UpdateSourceTrigger=PropertyChanged}"
                                  Height="100" AcceptsReturn="True" Margin="0,0,0,4"
                                  FontFamily="Consolas" FontSize="11"
                                  NullText="SELECT id, name, parent_id FROM ... WHERE Tenant_Id = @TenantId" />
                    <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75">
                        <Run Text="Tham số hệ thống: " />
                        <Run Text="@TenantId  @Today  @CurrentUser" FontFamily="Consolas" Foreground="#059669" />
                    </TextBlock>
                </StackPanel>

                <!-- Order By -->
                <TextBlock Text="Sắp xếp (ORDER BY)" FontSize="11" Foreground="#64748B"
                           Margin="0,12,0,3" />
                <dxe:TextEdit Text="{Binding FkOrderBy, UpdateSourceTrigger=PropertyChanged}"
                              Height="32" NullText="VD: Order_No ASC, Ten_PhongBan ASC" />
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             SECTION 2 — Cấu hình cây (Tree Config)
             ══════════════════════════════════════════════════════ -->
        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Cấu hình cây (Tree Config)" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,6" />
                <Border Background="#EFF6FF" CornerRadius="6" Padding="10,6"
                        Margin="0,0,0,14" BorderBrush="#BFDBFE" BorderThickness="1">
                    <TextBlock FontSize="10" Foreground="#1E40AF" TextWrapping="Wrap">
                        <Run Text="Dữ liệu nguồn phải là bảng phẳng (flat table) — engine sẽ build cây dựa vào cột ParentId." />
                        <LineBreak />
                        <Run Text="Node gốc = các row có ParentId IS NULL hoặc khớp TreeRootFilter." />
                    </TextBlock>
                </Border>

                <!-- TreeParentColumn + TreeRootFilter -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cột ParentId" FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,3" FontWeight="SemiBold" />
                        <dxe:TextEdit Text="{Binding TreeParentColumn, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32" NullText="VD: Parent_Id" FontFamily="Consolas" />
                        <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,3,0,0"
                                   Text="Tên cột chứa ParentId trong bảng nguồn." />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Filter node gốc (TreeRootFilter)" FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,3" FontWeight="SemiBold" />
                        <dxe:TextEdit Text="{Binding TreeRootFilter, UpdateSourceTrigger=PropertyChanged}"
                                      Height="32" NullText="VD: Parent_Id IS NULL" FontFamily="Consolas" />
                        <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,3,0,0"
                                   Text="WHERE clause xác định node gốc. Để trống = ParentId IS NULL." />
                    </StackPanel>
                </Grid>

                <!-- TreeSelectableLevel + TreeLoadMode -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Node được phép chọn" FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,3" FontWeight="SemiBold" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding TreeSelectableLevelOptions}"
                                          EditValue="{Binding TreeSelectableLevel}"
                                          IsTextEditable="False" Height="32" Margin="0,0,0,4" />
                        <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" TextWrapping="Wrap">
                            <Run Text="all" FontFamily="Consolas" />
                            <Run Text=" = tất cả  |  " />
                            <Run Text="leaf" FontFamily="Consolas" />
                            <Run Text=" = chỉ node lá  |  " />
                            <Run Text="branch" FontFamily="Consolas" />
                            <Run Text=" = chỉ node cha" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Chế độ load dữ liệu" FontSize="11" Foreground="#64748B"
                                   Margin="0,0,0,3" FontWeight="SemiBold" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding TreeLoadModeOptions}"
                                          EditValue="{Binding TreeLoadMode}"
                                          IsTextEditable="False" Height="32" Margin="0,0,0,4" />
                        <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" TextWrapping="Wrap">
                            <Run Text="all_at_once" FontFamily="Consolas" />
                            <Run Text=" = load toàn bộ  |  " />
                            <Run Text="lazy" FontFamily="Consolas" />
                            <Run Text=" = load từng level" />
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             SECTION 3 — Cascading Reload
             ══════════════════════════════════════════════════════ -->
        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Cascading Reload" FontSize="13" FontWeight="SemiBold"
                           Foreground="#1E293B" Margin="0,0,0,14" />

                <TextBlock Text="Tự reload khi field thay đổi" FontSize="11" FontWeight="SemiBold"
                           Foreground="#374151" Margin="0,0,0,6" />
                <dxe:TextEdit Text="{Binding ReloadTriggerFields, UpdateSourceTrigger=PropertyChanged}"
                              Height="32" NullText="VD: ProvinceId  hoặc  ProvinceId,DistrictId" />
                <TextBlock FontSize="10" Foreground="#64748B" Opacity="0.75" Margin="0,4,0,0"
                           TextWrapping="Wrap">
                    <Run Text="Khi bất kỳ field nào trong danh sách thay đổi → xóa giá trị + reload data source." />
                    <LineBreak />
                    <Run Text="Nhiều field: phân cách dấu phẩy, không cần khoảng trắng. Để trống = không cascading." />
                </TextBlock>

                <!-- Ví dụ cascading -->
                <Border Background="#F0FDF4" CornerRadius="6" Padding="10,8"
                        Margin="0,12,0,0" BorderBrush="#BBF7D0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#166534"
                                   Text="Ví dụ: TreePicker + Cascading" Margin="0,0,0,4" />
                        <TextBlock FontSize="10" Foreground="#166534" TextWrapping="Wrap">
                            <Run Text="• Field tỉnh/thành:" FontFamily="Consolas" />
                            <Run Text=" TreePicker, load DM_TinhThanh (không trigger)" />
                            <LineBreak />
                            <Run Text="• Field quận/huyện:" FontFamily="Consolas" />
                            <Run Text=" TreePicker, ReloadTriggerFields = " />
                            <Run Text="TinhThanhId" FontFamily="Consolas" Foreground="#059669" />
                            <LineBreak />
                            <Run Text="• Khi user chọn tỉnh → quận/huyện tự reload + clear." />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════
             SECTION 4 — Kiểm tra & Diễn giải
             ══════════════════════════════════════════════════════ -->
        <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <TextBlock DockPanel.Dock="Left" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" VerticalAlignment="Center"
                               Text="Kiểm tra &amp; Diễn giải cấu hình" />
                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                            Command="{Binding ExplainConfigCommand}"
                            Height="26" Padding="10,0" FontSize="11"
                            Foreground="#1D4ED8" Background="Transparent"
                            BorderBrush="#1D4ED8" BorderThickness="1" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶ " FontSize="10" />
                            <TextBlock Text="Diễn giải" />
                        </StackPanel>
                    </Button>
                </DockPanel>
                <TextBlock FontSize="11" Foreground="#64748B" Margin="0,0,0,8"
                           Text="Bấm Diễn giải để kiểm tra toàn bộ cấu hình bằng tiếng Việt trước khi lưu." />

                <Border Visibility="{Binding HasConfigExplanation, Converter={StaticResource BoolToVis}}"
                        Background="#F8FAFC" CornerRadius="6" Padding="12"
                        BorderBrush="#E2E8F0" BorderThickness="1">
                    <TextBox Text="{Binding ConfigExplanation, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Cascadia Code, Consolas" FontSize="11"
                             Foreground="#1E293B"
                             Background="Transparent" BorderThickness="0"
                             TextWrapping="Wrap" AcceptsReturn="True" />
                </Border>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
