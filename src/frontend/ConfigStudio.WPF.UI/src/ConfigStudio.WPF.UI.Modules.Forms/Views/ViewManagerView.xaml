<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.ViewManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="760"
             d:DesignWidth="1280"
             mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Tập giá trị literal cho combo trong lưới con -->
        <x:Array x:Key="RenderModes" Type="sys:String">
            <sys:String>Text</sys:String>
            <sys:String>Html</sys:String>
            <sys:String>Image</sys:String>
            <sys:String>Link</sys:String>
            <sys:String>Badge</sys:String>
            <sys:String>Boolean</sys:String>
            <sys:String>Template</sys:String>
        </x:Array>
        <x:Array x:Key="ColumnKinds" Type="sys:String">
            <sys:String>Data</sys:String>
            <sys:String>Selection</sys:String>
            <sys:String>Command</sys:String>
            <sys:String>TreeSpin</sys:String>
        </x:Array>
        <x:Array x:Key="TextAligns" Type="sys:String">
            <sys:String>left</sys:String>
            <sys:String>center</sys:String>
            <sys:String>right</sys:String>
        </x:Array>
        <x:Array x:Key="FixedPositions" Type="sys:String">
            <sys:String>none</sys:String>
            <sys:String>left</sys:String>
            <sys:String>right</sys:String>
        </x:Array>
        <x:Array x:Key="SortOrders" Type="sys:String">
            <x:Static Member="sys:String.Empty" />
            <sys:String>asc</sys:String>
            <sys:String>desc</sys:String>
        </x:Array>
        <x:Array x:Key="SummaryTypes" Type="sys:String">
            <sys:String>count</sys:String>
            <sys:String>sum</sys:String>
            <sys:String>avg</sys:String>
            <sys:String>min</sys:String>
            <sys:String>max</sys:String>
        </x:Array>
        <x:Array x:Key="ActionTypes" Type="sys:String">
            <sys:String>BuiltIn</sys:String>
            <sys:String>Export</sys:String>
            <sys:String>Print</sys:String>
            <sys:String>Navigate</sys:String>
            <sys:String>Event</sys:String>
            <sys:String>Api</sys:String>
        </x:Array>
        <x:Array x:Key="ActionScopes" Type="sys:String">
            <sys:String>Toolbar</sys:String>
            <sys:String>Row</sys:String>
            <sys:String>Both</sys:String>
        </x:Array>
        <x:Array x:Key="ExportEngines" Type="sys:String">
            <sys:String>Grid</sys:String>
            <sys:String>Server</sys:String>
        </x:Array>

        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────── -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="Quản Lý View (Grid / Tree Grid)"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                        <TextBlock Text="Cấu hình hiển thị danh sách metadata-driven: nguồn dữ liệu, cột, hành vi, export/print"
                                   FontSize="12" Opacity="0.6" Margin="0,2,0,0"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <dx:SimpleButton Command="{Binding RefreshCommand}" ToolTip="Làm mới (F5)"
                                         Width="32" Height="32" Content="↻" FontSize="16" />
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <dxe:TextEdit Width="340"
                                  NullText="Tìm theo View_Code, View_Type, Table_Code..."
                                  EditValue="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,12,0" />
                    <dxe:CheckEdit Content="Hiện cả View ẩn (inactive)"
                                   IsChecked="{Binding ShowInactive}"
                                   VerticalAlignment="Center" Margin="0,0,12,0" />
                    <Border Background="#EEF5FF" BorderBrush="#DCEAFE" BorderThickness="1"
                            CornerRadius="4" Padding="10,5">
                        <TextBlock FontSize="12" Foreground="#1E3A8A" FontWeight="SemiBold"
                                   Text="{Binding TenantId, Mode=OneWay, StringFormat=Tenant_Id: {0}}" />
                    </Border>
                </StackPanel>

                <Border Grid.Row="2" Margin="0,10,0,0" Padding="10,8"
                        Background="#FEE2E2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="6"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding LoadErrorMessage}" Foreground="#991B1B"
                                   FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- ── Master-detail ───────────────────────────────── -->
        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" MinWidth="280" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1.6*" MinWidth="420" />
            </Grid.ColumnDefinitions>

            <!-- Thanh kéo co giãn 2 panel -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="Transparent"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          Cursor="SizeWE" ToolTip="Kéo để chỉnh độ rộng 2 bên">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}">
                            <Border Width="2" HorizontalAlignment="Center" CornerRadius="1"
                                    Background="#CBD5E1" />
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Lưới danh sách View -->
            <Border Grid.Column="0" BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                <dxg:GridControl ItemsSource="{Binding ViewsView}"
                                 SelectedItem="{Binding SelectedView, Mode=TwoWay}"
                                 AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                       AllowEditing="False" AllowPerPixelScrolling="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn Header="Id" FieldName="ViewId" Width="50" />
                        <dxg:GridColumn Header="View_Code" FieldName="ViewCode" Width="*" />
                        <dxg:GridColumn Header="Type" FieldName="ViewType" Width="80" />
                        <dxg:GridColumn Header="Bảng" FieldName="TableCode" Width="120" />
                        <dxg:GridColumn Header="Active" FieldName="IsActive" Width="60" />
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </Border>

            <!-- Editor -->
            <Border Grid.Column="2" BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6"
                    Background="#FCFDFF">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding EditorTitle}"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />

                    <dx:DXTabControl Grid.Row="1">
                        <!-- TAB 1: Cơ bản & nguồn -->
                        <dx:DXTabItem Header="Cơ bản">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                                <StackPanel>
                                    <!-- 1. View_Type — chọn trước vì quyết định tiền tố View_Code -->
                                    <TextBlock Text="① View_Type * (quyết định tiền tố View_Code)" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding ViewTypeOptions}"
                                                      EditValue="{Binding EditViewType}"
                                                      IsTextEditable="False" Margin="0,0,0,10" />

                                    <!-- 2. View_Code = {View_Type}_ + phần user nhập -->
                                    <TextBlock Text="② View_Code * (tự ghép: {View_Type}_ + phần bạn nhập)" Style="{StaticResource EditorLabel}" />
                                    <DockPanel Margin="0,0,0,2">
                                        <Border DockPanel.Dock="Left" Background="#EEF2FF" BorderBrush="#C7D2FE"
                                                BorderThickness="1,1,0,1" CornerRadius="3,0,0,3" Padding="9,0">
                                            <TextBlock Text="{Binding ViewCodePrefix}" VerticalAlignment="Center"
                                                       FontWeight="SemiBold" Foreground="#3730A3" />
                                        </Border>
                                        <dxe:TextEdit EditValue="{Binding EditViewCodeSuffix, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="VD: TrinhDoVanHoa, KhachHang" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding EditViewCode, StringFormat=→ View_Code: {0}}"
                                               FontSize="11" Opacity="0.6" Margin="2,0,0,10" />

                                    <!-- 3. Bảng nguồn -->
                                    <TextBlock Text="③ Bảng nguồn (Table) *" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding Tables}"
                                                      DisplayMember="DisplayText"
                                                      SelectedItem="{Binding EditTable}"
                                                      IsTextEditable="False"
                                                      NullText="Chọn bảng..." Margin="0,0,0,10" />

                                    <!-- 4. Nguồn nâng cao (khi ≠ Table) -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Source_Type" Style="{StaticResource EditorLabel}" />
                                            <dxe:ComboBoxEdit Width="120" ItemsSource="{Binding SourceTypeOptions}"
                                                              EditValue="{Binding EditSourceType}" IsTextEditable="False" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Source_Object (view/SP/SQL/endpoint khi ≠ Table)" Style="{StaticResource EditorLabel}" />
                                            <dxe:TextEdit EditValue="{Binding EditSourceObject, UpdateSourceTrigger=PropertyChanged}"
                                                          NullText="Để trống khi Source_Type = Table" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Title_Key (i18n tiêu đề màn)" Style="{StaticResource EditorLabel}" />
                                    <DockPanel Margin="0,0,0,10">
                                        <dx:SimpleButton DockPanel.Dock="Right" Content="🌐 Dịch" Width="64" Margin="6,0,0,0"
                                                         Command="{Binding OpenTitleI18nCommand}"
                                                         ToolTip="Tạo/sửa bản dịch Title_Key (tự sinh key theo convention nếu trống)" />
                                        <dxe:TextEdit EditValue="{Binding EditTitleKey, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="VD: khach_hang.view.grid.title" />
                                    </DockPanel>

                                    <TextBlock Text="Form Thêm/Sửa (Edit_Form — null = chỉ đọc)" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding Forms}" DisplayMember="FormCode"
                                                      SelectedItem="{Binding EditEditForm}"
                                                      NullText="Không gắn form sửa" Margin="0,0,0,10" />

                                    <dxe:CheckEdit Content="Is_Active (View đang dùng)" IsChecked="{Binding EditIsActive}"
                                                   Margin="0,0,0,10" />

                                    <TextBlock Text="Description" Style="{StaticResource EditorLabel}" />
                                    <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" MinHeight="70" Padding="8"
                                             BorderBrush="#D5DEED" BorderThickness="1" />
                                </StackPanel>
                            </ScrollViewer>
                        </dx:DXTabItem>

                        <!-- TAB 2: Hành vi lưới -->
                        <dx:DXTabItem Header="Hành vi">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Page_Size" Style="{StaticResource EditorLabel}" />
                                            <dxe:SpinEdit Width="120" EditValue="{Binding EditPageSize}"
                                                          MinValue="1" MaxValue="1000" MaskUseAsDisplayFormat="True" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Selection_Mode" Style="{StaticResource EditorLabel}" />
                                            <dxe:ComboBoxEdit Width="160" HorizontalAlignment="Left"
                                                              ItemsSource="{Binding SelectionModeOptions}"
                                                              EditValue="{Binding EditSelectionMode}" IsTextEditable="False" />
                                        </StackPanel>
                                    </Grid>

                                    <dxe:CheckEdit Content="Allow_Paging — phân trang" IsChecked="{Binding EditAllowPaging}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Virtual_Scroll — cuộn ảo" IsChecked="{Binding EditVirtualScroll}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Show_Filter_Row — dòng lọc" IsChecked="{Binding EditShowFilterRow}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Show_Group_Panel — panel nhóm" IsChecked="{Binding EditShowGroupPanel}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Show_Search_Box — ô tìm kiếm" IsChecked="{Binding EditShowSearchBox}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Show_Column_Chooser — chọn cột" IsChecked="{Binding EditShowColumnChooser}" Margin="0,2" />

                                    <Border Height="1" Background="#E2E8F0" Margin="0,10" />
                                    <TextBlock Text="Quyền CRUD trên lưới" Style="{StaticResource EditorLabel}" />
                                    <dxe:CheckEdit Content="Allow_Add — cho thêm mới" IsChecked="{Binding EditAllowAdd}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Allow_Edit — cho sửa" IsChecked="{Binding EditAllowEdit}" Margin="0,2" />
                                    <dxe:CheckEdit Content="Allow_Delete — cho xóa" IsChecked="{Binding EditAllowDelete}" Margin="0,2" />
                                </StackPanel>
                            </ScrollViewer>
                        </dx:DXTabItem>

                        <!-- TAB 3: Export / Print -->
                        <dx:DXTabItem Header="Export / Print">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                                <StackPanel>
                                    <dxe:CheckEdit Content="Allow_Export — cho xuất file" IsChecked="{Binding EditAllowExport}" Margin="0,2,0,10" />

                                    <TextBlock Text="Export_Formats (vd: xlsx,csv,pdf,docx)" Style="{StaticResource EditorLabel}" />
                                    <dxe:TextEdit EditValue="{Binding EditExportFormats, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="xlsx,csv" Margin="0,0,0,10" />

                                    <TextBlock Text="Export_File_Name_Key (i18n — null = View_Code)" Style="{StaticResource EditorLabel}" />
                                    <DockPanel Margin="0,0,0,10">
                                        <dx:SimpleButton DockPanel.Dock="Right" Content="🌐 Dịch" Width="64" Margin="6,0,0,0"
                                                         Command="{Binding OpenExportFileNameI18nCommand}"
                                                         ToolTip="Tạo/sửa bản dịch tên file xuất (tự sinh key nếu trống)" />
                                        <dxe:TextEdit EditValue="{Binding EditExportFileNameKey, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="VD: khach_hang.view.export.filename" />
                                    </DockPanel>

                                    <dxe:CheckEdit Content="Allow_Print — cho in" IsChecked="{Binding EditAllowPrint}" Margin="0,2" />

                                    <Border Background="#F0F9FF" BorderBrush="#BAE6FD" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#0369A1">
                                            xlsx/csv xuất client-side qua DxGrid; pdf/docx xuất server-side theo template.
                                            Export luôn lấy giá trị thuần (bỏ Render_Mode). Chi tiết nút xuất khai báo ở tab Actions.
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </dx:DXTabItem>

                        <!-- TAB 4: TreeList -->
                        <dx:DXTabItem Header="Cây (TreeList)">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,8,0">
                                <StackPanel>
                                    <Border Background="#FEF9C3" BorderBrush="#FDE68A" BorderThickness="1"
                                            CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                                            Visibility="{Binding IsTreeList, Converter={StaticResource BoolToVis}}">
                                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#854D0E"
                                                   Text="View_Type = TreeList — khai báo cột khóa, cột cha và cấp mở sẵn để dựng cây." />
                                    </Border>
                                    <TextBlock Text="Key_Field — cột khóa" Style="{StaticResource EditorLabel}" />
                                    <dxe:TextEdit EditValue="{Binding EditKeyField, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="VD: Id" Margin="0,0,0,10" />
                                    <TextBlock Text="Parent_Field — cột cha (hierarchy)" Style="{StaticResource EditorLabel}" />
                                    <dxe:TextEdit EditValue="{Binding EditParentField, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="VD: ParentId" Margin="0,0,0,10" />
                                    <TextBlock Text="Expand_Level — mở sẵn tới cấp" Style="{StaticResource EditorLabel}" />
                                    <dxe:SpinEdit Width="120" HorizontalAlignment="Left"
                                                  EditValue="{Binding EditExpandLevel}" MinValue="0" MaxValue="20" />
                                </StackPanel>
                            </ScrollViewer>
                        </dx:DXTabItem>

                        <!-- TAB 5: Cột -->
                        <dx:DXTabItem Header="Cột">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <dx:SimpleButton Command="{Binding AddColumnCommand}" Content="+ Thêm cột" Margin="0,0,8,0" />
                                    <dx:SimpleButton Command="{Binding RemoveColumnCommand}" Content="− Xóa cột" Margin="0,0,8,0" />
                                    <dx:SimpleButton Command="{Binding MoveColumnUpCommand}" Content="↑" Width="32" Margin="0,0,4,0" />
                                    <dx:SimpleButton Command="{Binding MoveColumnDownCommand}" Content="↓" Width="32" Margin="0,0,12,0" />
                                    <dx:SimpleButton Command="{Binding BrowseColumnCommand}" Content="🔍 Chọn cột" Margin="0,0,8,0"
                                                     ToolTip="Chọn cột từ Sys_Column của bảng nguồn" />
                                    <dx:SimpleButton Command="{Binding OpenColumnCaptionI18nCommand}" Content="🌐 Dịch caption"
                                                     ToolTip="Tạo/sửa bản dịch Caption_Key cho cột đang chọn" />
                                </StackPanel>
                                <dxg:GridControl Grid.Row="1" ItemsSource="{Binding EditColumns}"
                                                 SelectedItem="{Binding SelectedColumn, Mode=TwoWay}"
                                                 AutoGenerateColumns="None">
                                    <dxg:GridControl.View>
                                        <dxg:TableView NavigationStyle="Cell" ShowGroupPanel="False"
                                                       AllowEditing="True" AllowPerPixelScrolling="True"
                                                       NewItemRowPosition="None" />
                                    </dxg:GridControl.View>
                                    <dxg:GridControl.Columns>
                                        <dxg:GridColumn Header="Field_Name *" FieldName="FieldName" Width="130" />
                                        <dxg:GridColumn Header="Caption (i18n)" FieldName="CaptionKey" Width="170" AllowEditing="False">
                                            <dxg:GridColumn.CellTemplate>
                                                <DataTemplate>
                                                    <DockPanel LastChildFill="True">
                                                        <dx:SimpleButton DockPanel.Dock="Right" Content="🌐" Width="26" Padding="0"
                                                                         ToolTip="Dịch / tạo key caption (i18n)"
                                                                         Command="{Binding DataContext.OpenColumnCaptionI18nRowCommand,
                                                                                   RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                                         CommandParameter="{Binding RowData.Row}" />
                                                        <TextBlock Text="{Binding RowData.Row.CaptionKey}" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" Margin="2,0"
                                                                   ToolTip="{Binding RowData.Row.CaptionKey}" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </dxg:GridColumn.CellTemplate>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Kind" FieldName="ColumnKind" Width="90">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource ColumnKinds}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Render" FieldName="RenderMode" Width="90">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource RenderModes}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Width" FieldName="Width" Width="70" />
                                        <dxg:GridColumn Header="MinWidth" FieldName="MinWidth" Width="70" />
                                        <dxg:GridColumn Header="Align" FieldName="TextAlign" Width="80">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource TextAligns}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Ghim" FieldName="FixedPosition" Width="70"
                                                        ToolTip="Đóng băng cột: none / left / right">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource FixedPositions}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Format" FieldName="DisplayFormat" Width="80" />
                                        <dxg:GridColumn Header="Visible" FieldName="IsVisible" Width="60" />
                                        <dxg:GridColumn Header="Sort" FieldName="AllowSort" Width="55" />
                                        <dxg:GridColumn Header="SortMặc định" FieldName="SortOrder" Width="80"
                                                        ToolTip="Sắp xếp mặc định khi mở: asc / desc (trống = không)">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource SortOrders}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="SortIdx" FieldName="SortIndex" Width="60"
                                                        ToolTip="Thứ tự ưu tiên khi sort nhiều cột (trống = không tham gia)" />
                                        <dxg:GridColumn Header="Filter" FieldName="AllowFilter" Width="55" />
                                        <dxg:GridColumn Header="Group" FieldName="AllowGroup" Width="55" />
                                        <dxg:GridColumn Header="Summary" FieldName="SummaryType" Width="80">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource SummaryTypes}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Export" FieldName="AllowExport" Width="60" />
                                        <dxg:GridColumn Header="Order" FieldName="OrderNo" Width="55" AllowEditing="False" />
                                    </dxg:GridControl.Columns>
                                </dxg:GridControl>
                            </Grid>
                        </dx:DXTabItem>

                        <!-- TAB 6: Actions -->
                        <dx:DXTabItem Header="Actions">
                            <Grid Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <dx:SimpleButton Command="{Binding AddActionCommand}" Content="+ Thêm action" Margin="0,0,8,0" />
                                    <dx:SimpleButton Command="{Binding RemoveActionCommand}" Content="− Xóa action" Margin="0,0,12,0" />
                                    <dx:SimpleButton Command="{Binding OpenActionLabelI18nCommand}" Content="🌐 Dịch nhãn"
                                                     ToolTip="Tạo/sửa bản dịch Label_Key cho action đang chọn" />
                                </StackPanel>
                                <dxg:GridControl Grid.Row="1" ItemsSource="{Binding EditActions}"
                                                 SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                                                 AutoGenerateColumns="None">
                                    <dxg:GridControl.View>
                                        <dxg:TableView NavigationStyle="Cell" ShowGroupPanel="False"
                                                       AllowEditing="True" AllowPerPixelScrolling="True"
                                                       NewItemRowPosition="None" />
                                    </dxg:GridControl.View>
                                    <dxg:GridControl.Columns>
                                        <dxg:GridColumn Header="Action_Code *" FieldName="ActionCode" Width="110" />
                                        <dxg:GridColumn Header="Type" FieldName="ActionType" Width="90">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource ActionTypes}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Scope" FieldName="Scope" Width="80">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource ActionScopes}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Label (i18n)" FieldName="LabelKey" Width="160" AllowEditing="False">
                                            <dxg:GridColumn.CellTemplate>
                                                <DataTemplate>
                                                    <DockPanel LastChildFill="True">
                                                        <dx:SimpleButton DockPanel.Dock="Right" Content="🌐" Width="26" Padding="0"
                                                                         ToolTip="Dịch / tạo key nhãn (i18n)"
                                                                         Command="{Binding DataContext.OpenActionLabelI18nRowCommand,
                                                                                   RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                                         CommandParameter="{Binding RowData.Row}" />
                                                        <TextBlock Text="{Binding RowData.Row.LabelKey}" VerticalAlignment="Center"
                                                                   TextTrimming="CharacterEllipsis" Margin="2,0"
                                                                   ToolTip="{Binding RowData.Row.LabelKey}" />
                                                    </DockPanel>
                                                </DataTemplate>
                                            </dxg:GridColumn.CellTemplate>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Icon" FieldName="Icon" Width="60" />
                                        <dxg:GridColumn Header="Export_Format" FieldName="ExportFormat" Width="90" />
                                        <dxg:GridColumn Header="Engine" FieldName="ExportEngine" Width="80">
                                            <dxg:GridColumn.EditSettings>
                                                <dxe:ComboBoxEditSettings ItemsSource="{StaticResource ExportEngines}" />
                                            </dxg:GridColumn.EditSettings>
                                        </dxg:GridColumn>
                                        <dxg:GridColumn Header="Target" FieldName="Target" Width="*" />
                                        <dxg:GridColumn Header="Req_Sel" FieldName="RequireSelection" Width="65" />
                                    </dxg:GridControl.Columns>
                                </dxg:GridControl>
                            </Grid>
                        </dx:DXTabItem>
                    </dx:DXTabControl>

                    <!-- Action buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                        <dx:SimpleButton Command="{Binding SaveCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SaveButtonText}" Margin="6,0,0,0" />
                            </StackPanel>
                        </dx:SimpleButton>
                        <dx:SimpleButton Command="{Binding NewCommand}" Content="Tạo mới" Margin="0,0,8,0" />
                        <dx:SimpleButton Command="{Binding DeactivateCommand}" Content="Ẩn View"
                                         ToolTip="Soft-delete: set Is_Active = 0" />
                    </StackPanel>

                    <!-- Status -->
                    <Border Grid.Row="3" Margin="0,10,0,0" Padding="10,8" CornerRadius="6"
                            Visibility="{Binding HasSaveStatus, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#DCFCE7" />
                                <Setter Property="BorderBrush" Value="#86EFAC" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSaveStatusError}" Value="True">
                                        <Setter Property="Background" Value="#FEE2E2" />
                                        <Setter Property="BorderBrush" Value="#FCA5A5" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SaveStatusMessage}" FontSize="12" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#166534" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSaveStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="#991B1B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Footer ───────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6" Background="#EEF5FF" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock FontSize="12" Opacity="0.6" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hiển thị {0} / {1} View">
                            <Binding Path="FilteredCount" />
                            <Binding Path="TotalViews" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
