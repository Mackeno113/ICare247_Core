<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.PublishChecklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Models"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <DockPanel>
        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Height="52"
                Background="{DynamicResource ShellTitleBarBackgroundBrush}"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <Button DockPanel.Dock="Left"
                        Command="{Binding BackCommand}"
                        ToolTip="Quay lại Form Editor"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="←" FontSize="16" Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Text="Back" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="White" />
                    </StackPanel>
                </Button>

                <TextBlock Text="✅" FontSize="18" Foreground="White"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
                <TextBlock Margin="8,0,0,0" Foreground="White" FontSize="16"
                           FontWeight="SemiBold" VerticalAlignment="Center">
                    <Run Text="Publish Checklist — " />
                    <Run Text="{Binding FormCode, Mode=OneWay}" />
                </TextBlock>

                <Button DockPanel.Dock="Right"
                        Command="{Binding RunAllChecksCommand}"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="White" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="▶" Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Text="Run All Checks" Margin="6,0,0,0"
                                   VerticalAlignment="Center" Foreground="White" />
                    </StackPanel>
                </Button>
            </DockPanel>
        </Border>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Height="60"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" FontSize="14"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <dx:SimpleButton Command="{Binding BackCommand}"
                                     Content="Back to Form Editor" Margin="0,0,8,0" />
                    <dx:SimpleButton Command="{Binding PublishCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" VerticalAlignment="Center" />
                            <TextBlock Text="Publish" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </dx:SimpleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Checklist Items ────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
            <ItemsControl ItemsSource="{Binding ChecklistItems}" Margin="24,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ChecklistItem}">
                        <Border Padding="12,10" Margin="0,0,0,6"
                                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="4"
                                Background="{DynamicResource ShellContentBackgroundBrush}">
                            <DockPanel>
                                <!-- Jump To button -->
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding DataContext.JumpToCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="Jump To"
                                        Padding="8,4" FontSize="12"
                                        ToolTip="Navigate đến editor để sửa lỗi"
                                        Background="Transparent" BorderBrush="Transparent"
                                        Visibility="{Binding IsFailed, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}" />

                                <!-- Status icon -->
                                <TextBlock DockPanel.Dock="Left"
                                           Text="{Binding StatusIcon}"
                                           FontSize="18"
                                           Foreground="{Binding StatusColor}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />

                                <!-- Description + Detail -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Description}" FontSize="14"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <TextBlock Text="{Binding Detail}" FontSize="12"
                                               Foreground="#EF5350" TextWrapping="Wrap"
                                               Margin="0,2,0,0"
                                               Visibility="{Binding Detail, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
