<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.PublishChecklistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Models"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="800"
             mc:Ignorable="d">

    <DockPanel>
        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Height="52"
                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <Button DockPanel.Dock="Left"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" ToolTip="Quay lại Form Editor">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" VerticalAlignment="Center" />
                        <TextBlock Text="Back" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <materialDesign:PackIcon Kind="CheckboxMarkedCircleOutline" Width="24" Height="24"
                                         Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0" />
                <TextBlock Margin="8,0,0,0" Foreground="White" FontSize="16"
                           FontWeight="SemiBold" VerticalAlignment="Center">
                    <Run Text="Publish Checklist — " />
                    <Run Text="{Binding FormCode, Mode=OneWay}" />
                </TextBlock>

                <Button DockPanel.Dock="Right"
                        Command="{Binding RunAllChecksCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="White" Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlayCircleOutline" VerticalAlignment="Center" />
                        <TextBlock Text="Run All Checks" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>
        </Border>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Height="60"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <!-- Summary -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Summary}" FontSize="14"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Actions -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding BackCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="Back to Form Editor" Margin="0,0,8,0" />
                    <Button Command="{Binding PublishCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Publish" VerticalAlignment="Center" />
                            <TextBlock Text="Publish" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── Checklist Items ────────────────────────────────── -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
            <ItemsControl ItemsSource="{Binding ChecklistItems}" Margin="24,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ChecklistItem}">
                        <materialDesign:Card Padding="12,10" Margin="0,0,0,6">
                            <DockPanel>
                                <!-- Jump To button (hiện nếu failed + có JumpToView) -->
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding DataContext.JumpToCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource MaterialDesignFlatButton}"
                                        Content="Jump To"
                                        Padding="8,4" FontSize="12"
                                        ToolTip="Navigate đến editor để sửa lỗi">
                                    <Button.Visibility>
                                        <MultiBinding FallbackValue="Collapsed">
                                            <MultiBinding.Converter>
                                                <StaticResource ResourceKey="BooleanToVisibilityConverter" />
                                            </MultiBinding.Converter>
                                            <Binding Path="IsFailed" />
                                        </MultiBinding>
                                    </Button.Visibility>
                                </Button>

                                <!-- Status icon -->
                                <materialDesign:PackIcon DockPanel.Dock="Left"
                                                         Kind="{Binding StatusIcon}"
                                                         Width="24" Height="24"
                                                         Foreground="{Binding StatusColor}"
                                                         VerticalAlignment="Center"
                                                         Margin="0,0,12,0" />

                                <!-- Description + Detail -->
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Description}" FontSize="14"
                                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                                    <TextBlock Text="{Binding Detail}" FontSize="12"
                                               Foreground="#EF5350" TextWrapping="Wrap"
                                               Margin="0,2,0,0"
                                               Visibility="{Binding Detail, Converter={StaticResource NullableToVisibilityConverter}, FallbackValue=Collapsed}" />
                                </StackPanel>
                            </DockPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
