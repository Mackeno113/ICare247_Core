<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.LookupTemplateManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:text="clr-namespace:ConfigStudio.WPF.UI.Core.Constants;assembly=ConfigStudio.WPF.UI.Core"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="760"
             d:DesignWidth="1280"
             mc:Ignorable="d">
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="StatusBanner" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppDangerSoftBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AppDangerLightBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppAccentDarkBrush}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AppDangerDarkBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ShellContentBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{DynamicResource AppCommandBarHostStyle}">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="{x:Static text:LookupTemplateUiText.ScreenTitle}"
                               FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextBrush}" />
                    <TextBlock Text="{x:Static text:LookupTemplateUiText.ScreenSubtitle}"
                               FontSize="12" Foreground="{DynamicResource AppTextMutedBrush}" />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="{x:Static text:LookupTemplateUiText.Refresh}"
                            Command="{Binding RefreshCommand}"
                            Style="{DynamicResource AppOutlineButtonStyle}"
                            Width="42" Margin="0,0,8,0" />
                    <Button Content="{x:Static text:LookupTemplateUiText.New}"
                            Command="{Binding NewCommand}"
                            Style="{DynamicResource AppActionButtonStyle}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*" MinWidth="330" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1.6*" MinWidth="560" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="{x:Static text:LookupTemplateUiText.ListTitle}"
                           FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource AppTextBrush}" />
                <dxg:GridControl Grid.Row="1" ItemsSource="{Binding Templates}"
                                 SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                                 AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView NavigationStyle="Row" AllowEditing="False" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn Header="{x:Static text:LookupTemplateUiText.TemplateCode}"
                                        FieldName="TemplateCode" Width="150" />
                        <dxg:GridColumn Header="{x:Static text:LookupTemplateUiText.Name}"
                                        FieldName="Ten" Width="*" />
                        <dxg:GridColumn Header="{x:Static text:LookupTemplateUiText.QueryMode}"
                                        FieldName="QueryMode" Width="90" />
                        <dxg:GridColumn Header="{x:Static text:LookupTemplateUiText.Active}"
                                        FieldName="IsActive" Width="75" />
                        <dxg:GridColumn Header="{x:Static text:LookupTemplateUiText.System}"
                                        FieldName="IsSystem" Width="75" />
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </Grid>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          Background="Transparent" />

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="{Binding EditorTitle}" FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,10" Foreground="{DynamicResource AppTextBrush}" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="0,0,8,0">
                        <Border Padding="12,10" Margin="0,0,0,16"
                                Background="{DynamicResource AppAccentSoftBrush}"
                                BorderBrush="{DynamicResource AppAccentLightBrush}"
                                BorderThickness="1" CornerRadius="4">
                            <TextBlock Text="{x:Static text:LookupTemplateUiText.EditorHelp}"
                                       TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource AppAccentDarkBrush}" />
                        </Border>
                        <TextBlock Text="{x:Static text:LookupTemplateUiText.BasicSection}"
                                   Style="{DynamicResource AppSectionTitleStyle}" />
                        <Grid Margin="0,0,0,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.TemplateCode}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditTemplateCode, UpdateSourceTrigger=PropertyChanged}"
                                              IsEnabled="{Binding IsTemplateCodeEditable}"
                                              NullText="TPL_MAU_LOOKUP" />
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.CodeHelp}"
                                           Style="{DynamicResource AppHelpTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.Name}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditTen, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Công ty theo quyền" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,12,0,0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.Description}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditMoTa, UpdateSourceTrigger=PropertyChanged}"
                                              AcceptsReturn="True" TextWrapping="Wrap"
                                              VerticalScrollBarVisibility="Auto" MinHeight="64" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{x:Static text:LookupTemplateUiText.SourceSection}"
                                   Style="{DynamicResource AppSectionTitleStyle}" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.QueryMode}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:ComboBoxEdit ItemsSource="{Binding QueryModeOptions}"
                                                  EditValue="{Binding EditQueryMode, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.SourceName}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditSourceName, UpdateSourceTrigger=PropertyChanged}"
                                              AcceptsReturn="True" TextWrapping="Wrap"
                                              VerticalScrollBarVisibility="Auto" MinHeight="88"
                                              FontFamily="Cascadia Code, Consolas" />
                                <TextBlock Text="{Binding SourceHelpText}"
                                           Style="{DynamicResource AppHelpTextStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{x:Static text:LookupTemplateUiText.ColumnSection}"
                                   Style="{DynamicResource AppSectionTitleStyle}" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.ValueColumn}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditValueColumn, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Id" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.DisplayColumn}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditDisplayColumn, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Ten" />
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.CodeField}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditCodeField, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Ma" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{x:Static text:LookupTemplateUiText.AdvancedSection}"
                                   Style="{DynamicResource AppSectionTitleStyle}" />
                        <Grid Margin="0,0,0,24">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.FilterSql}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditFilterSql, UpdateSourceTrigger=PropertyChanged}"
                                              AcceptsReturn="True" TextWrapping="Wrap"
                                              VerticalScrollBarVisibility="Auto" MinHeight="72"
                                              FontFamily="Cascadia Code, Consolas" />
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.FilterHelp}"
                                           Style="{DynamicResource AppHelpTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.OrderBy}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditOrderBy, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="Ten" />
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.ParentColumn}"
                                           Style="{DynamicResource AppFieldLabelStyle}" Margin="0,12,0,5" />
                                <dxe:TextEdit EditValue="{Binding EditParentColumn, UpdateSourceTrigger=PropertyChanged}"
                                              NullText="CongTy_Cha_Id" />
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.ParentHelp}"
                                           Style="{DynamicResource AppHelpTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,16,0,0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.PopupColumnsJson}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditPopupColumnsJson, UpdateSourceTrigger=PropertyChanged}"
                                              AcceptsReturn="True" TextWrapping="Wrap"
                                              VerticalScrollBarVisibility="Auto" MinHeight="92"
                                              FontFamily="Cascadia Code, Consolas" />
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.PopupHelp}"
                                           Style="{DynamicResource AppHelpTextStyle}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,16,0,0">
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.CanonicalParams}"
                                           Style="{DynamicResource AppFieldLabelStyle}" />
                                <dxe:TextEdit EditValue="{Binding EditCanonicalParams, UpdateSourceTrigger=PropertyChanged}"
                                              AcceptsReturn="True" TextWrapping="Wrap"
                                              VerticalScrollBarVisibility="Auto" MinHeight="92"
                                              FontFamily="Cascadia Code, Consolas" />
                                <TextBlock Text="{x:Static text:LookupTemplateUiText.CanonicalHelp}"
                                           Style="{DynamicResource AppHelpTextStyle}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{x:Static text:LookupTemplateUiText.SyncSection}"
                                   Style="{DynamicResource AppSectionTitleStyle}" />
                        <WrapPanel Margin="0,0,0,16">
                            <dxe:CheckEdit Content="{x:Static text:LookupTemplateUiText.Active}"
                                           IsChecked="{Binding EditIsActive}" Margin="0,0,18,0" />
                            <dxe:CheckEdit Content="{x:Static text:LookupTemplateUiText.System}"
                                           IsChecked="{Binding EditIsSystem, Mode=OneWay}" IsReadOnly="True" Margin="0,0,18,0" />
                            <dxe:CheckEdit Content="{x:Static text:LookupTemplateUiText.Customized}"
                                           IsChecked="{Binding EditIsCustomized, Mode=OneWay}" IsReadOnly="True" />
                        </WrapPanel>
                        <TextBlock Foreground="{DynamicResource AppTextMutedBrush}" FontSize="12">
                            <Run Text="{x:Static text:LookupTemplateUiText.SyncedAt}" />
                            <Run Text=": " />
                            <Run Text="{Binding EditSyncedAt, Mode=OneWay}" />
                            <Run Text=" · " />
                            <Run Text="{x:Static text:LookupTemplateUiText.SourceVer}" />
                            <Run Text=": " />
                            <Run Text="{Binding EditSourceVer, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Margin="0,10,0,0" Padding="10,8"
                        Style="{StaticResource StatusBanner}"
                        Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                               Style="{StaticResource StatusText}" />
                </Border>

                <DockPanel Grid.Row="3" Margin="0,12,0,0">
                    <Button DockPanel.Dock="Left" Content="{x:Static text:LookupTemplateUiText.Delete}"
                            Command="{Binding DeleteCommand}"
                            Style="{DynamicResource AppOutlineButtonStyle}"
                            Foreground="{DynamicResource AppDangerBrush}" />
                    <Button DockPanel.Dock="Right" Content="{x:Static text:LookupTemplateUiText.Save}"
                            Command="{Binding SaveCommand}"
                            Style="{DynamicResource AppActionButtonStyle}" />
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
