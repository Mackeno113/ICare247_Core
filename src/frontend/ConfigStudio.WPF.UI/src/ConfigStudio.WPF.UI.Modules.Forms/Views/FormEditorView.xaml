<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FormEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Models"
             xmlns:conv="clr-namespace:ConfigStudio.WPF.UI.Core.Converters;assembly=ConfigStudio.WPF.UI.Core"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppPageBackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveFormCommand}" />
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding UndoCommand}" />
        <KeyBinding Modifiers="Control" Key="Y" Command="{Binding RedoCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisConverter x:Key="InvBoolToVis" />

        <!-- ── Color Palette ────────────────────────────────── -->
        <Color x:Key="AccentColor">#3B82F6</Color>
        <Color x:Key="AccentDarkColor">#1D4ED8</Color>
        <Color x:Key="AccentLightColor">#DBEAFE</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="MutedColor">#64748B</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="SuccessColor">#22C55E</Color>

        <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush"   Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="AccentLightBrush"  Color="{StaticResource AccentLightColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"      Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="MutedBrush"         Color="{StaticResource MutedColor}" />
        <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="DangerBrush"        Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="SuccessBrush"       Color="{StaticResource SuccessColor}" />

        <!-- ── Shadows ──────────────────────────────────────── -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="1"
                          Direction="270" Opacity="0.08" Color="{DynamicResource AppTextStrongColor}" />
        <DropShadowEffect x:Key="ElevatedShadow" BlurRadius="16" ShadowDepth="2"
                          Direction="270" Opacity="0.12" Color="{DynamicResource AppTextStrongColor}" />

        <!-- ── Form Label ───────────────────────────────────── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin"     Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ── Help Text dưới mỗi field ─────────────────────── -->
        <Style x:Key="HelpTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11" />
            <Setter Property="Foreground"  Value="{StaticResource MutedBrush}" />
            <Setter Property="Opacity"     Value="0.75" />
            <Setter Property="Margin"      Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ── Field Group ──────────────────────────────────── -->
        <Style x:Key="FieldGroupStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <!-- ── Readonly Value ───────────────────────────────── -->
        <Style x:Key="ReadonlyValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13" />
            <Setter Property="FontFamily"   Value="Cascadia Code, Consolas, monospace" />
            <Setter Property="Foreground"   Value="{StaticResource MutedBrush}" />
            <Setter Property="Background"   Value="{DynamicResource AppSurfaceMutedBrush}" />
            <Setter Property="Padding"      Value="10,8" />
        </Style>

        <!-- ── Section Card ─────────────────────────────────── -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="8" />
            <Setter Property="Padding"          Value="20,16" />
            <Setter Property="Margin"           Value="0,0,0,12" />
            <Setter Property="Effect"           Value="{StaticResource CardShadow}" />
        </Style>

        <!-- ── Section Title ────────────────────────────────── -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Margin"     Value="0,0,0,14" />
        </Style>

        <!-- ── Tab Badge ────────────────────────────────────── -->
        <Style x:Key="TabBadgeStyle" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource AccentLightBrush}" />
            <Setter Property="CornerRadius"  Value="10" />
            <Setter Property="Padding"       Value="7,2" />
            <Setter Property="Margin"        Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Icon Button (toolbar) ────────────────────────── -->
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width"           Value="32" />
            <Setter Property="Height"          Value="32" />
            <Setter Property="Margin"          Value="1,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Foreground"      Value="{DynamicResource AppTextSecondaryBrush}" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                ToolTip="{TemplateBinding ToolTip}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Inline Action Button ─────────────────────────── -->
        <Style x:Key="InlineBtnStyle" TargetType="Button" BasedOn="{StaticResource IconBtnStyle}">
            <Setter Property="Width"    Value="28" />
            <Setter Property="Height"   Value="28" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <!-- ── Inline Delete Button ─────────────────────────── -->
        <Style x:Key="InlineDeleteBtnStyle" TargetType="Button" BasedOn="{StaticResource InlineBtnStyle}">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppDangerSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Toolbar Separator ────────────────────────────── -->
        <Style x:Key="ToolbarSeparatorStyle" TargetType="Border">
            <Setter Property="Width"           Value="1" />
            <Setter Property="Background"      Value="{StaticResource BorderBrush}" />
            <Setter Property="Margin"          Value="6,6" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0: Header Bar — back + title + actions
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <DockPanel>
                <!-- ← Back button -->
                <Button DockPanel.Dock="Left" Command="{Binding BackToListCommand}"
                        ToolTip="Quay lại danh sách form"
                        Style="{StaticResource IconBtnStyle}"
                        Width="36" Height="36">
                    <TextBlock Text="←" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MutedBrush}" />
                </Button>

                <!-- Accent divider bar -->
                <Border DockPanel.Dock="Left" Width="3" Height="28"
                        Background="{StaticResource AccentBrush}" CornerRadius="2"
                        Margin="12,0,14,0" VerticalAlignment="Center" />

                <!-- Title area -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <!-- Create mode -->
                    <TextBlock Text="Tạo Form Mới"
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextStrongBrush}"
                               Visibility="{Binding IsNewForm, Converter={StaticResource BoolToVis}}" />
                    <!-- Edit mode -->
                    <TextBlock Text="{Binding FormName}"
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppTextStrongBrush}"
                               Visibility="{Binding IsNewForm, Converter={StaticResource InvBoolToVis}}" />
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0"
                                Visibility="{Binding IsNewForm, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Text="{Binding FormCode}"
                                   FontSize="12" FontFamily="Cascadia Code, Consolas"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="  ·  v" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding Version}" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="  ·  " FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <Border Background="{DynamicResource AppSuccessSoftBrush}" CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Platform}" FontSize="11"
                                       Foreground="{DynamicResource AppSuccessBrush}" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Dirty indicator -->
                <Border DockPanel.Dock="Left" Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}">
                    <Border Style="{DynamicResource AppDirtyIndicatorPillStyle}">
                        <TextBlock Text="Chưa lưu" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppWarningBrush}" />
                    </Border>
                </Border>

                <!-- Right-aligned action buttons -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Nút Lưu — chế độ tạo mới (INSERT): nhãn đồng nhất "Lưu" -->
                    <dx:SimpleButton Command="{Binding CreateNewFormCommand}" Margin="0,0,8,0"
                                     Visibility="{Binding IsNewForm, Converter={StaticResource BoolToVis}}"
                                     IsEnabled="{Binding CanCreateNewForm}"
                                     ToolTip="Lưu form mới. Cần nhập Form_Code, Form_Name và chọn Business Table."
                                     Height="34" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" VerticalAlignment="Center" FontSize="13" />
                            <TextBlock Text="Lưu" Margin="6,0,0,0"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </dx:SimpleButton>

                    <!-- Chế độ sửa (UPDATE): KHÔNG nút Lưu — auto-save toàn cục. Dải chỉ báo trạng thái. -->
                    <Border Margin="0,0,8,0" Padding="12,0" Height="34" CornerRadius="6"
                            VerticalAlignment="Center"
                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                            Visibility="{Binding IsNewForm, Converter={StaticResource InvBoolToVis}}"
                            ToolTip="Mọi thay đổi tự lưu. Nhấn Ctrl+S để lưu ngay.">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="💾" VerticalAlignment="Center" FontSize="13" />
                            <TextBlock Text="{Binding SaveStatusText}" Margin="6,0,0,0"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <dx:SimpleButton Command="{Binding ViewDependenciesCommand}"
                                     Margin="0,0,6,0" ToolTip="Xem biểu đồ phụ thuộc"
                                     Height="34" Padding="12,0">
                        <TextBlock Text="Dependencies" FontSize="12" />
                    </dx:SimpleButton>

                    <dx:SimpleButton Command="{Binding PublishCommand}"
                                     Height="34" Padding="16,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" VerticalAlignment="Center" FontSize="11" />
                            <TextBlock Text="Publish" Margin="6,0,0,0" FontWeight="SemiBold" />
                        </StackPanel>
                    </dx:SimpleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1: Toolbar — structure editing
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{DynamicResource AppCommandBarHostStyle}">
            <StackPanel Orientation="Horizontal">
                <dx:SimpleButton Command="{Binding AddSectionCommand}" Height="28"
                                 Padding="10,0" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Section" Margin="5,0,0,0" FontSize="12" />
                    </StackPanel>
                </dx:SimpleButton>

                <dx:SimpleButton Command="{Binding AddFieldCommand}" Height="28"
                                 Padding="10,0" Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="＋" FontSize="13" VerticalAlignment="Center"
                                   FontWeight="Bold" />
                        <TextBlock Text="Field" Margin="5,0,0,0" FontSize="12" />
                    </StackPanel>
                </dx:SimpleButton>

                <Border Style="{StaticResource ToolbarSeparatorStyle}" />

                <Button Style="{StaticResource IconBtnStyle}"
                        Command="{Binding MoveUpCommand}" ToolTip="Di chuyển lên">
                    <TextBlock Text="↑" FontSize="15" />
                </Button>
                <Button Style="{StaticResource IconBtnStyle}"
                        Command="{Binding MoveDownCommand}" ToolTip="Di chuyển xuống">
                    <TextBlock Text="↓" FontSize="15" />
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}" />

                <Button Style="{StaticResource IconBtnStyle}"
                        Command="{Binding ExpandAllCommand}" ToolTip="Mở rộng tất cả">
                    <TextBlock Text="⊞" FontSize="14" />
                </Button>
                <Button Style="{StaticResource IconBtnStyle}"
                        Command="{Binding CollapseAllCommand}" ToolTip="Thu gọn tất cả">
                    <TextBlock Text="⊟" FontSize="14" />
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}" />

                <Button Style="{StaticResource IconBtnStyle}"
                        Command="{Binding DeleteNodeCommand}" ToolTip="Xóa node đang chọn"
                        Foreground="{StaticResource DangerBrush}">
                    <TextBlock Text="🗑" FontSize="13" />
                </Button>

                <Border Style="{StaticResource ToolbarSeparatorStyle}" />

                <!-- Auto-generate fields từ Target DB schema -->
                <dx:SimpleButton Command="{Binding AutoGenerateFieldsCommand}"
                                 Height="28" Padding="10,0"
                                 ToolTip="Tạo fields tự động từ cấu trúc cột Target DB">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✨" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Tạo Fields tự động" Margin="5,0,0,0" FontSize="12" />
                    </StackPanel>
                </dx:SimpleButton>

                <Border Style="{StaticResource ToolbarSeparatorStyle}" />

                <!-- Đồng bộ Schema — hiện khi có diff -->
                <dx:SimpleButton Command="{Binding SyncSchemaCommand}"
                                 Height="28" Padding="10,0"
                                 ToolTip="Đồng bộ cấu trúc cột Target DB với form hiện tại">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Text="Đồng bộ Schema" Margin="5,0,0,0" FontSize="12" />
                        <!-- Badge số issues — chỉ hiện khi HasSchemaSyncIssues -->
                        <Border Margin="5,0,0,0" CornerRadius="8" Padding="5,1"
                                Background="{DynamicResource AppWarningBrush}" VerticalAlignment="Center"
                                Visibility="{Binding HasSchemaSyncIssues,
                                             Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding SchemaSyncBadgeCount}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                </dx:SimpleButton>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2: Main Content — TreeView (left) + TabControl (right)
             ═══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="16,12,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240" MaxWidth="500" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ── Left Panel: Structure TreeView ─────────────── -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,0" Padding="0">
                <DockPanel>
                    <!-- Panel header -->
                    <Border DockPanel.Dock="Top" Padding="14,10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="Cấu trúc Form" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}S · {1}F">
                                            <Binding Path="TotalSections" />
                                            <Binding Path="TotalFields" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Search box -->
                    <Border DockPanel.Dock="Top" Padding="10,8">
                        <dxe:TextEdit NullText="🔍  Tìm section / field..."
                                      EditValue="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                            <dxe:TextEdit.InputBindings>
                                <KeyBinding Key="Escape"
                                            Command="{Binding DataContext.ClearSearchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                            </dxe:TextEdit.InputBindings>
                        </dxe:TextEdit>
                    </Border>

                    <!-- TreeView -->
                    <TreeView ItemsSource="{Binding Sections}"
                              SelectedItemChanged="OnTreeSelectedItemChanged"
                              MouseDoubleClick="OnTreeMouseDoubleClick"
                              ContextMenuOpening="OnTreeContextMenuOpening"
                              BorderThickness="0" Padding="6,4"
                              Background="Transparent">
                        <!-- D2b — Chuyển các field đã tick sang Section/Tab khác.
                             ContextMenu.DataContext = VM qua PlacementTarget; mỗi item mang sẵn
                             MoveCommand nên bind thẳng, không cần RelativeSource xuyên Popup. -->
                        <TreeView.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                       RelativeSource={RelativeSource Self}}">
                                <MenuItem Header="{Binding BulkMoveHeader}"
                                          ItemsSource="{Binding MoveTargets}"
                                          IsEnabled="{Binding CanMoveBulk}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding Header}" />
                                            <Setter Property="Command" Value="{Binding MoveCommand}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <Separator />
                                <MenuItem Header="{Binding BulkDeleteHeader}"
                                          Command="{Binding DeleteBulkCommand}"
                                          IsEnabled="{Binding CanMoveBulk}" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:FormTreeNode}"
                                                       ItemsSource="{Binding Children}">
                                <Grid Margin="2,4"
                                      ToolTip="{Binding NodeTooltip}"
                                      Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Icon -->
                                    <Border Grid.Column="0" Width="24" Height="24"
                                            CornerRadius="5"
                                            Background="{StaticResource AccentLightBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IconText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Foreground="{StaticResource AccentDarkBrush}" />
                                    </Border>

                                    <!-- D2 — Bulk multi-select checkbox (chi hien tren field) -->
                                    <CheckBox Grid.Column="1" Margin="6,0,2,0"
                                              IsChecked="{Binding IsMultiChecked, Mode=TwoWay}"
                                              Click="OnFieldBulkChecked"
                                              VerticalAlignment="Center"
                                              ToolTip="Chọn để bulk edit">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NodeType}" Value="Field">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>
                                    <!-- Name + SubText -->
                                    <StackPanel Grid.Column="2" Margin="8,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{DynamicResource AppTextBrush}" />
                                        <TextBlock Text="{Binding SubText}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" />
                                    </StackPanel>

                                    <!-- Required badge -->
                                    <Border Grid.Column="3" Background="{DynamicResource AppDangerSoftBrush}"
                                            CornerRadius="4" Padding="4,1"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="*" Foreground="{StaticResource DangerBrush}"
                                                   FontSize="11" FontWeight="Bold" />
                                    </Border>


                                </Grid>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>

                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="Visibility" Value="{Binding IsActive, Converter={StaticResource BoolToVis}}" />
                                <Setter Property="Padding" Value="2,1" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="Transparent" />

            <!-- ── Right Panel: TabControl ────────────────────── -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                    Margin="0,0,0,0" Padding="0">
                <TabControl BorderThickness="0" Background="Transparent"
                            Padding="0"
                            SelectedIndex="{Binding ActiveTabIndex, Mode=TwoWay}">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Padding" Value="14,8" />
                            <Setter Property="FontSize" Value="13" />
                        </Style>
                    </TabControl.Resources>

                    <!-- ══════════════════════════════════════════════
                         TAB 1: Thông tin Form (metadata Ui_Form)
                         ══════════════════════════════════════════════ -->
                    <TabItem Header="Thông tin Form">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="24,20,24,24">

                                <!-- ── Intro Panel: Giới thiệu màn hình ── -->
                                <Border Background="{DynamicResource AppInfoSoftBrush}" CornerRadius="8"
                                        Padding="16,14" Margin="0,0,0,16"
                                        BorderBrush="{DynamicResource AppInfoBorderBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Left" Width="36" Height="36"
                                                CornerRadius="18" Background="{StaticResource AccentLightBrush}"
                                                Margin="0,0,14,0" VerticalAlignment="Top">
                                            <TextBlock Text="📋" FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="Cấu hình metadata của Form"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppInfoDarkBrush}" Margin="0,0,0,4" />
                                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource AppInfoBrush}" LineHeight="18">
                                                Màn hình này dùng để thiết lập thông tin cơ bản cho một Form trong hệ thống.
                                                Mỗi Form đại diện cho một giao diện nhập liệu (ví dụ: Đơn đặt hàng, Nghỉ phép, Nhập kho...)
                                                và được gắn với một bảng dữ liệu (Business Table) để xác định nguồn dữ liệu mà form sẽ đọc/ghi.
                                                Các trường có dấu (*) là bắt buộc.
                                            </TextBlock>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>

                                <!-- ── Card: Thông tin cơ bản ──────── -->
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="THÔNG TIN CƠ BẢN"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Left column -->
                                            <StackPanel Grid.Column="0">
                                                <!-- Form Code -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <DockPanel>
                                                        <TextBlock Text="Form Code *"
                                                                   Style="{StaticResource FieldLabelStyle}"
                                                                   DockPanel.Dock="Left" />
                                                        <TextBlock DockPanel.Dock="Right"
                                                                   Text="Đang kiểm tra..."
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource AccentBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding IsCheckingFormCode, Converter={StaticResource BoolToVis}}" />
                                                    </DockPanel>
                                                    <dxe:TextEdit EditValue="{Binding FormCode, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="VD: PO_ORDER"
                                                                  CharacterCasing="Upper"
                                                                  ToolTip="Mã định danh duy nhất của form, dùng để tra cứu và tham chiếu trong hệ thống. Chỉ chấp nhận chữ IN HOA, số và dấu gạch dưới." />
                                                    <TextBlock Text="{Binding FormCodeError}"
                                                               FontSize="11" Margin="0,4,0,0"
                                                               Foreground="{StaticResource DangerBrush}"
                                                               TextWrapping="Wrap"
                                                               Visibility="{Binding HasFormCodeError, Converter={StaticResource BoolToVis}}" />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Mã duy nhất trong tenant. Chỉ gồm A-Z, 0-9, dấu _ (VD: PO_ORDER, HR_LEAVE). Không trùng với form khác." />
                                                </StackPanel>

                                                <!-- Tên Form -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Tên Form *"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:TextEdit EditValue="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="VD: Đơn Đặt Hàng"
                                                                  ToolTip="Tên hiển thị của form cho người dùng cuối." />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Tên thân thiện hiển thị trên giao diện. Nên đặt ngắn gọn, dễ hiểu (VD: Đơn Đặt Hàng, Phiếu Nghỉ Phép)." />
                                                </StackPanel>

                                                <!-- Platform -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Platform *"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:ComboBoxEdit ItemsSource="{Binding PlatformOptions}"
                                                                      EditValue="{Binding Platform, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      ToolTip="Nền tảng mà form này sẽ hiển thị: web, mobile hoặc wpf." />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Nền tảng đích để render form. Mỗi platform có bộ control riêng (VD: web dùng HTML, mobile dùng native component)." />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Right column -->
                                            <StackPanel Grid.Column="2">
                                                <!-- Business Table -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Business Table *"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxg:LookUpEdit ItemsSource="{Binding TableLookupItems}"
                                                                    SelectedItem="{Binding SelectedTable}"
                                                                    DisplayMember="DisplayText"
                                                                    NullText="Chọn bảng dữ liệu..."
                                                                    ToolTip="Bảng dữ liệu chính (Sys_Table) mà form này sẽ đọc/ghi dữ liệu. Xác định tenant và cấu trúc cột." />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Bảng nguồn dữ liệu từ Sys_Table. Form sẽ đọc/ghi vào bảng này. Đồng thời xác định tenant (phân quyền dữ liệu theo đơn vị)." />
                                                </StackPanel>

                                                <!-- Display Mode -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Chế độ mở form"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:ComboBoxEdit ItemsSource="{Binding DisplayModeOptions}"
                                                                      EditValue="{Binding DisplayMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                      ToolTip="Popup: mở dialog inline trên trang danh sách. Tab: mở sang tab riêng." />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Popup = dialog trực tiếp trên lưới danh mục. Tab = điều hướng sang trang riêng (phù hợp form nhiều section)." />
                                                </StackPanel>

                                                <!-- Is Active -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}"
                                                            Margin="0,8,0,0">
                                                    <dxe:CheckEdit IsChecked="{Binding IsFormActive}"
                                                                   Content="Kích hoạt (Is Active)"
                                                                   FontSize="13"
                                                                   ToolTip="Bật/tắt form. Form bị tắt sẽ không hiển thị cho người dùng cuối nhưng vẫn lưu trong hệ thống." />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Tắt để ẩn form khỏi người dùng cuối mà không cần xóa. Dữ liệu cấu hình vẫn được giữ nguyên." />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── Card: Tiêu đề hiển thị (đa ngôn ngữ) ── -->
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="TIÊU ĐỀ HIỂN THỊ (ĐA NGÔN NGỮ)"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6"
                                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                    Padding="10,8" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FormTitleVi}"
                                                           FontSize="13" Foreground="{DynamicResource AppTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="Tiêu đề hiển thị tiếng Việt hiện tại" />
                                            </Border>
                                            <dx:SimpleButton Grid.Column="2"
                                                             Command="{Binding OpenFormTitleI18nCommand}"
                                                             Height="34" Padding="12,0"
                                                             ToolTip="Nhập tiêu đề form cho tất cả ngôn ngữ">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" />
                                                    <TextBlock Text="Dịch" Margin="6,0,0,0" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </dx:SimpleButton>
                                        </Grid>
                                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                                   Text="Hiển thị ở popup Thêm mới + header form cho người dùng. Cần chọn Business Table trước để sinh key. Nhấn Lưu thay đổi sau khi dịch." />
                                    </StackPanel>
                                </Border>

                                <!-- ── Card: Bố cục hiển thị (Blazor runtime) ── -->
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="BỐ CỤC HIỂN THỊ"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Style="{StaticResource FieldGroupStyle}">
                                                <TextBlock Text="Bề rộng tối đa (px)"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <dxe:TextEdit EditValue="{Binding MaxWidth, UpdateSourceTrigger=PropertyChanged}"
                                                              NullText="Mặc định (880)"
                                                              ToolTip="Giới hạn bề rộng form khi render. Trống = 880px." />
                                                <TextBlock Style="{StaticResource HelpTextStyle}"
                                                           Text="Form không giãn quá số px này. Trống = mặc định 880px." />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Style="{StaticResource FieldGroupStyle}">
                                                <TextBlock Text="Số cột"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <dxe:ComboBoxEdit ItemsSource="{Binding FormColumnsOptions}"
                                                                  EditValue="{Binding FormColumns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="Mặc định (4)"
                                                                  ToolTip="Số cột lưới nền. Chọn 1 = mỗi field 1 dòng." />
                                                <TextBlock Style="{StaticResource HelpTextStyle}"
                                                           Text="1 = mỗi field 1 dòng. Trống = 4 cột (mặc định)." />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── Card: Mô tả ─────────────────── -->
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="MÔ TẢ"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <dxe:MemoEdit EditValue="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="VD: Form nhập đơn đặt hàng cho bộ phận mua hàng, hỗ trợ duyệt nhiều cấp..."
                                                      Height="90" AcceptsReturn="True"
                                                      ToolTip="Ghi chú nội bộ về mục đích, phạm vi sử dụng của form. Không hiển thị cho end-user." />
                                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                                   Text="Ghi chú nội bộ cho quản trị viên. Mô tả mục đích, phạm vi sử dụng, hoặc lưu ý đặc biệt. Trường này không hiển thị cho người dùng cuối." />
                                    </StackPanel>
                                </Border>

                                <!-- ── Card: Version & Checksum (edit only) ── -->
                                <Border Style="{StaticResource SectionCardStyle}"
                                        Visibility="{Binding IsNewForm, Converter={StaticResource InvBoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="PHIÊN BẢN"
                                                   Style="{StaticResource SectionTitleStyle}" />
                                        <TextBlock Style="{StaticResource HelpTextStyle}"
                                                   Margin="0,0,0,12"
                                                   Text="Thông tin phiên bản do hệ thống tự quản lý. Version tăng mỗi khi Publish. Checksum dùng để phát hiện thay đổi giữa các lần deploy." />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Version"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <Border Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6"
                                                        Padding="14,8" MinWidth="80"
                                                        ToolTip="Số phiên bản hiện tại. Tự tăng mỗi lần Publish thành công.">
                                                    <TextBlock FontSize="20" FontWeight="Bold"
                                                               Foreground="{StaticResource AccentDarkBrush}">
                                                        <TextBlock.Text>
                                                            <Binding Path="Version" StringFormat="v{0}" />
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Checksum"
                                                           Style="{StaticResource FieldLabelStyle}" />
                                                <TextBlock Text="{Binding Checksum}"
                                                           Style="{StaticResource ReadonlyValueStyle}"
                                                           ToolTip="Mã hash (SHA-256) của toàn bộ cấu hình form. Dùng để so sánh xem form có thay đổi so với bản đã deploy hay không." />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ── Error Message (create mode) ──── -->
                                <Border Background="{DynamicResource AppDangerSoftBrush}" CornerRadius="8" Padding="14,10"
                                        BorderBrush="{DynamicResource AppDangerLightBrush}" BorderThickness="1"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding HasCreateError, Converter={StaticResource BoolToVis}}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="⚠"
                                                   FontSize="16" Margin="0,0,10,0"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding CreateErrorMessage}"
                                                   Foreground="{DynamicResource AppDangerBrush}" FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </DockPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ══════════════════════════════════════════════
                         TAB 2: Thuộc tính node (Section / Field)
                         ══════════════════════════════════════════════ -->
                    <TabItem Header="Thuộc tính">
                        <Grid>
                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsNodeSelected, Converter={StaticResource InvBoolToVis}}">
                                <Border Width="64" Height="64" CornerRadius="32"
                                        Background="{DynamicResource AppPageBackgroundBrush}"
                                        HorizontalAlignment="Center" Margin="0,0,0,16">
                                    <TextBlock Text="☝" FontSize="28"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedBrush}" />
                                </Border>
                                <TextBlock Text="Chọn một node từ cây bên trái"
                                           FontSize="14" Foreground="{StaticResource MutedBrush}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="để xem và chỉnh sửa thuộc tính"
                                           FontSize="12" Foreground="{StaticResource MutedBrush}"
                                           Opacity="0.7"
                                           HorizontalAlignment="Center" Margin="0,4,0,0" />
                            </StackPanel>

                            <!-- Property editor -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsNodeSelected, Converter={StaticResource BoolToVis}}">
                                <StackPanel Margin="24,20,24,24" MaxWidth="560">

                                    <!-- ── Section Properties ──────── -->
                                    <StackPanel Visibility="{Binding IsSectionSelected, Converter={StaticResource BoolToVis}}">

                                        <!-- Card: Thông tin cơ bản -->
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="THUỘC TÍNH SECTION"
                                                           Style="{StaticResource SectionTitleStyle}" />

                                                <!-- Section Code -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Section Code *"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:TextEdit EditValue="{Binding SelectedNode.Code, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="VD: thong_tin_co_ban"
                                                                  ToolTip="Mã định danh duy nhất trong form. Dùng chữ thường, số và dấu _. Không thay đổi được sau khi các rule/event tham chiếu." />
                                                    <!-- Lỗi validation -->
                                                    <Border Background="{DynamicResource AppDangerSoftBrush}" CornerRadius="4" Padding="8,4"
                                                            Margin="0,4,0,0"
                                                            Visibility="{Binding HasSectionCodeError, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding SectionCodeError}"
                                                                   Foreground="{DynamicResource AppDangerBrush}" FontSize="11" />
                                                    </Border>
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Chỉ dùng chữ thường (a-z), số (0-9), dấu gạch dưới (_). VD: ho_ten, dia_chi" />
                                                </StackPanel>

                                                <!-- Title Key (readonly, auto-generated) -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Title Key (tự động)"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Grid.Column="0"
                                                                Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6"
                                                                BorderBrush="{StaticResource BorderBrush}"
                                                                BorderThickness="1" Padding="10,7">
                                                            <TextBlock Text="{Binding SectionTitleKeyPreview}"
                                                                       FontFamily="Cascadia Code, Consolas, monospace"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding SectionTitleKeyPreview}" />
                                                        </Border>
                                                    </Grid>
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Tự sinh từ Form Code + section + Section Code. Dùng để tra Sys_Resource." />
                                                </StackPanel>

                                                <!-- Thứ tự + Is Active -->
                                                <Grid Margin="0,0,0,18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="16" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Thứ tự"
                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                        <dxe:TextEdit EditValue="{Binding SelectedNode.SortOrder, UpdateSourceTrigger=PropertyChanged}"
                                                                      NullText="0"
                                                                      ToolTip="Thứ tự hiển thị section trong form (số nhỏ hiển thị trước)." />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom"
                                                                Margin="0,0,0,2">
                                                        <dxe:CheckEdit IsChecked="{Binding SelectedNode.IsActive}"
                                                                       Content="Hiển thị (Is Active)"
                                                                       FontSize="13"
                                                                       ToolTip="Bật/tắt section. Section bị tắt sẽ không render cho người dùng cuối." />
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Thuộc Tab — gán section vào tab (Ui_Section.Tab_Id) -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Thuộc Tab"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxg:LookUpEdit ItemsSource="{Binding Tabs}"
                                                                    EditValue="{Binding SelectedNode.TabId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    ValueMember="TabId"
                                                                    DisplayMember="DisplayLabel"
                                                                    NullText="(Không thuộc tab nào — form phẳng)"
                                                                    ToolTip="Gán section vào một tab. Để trống = section không thuộc tab nào (render phẳng). Cần nhấn Lưu Section để áp dụng." />
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Tạo/sửa tab tại tab '📑 Tabs'. Đổi xong nhớ nhấn Lưu Section bên dưới." />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <!-- Card: Tên hiển thị đa ngôn ngữ (popup) -->
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="TÊN HIỂN THỊ (ĐA NGÔN NGỮ)"
                                                           Style="{StaticResource SectionTitleStyle}" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6"
                                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                            Padding="10,8" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding SelectedNode.ResourceVi}"
                                                                   FontSize="13" Foreground="{DynamicResource AppTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="Tên hiển thị tiếng Việt hiện tại" />
                                                    </Border>
                                                    <dx:SimpleButton Grid.Column="2"
                                                                     Command="{Binding OpenSectionI18nCommand}"
                                                                     Height="34" Padding="12,0"
                                                                     ToolTip="Mở popup nhập bản dịch cho tất cả ngôn ngữ">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" />
                                                            <TextBlock Text="Dịch" Margin="6,0,0,0" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </dx:SimpleButton>
                                                </Grid>
                                                <TextBlock Style="{StaticResource HelpTextStyle}"
                                                           Text="Nhấn 🌐 Dịch để nhập/sửa bản dịch mọi ngôn ngữ (lưu ngay). Cần đặt Section Code trước để sinh key." />
                                            </StackPanel>
                                        </Border>

                                        <!-- Auto-save: section tự lưu khi thay đổi hợp lệ -->
                                        <TextBlock Margin="0,6,0,0" Style="{StaticResource HelpTextStyle}"
                                                   Text="✓ Tự động lưu khi bạn sửa (Section Code hợp lệ). Không cần bấm Lưu." />

                                    </StackPanel>

                                    <!-- ── Field Properties ────────── -->
                                    <StackPanel Visibility="{Binding IsFieldSelected, Converter={StaticResource BoolToVis}}">
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <DockPanel Margin="0,0,0,14">
                                                    <TextBlock Text="THUỘC TÍNH FIELD"
                                                               Style="{StaticResource SectionTitleStyle}"
                                                               Margin="0" VerticalAlignment="Center" />
                                                    <dx:SimpleButton DockPanel.Dock="Right"
                                                                     Command="{Binding OpenFieldConfigCommand}"
                                                                     HorizontalAlignment="Right"
                                                                     Height="28" Padding="10,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="⚙" FontSize="12"
                                                                       VerticalAlignment="Center" />
                                                            <TextBlock Text="Chi tiết" Margin="5,0,0,0"
                                                                       FontSize="12" />
                                                        </StackPanel>
                                                    </dx:SimpleButton>
                                                </DockPanel>

                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Field Code"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:TextEdit EditValue="{Binding SelectedNode.Code, Mode=OneWay}"
                                                                  NullText="Field Code"
                                                                  IsReadOnly="True" />
                                                </StackPanel>

                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Tên hiển thị"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:TextEdit EditValue="{Binding SelectedNode.DisplayName, Mode=OneWay}"
                                                                  NullText="Tên hiển thị"
                                                                  IsReadOnly="True" />
                                                </StackPanel>

                                                <Grid Margin="0,0,0,18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Field Type"
                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                        <dxe:TextEdit EditValue="{Binding SelectedNode.FieldType, Mode=OneWay}"
                                                                      NullText="Field Type"
                                                                      IsReadOnly="True" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Editor Type"
                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                        <dxe:TextEdit EditValue="{Binding SelectedNode.EditorType, Mode=OneWay}"
                                                                      NullText="Editor Type"
                                                                      IsReadOnly="True" />
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Thứ tự sắp xếp"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:TextEdit EditValue="{Binding SelectedNode.SortOrder, Mode=OneWay}"
                                                                  NullText="0"
                                                                  IsReadOnly="True" />
                                                </StackPanel>

                                                <dxe:CheckEdit Content="Bắt buộc (Required)"
                                                               IsChecked="{Binding SelectedNode.IsRequired, Mode=OneWay}"
                                                               IsReadOnly="True"
                                                               FontSize="13"
                                                               Margin="0,4,0,0" />
                                                <dxe:CheckEdit Content="Field ảo (Virtual)"
                                                               IsChecked="{Binding SelectedNode.IsVirtual, Mode=OneWay}"
                                                               IsReadOnly="True"
                                                               FontSize="13"
                                                               Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Hint card -->
                                        <Border Background="{DynamicResource AppInfoSoftBrush}" CornerRadius="8"
                                                Padding="14,12"
                                                BorderBrush="{DynamicResource AppInfoBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="💡  Mở Chi tiết để cấu hình:"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppInfoBrush}"
                                                           Margin="0,0,0,6" />
                                                <TextBlock Text="  •  Control Properties (min, max, format...)"
                                                           FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text="  •  Validation Rules (required, range...)"
                                                           FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                                <TextBlock Text="  •  Events (onChange, onBlur...)"
                                                           FontSize="12" Foreground="{StaticResource MutedBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>

                    <!-- ══════════════════════════════════════════════
                         TAB 3: Events
                         ══════════════════════════════════════════════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Events" FontSize="13" FontWeight="Medium" />
                                <Border Style="{StaticResource TabBadgeStyle}">
                                    <TextBlock FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AccentDarkBrush}"
                                               Text="{Binding Events.Count}" />
                                </Border>
                            </StackPanel>
                        </TabItem.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Events toolbar -->
                            <Border Grid.Row="0" Padding="12,8"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{DynamicResource AppSurfaceMutedBrush}">
                                <DockPanel>
                                    <TextBlock Text="Danh sách Events" FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AppTextBrush}" />
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Style="{StaticResource InlineBtnStyle}"
                                                Command="{Binding AddEventCommand}"
                                                ToolTip="Thêm Event mới" Content="＋"
                                                FontSize="15" />
                                        <Button Style="{StaticResource InlineBtnStyle}"
                                                Command="{Binding EditEventCommand}"
                                                ToolTip="Mở Event Editor" Content="✎"
                                                FontSize="14" />
                                        <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                                Command="{Binding RemoveEventCommand}"
                                                ToolTip="Xóa Event đang chọn" Content="✕"
                                                FontSize="12" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Events DataGrid -->
                            <dxg:GridControl Grid.Row="1"
                                             ItemsSource="{Binding Events}"
                                             SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                             AutoPopulateColumns="False">
                                <dxg:GridControl.View>
                                    <dxg:TableView ShowGroupPanel="False"
                                                   AllowEditing="False"
                                                   AllowPerPixelScrolling="True"
                                                   NavigationStyle="Row">
                                        <dxg:TableView.RowStyle>
                                            <Style TargetType="dxg:RowControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Row.IsActive}" Value="False">
                                                        <Setter Property="Opacity" Value="0.4" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </dxg:TableView.RowStyle>
                                    </dxg:TableView>
                                </dxg:GridControl.View>
                                <dxg:GridControl.Columns>
                                    <dxg:GridColumn Header="#"         FieldName="OrderNo"          Width="45" />
                                    <dxg:GridColumn Header="Trigger"   FieldName="TriggerCode"      Width="110" />
                                    <dxg:GridColumn Header="Field Target" FieldName="FieldTarget"   Width="130" />
                                    <dxg:GridColumn Header="Condition" FieldName="ConditionPreview" Width="*">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Row.ConditionPreview, FallbackValue='—'}"
                                                           VerticalAlignment="Center" Margin="4,0"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="11" Foreground="{StaticResource MutedBrush}" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                    <dxg:GridColumn Header="Actions"   FieldName="ActionsCount"     Width="70" />
                                    <dxg:GridColumn Header="Active"    FieldName="IsActive"         Width="60">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <dxe:CheckEdit IsChecked="{Binding Row.IsActive, Mode=OneWay}"
                                                               IsReadOnly="True"
                                                               HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                    <!-- Actions column -->
                                    <dxg:GridColumn Header="" Width="70" AllowSorting="False"
                                                    AllowEditing="False">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal"
                                                            VerticalAlignment="Center" Margin="4,0">
                                                    <Button Style="{StaticResource InlineBtnStyle}"
                                                            Command="{Binding DataContext.EditEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                            CommandParameter="{Binding Row}"
                                                            ToolTip="Mở Event Editor" Content="✎"
                                                            FontSize="13" />
                                                    <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                                            Command="{Binding DataContext.RemoveEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                            CommandParameter="{Binding Row}"
                                                            ToolTip="Xóa event" Content="✕"
                                                            FontSize="11" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                </dxg:GridControl.Columns>
                            </dxg:GridControl>
                        </Grid>
                    </TabItem>

                    <!-- ══════════════════════════════════════════════
                         TAB 4: Permissions
                         ══════════════════════════════════════════════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Permissions" FontSize="13" FontWeight="Medium" />
                                <Border Style="{StaticResource TabBadgeStyle}">
                                    <TextBlock FontSize="11" FontWeight="Bold"
                                               Foreground="{StaticResource AccentDarkBrush}"
                                               Text="{Binding Permissions.Count}" />
                                </Border>
                            </StackPanel>
                        </TabItem.Header>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Info bar -->
                            <Border Grid.Row="0" Padding="12,8"
                                    Background="{DynamicResource AppInfoSoftBrush}"
                                    BorderBrush="{DynamicResource AppInfoBorderBrush}" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock Text="💡" Margin="0,0,8,0" FontSize="13"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="Cấu hình quyền truy cập form theo từng role. Thay đổi được lưu khi nhấn Lưu."
                                               FontSize="12"
                                               Foreground="{StaticResource MutedBrush}"
                                               VerticalAlignment="Center" />
                                </DockPanel>
                            </Border>

                            <!-- Permissions DataGrid -->
                            <dxg:GridControl Grid.Row="1"
                                             ItemsSource="{Binding Permissions}"
                                             AutoPopulateColumns="False">
                                <dxg:GridControl.View>
                                    <dxg:TableView ShowGroupPanel="False"
                                                   AllowEditing="True"
                                                   AllowPerPixelScrolling="True"
                                                   NavigationStyle="Cell" />
                                </dxg:GridControl.View>
                                <dxg:GridControl.Columns>
                                    <dxg:GridColumn Header="Role" FieldName="RoleName"
                                                    Width="130" AllowEditing="False" />
                                    <dxg:GridColumn Header="Mô tả" FieldName="RoleDescription"
                                                    Width="*" AllowEditing="False">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Row.RoleDescription}"
                                                           VerticalAlignment="Center" Margin="4,0"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedBrush}" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                    <dxg:GridColumn Header="Xem" FieldName="CanRead"
                                                    Width="65" AllowSorting="False">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <dxe:CheckEdit IsChecked="{Binding Row.CanRead, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               HorizontalAlignment="Center"
                                                               Command="{Binding DataContext.DirtyCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                    <dxg:GridColumn Header="Nhập" FieldName="CanWrite"
                                                    Width="65" AllowSorting="False">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <dxe:CheckEdit IsChecked="{Binding Row.CanWrite, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               HorizontalAlignment="Center"
                                                               Command="{Binding DataContext.DirtyCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                    <dxg:GridColumn Header="Gửi" FieldName="CanSubmit"
                                                    Width="65" AllowSorting="False">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <dxe:CheckEdit IsChecked="{Binding Row.CanSubmit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                               HorizontalAlignment="Center"
                                                               Command="{Binding DataContext.DirtyCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>
                                </dxg:GridControl.Columns>
                            </dxg:GridControl>
                        </Grid>
                    </TabItem>

                    <!-- ── Tab D3: Grid-edit Mode (Excel-like) ──────── -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" FontSize="14"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Bảng Fields" Margin="6,0,0,0"
                                           VerticalAlignment="Center" />
                                <Border Style="{StaticResource TabBadgeStyle}">
                                    <TextBlock Text="{Binding TotalFields}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentDarkBrush}" />
                                </Border>
                            </StackPanel>
                        </TabItem.Header>

                        <DockPanel>
                            <!-- Header hint -->
                            <Border DockPanel.Dock="Top" Margin="14,12,14,6" Padding="10,7"
                                    Background="{DynamicResource AppAccentSoftBrush}"
                                    BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1"
                                    CornerRadius="5">
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource AppAccentDarkBrush}"
                                           TextWrapping="Wrap">
                                    <Run Text="ℹ" />
                                    <Run Text=" Edit trực tiếp trên bảng — Tab/Enter chuyển ô, F2 vào edit mode, mỗi ô tự lưu sau 800ms. Sửa đồng bộ với TreeView." />
                                </TextBlock>
                            </Border>

                            <dxg:GridControl Margin="14,0,14,14"
                                             ItemsSource="{Binding AllFields}"
                                             AutoPopulateColumns="False">
                                <dxg:GridControl.View>
                                    <dxg:TableView x:Name="FieldsGridView"
                                                   NavigationStyle="Cell"
                                                   ShowGroupPanel="True"
                                                   AllowPerPixelScrolling="True"
                                                   AllowEditing="True"
                                                   EditorShowMode="MouseDownFocused"
                                                   CellValueChanged="OnFieldsGridCellValueChanged" />
                                </dxg:GridControl.View>

                                <dxg:GridControl.Columns>
                                    <!-- Section (grouped) -->
                                    <dxg:GridColumn Header="Section" FieldName="ParentSectionCode"
                                                    Width="120" AllowEditing="False"
                                                    GroupIndex="0" />

                                    <!-- # OrderNo (readonly) -->
                                    <dxg:GridColumn Header="#" FieldName="SortOrder"
                                                    Width="50" AllowEditing="False" />

                                    <!-- ColumnCode (readonly) -->
                                    <dxg:GridColumn Header="Field Code" FieldName="Code"
                                                    Width="160" AllowEditing="False">
                                        <dxg:GridColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Row.Code}"
                                                           FontFamily="Cascadia Code, Consolas"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           Margin="6,0" />
                                            </DataTemplate>
                                        </dxg:GridColumn.CellTemplate>
                                    </dxg:GridColumn>

                                    <!-- Display name (readonly, resolved from i18n) -->
                                    <dxg:GridColumn Header="Tên (vi)" FieldName="DisplayName"
                                                    Width="*" AllowEditing="False" />

                                    <!-- EditorType (combo edit) -->
                                    <dxg:GridColumn Header="Editor" FieldName="EditorType" Width="130">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:ComboBoxEditSettings
                                                                      ItemsSource="{Binding DataContext.AvailableEditorTypes, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}" />
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <!-- ColSpan (combo edit) -->
                                    <dxg:GridColumn Header="ColSpan" FieldName="ColSpan" Width="80">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:ComboBoxEditSettings
                                                                      ItemsSource="{Binding DataContext.ColSpanOptions, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}" />
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <!-- IsRequired (check) -->
                                    <dxg:GridColumn Header="Required" FieldName="IsRequired" Width="80">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:CheckEditSettings />
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <!-- IsVisible (check) -->
                                    <dxg:GridColumn Header="Visible" FieldName="IsVisible" Width="75">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:CheckEditSettings />
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <!-- IsReadOnly (check) -->
                                    <dxg:GridColumn Header="ReadOnly" FieldName="IsReadOnly" Width="85">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:CheckEditSettings />
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>

                                    <!-- LockOnEdit (check) — ADR-017 -->
                                    <dxg:GridColumn Header="Lock@Edit" FieldName="LockOnEdit" Width="95">
                                        <dxg:GridColumn.EditSettings>
                                            <dxe:CheckEditSettings />
                                        </dxg:GridColumn.EditSettings>
                                    </dxg:GridColumn>
                                </dxg:GridControl.Columns>
                            </dxg:GridControl>
                        </DockPanel>
                    </TabItem>

                    <!-- ══════════════════════════════════════════════
                         TAB 6: Tabs (Ui_Tab) — quản lý tab + i18n
                         ══════════════════════════════════════════════ -->
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📑" FontSize="13" VerticalAlignment="Center" />
                                <TextBlock Text="Tabs" Margin="6,0,0,0" VerticalAlignment="Center" />
                                <Border Style="{StaticResource TabBadgeStyle}">
                                    <TextBlock Text="{Binding Tabs.Count}"
                                               FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentDarkBrush}" />
                                </Border>
                            </StackPanel>
                        </TabItem.Header>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" MinWidth="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- ── Master list ───────────────────────── -->
                            <DockPanel Grid.Column="0">
                                <Border DockPanel.Dock="Top" Padding="12,8"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1" Background="{DynamicResource AppSurfaceMutedBrush}">
                                    <DockPanel>
                                        <TextBlock Text="Danh sách Tab" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="{DynamicResource AppTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <dx:SimpleButton DockPanel.Dock="Right"
                                                         Command="{Binding AddTabCommand}"
                                                         HorizontalAlignment="Right"
                                                         Height="26" Padding="8,0"
                                                         ToolTip="Thêm tab mới">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="＋" FontSize="13" FontWeight="Bold"
                                                           VerticalAlignment="Center" />
                                                <TextBlock Text="Tab" Margin="4,0,0,0" FontSize="12" />
                                            </StackPanel>
                                        </dx:SimpleButton>
                                    </DockPanel>
                                </Border>

                                <ListBox ItemsSource="{Binding Tabs}"
                                         SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                                         BorderThickness="0" Background="Transparent"
                                         Padding="6,4"
                                         HorizontalContentAlignment="Stretch">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="2,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="24" Height="24"
                                                        CornerRadius="5"
                                                        Background="{StaticResource AccentLightBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="📑" FontSize="12"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayLabel}"
                                                               FontSize="13" FontWeight="Medium"
                                                               Foreground="{DynamicResource AppTextBrush}" />
                                                    <TextBlock Text="{Binding TabCode}"
                                                               FontSize="11"
                                                               FontFamily="Cascadia Code, Consolas"
                                                               Foreground="{StaticResource MutedBrush}" />
                                                </StackPanel>
                                                <Border Grid.Column="2" Background="{DynamicResource AppSuccessSoftBrush}"
                                                        CornerRadius="4" Padding="5,1"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}">
                                                    <TextBlock Text="mặc định" FontSize="10"
                                                               Foreground="{DynamicResource AppSuccessBrush}" FontWeight="SemiBold" />
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>

                            <!-- ── Detail editor ─────────────────────── -->
                            <Grid Grid.Column="1">
                                <!-- Empty state -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding IsTabSelected, Converter={StaticResource InvBoolToVis}}">
                                    <Border Width="64" Height="64" CornerRadius="32"
                                            Background="{DynamicResource AppPageBackgroundBrush}"
                                            HorizontalAlignment="Center" Margin="0,0,0,16">
                                        <TextBlock Text="📑" FontSize="26"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="Chọn hoặc thêm một tab"
                                               FontSize="14" Foreground="{StaticResource MutedBrush}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="để cấu hình tiêu đề đa ngôn ngữ"
                                               FontSize="12" Foreground="{StaticResource MutedBrush}"
                                               Opacity="0.7" HorizontalAlignment="Center"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              Visibility="{Binding IsTabSelected, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="24,20,24,24" MaxWidth="560">

                                        <!-- Card: Thuộc tính tab -->
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="THUỘC TÍNH TAB"
                                                           Style="{StaticResource SectionTitleStyle}" />

                                                <!-- Tab Code -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Tab Code *"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <dxe:TextEdit EditValue="{Binding SelectedTab.TabCode, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="VD: thong_tin"
                                                                  ToolTip="Mã định danh tab, duy nhất trong form. Chữ thường, số, dấu _." />
                                                    <Border Background="{DynamicResource AppDangerSoftBrush}" CornerRadius="4" Padding="8,4"
                                                            Margin="0,4,0,0"
                                                            Visibility="{Binding HasTabCodeError, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding TabCodeError}"
                                                                   Foreground="{DynamicResource AppDangerBrush}" FontSize="11" />
                                                    </Border>
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Chỉ a-z, 0-9, dấu gạch dưới (_). VD: thong_tin, bao_hiem" />
                                                </StackPanel>

                                                <!-- Title Key (auto preview) -->
                                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                                    <TextBlock Text="Title Key (tự động)"
                                                               Style="{StaticResource FieldLabelStyle}" />
                                                    <Border Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6"
                                                            BorderBrush="{StaticResource BorderBrush}"
                                                            BorderThickness="1" Padding="10,7">
                                                        <TextBlock Text="{Binding TabTitleKeyPreview}"
                                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource MutedBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="{Binding TabTitleKeyPreview}" />
                                                    </Border>
                                                    <TextBlock Style="{StaticResource HelpTextStyle}"
                                                               Text="Tự sinh từ Table Code + tab + Tab Code. Dùng tra Sys_Resource." />
                                                </StackPanel>

                                                <!-- Icon Key + Thứ tự -->
                                                <Grid Margin="0,0,0,18">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="16" />
                                                        <ColumnDefinition Width="90" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Icon Key"
                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                        <dxe:TextEdit EditValue="{Binding SelectedTab.IconKey, UpdateSourceTrigger=PropertyChanged}"
                                                                      NullText="VD: user, file-text"
                                                                      ToolTip="Icon tùy chọn trên tab header (không phải text dịch)." />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Thứ tự"
                                                                   Style="{StaticResource FieldLabelStyle}" />
                                                        <dxe:TextEdit EditValue="{Binding SelectedTab.OrderNo, UpdateSourceTrigger=PropertyChanged}"
                                                                      NullText="0"
                                                                      ToolTip="Thứ tự hiển thị tab (trái → phải)." />
                                                    </StackPanel>
                                                </Grid>

                                                <dxe:CheckEdit IsChecked="{Binding SelectedTab.IsDefault}"
                                                               Content="Tab mặc định (mở đầu tiên khi load form)"
                                                               FontSize="13"
                                                               ToolTip="Tab tự mở khi form load. Tối đa 1 tab/form — bật tab này sẽ tắt tab khác." />
                                            </StackPanel>
                                        </Border>

                                        <!-- Card: Tên hiển thị đa ngôn ngữ (popup) -->
                                        <Border Style="{StaticResource SectionCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="TÊN HIỂN THỊ (ĐA NGÔN NGỮ)"
                                                           Style="{StaticResource SectionTitleStyle}" />
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6"
                                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                            Padding="10,8" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding SelectedTab.ResourceVi}"
                                                                   FontSize="13" Foreground="{DynamicResource AppTextBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   ToolTip="Tiêu đề tab tiếng Việt hiện tại" />
                                                    </Border>
                                                    <dx:SimpleButton Grid.Column="2"
                                                                     Command="{Binding OpenTabI18nCommand}"
                                                                     Height="34" Padding="12,0"
                                                                     ToolTip="Mở popup nhập bản dịch cho tất cả ngôn ngữ">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" />
                                                            <TextBlock Text="Dịch" Margin="6,0,0,0" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </dx:SimpleButton>
                                                </Grid>
                                                <TextBlock Style="{StaticResource HelpTextStyle}"
                                                           Text="Nhấn 🌐 Dịch để nhập/sửa tiêu đề tab mọi ngôn ngữ (lưu ngay). Cần đặt Tab Code trước để sinh key." />
                                            </StackPanel>
                                        </Border>

                                        <!-- Xóa Tab (Tab tự lưu khi thay đổi hợp lệ) -->
                                        <Grid Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <dx:SimpleButton Grid.Column="0"
                                                             Command="{Binding DeleteTabCommand}"
                                                             Content="Xóa Tab" Height="34" Padding="14,0"
                                                             ToolTip="Xóa tab — section thuộc tab sẽ gỡ về dạng phẳng." />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0"
                                                       Style="{StaticResource HelpTextStyle}"
                                                       Text="✓ Tự động lưu khi sửa (Tab Code hợp lệ)." />
                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 3: Quick Property Bar (D1 single + D2 bulk)
             ═══════════════════════════════════════════════════════════════ -->
        <!-- Single-field mode (D1) -->
        <Border Grid.Row="3"
                Margin="16,8,16,0" Padding="14,10"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}"
                Visibility="{Binding IsSingleFieldEditMode, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Field code badge -->
                <Border Grid.Column="0"
                        Background="{StaticResource AccentLightBrush}"
                        CornerRadius="4" Padding="8,3" Margin="0,0,10,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,4,0" Foreground="{StaticResource AccentDarkBrush}" />
                        <TextBlock Text="{Binding SelectedNode.Code}"
                                   FontFamily="Cascadia Code, Consolas"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentDarkBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Editor type -->
                <TextBlock Grid.Column="1" Text="Editor:" FontSize="11"
                           Margin="6,0,4,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <dxe:ComboBoxEdit Grid.Column="2"
                                  Width="130" Height="28"
                                  ItemsSource="{Binding AvailableEditorTypes}"
                                  EditValue="{Binding SelectedNode.EditorType, UpdateSourceTrigger=PropertyChanged}"

                                  Margin="0,0,12,0" VerticalAlignment="Center" />

                <!-- ColSpan -->
                <TextBlock Grid.Column="3" Text="ColSpan:" FontSize="11"
                           Margin="0,0,4,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <dxe:ComboBoxEdit Grid.Column="4"
                                  Width="60" Height="28"
                                  ItemsSource="{Binding ColSpanOptions}"
                                  EditValue="{Binding SelectedNode.ColSpan, UpdateSourceTrigger=PropertyChanged}"

                                  Margin="0,0,14,0" VerticalAlignment="Center"
                                  ToolTip="1=1/4, 2=Half, 3=3/4, 4=Full" />

                <!-- Toggle group -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <dxe:CheckEdit Content="Required"
                                   IsChecked="{Binding SelectedNode.IsRequired, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,12,0" FontSize="12"
                                   ToolTip="Không cho để trống" />
                    <dxe:CheckEdit Content="Visible"
                                   IsChecked="{Binding SelectedNode.IsVisible, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,12,0" FontSize="12"
                                   ToolTip="Hiển thị trên form" />
                    <dxe:CheckEdit Content="ReadOnly"
                                   IsChecked="{Binding SelectedNode.IsReadOnly, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,12,0" FontSize="12"
                                   ToolTip="Chỉ xem, không sửa được" />
                    <dxe:CheckEdit Content="Lock@Edit"
                                   IsChecked="{Binding SelectedNode.LockOnEdit, UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="12"
                                   ToolTip="Khóa khi sửa (cho nhập lúc tạo, không cho đổi khi update)" />
                </StackPanel>

                <!-- Spacer column 6 (empty) -->
                <Border Grid.Column="6" Width="14" />

                <!-- Status indicator -->
                <TextBlock Grid.Column="7"
                           Text="{Binding FieldQuickSaveStatusText}"
                           FontSize="11" Opacity="0.7"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,12,0"
                           Foreground="{StaticResource MutedBrush}" />

                <!-- Open Full Config button -->
                <dx:SimpleButton Grid.Column="8"
                                 Command="{Binding OpenFieldConfigCommand}"
                                 Height="28" Padding="10,0"
                                 ToolTip="Mở cấu hình chi tiết (Ctrl+Enter)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" FontSize="13" VerticalAlignment="Center" />
                        <TextBlock Text="Chi tiết" Margin="5,0,0,0" FontSize="11" />
                    </StackPanel>
                </dx:SimpleButton>
            </Grid>
        </Border>

        <!-- Bulk-edit mode (D2) — visible khi ≥ 2 field duoc tick -->
        <Border Grid.Row="3"
                Margin="16,8,16,0" Padding="14,10"
                Background="{DynamicResource AppWarningSoftBrush}"
                BorderBrush="{DynamicResource AppWarningBrush}" BorderThickness="1"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}"
                Visibility="{Binding IsBulkMode, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Bulk count badge -->
                <Border Grid.Column="0"
                        Background="{DynamicResource AppWarningBrush}"
                        CornerRadius="4" Padding="8,3" Margin="0,0,12,0"
                        VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center">
                        <Run Text="⚡ Bulk edit:" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                        <Run Text="{Binding BulkCount, Mode=OneWay}" Foreground="White" FontSize="12" FontWeight="Bold" />
                        <Run Text="field" Foreground="White" FontSize="11" />
                    </TextBlock>
                </Border>

                <!-- Editor type — "" = giu nguyen -->
                <TextBlock Grid.Column="1" Text="Editor:" FontSize="11"
                           Margin="4,0,4,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <dxe:ComboBoxEdit Grid.Column="2"
                                  Width="130" Height="28"
                                  ItemsSource="{Binding BulkEditorTypeOptions}"
                                  EditValue="{Binding BulkEditorType, UpdateSourceTrigger=PropertyChanged}"

                                  NullText="(giữ nguyên)"
                                  Margin="0,0,12,0" VerticalAlignment="Center"
                                  ToolTip="Trống = giữ nguyên cho mỗi field" />

                <!-- ColSpan — 0 = giu nguyen -->
                <TextBlock Grid.Column="3" Text="ColSpan:" FontSize="11"
                           Margin="0,0,4,0" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}" />
                <dxe:ComboBoxEdit Grid.Column="4"
                                  Width="78" Height="28"
                                  ItemsSource="{Binding BulkColSpanOptions}"
                                  EditValue="{Binding BulkColSpan, UpdateSourceTrigger=PropertyChanged}"

                                  Margin="0,0,14,0" VerticalAlignment="Center"
                                  ToolTip="0 = giữ nguyên, 1..4 = đổi sang ColSpan đó" />

                <!-- 3-state checkboxes: null = giu nguyen, true/false = doi cho tat ca -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <dxe:CheckEdit Content="Required"
                                   IsThreeState="True"
                                   IsChecked="{Binding BulkIsRequired, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,12,0" FontSize="12"
                                   ToolTip="Trạng thái xám = giữ nguyên" />
                    <dxe:CheckEdit Content="Visible"
                                   IsThreeState="True"
                                   IsChecked="{Binding BulkIsVisible, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,12,0" FontSize="12" />
                    <dxe:CheckEdit Content="ReadOnly"
                                   IsThreeState="True"
                                   IsChecked="{Binding BulkIsReadOnly, UpdateSourceTrigger=PropertyChanged}"
                                   Margin="0,0,12,0" FontSize="12" />
                    <dxe:CheckEdit Content="Lock@Edit"
                                   IsThreeState="True"
                                   IsChecked="{Binding BulkLockOnEdit, UpdateSourceTrigger=PropertyChanged}"
                                   FontSize="12" />
                </StackPanel>

                <!-- Spacer column 6 -->
                <Border Grid.Column="6" Width="14" />

                <!-- Delete button — xóa hàng loạt field đã tick -->
                <dx:SimpleButton Grid.Column="7"
                                 Command="{Binding DeleteBulkCommand}"
                                 Height="28" Padding="12,0" Margin="0,0,6,0"
                                 ToolTip="Xóa tất cả field đã chọn khỏi form (không hoàn tác)">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppDangerBrush}" />
                        <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppDangerDarkBrush}">
                            <Run Text="Xóa (" /><Run Text="{Binding BulkCount, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                    </StackPanel>
                </dx:SimpleButton>

                <!-- Apply button -->
                <dx:SimpleButton Grid.Column="8"
                                 Command="{Binding ApplyBulkCommand}"
                                 Height="28" Padding="14,0" Margin="0,0,6,0"
                                 ToolTip="Áp dụng các thay đổi vào tất cả field đã chọn">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" FontSize="13" VerticalAlignment="Center"
                                   FontWeight="Bold" Foreground="{DynamicResource AppSuccessBrush}" />
                        <TextBlock VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" FontWeight="SemiBold">
                            <Run Text="Apply (" /><Run Text="{Binding BulkCount, Mode=OneWay}" /><Run Text=")" />
                        </TextBlock>
                    </StackPanel>
                </dx:SimpleButton>

                <!-- Clear button -->
                <dx:SimpleButton Grid.Column="9"
                                 Command="{Binding ClearBulkSelectionCommand}"
                                 Height="28" Padding="10,0"
                                 ToolTip="Bỏ chọn tất cả">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✕" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="Clear" Margin="5,0,0,0" FontSize="11" />
                    </StackPanel>
                </dx:SimpleButton>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 4: Status bar
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Margin="16,8,16,12" Padding="14,8"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                CornerRadius="8"
                Effect="{StaticResource CardShadow}">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource AccentLightBrush}"
                            CornerRadius="4" Padding="8,3" Margin="0,0,12,0">
                        <TextBlock FontSize="11" Foreground="{StaticResource AccentDarkBrush}"
                                   FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} sections · {1} fields">
                                    <Binding Path="TotalSections" />
                                    <Binding Path="TotalFields" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="Form_Id:" FontSize="11"
                               Foreground="{StaticResource MutedBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding FormId}" FontSize="11"
                               FontFamily="Cascadia Code, Consolas"
                               Foreground="{StaticResource MutedBrush}"
                               Margin="4,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
