<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.ColumnPickerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="520" MinHeight="360" MaxHeight="600"
             mc:Ignorable="d"
             Background="#F8FAFC">

    <UserControl.Resources>
        <!-- ── Action button ─────────────────────────────────── -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="18,0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost button ──────────────────────────────────── -->
        <Style x:Key="GhostBtnStyle" TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                BorderBrush="#CBD5E1" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── ListBox item: loại bỏ default highlight màu xanh ─ -->
        <Style x:Key="ColumnItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding"                    Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBd"
                                Background="White"
                                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                                Padding="14,9">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#F0F9FF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#DBEAFE" />
                                <Setter TargetName="ItemBd" Property="BorderBrush" Value="#93C5FD" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header     -->
            <RowDefinition Height="Auto" />   <!-- Search bar -->
            <RowDefinition Height="*"    />   <!-- List       -->
            <RowDefinition Height="Auto" />   <!-- Footer     -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- HEADER                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Border Background="#EFF6FF" CornerRadius="8" Width="36" Height="36"
                        Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="📋" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Chọn Column"
                               FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" />
                    <TextBlock Text="{Binding FilteredColumns.Count, StringFormat={}{0} column khả dụng}"
                               FontSize="12" Foreground="#64748B" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- SEARCH BAR                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="#94A3B8" />

                <TextBox Grid.Column="1"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="1" BorderBrush="#CBD5E1"
                         Background="White" Height="32" Padding="8,0"
                         VerticalContentAlignment="Center" FontSize="13"
                         ToolTip="Tìm theo Column Code hoặc Data Type">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- COLUMN LIST                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <ListBox Grid.Row="2"
                 ItemsSource="{Binding FilteredColumns}"
                 SelectedItem="{Binding SelectedColumn}"
                 ItemContainerStyle="{StaticResource ColumnItemStyle}"
                 BorderThickness="0"
                 Background="White"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <!-- Double-click → ExecuteSelect trực tiếp -->
                    <Grid>
                        <Grid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding DataContext.SelectCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}" />
                        </Grid.InputBindings>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Column Code -->
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ColumnCode}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center" />

                        <!-- DataType badge -->
                        <Border Grid.Column="1"
                                Background="#EFF6FF" CornerRadius="4"
                                Padding="7,2" VerticalAlignment="Center"
                                Margin="8,0,6,0">
                            <TextBlock Text="{Binding DataType}"
                                       FontSize="11" Foreground="#1D4ED8"
                                       FontFamily="Cascadia Code, Consolas" />
                        </Border>

                        <!-- Nullable badge -->
                        <Border Grid.Column="2"
                                CornerRadius="4" Padding="7,2"
                                VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#FEF3C7" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNullable}" Value="False">
                                            <Setter Property="Background" Value="#F1F5F9" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text"       Value="NULL" />
                                        <Setter Property="Foreground" Value="#92400E" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsNullable}" Value="False">
                                                <Setter Property="Text"       Value="NOT NULL" />
                                                <Setter Property="Foreground" Value="#475569" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- FOOTER BUTTONS                                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1"
                        Content="Hủy"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource GhostBtnStyle}" />

                <Button Grid.Column="3"
                        Command="{Binding SelectCommand}"
                        Style="{StaticResource ActionBtnStyle}"
                        Background="#3B82F6" Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Chọn" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
