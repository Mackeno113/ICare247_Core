<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.SysLookupManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700" d:DesignWidth="1200"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ──────────────────────────────────────────── -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="14,10"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📋" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <StackPanel>
                    <TextBlock Text="Quản lý Sys_Lookup" FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock Text="Danh mục dùng chung — Gender, MaritalStatus, BloodType, ..."
                               FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                </StackPanel>
                <dx:SimpleButton Content="⟳ Tải lại" Margin="16,0,0,0"
                                 Command="{Binding RefreshCommand}"
                                 IsEnabled="{Binding IsNotBusy}" />
                <TextBlock Text="⏳" FontSize="16" Margin="12,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <!-- ── Body — 2 cột ────────────────────────────────────── -->
        <Grid Grid.Row="1" Margin="16,10,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── Left: Lookup Code list ─────────────────────── -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ShellContentBackgroundBrush}"
                    BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header left -->
                    <Border Grid.Row="0" Padding="10,8" Background="#EBF4FF"
                            CornerRadius="6,6,0,0" BorderBrush="#D0E4FF" BorderThickness="0,0,0,1">
                        <TextBlock Text="Lookup Codes" FontWeight="SemiBold" FontSize="13"/>
                    </Border>

                    <!-- ListBox codes -->
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LookupCodes}"
                             SelectedItem="{Binding SelectedCode}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Padding="8,6"
                                           FontFamily="Consolas" FontSize="13"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Add new code footer -->
                    <Border Grid.Row="2" Padding="8"
                            BorderBrush="#D0E4FF" BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <dxe:TextEdit Grid.Column="0"
                                             Text="{Binding NewCodeText, UpdateSourceTrigger=PropertyChanged}"
                                             NullText="VD: BLOOD_TYPE"
                                             FontFamily="Consolas" FontSize="12"/>
                                <dx:SimpleButton Grid.Column="1" Content="+ Thêm"
                                                 Margin="4,0,0,0"
                                                 Command="{Binding AddCodeCommand}"
                                                 ToolTip="Thêm lookup code mới"/>
                            </Grid>
                            <!-- Lỗi new code -->
                            <TextBlock Text="{Binding NewCodeError}"
                                       Foreground="Red" FontSize="11"
                                       Visibility="{Binding HasNewCodeError, Converter={StaticResource BoolToVis}}"
                                       Margin="0,2,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ─── Right: Items ───────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource ShellContentBackgroundBrush}"
                        BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar items -->
                        <Border Grid.Row="0" Padding="10,8" Background="#EBF4FF"
                                CornerRadius="6,6,0,0" BorderBrush="#D0E4FF" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center"
                                           FontWeight="SemiBold" FontSize="13">
                                    <Run Text="Items —"/>
                                    <Run Text="{Binding SelectedCode, TargetNullValue='(chọn code bên trái)'}"
                                         FontFamily="Consolas" Foreground="#1565C0"/>
                                </TextBlock>
                                <dx:SimpleButton Content="+ Thêm Item" Margin="16,0,4,0"
                                                 Command="{Binding AddItemCommand}"/>
                                <dx:SimpleButton Content="✏ Sửa" Margin="4,0,4,0"
                                                 Command="{Binding EditItemCommand}"/>
                                <dx:SimpleButton Content="🗑 Xóa" Margin="4,0,0,0"
                                                 Command="{Binding DeleteItemCommand}"
                                                 ToolTip="Xóa item đang chọn (không thể hoàn tác)"/>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid items -->
                        <dxg:GridControl Grid.Row="1"
                                         ItemsSource="{Binding Items}"
                                         SelectedItem="{Binding SelectedItem}"
                                         AutoGenerateColumns="None">
                            <dxg:GridControl.View>
                                <dxg:TableView AllowEditing="False"
                                               ShowGroupPanel="False"
                                               AutoWidth="True"/>
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn FieldName="ItemCode"  Header="Item Code"  Width="140"/>
                                <dxg:GridColumn FieldName="LabelVi"   Header="Tên (VI)"   Width="160"/>
                                <dxg:GridColumn FieldName="LabelEn"   Header="Tên (EN)"   Width="160"/>
                                <dxg:GridColumn FieldName="LabelKey"  Header="Label Key"  Width="220"/>
                                <dxg:GridColumn FieldName="SortOrder" Header="Thứ tự"     Width="80"
                                                HorizontalHeaderContentAlignment="Center"/>
                                <dxg:GridColumn FieldName="IsActive"  Header="Hoạt động"  Width="90"
                                                HorizontalHeaderContentAlignment="Center">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding RowData.Row.IsActive, Mode=OneWay}"
                                                      IsEnabled="False" HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </Grid>
                </Border>

                <!-- ── Editor panel — thêm / sửa item ────────── -->
                <Border Grid.Row="1" Margin="0,8,0,0" Padding="14,12"
                        Visibility="{Binding IsEditorVisible, Converter={StaticResource BoolToVis}}"
                        Background="{DynamicResource ShellContentBackgroundBrush}"
                        BorderBrush="#FFA000" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <!-- Header editor -->
                        <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                            <Setter Property="Text" Value="✏ Sửa Item"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                            <Setter Property="Text" Value="+ Thêm Item mới"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Fields -->
                        <UniformGrid Columns="3">
                            <!-- Item Code -->
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Item Code *" FontSize="12" Margin="0,0,0,4"/>
                                <dxe:TextEdit
                                    Text="{Binding EditItemCode, UpdateSourceTrigger=PropertyChanged}"
                                    NullText="VD: KXD" FontFamily="Consolas"/>
                            </StackPanel>

                            <!-- Label Vi -->
                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Tên tiếng Việt" FontSize="12" Margin="0,0,0,4"/>
                                <dxe:TextEdit
                                    Text="{Binding EditLabelVi, UpdateSourceTrigger=PropertyChanged}"
                                    NullText="VD: Không xác định"/>
                            </StackPanel>

                            <!-- Label En -->
                            <StackPanel>
                                <TextBlock Text="Tên tiếng Anh" FontSize="12" Margin="0,0,0,4"/>
                                <dxe:TextEdit
                                    Text="{Binding EditLabelEn, UpdateSourceTrigger=PropertyChanged}"
                                    NullText="VD: Unknown"/>
                            </StackPanel>

                            <!-- Sort Order -->
                            <StackPanel Margin="0,8,12,0">
                                <TextBlock Text="Thứ tự" FontSize="12" Margin="0,0,0,4"/>
                                <dxe:SpinEdit Value="{Binding EditSortOrder}"
                                             MinValue="0" MaxValue="9999"
                                             IsFloatValue="False"/>
                            </StackPanel>

                            <!-- Is Active -->
                            <StackPanel Margin="0,8,12,0" VerticalAlignment="Bottom">
                                <dxe:CheckEdit Content="Đang hoạt động"
                                              IsChecked="{Binding EditIsActive}"
                                              Margin="0,0,0,4"/>
                            </StackPanel>

                            <!-- Buttons -->
                            <StackPanel Margin="0,8,0,0" Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <dx:SimpleButton Content="💾 Lưu"
                                                 Command="{Binding SaveItemCommand}"
                                                 IsEnabled="{Binding IsNotBusy}"
                                                 Margin="0,0,8,0"/>
                                <dx:SimpleButton Content="Hủy"
                                                 Command="{Binding CancelEditCommand}"/>
                            </StackPanel>
                        </UniformGrid>

                        <!-- Error -->
                        <TextBlock Text="{Binding EditorError}"
                                   Foreground="Red" FontSize="12"
                                   Visibility="{Binding HasEditorError, Converter={StaticResource BoolToVis}}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Status bar ────────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="16,6,16,10" Padding="10,5"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.75"/>
        </Border>
    </Grid>
</UserControl>
