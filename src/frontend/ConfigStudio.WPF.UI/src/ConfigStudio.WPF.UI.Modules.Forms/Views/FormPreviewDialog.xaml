<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FormPreviewDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="820" MinHeight="480" MaxHeight="700"
             mc:Ignorable="d"
             Background="#F8FAFC">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ── Ghost button ──────────────────────────────────── -->
        <Style x:Key="GhostBtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="18,0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush"     Value="#CBD5E1" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="#475569" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header   -->
            <RowDefinition Height="*"    />   <!-- Content  -->
            <RowDefinition Height="Auto" />   <!-- Footer   -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- HEADER                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Border Grid.Column="0" Background="#EFF6FF" CornerRadius="8"
                        Width="40" Height="40" Margin="0,0,14,0" VerticalAlignment="Center">
                    <TextBlock Text="👁" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <!-- Form info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FormName}"
                               FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="{Binding FormCode}"
                                   FontSize="12" Foreground="#64748B"
                                   FontFamily="Cascadia Code, Consolas" />
                        <TextBlock Text=" · " FontSize="12" Foreground="#CBD5E1" />
                        <TextBlock Text="{Binding Sections.Count, StringFormat={}{0} sections}"
                                   FontSize="12" Foreground="#64748B" />
                        <TextBlock Text=" · " FontSize="12" Foreground="#CBD5E1" />
                        <TextBlock Text="{Binding TotalFieldCount, StringFormat={}{0} fields}"
                                   FontSize="12" Foreground="#64748B" />
                    </StackPanel>
                </StackPanel>

                <!-- Loading badge -->
                <Border Grid.Column="2"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Background="#EFF6FF" CornerRadius="6" Padding="10,4">
                    <TextBlock Text="⏳ Đang tải..." FontSize="12" Foreground="#1D4ED8" />
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- CONTENT — lỗi tải                                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}"
                Background="#FEF2F2" CornerRadius="8" Margin="20"
                BorderBrush="#FCA5A5" BorderThickness="1" Padding="16,12">
            <StackPanel>
                <TextBlock Text="⚠ Lỗi tải preview"
                           FontSize="14" FontWeight="SemiBold" Foreground="#DC2626"
                           Margin="0,0,0,6" />
                <TextBlock Text="{Binding LoadError}"
                           FontSize="12" Foreground="#7F1D1D" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- CONTENT — sections list                             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasLoadError}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>

            <ItemsControl ItemsSource="{Binding Sections}" Margin="16,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Section card -->
                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                CornerRadius="8" Margin="0,0,0,12">
                            <StackPanel>

                                <!-- Section header -->
                                <Border Background="#F8FAFC"
                                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                                        CornerRadius="8,8,0,0" Padding="14,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayTitle}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#1E293B" />
                                        <Border Grid.Column="1"
                                                Background="#DBEAFE" CornerRadius="10" Padding="8,2">
                                            <TextBlock Text="{Binding FieldCount, StringFormat={}{0} fields}"
                                                       FontSize="11" Foreground="#1D4ED8"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Field cards — WrapPanel 4 cols -->
                                <ItemsControl ItemsSource="{Binding Fields}" Margin="10,8,10,10">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Field card -->
                                            <Border Width="180" Margin="4"
                                                    Background="White"
                                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                                    CornerRadius="6" Padding="10,8">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Opacity" Value="1" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                                <Setter Property="Opacity" Value="0.40" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <StackPanel>
                                                    <!-- Top row: EditorType badge + RO badge -->
                                                    <Grid Margin="0,0,0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                Background="{Binding EditorTypeBg}"
                                                                CornerRadius="4" Padding="6,2"
                                                                HorizontalAlignment="Left"
                                                                MaxWidth="115">
                                                            <TextBlock Text="{Binding EditorType}"
                                                                       Foreground="{Binding EditorTypeFg}"
                                                                       FontSize="10" FontWeight="SemiBold"
                                                                       FontFamily="Cascadia Code, Consolas"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>

                                                        <Border Grid.Column="1"
                                                                Visibility="{Binding IsReadOnly, Converter={StaticResource BoolToVis}}"
                                                                Background="#F1F5F9" CornerRadius="4"
                                                                Padding="5,2" Margin="4,0,0,0">
                                                            <TextBlock Text="RO" FontSize="9"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#475569" />
                                                        </Border>
                                                    </Grid>

                                                    <!-- Label key -->
                                                    <TextBlock Text="{Binding LabelKey}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#1E293B"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,0,0,2" />

                                                    <!-- Column code -->
                                                    <TextBlock Text="{Binding ColumnCode}"
                                                               FontSize="10" Foreground="#94A3B8"
                                                               FontFamily="Cascadia Code, Consolas"
                                                               TextTrimming="CharacterEllipsis" />

                                                    <!-- Rule count badge -->
                                                    <Border Visibility="{Binding RuleCount, Converter={StaticResource BoolToVis}}"
                                                            Background="#FEF3C7" CornerRadius="3"
                                                            Padding="5,1" HorizontalAlignment="Left"
                                                            Margin="0,5,0,0">
                                                        <TextBlock Text="{Binding RuleCount, StringFormat={}{0} rules}"
                                                                   FontSize="9" Foreground="#92400E" />
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- FOOTER                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Legend -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RO = ReadOnly" FontSize="11" Foreground="#94A3B8"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <TextBlock Text="  Mờ = IsVisible=false" FontSize="11" Foreground="#94A3B8"
                               VerticalAlignment="Center" />
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Đóng"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource GhostBtnStyle}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
