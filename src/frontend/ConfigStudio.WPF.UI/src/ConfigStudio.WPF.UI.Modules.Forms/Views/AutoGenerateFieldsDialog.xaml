<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.AutoGenerateFieldsDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="580" MinHeight="400" MaxHeight="680"
             mc:Ignorable="d"
             Background="#F8FAFC">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ── Badge pill ────────────────────────────────────── -->
        <Style x:Key="EditorBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius"    Value="4" />
            <Setter Property="Padding"         Value="7,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Column row ────────────────────────────────────── -->
        <Style x:Key="ColumnRowStyle" TargetType="Border">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding"         Value="14,10" />
        </Style>

        <!-- ── Action button ─────────────────────────────────── -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="18,0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost button ──────────────────────────────────── -->
        <Style x:Key="GhostBtnStyle" TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                BorderBrush="#CBD5E1" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header     -->
            <RowDefinition Height="Auto" />   <!-- Subheader toolbar -->
            <RowDefinition Height="*"    />   <!-- Column list -->
            <RowDefinition Height="Auto" />   <!-- Section picker -->
            <RowDefinition Height="Auto" />   <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- HEADER                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#EFF6FF" CornerRadius="8" Width="36" Height="36"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="✨" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" />
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <!-- Thống kê cột -->
                            <Border Background="#F0FDF4" CornerRadius="4" Padding="7,2" Margin="0,0,6,0">
                                <TextBlock FontSize="11" Foreground="#16A34A">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} cột sẽ tạo">
                                            <Binding Path="SelectedCount" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                            <Border Background="#FEF3C7" CornerRadius="4" Padding="7,2"
                                    Visibility="{Binding SkippedCount, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="11" Foreground="#92400E">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} cột ẩn (PK/Identity)">
                                            <Binding Path="SkippedCount" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- SUBHEADER — Select All / Deselect All               -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Chọn cột cần tạo field:"
                           FontSize="12" FontWeight="SemiBold" Foreground="#475569"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <Button Content="Tất cả" Command="{Binding SelectAllCommand}"
                        Style="{StaticResource GhostBtnStyle}"
                        Height="26" Padding="10,0" FontSize="12" FontWeight="Normal"
                        Margin="0,0,6,0" />
                <Button Content="Bỏ chọn" Command="{Binding DeselectAllCommand}"
                        Style="{StaticResource GhostBtnStyle}"
                        Height="26" Padding="10,0" FontSize="12" FontWeight="Normal" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- COLUMN LIST                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">

            <!-- Loading indicator -->
            <Grid>
                <!-- Spinner khi đang load -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="⏳  Đang đọc schema từ Target DB..." FontSize="13"
                               Foreground="#64748B" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Error message -->
                <Border Margin="20" CornerRadius="6" Padding="16"
                        Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding LoadError}"
                               FontSize="13" Foreground="#DC2626" TextWrapping="Wrap" />
                </Border>

                <!-- Column list — luôn hiển thị; khi IsLoading thì collection rỗng nên list trống -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding VisibleColumns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ColumnRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />   <!-- CheckBox -->
                                            <ColumnDefinition Width="*"    />   <!-- Column info -->
                                            <ColumnDefinition Width="Auto" />   <!-- EditorType badge -->
                                        </Grid.ColumnDefinitions>

                                        <!-- CheckBox -->
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                  VerticalAlignment="Center" Margin="0,0,12,0" />

                                        <!-- Column name + type info -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Column.ColumnName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#1E293B" />
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock Text="{Binding Column.DataType}"
                                                           FontSize="11" Foreground="#64748B"
                                                           FontFamily="Cascadia Code, Consolas" />
                                                <TextBlock Text=" · " FontSize="11" Foreground="#CBD5E1" />
                                                <!-- NULL / NOT NULL badge dùng DataTrigger -->
                                                <TextBlock FontSize="11" Text="NULL" Foreground="#94A3B8">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text"       Value="NOT NULL" />
                                                            <Setter Property="Foreground" Value="#64748B" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Column.IsNullable}" Value="True">
                                                                    <Setter Property="Text"       Value="NULL" />
                                                                    <Setter Property="Foreground" Value="#94A3B8" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- EditorType badge -->
                                        <Border Grid.Column="2" Style="{StaticResource EditorBadgeStyle}"
                                                Background="{Binding EditorTypeBadgeColor}"
                                                Opacity="0.15">
                                            <TextBlock Text="{Binding Column.DefaultEditorType}"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{Binding EditorTypeBadgeColor}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- SECTION PICKER                                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Thêm vào Section:"
                           FontSize="12" FontWeight="SemiBold" Foreground="#475569"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableSections}"
                          SelectedItem="{Binding SelectedSection}"
                          DisplayMemberPath="Label"
                          Height="34" FontSize="13" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- FOOTER BUTTONS                                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="4" Background="White" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"    />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10"   />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Busy indicator -->
                <TextBlock Grid.Column="0"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                           Text="Đang tải..." FontSize="12" Foreground="#64748B"
                           VerticalAlignment="Center" />

                <!-- Cancel -->
                <Button Grid.Column="1"
                        Content="Hủy"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource GhostBtnStyle}" />

                <!-- Generate -->
                <Button Grid.Column="3"
                        Command="{Binding GenerateCommand}"
                        Style="{StaticResource ActionBtnStyle}"
                        Background="#3B82F6" Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✨" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}Tạo {0} Fields">
                                    <Binding Path="SelectedCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>

</UserControl>
