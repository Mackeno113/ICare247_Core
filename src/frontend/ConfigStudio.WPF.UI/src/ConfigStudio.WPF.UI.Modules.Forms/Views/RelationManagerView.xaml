<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.RelationManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="760"
             d:DesignWidth="1280"
             mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="EditorLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────── -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <TextBlock Text="🔗 Quản lý quan hệ (Sys_Relation)" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                    <Border Background="{DynamicResource AppAccentSoftBrush}" BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1"
                            CornerRadius="4" Padding="10,5" Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="12" Foreground="{DynamicResource AppAccentDarkBrush}"
                                   Text="Registry quan hệ master-detail + soft-check FK khi xóa" />
                    </Border>
                    <dxe:CheckEdit Content="Hiện đã ẩn" IsChecked="{Binding ShowInactive}"
                                   VerticalAlignment="Center" Margin="14,0,0,0" />
                </StackPanel>

                <Border Grid.Row="1" Margin="0,10,0,0" Padding="10,8"
                        Background="{DynamicResource AppDangerSoftBrush}" BorderBrush="{DynamicResource AppDangerLightBrush}" BorderThickness="1" CornerRadius="6"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding LoadErrorMessage}" Foreground="{DynamicResource AppDangerDarkBrush}"
                                   FontSize="12" TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <!-- ── Master-detail ───────────────────────────────── -->
        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" MinWidth="360" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="1*" MinWidth="380" />
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="Transparent"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                          Cursor="SizeWE" ToolTip="Kéo để chỉnh độ rộng 2 bên">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Border Background="{TemplateBinding Background}">
                            <Border Width="2" HorizontalAlignment="Center" CornerRadius="1"
                                    Background="{DynamicResource AppBorderStrongBrush}" />
                        </Border>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <!-- Lưới danh sách quan hệ -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">
                <dxg:GridControl ItemsSource="{Binding Relations}"
                                 SelectedItem="{Binding SelectedRelation, Mode=TwoWay}"
                                 AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                       AllowEditing="False" AllowPerPixelScrolling="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn Header="Id" FieldName="RelationId" Width="46" />
                        <dxg:GridColumn Header="Mã" FieldName="RelationCode" Width="110" />
                        <dxg:GridColumn Header="Bảng cha" FieldName="MasterTableCode" Width="*" />
                        <dxg:GridColumn Header="Bảng con" FieldName="DetailTableCode" Width="*" />
                        <dxg:GridColumn Header="Cột FK" FieldName="DetailFkColumn" Width="140" />
                        <dxg:GridColumn Header="Loại" FieldName="RelationType" Width="90" />
                        <dxg:GridColumn Header="On_Delete" FieldName="OnDelete" Width="80" />
                        <dxg:GridColumn Header="Active" FieldName="IsActive" Width="56" />
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </Border>

            <!-- Editor -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource AppSurfaceBrush}">
                <Grid Margin="14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding EditorTitle}"
                               FontSize="18" FontWeight="SemiBold" Margin="0,0,0,10"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Relation_Code (tùy chọn, unique)" Style="{StaticResource EditorLabel}" />
                            <dxe:TextEdit EditValue="{Binding EditRelationCode, UpdateSourceTrigger=PropertyChanged}"
                                          NullText="VD: NhanVien_NoiSinh_TinhThanhPho" Margin="0,0,0,10" />

                            <TextBlock Text="Bảng cha (Master) * — phía '1'" Style="{StaticResource EditorLabel}" />
                            <dxe:ComboBoxEdit ItemsSource="{Binding Tables}" DisplayMember="DisplayText"
                                              SelectedItem="{Binding EditMasterTable}"
 NullText="Chọn bảng cha..." Margin="0,0,0,10" />

                            <TextBlock Text="Master_Key_Column (cột khóa bảng cha)" Style="{StaticResource EditorLabel}" />
                            <dxe:ComboBoxEdit ItemsSource="{Binding MasterColumns}"
                                              EditValue="{Binding EditMasterKeyColumn, UpdateSourceTrigger=PropertyChanged}"
                                              IsTextEditable="True" NullText="Id" Margin="0,0,0,10" />

                            <TextBlock Text="Bảng con (Detail) * — phía 'N'" Style="{StaticResource EditorLabel}" />
                            <dxe:ComboBoxEdit ItemsSource="{Binding Tables}" DisplayMember="DisplayText"
                                              SelectedItem="{Binding EditDetailTable}"
 NullText="Chọn bảng con..." Margin="0,0,0,10" />

                            <TextBlock Text="Detail_FK_Column * — cột FK ở bảng con trỏ về cha" Style="{StaticResource EditorLabel}" />
                            <dxe:ComboBoxEdit ItemsSource="{Binding DetailColumns}"
                                              EditValue="{Binding EditDetailFkColumn, UpdateSourceTrigger=PropertyChanged}"
                                              IsTextEditable="True" NullText="VD: NoiSinh_TinhThanhPhoID" Margin="0,0,0,10" />

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Relation_Type" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding RelationTypeOptions}"
                                                      EditValue="{Binding EditRelationType}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="On_Delete (xóa master)" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding OnDeleteOptions}"
                                                      EditValue="{Binding EditOnDelete}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Display_Column (cột cha hiển thị)" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding MasterColumns}"
                                                      EditValue="{Binding EditDisplayColumn, UpdateSourceTrigger=PropertyChanged}"
                                                      IsTextEditable="True" NullText="VD: Ten" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Value_Column (cột cha giá trị)" Style="{StaticResource EditorLabel}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding MasterColumns}"
                                                      EditValue="{Binding EditValueColumn, UpdateSourceTrigger=PropertyChanged}"
                                                      IsTextEditable="True" NullText="VD: Id" />
                                </StackPanel>
                            </Grid>

                            <dxe:CheckEdit Content="Is_Active (quan hệ đang dùng)" IsChecked="{Binding EditIsActive}"
                                           Margin="0,0,0,10" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── Thanh hành động ──────────────────────────────── -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,10"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <dx:SimpleButton Content="＋ Tạo mới" Width="100" Command="{Binding NewCommand}"
                                 ToolTip="Ctrl+N — soạn quan hệ mới" />
                <dx:SimpleButton Content="💾 Lưu" Width="90" Margin="8,0,0,0" Command="{Binding SaveCommand}"
                                 ToolTip="Ctrl+S — lưu quan hệ đang soạn" />
                <dx:SimpleButton Content="🗑 Ẩn" Width="80" Margin="8,0,0,0" Command="{Binding DeleteCommand}"
                                 ToolTip="Ẩn (soft-delete) quan hệ đang chọn" />
                <dx:SimpleButton Content="⟳ Tải lại" Width="90" Margin="8,0,0,0" Command="{Binding RefreshCommand}"
                                 ToolTip="F5 — tải lại danh sách" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
