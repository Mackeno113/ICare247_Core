<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FieldConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Models"
             xmlns:conv="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700"
             d:DesignWidth="950"
             mc:Ignorable="d"
             Background="#F1F5F9">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisConverter x:Key="InvBoolToVis" />

        <!-- ── Color Palette (giống FormEditorView) ────────────── -->
        <Color x:Key="AccentColor">#3B82F6</Color>
        <Color x:Key="AccentDarkColor">#1D4ED8</Color>
        <Color x:Key="AccentLightColor">#DBEAFE</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="MutedColor">#64748B</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="SuccessColor">#22C55E</Color>
        <Color x:Key="WarnColor">#F59E0B</Color>

        <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush"   Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="AccentLightBrush"  Color="{StaticResource AccentLightColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"      Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="MutedBrush"        Color="{StaticResource MutedColor}" />
        <SolidColorBrush x:Key="BorderBrush"       Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="DangerBrush"       Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="SuccessBrush"      Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="WarnBrush"         Color="{StaticResource WarnColor}" />

        <!-- ── Shadows ────────────────────────────────────────── -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="1"
                          Direction="270" Opacity="0.08" Color="#000000" />

        <!-- ── Section Card ───────────────────────────────────── -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="8" />
            <Setter Property="Padding"          Value="20,16" />
            <Setter Property="Margin"           Value="0,0,0,12" />
            <Setter Property="Effect"           Value="{StaticResource CardShadow}" />
        </Style>

        <!-- ── Section Title ──────────────────────────────────── -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="Margin"     Value="0,0,0,14" />
        </Style>

        <!-- ── Field Label ────────────────────────────────────── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin"     Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ── Help Text ──────────────────────────────────────── -->
        <Style x:Key="HelpTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11" />
            <Setter Property="Foreground"  Value="{StaticResource MutedBrush}" />
            <Setter Property="Opacity"     Value="0.75" />
            <Setter Property="Margin"      Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ── Field Group ────────────────────────────────────── -->
        <Style x:Key="FieldGroupStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <!-- ── Icon Button ────────────────────────────────────── -->
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width"           Value="32" />
            <Setter Property="Height"          Value="32" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Foreground"      Value="#475569" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E2E8F0" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Inline Delete Button ───────────────────────────── -->
        <Style x:Key="InlineDeleteBtnStyle" TargetType="Button" BasedOn="{StaticResource IconBtnStyle}">
            <Setter Property="Width"      Value="28" />
            <Setter Property="Height"     Value="28" />
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Small Secondary Button (+ Thêm cột / + Thêm param) ── -->
        <Style x:Key="SmallSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height"           Value="26" />
            <Setter Property="Padding"          Value="10,0" />
            <Setter Property="FontSize"         Value="11" />
            <Setter Property="Foreground"       Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="Background"       Value="Transparent" />
            <Setter Property="BorderBrush"      Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#BFDBFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab Badge ──────────────────────────────────────── -->
        <Style x:Key="TabBadgeStyle" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource AccentLightBrush}" />
            <Setter Property="CornerRadius"  Value="10" />
            <Setter Property="Padding"       Value="7,2" />
            <Setter Property="Margin"        Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Control Props DataTemplates ─────────────────────── -->
        <DataTemplate x:Key="StringPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}">
                <TextBlock Text="{Binding Definition.Label}" Style="{StaticResource FieldLabelStyle}" />
                <dxe:TextEdit EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              NullText="{Binding Definition.Description}" />
                <TextBlock Text="{Binding Definition.Description}" Style="{StaticResource HelpTextStyle}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="NumberPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}">
                <TextBlock Text="{Binding Definition.Label}" Style="{StaticResource FieldLabelStyle}" />
                <dxe:TextEdit EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              NullText="0" Width="150" HorizontalAlignment="Left" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="BooleanPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}" Orientation="Horizontal">
                <dxe:ToggleSwitchEdit IsChecked="{Binding Value}" Margin="0,0,10,0" />
                <TextBlock Text="{Binding Definition.Label}" VerticalAlignment="Center"
                           FontSize="13" Foreground="#374151" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="EnumPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}">
                <TextBlock Text="{Binding Definition.Label}" Style="{StaticResource FieldLabelStyle}" />
                <dxe:ComboBoxEdit ItemsSource="{Binding Definition.AllowedValues}"
                                  EditValue="{Binding Value}"
                                  Width="220" HorizontalAlignment="Left" />
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: Header bar -->
            <RowDefinition Height="Auto" />  <!-- 1: Error banner (ẩn khi không có lỗi) -->
            <RowDefinition Height="*" />     <!-- 2: TabControl -->
            <RowDefinition Height="Auto" />  <!-- 3: Footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0: Header Bar — back + field info + dirty indicator
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,12">
            <DockPanel>
                <!-- ← Back -->
                <Button DockPanel.Dock="Left" Command="{Binding CancelCommand}"
                        ToolTip="Quay lại Form Editor"
                        Style="{StaticResource IconBtnStyle}" Width="36" Height="36">
                    <TextBlock Text="←" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MutedBrush}" />
                </Button>

                <!-- Accent bar -->
                <Border DockPanel.Dock="Left" Width="3" Height="28"
                        Background="{StaticResource AccentBrush}" CornerRadius="2"
                        Margin="12,0,14,0" VerticalAlignment="Center" />

                <!-- Title -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Cấu hình Field" FontSize="17" FontWeight="Bold"
                                   Foreground="#0F172A" />
                        <!-- Dirty indicator -->
                        <TextBlock Text=" ●" FontSize="14" Foreground="{StaticResource WarnBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"
                                   ToolTip="Có thay đổi chưa lưu" />
                    </StackPanel>
                    <!-- Breadcrumb -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Form" FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text=" › " FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding SectionName}" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text=" › " FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding ColumnCode}" FontSize="12"
                                   FontFamily="Cascadia Code, Consolas"
                                   Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                </StackPanel>

                <!-- Actions: Save + Cancel -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <dx:SimpleButton Command="{Binding CancelCommand}" Content="Hủy"
                                     Margin="0,0,8,0" />
                    <dx:SimpleButton Command="{Binding SaveFieldCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" VerticalAlignment="Center" />
                            <TextBlock Text=" Lưu Field" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </dx:SimpleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             BANNER: Lỗi load dữ liệu (chỉ hiện khi HasLoadError = true)
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="#FEF2F2" BorderBrush="#FECACA" BorderThickness="0,0,0,1"
                Padding="16,8"
                Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="14" Foreground="#DC2626"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding LoadError, Mode=OneWay}"
                           FontSize="12" Foreground="#DC2626"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 1: TabControl — 4 tabs
             ═══════════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="2" Margin="16,12,16,0"
                    Background="Transparent" BorderThickness="0">

            <!-- ═══ TAB 1: Basic ═══════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Cơ bản" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel>

                        <!-- ── Card: Thông Tin Cơ Bản ─────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Thông Tin Cơ Bản" Style="{StaticResource SectionTitleStyle}" />

                                <!-- Column (DB) -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Column (DB)" Style="{StaticResource FieldLabelStyle}" />
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Command="{Binding BrowseColumnCommand}"
                                                ToolTip="Browse columns" Style="{StaticResource IconBtnStyle}"
                                                Margin="6,0,0,0">
                                            <TextBlock Text="🔍" FontSize="13" />
                                        </Button>
                                        <dxe:ComboBoxEdit ItemsSource="{Binding AvailableColumns}"
                                                          EditValue="{Binding SelectedColumn}"
                                                          DisplayMember="DisplayName"
                                                          NullText="Chọn column..." />
                                    </DockPanel>
                                    <TextBlock Text="Cột DB mà field này bind vào. Quyết định kiểu dữ liệu và constraint."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Net Type (readonly) -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Net Type" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding NetType}" FontSize="13"
                                               FontFamily="Cascadia Code, Consolas"
                                               Foreground="#0891B2" Background="#F8FAFC"
                                               Padding="10,8" />
                                    <TextBlock Text="Kiểu dữ liệu .NET tự động xác định từ column đã chọn."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Editor Type -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Editor Type" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding AvailableEditorTypes}"
                                                      EditValue="{Binding SelectedEditorType}"
                                                      Width="280" HorizontalAlignment="Left" />
                                    <TextBlock Text="Loại UI component hiển thị field. Thay đổi sẽ cập nhật tab Control Props."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Order No -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Thứ tự hiển thị" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:TextEdit EditValue="{Binding OrderNo, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="100" HorizontalAlignment="Left" />
                                    <TextBlock Text="Thứ tự sắp xếp field trong section (Order_No)."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ── Card: Display (i18n) ───────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Display (i18n)" Style="{StaticResource SectionTitleStyle}"
                                               DockPanel.Dock="Left" Margin="0" />
                                    <Button DockPanel.Dock="Right" Command="{Binding ManageI18nCommand}"
                                            HorizontalAlignment="Right"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Mở quản lý i18n">
                                        <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                                            <Run Text="🌐" /><Run Text=" Manage i18n →" />
                                        </TextBlock>
                                    </Button>
                                </DockPanel>

                                <!-- Label Key -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Label Key" Style="{StaticResource FieldLabelStyle}" />
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" Background="#F0FDFA"
                                                CornerRadius="4" Padding="8,5" Margin="8,0,0,0">
                                            <TextBlock FontSize="11" Foreground="#0D9488">
                                                <Run Text="→ " />
                                                <Run Text="{Binding LabelPreview, Mode=OneWay}" FontWeight="SemiBold" />
                                            </TextBlock>
                                        </Border>
                                        <dxe:TextEdit EditValue="{Binding LabelKey, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="vd: lbl.soluong" />
                                    </DockPanel>
                                    <TextBlock Text="Key trong Sys_Resource. Preview hiển thị giá trị đã dịch."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Placeholder Key -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Placeholder Key" Style="{StaticResource FieldLabelStyle}" />
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" Background="#F0FDFA"
                                                CornerRadius="4" Padding="8,5" Margin="8,0,0,0">
                                            <TextBlock FontSize="11" Foreground="#0D9488">
                                                <Run Text="→ " />
                                                <Run Text="{Binding PlaceholderPreview, Mode=OneWay}" FontWeight="SemiBold" />
                                            </TextBlock>
                                        </Border>
                                        <dxe:TextEdit EditValue="{Binding PlaceholderKey, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="vd: ph.soluong" />
                                    </DockPanel>
                                </StackPanel>

                                <!-- Tooltip Key -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Tooltip Key" Style="{StaticResource FieldLabelStyle}" />
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right" Background="#F0FDFA"
                                                CornerRadius="4" Padding="8,5" Margin="8,0,0,0">
                                            <TextBlock FontSize="11" Foreground="#0D9488">
                                                <Run Text="→ " />
                                                <Run Text="{Binding TooltipPreview, Mode=OneWay}" FontWeight="SemiBold" />
                                            </TextBlock>
                                        </Border>
                                        <dxe:TextEdit EditValue="{Binding TooltipKey, UpdateSourceTrigger=PropertyChanged}"
                                                      NullText="vd: tip.soluong" />
                                    </DockPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB 2: Control Props ═══════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Control Props" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel>

                        <!-- Editor type badge -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <TextBlock Text="Cấu hình cho " FontSize="13" FontWeight="SemiBold"
                                               Foreground="#1E293B" VerticalAlignment="Center" />
                                    <Border Background="{StaticResource AccentLightBrush}"
                                            CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="{Binding SelectedEditorType}" FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentDarkBrush}" />
                                    </Border>
                                </StackPanel>

                                <!-- Dynamic props form -->
                                <ItemsControl ItemsSource="{Binding ControlProps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ControlPropValue}">
                                            <ContentControl Content="{Binding}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource StringPropTemplate}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Definition.PropType}" Value="Number">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource NumberPropTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Definition.PropType}" Value="Boolean">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource BooleanPropTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Definition.PropType}" Value="Enum">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource EnumPropTemplate}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Lookup Config (chỉ hiện khi EditorType = RadioGroup / LookupComboBox) -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding IsLookupEditor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Cấu hình Lookup" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1E293B" Margin="0,0,0,12" />

                                <!-- Lookup Code -->
                                <TextBlock Text="Lookup Code" FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3" />
                                <dxe:ComboBoxEdit ItemsSource="{Binding AvailableLookupCodes}"
                                                  EditValue="{Binding LookupCode, UpdateSourceTrigger=PropertyChanged}"
                                                  IsTextEditable="True"
                                                  Height="32" Margin="0,0,0,4" />
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}"
                                           Margin="0,0,0,12">
                                    <Run Text="Mã danh mục trong Sys_Lookup. VD: " />
                                    <Run Text="GENDER" FontFamily="Consolas" Foreground="{StaticResource AccentDarkBrush}" />
                                </TextBlock>

                                <!-- Preview items -->
                                <TextBlock Text="Xem trước options:" FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"
                                           Visibility="{Binding LookupPreviewItems.Count, Converter={StaticResource BoolToVis}}" />
                                <ItemsControl ItemsSource="{Binding LookupPreviewItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <Border Background="{StaticResource AccentLightBrush}"
                                                        CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding ItemCode}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource AccentDarkBrush}" />
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="12"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── FK Lookup Config (chỉ hiện khi EditorType = LookupBox) ── -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding IsFkLookupEditor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Cấu hình FK Lookup" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#1E293B" Margin="0,0,0,14" />

                                <!-- ── Mode selector ──────────────────────────── -->
                                <TextBlock Text="Chế độ truy vấn" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#374151" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <RadioButton Content="Bảng / View"
                                             IsChecked="{Binding IsTableMode, Mode=OneWay}"
