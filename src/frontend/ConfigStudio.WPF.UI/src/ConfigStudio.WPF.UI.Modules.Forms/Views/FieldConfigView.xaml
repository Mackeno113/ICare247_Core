<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FieldConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Models"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700"
             d:DesignWidth="900"
             mc:Ignorable="d">

    <UserControl.Resources>
        <!-- Template selector cho ControlPropValue dựa trên PropType -->
        <DataTemplate x:Key="StringPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <DockPanel Margin="0,4">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Definition.Label}"
                           Width="200" VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                <dxe:TextEdit EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              NullText="{Binding Definition.Description}"
                              Margin="8,0,0,0" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="NumberPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <DockPanel Margin="0,4">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Definition.Label}"
                           Width="200" VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                <dxe:TextEdit EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              NullText="Nhập số..."
                              Margin="8,0,0,0" Width="150" HorizontalAlignment="Left" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="BooleanPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <DockPanel Margin="0,4">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Definition.Label}"
                           Width="200" VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                <dxe:ToggleSwitchEdit IsChecked="{Binding Value}"
                                      Margin="8,0,0,0" HorizontalAlignment="Left" />
            </DockPanel>
        </DataTemplate>

        <DataTemplate x:Key="EnumPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <DockPanel Margin="0,4">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Definition.Label}"
                           Width="200" VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                <dxe:ComboBoxEdit ItemsSource="{Binding Definition.AllowedValues}"
                                  EditValue="{Binding Value}"
                                  Margin="8,0,0,0" Width="200" HorizontalAlignment="Left" />
            </DockPanel>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- ── Header ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Height="52"
                Background="{DynamicResource ShellTitleBarBackgroundBrush}"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <Button DockPanel.Dock="Left"
                        Command="{Binding CancelCommand}"
                        ToolTip="Quay lại Form Editor"
                        Background="Transparent" BorderBrush="Transparent"
                        Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="←" VerticalAlignment="Center" FontSize="16" Foreground="White" />
                        <TextBlock Text="Back" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="White" />
                    </StackPanel>
                </Button>

                <TextBlock DockPanel.Dock="Left" Margin="16,0,0,0"
                           VerticalAlignment="Center" Foreground="White"
                           FontSize="16" FontWeight="SemiBold">
                    <Run Text="Field: " />
                    <Run Text="{Binding ColumnCode, Mode=OneWay}" FontWeight="Bold" />
                </TextBlock>

                <TextBlock DockPanel.Dock="Left" Margin="16,0,0,0"
                           VerticalAlignment="Center" Foreground="#B0BEC5"
                           FontSize="13">
                    <Run Text="Section: " />
                    <Run Text="{Binding SectionName, Mode=OneWay}" />
                </TextBlock>

                <!-- Breadcrumb -->
                <TextBlock DockPanel.Dock="Right" Margin="0,0,8,0"
                           VerticalAlignment="Center" Foreground="#90CAF9"
                           FontSize="12">
                    <Run Text="Form" />
                    <Run Text=" › " />
                    <Run Text="{Binding SectionName, Mode=OneWay}" />
                    <Run Text=" › " />
                    <Run Text="{Binding ColumnCode, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Height="52"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <dx:SimpleButton Command="{Binding SaveFieldCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" VerticalAlignment="Center" />
                            <TextBlock Text="Save Field" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </dx:SimpleButton>
                    <dx:SimpleButton Command="{Binding CancelCommand}" Content="Cancel" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Command="{Binding AddRuleCommand}"
                            Background="Transparent" BorderBrush="Transparent"
                            Content="Go to Validation Rules →"
                            Margin="0,0,8,0" />
                    <Button Command="{Binding AddEventCommand}"
                            Background="Transparent" BorderBrush="Transparent"
                            Content="Go to Events →" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ── TabControl (Fill) ──────────────────────────────── -->
        <TabControl Margin="16">

            <!-- ═══ TAB 1: Basic ═══════════════════════════════ -->
            <TabItem Header="Basic">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                    <StackPanel Margin="0,8,0,0">

                        <!-- Card: Thông Tin Cơ Bản -->
                        <Border Padding="16" Margin="0,0,0,16"
                                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource ShellContentBackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="Thông Tin Cơ Bản" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                           Margin="0,0,0,12" />

                                <!-- Column (DB) -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left" Text="Column (DB):" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <Button DockPanel.Dock="Right" Command="{Binding BrowseColumnCommand}"
                                            ToolTip="Browse columns" Padding="8,4" Margin="8,0,0,0"
                                            Background="Transparent" BorderBrush="Transparent">
                                        <TextBlock Text="🔍" />
                                    </Button>
                                    <dxe:ComboBoxEdit ItemsSource="{Binding AvailableColumns}"
                                                      EditValue="{Binding SelectedColumn}"
                                                      DisplayMember="DisplayName"
                                                      NullText="Chọn column..."
                                                      Margin="8,0,0,0" />
                                </DockPanel>

                                <!-- Net Type (readonly) -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left" Text="Net Type:" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <TextBlock Text="{Binding NetType}" VerticalAlignment="Center"
                                               Margin="8,0,0,0" FontWeight="SemiBold"
                                               Foreground="#0891B2" />
                                </DockPanel>

                                <!-- Editor Type -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left" Text="Editor Type:" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding AvailableEditorTypes}"
                                                      EditValue="{Binding SelectedEditorType}"
                                                      Margin="8,0,0,0" Width="250" HorizontalAlignment="Left" />
                                </DockPanel>

                                <!-- Order No -->
                                <DockPanel Margin="0,0,0,0">
                                    <TextBlock DockPanel.Dock="Left" Text="Order No:" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <dxe:TextEdit EditValue="{Binding OrderNo, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="8,0,0,0" Width="80" HorizontalAlignment="Left" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card: Display -->
                        <Border Padding="16" Margin="0,0,0,16"
                                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource ShellContentBackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="Display" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                           Margin="0,0,0,12" />

                                <!-- Label Key -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left" Text="Label Key:" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               Margin="12,0,0,0" FontStyle="Italic"
                                               Foreground="#0891B2">
                                        <Run Text="Preview: " />
                                        <Run Text="{Binding LabelPreview, Mode=OneWay}" FontWeight="SemiBold" />
                                    </TextBlock>
                                    <dxe:TextEdit EditValue="{Binding LabelKey, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="vd: lbl.soluong"
                                                  Margin="8,0,0,0" />
                                </DockPanel>

                                <!-- Placeholder Key -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left" Text="Placeholder Key:" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               Margin="12,0,0,0" FontStyle="Italic"
                                               Foreground="#0891B2">
                                        <Run Text="Preview: " />
                                        <Run Text="{Binding PlaceholderPreview, Mode=OneWay}" FontWeight="SemiBold" />
                                    </TextBlock>
                                    <dxe:TextEdit EditValue="{Binding PlaceholderKey, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="vd: ph.soluong"
                                                  Margin="8,0,0,0" />
                                </DockPanel>

                                <!-- Tooltip Key -->
                                <DockPanel Margin="0,0,0,12">
                                    <TextBlock DockPanel.Dock="Left" Text="Tooltip Key:" Width="120"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                                    <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center"
                                               Margin="12,0,0,0" FontStyle="Italic"
                                               Foreground="#0891B2">
                                        <Run Text="Preview: " />
                                        <Run Text="{Binding TooltipPreview, Mode=OneWay}" FontWeight="SemiBold" />
                                    </TextBlock>
                                    <dxe:TextEdit EditValue="{Binding TooltipKey, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="vd: tip.soluong"
                                                  Margin="8,0,0,0" />
                                </DockPanel>

                                <!-- Manage i18n button -->
                                <Button Command="{Binding ManageI18nCommand}"
                                        HorizontalAlignment="Left" Margin="120,0,0,0"
                                        Background="Transparent" BorderBrush="Transparent">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🌐" VerticalAlignment="Center" />
                                        <TextBlock Text="Manage i18n Keys →" Margin="6,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Card: Behavior -->
                        <Border Padding="16" Margin="0,0,0,16"
                                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6"
                                Background="{DynamicResource ShellContentBackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="Behavior" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                           Margin="0,0,0,12" />

                                <WrapPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,32,8">
                                        <TextBlock Text="Is Visible:" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}"
                                                   Margin="0,0,8,0" />
                                        <dxe:ToggleSwitchEdit IsChecked="{Binding IsVisible}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,32,8">
                                        <TextBlock Text="Is ReadOnly:" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}"
                                                   Margin="0,0,8,0" />
                                        <dxe:ToggleSwitchEdit IsChecked="{Binding IsReadOnly}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <TextBlock Text="Required:" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}"
                                                   Margin="0,0,8,0" />
                                        <dxe:ToggleSwitchEdit IsChecked="{Binding IsRequired}" />
                                        <TextBlock Text="(shortcut tạo Required rule)" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" FontSize="11"
                                                   Opacity="0.6" />
                                    </StackPanel>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB 2: Control Props ═══════════════════════ -->
            <TabItem Header="Control Props">
                <DockPanel Margin="8">
                    <TextBlock DockPanel.Dock="Top" Margin="0,8,0,16" FontSize="14"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                        <Run Text="Cấu hình thuộc tính cho Editor Type: " />
                        <Run Text="{Binding SelectedEditorType, Mode=OneWay}" FontWeight="Bold"
                             Foreground="{DynamicResource ShellTitleBarBackgroundBrush}" />
                    </TextBlock>

                    <!-- Raw JSON Preview -->
                    <Expander DockPanel.Dock="Bottom" Header="Raw JSON Preview"
                              IsExpanded="False" Margin="0,16,0,0">
                        <TextBox Text="{Binding ControlPropsJson, Mode=OneWay}"
                                 IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="12"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MaxHeight="200"
                                 Margin="0,8,0,0" />
                    </Expander>

                    <!-- Dynamic props form -->
                    <Border Padding="16" BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                        <ItemsControl ItemsSource="{Binding ControlProps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ControlPropValue}">
                                    <ContentControl Content="{Binding}">
                                        <ContentControl.Style>
                                            <Style TargetType="ContentControl">
                                                <Setter Property="ContentTemplate" Value="{StaticResource StringPropTemplate}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Definition.PropType}" Value="Number">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource NumberPropTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Definition.PropType}" Value="Boolean">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource BooleanPropTemplate}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Definition.PropType}" Value="Enum">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource EnumPropTemplate}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ContentControl.Style>
                                    </ContentControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══ TAB 3: Validation Rules ════════════════════ -->
            <TabItem Header="Validation Rules">
                <DockPanel Margin="8">
                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <dx:SimpleButton Command="{Binding AddRuleCommand}" ToolTip="Thêm rule mới">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" VerticalAlignment="Center" />
                                <TextBlock Text="Add Rule" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </dx:SimpleButton>
                    </StackPanel>

                    <!-- Rules GridControl -->
                    <dxg:GridControl ItemsSource="{Binding LinkedRules}"
                                     AutoPopulateColumns="False"
                                     Margin="0,0,0,0">
                        <dxg:GridControl.View>
                            <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                           AllowPerPixelScrolling="True" />
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn Header="Order" FieldName="OrderNo" Width="60" />
                            <dxg:GridColumn Header="Rule Type" FieldName="RuleTypeCode" Width="120" />
                            <dxg:GridColumn Header="Expression Preview" FieldName="ExpressionPreview" Width="*" />
                            <dxg:GridColumn Header="Error Key" FieldName="ErrorKey" Width="140" />
                            <dxg:GridColumn Header="Active" FieldName="IsActive" Width="70" />
                            <dxg:GridColumn Header="" Width="80" AllowEditing="False" AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.OpenRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    ToolTip="Cấu hình rule" Width="28" Height="28"
                                                    Background="Transparent" BorderBrush="Transparent">
                                                <TextBlock Text="⚙" />
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    ToolTip="Xóa rule" Width="28" Height="28"
                                                    Foreground="#EF4444"
                                                    Background="Transparent" BorderBrush="Transparent">
                                                <TextBlock Text="🗑" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </DockPanel>
            </TabItem>

            <!-- ═══ TAB 4: Events ══════════════════════════════ -->
            <TabItem Header="Events">
                <DockPanel Margin="8">
                    <!-- Toolbar -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <dx:SimpleButton Command="{Binding AddEventCommand}" ToolTip="Thêm event mới">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" VerticalAlignment="Center" />
                                <TextBlock Text="Add Event" Margin="4,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </dx:SimpleButton>
                    </StackPanel>

                    <!-- Events GridControl -->
                    <dxg:GridControl ItemsSource="{Binding LinkedEvents}"
                                     AutoPopulateColumns="False"
                                     Margin="0,0,0,0">
                        <dxg:GridControl.View>
                            <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                           AllowPerPixelScrolling="True" />
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn Header="Event ID" FieldName="EventId" Width="80" />
                            <dxg:GridColumn Header="Trigger" FieldName="TriggerCode" Width="120" />
                            <dxg:GridColumn Header="Condition Preview" FieldName="ConditionPreview" Width="*" />
                            <dxg:GridColumn Header="Actions" FieldName="ActionsCount" Width="100" />
                            <dxg:GridColumn Header="Active" FieldName="IsActive" Width="70" />
                            <dxg:GridColumn Header="" Width="50" AllowEditing="False" AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.OpenEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                CommandParameter="{Binding Row}"
                                                ToolTip="Cấu hình event" Width="28" Height="28"
                                                Background="Transparent" BorderBrush="Transparent">
                                            <TextBlock Text="⚙" />
                                        </Button>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </DockPanel>
            </TabItem>

        </TabControl>
    </DockPanel>
</UserControl>
