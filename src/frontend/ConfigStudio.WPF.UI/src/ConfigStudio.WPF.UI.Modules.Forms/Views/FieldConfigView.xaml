                                                    <!-- Filter SQL riêng -->
                                                    <TextBlock Text="Filter SQL (tùy chọn)" FontSize="10"
                                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                    <dxe:TextEdit Height="28"
                                                                  Text="{Binding FilterSql, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="VD: Is_Active = 1 AND Tenant_Id = @TenantId"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Kiểm tra & Diễn giải ───────────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding IsFkLookupEditor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Left" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#374151" VerticalAlignment="Center">
                                        <Run Text="🔍 "/>
                                        <Run Text="Kiểm tra &amp; Diễn giải cấu hình"/>
                                    </TextBlock>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                            Command="{Binding ExplainConfigCommand}"
                                            Style="{StaticResource SmallSecondaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▶ " FontSize="10"/>
                                            <TextBlock Text="Diễn giải"/>
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"
                                           Text="Bấm Diễn giải để kiểm tra toàn bộ cấu hình bằng tiếng Việt trước khi lưu."/>

                                <!-- Kết quả diễn giải -->
                                <Border Visibility="{Binding HasConfigExplanation, Converter={StaticResource BoolToVis}}"
                                        Background="#F8FAFC" CornerRadius="6" Padding="12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <TextBox Text="{Binding ConfigExplanation, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Cascadia Code, Consolas" FontSize="11"
                                             Foreground="#1E293B"
                                             Background="Transparent" BorderThickness="0"
                                             TextWrapping="Wrap" AcceptsReturn="True"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- JSON Preview -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <Expander Header="Raw JSON Preview" IsExpanded="False">
                                <TextBox Text="{Binding ControlPropsJson, Mode=OneWay}"
                                         IsReadOnly="True"
                                         FontFamily="Cascadia Code, Consolas" FontSize="12"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MaxHeight="200" Margin="0,8,0,0"
                                         Background="#F8FAFC" BorderBrush="{StaticResource BorderBrush}"
                                         Padding="10,8" />
                            </Expander>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB 3: Validation Rules ════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Rules" VerticalAlignment="Center" />
                        <Border Style="{StaticResource TabBadgeStyle}">
                            <TextBlock Text="{Binding LinkedRules.Count}" FontSize="10"
                                       FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel Margin="0,12,0,0">
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardStyle}"
                            Padding="12,8" Margin="0,0,0,8">
                        <DockPanel>
                            <dx:SimpleButton DockPanel.Dock="Left"
                                             Command="{Binding AddRuleCommand}"
                                             ToolTip="Thêm validation rule mới">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text=" Thêm Rule" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </dx:SimpleButton>

                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}">
                                <Run Text="Tổng: " />
                                <Run Text="{Binding LinkedRules.Count, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text=" rule" />
                            </TextBlock>
                        </DockPanel>
                    </Border>

                    <!-- Rules DataGrid -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                            Effect="{StaticResource CardShadow}">
                        <dxg:GridControl ItemsSource="{Binding LinkedRules}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                               AllowPerPixelScrolling="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="#" FieldName="OrderNo" Width="45" />
                                <dxg:GridColumn Header="Rule Type" FieldName="RuleTypeCode" Width="110" />
                                <dxg:GridColumn Header="Expression" FieldName="ExpressionPreview" Width="*" />
                                <dxg:GridColumn Header="Error Key" FieldName="ErrorKey" Width="130" />
                                <dxg:GridColumn Header="Active" FieldName="IsActive" Width="60" />
                                <dxg:GridColumn Header="" Width="70" AllowEditing="False" AllowSorting="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource IconBtnStyle}"
                                                        Width="28" Height="28" FontSize="13"
                                                        Command="{Binding DataContext.OpenRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Cấu hình rule" Content="⚙" />
                                                <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                                        Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Xóa rule" Content="🗑" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══ TAB 4: Events ══════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Events" VerticalAlignment="Center" />
                        <Border Style="{StaticResource TabBadgeStyle}">
                            <TextBlock Text="{Binding LinkedEvents.Count}" FontSize="10"
                                       FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel Margin="0,12,0,0">
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardStyle}"
                            Padding="12,8" Margin="0,0,0,8">
                        <DockPanel>
                            <dx:SimpleButton DockPanel.Dock="Left"
                                             Command="{Binding AddEventCommand}"
                                             ToolTip="Thêm event mới">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text=" Thêm Event" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </dx:SimpleButton>

                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}">
                                <Run Text="Tổng: " />
                                <Run Text="{Binding LinkedEvents.Count, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text=" event" />
                            </TextBlock>
                        </DockPanel>
                    </Border>

                    <!-- Events DataGrid -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                            Effect="{StaticResource CardShadow}">
                        <dxg:GridControl ItemsSource="{Binding LinkedEvents}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                               AllowPerPixelScrolling="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="ID" FieldName="EventId" Width="60" />
                                <dxg:GridColumn Header="Trigger" FieldName="TriggerCode" Width="110" />
                                <dxg:GridColumn Header="Condition" FieldName="ConditionPreview" Width="*" />
                                <dxg:GridColumn Header="Actions" FieldName="ActionsCount" Width="70" />
                                <dxg:GridColumn Header="Active" FieldName="IsActive" Width="60" />
                                <dxg:GridColumn Header="" Width="45" AllowEditing="False" AllowSorting="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource IconBtnStyle}"
                                                    Width="28" Height="28" FontSize="13"
                                                    Command="{Binding DataContext.OpenEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    ToolTip="Cấu hình event" Content="⚙" />
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </Border>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2: Footer — navigate links
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding AddRuleCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,16,0">
                    <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                        <Run Text="Validation Rules →" />
                    </TextBlock>
                </Button>
                <Button Command="{Binding AddEventCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                        <Run Text="Events →" />
                    </TextBlock>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
