<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FieldConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Models"
             xmlns:conv="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Converters"
             xmlns:coreconv="clr-namespace:ConfigStudio.WPF.UI.Core.Converters;assembly=ConfigStudio.WPF.UI.Core"
             xmlns:panels="clr-namespace:ConfigStudio.WPF.UI.Modules.Forms.Views.Panels.ControlProps"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="700"
             d:DesignWidth="950"
             mc:Ignorable="d"
             FontFamily="{DynamicResource AppFontFamily}"
             Background="{DynamicResource AppPageBackgroundBrush}">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveFieldCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <coreconv:InverseBoolToVisConverter x:Key="InvBoolToVis" />
        <conv:ColSpanConverter x:Key="ColSpanConverter" />

        <!-- ── Color Palette (giống FormEditorView) ────────────── -->
        <Color x:Key="AccentColor">#3B82F6</Color>
        <Color x:Key="AccentDarkColor">#1D4ED8</Color>
        <Color x:Key="AccentLightColor">#DBEAFE</Color>
        <Color x:Key="SurfaceColor">#FFFFFF</Color>
        <Color x:Key="MutedColor">#64748B</Color>
        <Color x:Key="BorderColor">#E2E8F0</Color>
        <Color x:Key="DangerColor">#EF4444</Color>
        <Color x:Key="SuccessColor">#22C55E</Color>
        <Color x:Key="WarnColor">#F59E0B</Color>

        <SolidColorBrush x:Key="AccentBrush"      Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentDarkBrush"   Color="{StaticResource AccentDarkColor}" />
        <SolidColorBrush x:Key="AccentLightBrush"  Color="{StaticResource AccentLightColor}" />
        <SolidColorBrush x:Key="SurfaceBrush"      Color="{StaticResource SurfaceColor}" />
        <SolidColorBrush x:Key="MutedBrush"        Color="{StaticResource MutedColor}" />
        <SolidColorBrush x:Key="BorderBrush"       Color="{StaticResource BorderColor}" />
        <SolidColorBrush x:Key="DangerBrush"       Color="{StaticResource DangerColor}" />
        <SolidColorBrush x:Key="SuccessBrush"      Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="WarnBrush"         Color="{StaticResource WarnColor}" />

        <!-- ── Shadows ────────────────────────────────────────── -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="8" ShadowDepth="1"
                          Direction="270" Opacity="0.08" Color="{DynamicResource AppTextStrongColor}" />

        <!-- ── Section Card ───────────────────────────────────── -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="8" />
            <Setter Property="Padding"          Value="20,16" />
            <Setter Property="Margin"           Value="0,0,0,12" />
            <Setter Property="Effect"           Value="{StaticResource CardShadow}" />
        </Style>

        <!-- ── Section Title ──────────────────────────────────── -->
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Margin"     Value="0,0,0,14" />
        </Style>

        <!-- ── Field Label ────────────────────────────────────── -->
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="Margin"     Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- ── Help Text ──────────────────────────────────────── -->
        <Style x:Key="HelpTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize"    Value="11" />
            <Setter Property="Foreground"  Value="{StaticResource MutedBrush}" />
            <Setter Property="Opacity"     Value="0.75" />
            <Setter Property="Margin"      Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- ── Field Group ────────────────────────────────────── -->
        <Style x:Key="FieldGroupStyle" TargetType="StackPanel">
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <!-- ── Icon Button ────────────────────────────────────── -->
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width"           Value="32" />
            <Setter Property="Height"          Value="32" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Foreground"      Value="{DynamicResource AppTextSecondaryBrush}" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Inline Delete Button ───────────────────────────── -->
        <Style x:Key="InlineDeleteBtnStyle" TargetType="Button" BasedOn="{StaticResource IconBtnStyle}">
            <Setter Property="Width"      Value="28" />
            <Setter Property="Height"     Value="28" />
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppDangerSoftBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Small Secondary Button (+ Thêm cột / + Thêm param) ── -->
        <Style x:Key="SmallSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height"           Value="26" />
            <Setter Property="Padding"          Value="10,0" />
            <Setter Property="FontSize"         Value="11" />
            <Setter Property="Foreground"       Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="Background"       Value="Transparent" />
            <Setter Property="BorderBrush"      Value="{StaticResource AccentDarkBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentLightBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab Badge ──────────────────────────────────────── -->
        <Style x:Key="TabBadgeStyle" TargetType="Border">
            <Setter Property="Background"    Value="{StaticResource AccentLightBrush}" />
            <Setter Property="CornerRadius"  Value="10" />
            <Setter Property="Padding"       Value="7,2" />
            <Setter Property="Margin"        Value="6,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- ── Control Props DataTemplates ─────────────────────── -->
        <DataTemplate x:Key="StringPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}">
                <TextBlock Text="{Binding Definition.Label}" Style="{StaticResource FieldLabelStyle}" />
                <dxe:TextEdit EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              NullText="{Binding Definition.Description}" />
                <TextBlock Text="{Binding Definition.Description}" Style="{StaticResource HelpTextStyle}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="NumberPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}">
                <TextBlock Text="{Binding Definition.Label}" Style="{StaticResource FieldLabelStyle}" />
                <dxe:TextEdit EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                              NullText="0" Width="150" HorizontalAlignment="Left" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="BooleanPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}" Orientation="Horizontal">
                <dxe:ToggleSwitchEdit IsChecked="{Binding Value}" Margin="0,0,10,0" />
                <TextBlock Text="{Binding Definition.Label}" VerticalAlignment="Center"
                           FontSize="13" Foreground="{DynamicResource AppTextSecondaryBrush}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="EnumPropTemplate" DataType="{x:Type models:ControlPropValue}">
            <StackPanel Style="{StaticResource FieldGroupStyle}">
                <TextBlock Text="{Binding Definition.Label}" Style="{StaticResource FieldLabelStyle}" />
                <dxe:ComboBoxEdit ItemsSource="{Binding Definition.AllowedValues}"
                                  EditValue="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                  Width="220" HorizontalAlignment="Left" />
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 0: Header bar -->
            <RowDefinition Height="Auto" />  <!-- 1: Error banner (ẩn khi không có lỗi) -->
            <RowDefinition Height="*" />     <!-- 2: Content (Left Panel + TabControl) -->
            <RowDefinition Height="Auto" />  <!-- 3: Footer -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />  <!-- 0: Left Panel — Field Navigator -->
            <ColumnDefinition Width="*" />    <!-- 1: Main content — TabControl -->
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 0: Header Bar — back + field info + dirty indicator
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Style="{DynamicResource AppCommandBarHostStyle}"
                Padding="20,12">
            <DockPanel>
                <!-- ← Back -->
                <Button DockPanel.Dock="Left" Command="{Binding CancelCommand}"
                        ToolTip="Quay lại Form Editor"
                        Style="{StaticResource IconBtnStyle}" Width="36" Height="36">
                    <TextBlock Text="←" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource MutedBrush}" />
                </Button>

                <!-- Accent bar -->
                <Border DockPanel.Dock="Left" Width="3" Height="28"
                        Background="{StaticResource AccentBrush}" CornerRadius="2"
                        Margin="12,0,14,0" VerticalAlignment="Center" />

                <!-- Title -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Cấu hình Field" FontSize="17" FontWeight="Bold"
                                   Foreground="{DynamicResource AppTextStrongBrush}" />
                        <!-- Dirty indicator -->
                        <TextBlock Text=" ●" FontSize="14" Foreground="{StaticResource WarnBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}"
                                   ToolTip="Có thay đổi chưa lưu" />
                    </StackPanel>
                    <!-- Breadcrumb: FormName › SectionName › ColumnCode -->
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,4">
                        <TextBlock Text="{Binding FormName}" FontSize="12"
                                   Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text=" › " FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding SectionName}" FontSize="12"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text=" › " FontSize="12" Foreground="{StaticResource MutedBrush}" />
                        <TextBlock Text="{Binding ColumnCode}" FontSize="12"
                                   FontFamily="Cascadia Code, Consolas"
                                   Foreground="{StaticResource AccentDarkBrush}" FontWeight="SemiBold" />
                    </StackPanel>
                    <!-- Badge row: EditorType | IsRequired | DataType -->
                    <StackPanel Orientation="Horizontal">
                        <!-- EditorType badge -->
                        <Border Background="{DynamicResource AppAccentSoftBrush}" CornerRadius="4" Padding="7,2" Margin="0,0,6,0">
                            <TextBlock Text="{Binding SelectedEditorType}" FontSize="11"
                                       Foreground="{DynamicResource AppAccentDarkBrush}" FontWeight="SemiBold" />
                        </Border>
                        <!-- IsRequired badge (chỉ hiện khi IsRequired = true) -->
                        <Border Background="{DynamicResource AppDangerSoftBrush}" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                Visibility="{Binding IsRequired, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Required" FontSize="11" Foreground="{DynamicResource AppDangerBrush}" FontWeight="SemiBold" />
                        </Border>
                        <!-- DataType badge (chỉ hiện khi có column được chọn) -->
                        <Border Background="{DynamicResource AppSuccessSoftBrush}" CornerRadius="4" Padding="7,2"
                                Visibility="{Binding HasDataType, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding DataTypeDisplay}" FontSize="11"
                                       Foreground="{DynamicResource AppSuccessDarkBrush}" FontFamily="Cascadia Code, Consolas" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Actions: Save + Cancel -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <dx:SimpleButton Command="{Binding CancelCommand}" Content="Hủy"
                                     Margin="0,0,8,0" />
                    <dx:SimpleButton Command="{Binding SaveFieldCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" VerticalAlignment="Center" />
                            <TextBlock Text=" Lưu Field" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </dx:SimpleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             BANNER: Lỗi load dữ liệu (chỉ hiện khi HasLoadError = true)
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Style="{DynamicResource AppErrorBannerStyle}"
                Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="14" Foreground="{DynamicResource AppDangerBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding LoadError, Mode=OneWay}"
                           FontSize="12" Foreground="{DynamicResource AppDangerBrush}"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             BANNER: Lỗi save (chỉ hiện khi HasSaveError = true)
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.ColumnSpan="2"
                Style="{DynamicResource AppStateBannerStyle}"
                Margin="0,32,0,0"
                Visibility="{Binding HasSaveError, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="💾" FontSize="14" Foreground="{DynamicResource AppWarningDarkBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock Text="{Binding SaveError, Mode=OneWay}"
                           FontSize="12" Foreground="{DynamicResource AppWarningDarkBrush}"
                           VerticalAlignment="Center" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2 / COL 0: Left Panel — Field Navigator
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Panel header -->
                <Border DockPanel.Dock="Top" Background="{DynamicResource AppSurfaceMutedBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <DockPanel>
                        <Button DockPanel.Dock="Right"
                                Command="{Binding RefreshNavigatorCommand}"
                                ToolTip="Tải lại danh sách fields"
                                Background="Transparent" BorderThickness="0"
                                Padding="4" Cursor="Hand">
                            <dx:DXImage Source="{dx:DXImage Image=Refresh_16x16.png}" Width="14" Height="14" />
                        </Button>
                        <TextBlock Text="Fields" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource MutedBrush}" />
                    </DockPanel>
                </Border>
                <!-- Field list grouped by section -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              ContextMenuOpening="OnNavigatorContextMenuOpening">
                    <!-- Bulk multi-select: tick field → right-click chuyển sang Section khác (y hệt FormEditor).
                         ContextMenu.DataContext = VM qua PlacementTarget; mỗi item mang sẵn MoveCommand. -->
                    <ScrollViewer.ContextMenu>
                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext,
                                                   RelativeSource={RelativeSource Self}}">
                            <MenuItem Header="{Binding BulkMoveHeader}"
                                      ItemsSource="{Binding MoveTargets}"
                                      IsEnabled="{Binding CanMoveBulk}">
                                <MenuItem.ItemContainerStyle>
                                    <Style TargetType="MenuItem">
                                        <Setter Property="Header" Value="{Binding Header}" />
                                        <Setter Property="Command" Value="{Binding MoveCommand}" />
                                        <Setter Property="CommandParameter" Value="{Binding}" />
                                    </Style>
                                </MenuItem.ItemContainerStyle>
                            </MenuItem>
                        </ContextMenu>
                    </ScrollViewer.ContextMenu>
                    <ItemsControl ItemsSource="{Binding FieldNavigatorGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- Section header — hiện tên section đã resolve (fallback mã); ToolTip giữ mã -->
                                    <Border Background="{DynamicResource AppPageBackgroundBrush}" Padding="10,5"
                                            ToolTip="{Binding SectionCode}">
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <!-- Field items -->
                                    <ItemsControl ItemsSource="{Binding Fields}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Background="Transparent" Tag="hidden">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Tag" Value="visible" />
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Bulk multi-select checkbox — ẩn với cột chưa tạo field -->
                                                    <CheckBox Grid.Column="0" Margin="8,0,0,0"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding IsMultiChecked, Mode=TwoWay}"
                                                              Click="OnFieldBulkChecked"
                                                              ToolTip="Chọn để chuyển sang Section khác">
                                                        <CheckBox.Style>
                                                            <Style TargetType="CheckBox">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsColumnOnly}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </CheckBox.Style>
                                                    </CheckBox>

                                                    <!-- Field name + editor type -->
                                                    <Button Grid.Column="1"
                                                            Command="{Binding DataContext.NavigateToFieldCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Cursor="Hand" HorizontalContentAlignment="Stretch"
                                                            Padding="0">
                                                        <Border Padding="12,7,4,7">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsCurrentField}" Value="True">
                                                                            <Setter Property="Background" Value="{StaticResource AccentLightBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <StackPanel ToolTip="{Binding StatusTooltip}">
                                                                <!-- Dòng chính: tên field đã resolve (fallback mã) -->
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="12"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsCurrentField}" Value="True">
                                                                                    <Setter Property="Foreground" Value="{StaticResource AccentDarkBrush}" />
                                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                                </DataTrigger>
                                                                                <!-- Cột chưa tạo field → mờ đi, chữ nghiêng -->
                                                                                <DataTrigger Binding="{Binding StatusKey}" Value="column">
                                                                                    <Setter Property="FontStyle" Value="Italic" />
                                                                                    <Setter Property="Opacity" Value="0.65" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                                <!-- Dòng phụ: EditorType · mã cột (mono) + badge trạng thái -->
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding EditorType}"
                                                                               FontSize="10" VerticalAlignment="Center"
                                                                               Foreground="{StaticResource MutedBrush}" />
                                                                    <TextBlock Text=" · " FontSize="10" VerticalAlignment="Center"
                                                                               Foreground="{StaticResource MutedBrush}" />
                                                                    <TextBlock Text="{Binding EffectiveCode}"
                                                                               FontSize="10" VerticalAlignment="Center"
                                                                               FontFamily="Cascadia Code, Consolas"
                                                                               Foreground="{StaticResource MutedBrush}"
                                                                               TextTrimming="CharacterEllipsis" />
                                                                    <!-- Badge trạng thái cấu hình -->
                                                                    <Border CornerRadius="3" Padding="5,0" Margin="6,1,0,0"
                                                                            VerticalAlignment="Center">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{DynamicResource AppSuccessSoftBrush}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding StatusKey}" Value="incomplete">
                                                                                        <Setter Property="Background" Value="{DynamicResource AppWarningSoftBrush}" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding StatusKey}" Value="column">
                                                                                        <Setter Property="Background" Value="{DynamicResource AppBorderBrush}" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding StatusLabel}" FontSize="9">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Foreground" Value="{DynamicResource AppSuccessDarkBrush}" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding StatusKey}" Value="incomplete">
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AppWarningDarkBrush}" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding StatusKey}" Value="column">
                                                                                            <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Border>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>

                                                    <!-- Nút ↑↓ — chỉ hiện khi hover -->
                                                    <StackPanel Grid.Column="2" Orientation="Vertical"
                                                                VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Tag,
                                                                        RelativeSource={RelativeSource AncestorType=Grid}}"
                                                                                 Value="visible">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                    <!-- Cột chưa tạo field: chưa có Order_No → ẩn nút ↑↓ -->
                                                                    <DataTrigger Binding="{Binding IsColumnOnly}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Button Command="{Binding DataContext.MoveFieldUpCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Padding="2" Cursor="Hand" ToolTip="Lên">
                                                            <TextBlock Text="▲" FontSize="8"
                                                                       Foreground="{StaticResource MutedBrush}" />
                                                        </Button>
                                                        <Button Command="{Binding DataContext.MoveFieldDownCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Padding="2" Cursor="Hand" ToolTip="Xuống">
                                                            <TextBlock Text="▼" FontSize="8"
                                                                       Foreground="{StaticResource MutedBrush}" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 2 / COL 1: TabControl — 4 tabs
             ═══════════════════════════════════════════════════════════════ -->
        <TabControl Grid.Row="2" Grid.Column="1" Margin="16,12,16,0"
                    Background="Transparent" BorderThickness="0">

            <!-- ═══ TAB 1: Basic ═══════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Cơ bản" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel>

                        <!-- ── Card: Thông Tin Cơ Bản ─────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Thông Tin Cơ Bản" Style="{StaticResource SectionTitleStyle}" />

                                <!-- 2 cột: trái = cấu hình (60%) · phải = diễn giải editor (40%) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- ── Cột trái: cấu hình ── -->
                                    <StackPanel Grid.Column="0">

                                <!-- Section -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Section" Style="{StaticResource FieldLabelStyle}" />
                                    <dxg:LookUpEdit ItemsSource="{Binding AvailableSections}"
                                                    SelectedItem="{Binding SelectedSection}"
                                                    DisplayMember="Label"
                                                    NullText="Chọn section..." />
                                    <TextBlock Text="Section chứa field này trong form."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Column (DB) -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Column (DB)" Style="{StaticResource FieldLabelStyle}" />

                                    <!-- Luôn hiện TextEdit để nhập/xem Column Code -->
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Command="{Binding BrowseColumnCommand}"
                                                ToolTip="Chọn từ danh sách cột" Style="{StaticResource IconBtnStyle}"
                                                Margin="6,0,0,0"
                                                Visibility="{Binding HasAvailableColumns, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="🔍" FontSize="13" />
                                        </Button>
                                        <dxg:LookUpEdit ItemsSource="{Binding AvailableColumns}"
                                                        SelectedItem="{Binding SelectedColumn}"
                                                        DisplayMember="DisplayName"
                                                        NullText="Chọn từ danh sách..."
                                                        Visibility="{Binding HasAvailableColumns, Converter={StaticResource BoolToVis}}" />
                                    </DockPanel>

                                    <!-- TextEdit luôn hiển thị để nhập/sửa Column Code trực tiếp -->
                                    <dxe:TextEdit EditValue="{Binding ColumnCode, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="Nhập tên cột (ví dụ: HoVaTen)..."
                                                  Margin="0,4,0,0" />

                                    <!-- Hint khi list rỗng và không phải virtual -->
                                    <Border Background="{DynamicResource AppWarningSoftBrush}" CornerRadius="4" Padding="8,6" Margin="0,4,0,0"
                                            BorderBrush="{DynamicResource AppWarningLightBrush}" BorderThickness="1"
                                            Visibility="{Binding IsColumnListEmpty, Converter={StaticResource BoolToVis}}">
                                        <TextBlock FontSize="11" Foreground="{DynamicResource AppWarningDarkBrush}" TextWrapping="Wrap">
                                            <Run Text="⚠" /><Run Text=" Sys_Column chưa có cột. Nhập tên cột — sẽ tự tạo khi lưu. Hoặc chạy " />
                                            <Run Text="Đồng bộ Schema" FontWeight="SemiBold" /><Run Text=" trước." />
                                        </TextBlock>
                                    </Border>

                                    <TextBlock Text="Cột DB mà field này bind vào. Bỏ trống nếu bật 'Field ảo' trong tab Behavior."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>


                                <!-- Net Type (readonly) -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Net Type" Style="{StaticResource FieldLabelStyle}" />
                                    <TextBlock Text="{Binding NetType}" FontSize="13"
                                               FontFamily="Cascadia Code, Consolas"
                                               Foreground="{DynamicResource AppInfoBrush}" Background="{DynamicResource AppSurfaceMutedBrush}"
                                               Padding="10,8" />
                                    <TextBlock Text="Kiểu dữ liệu .NET tự động xác định từ column đã chọn."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Editor Type -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Editor Type" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:ComboBoxEdit ItemsSource="{Binding AvailableEditorTypes}"
                                                      EditValue="{Binding SelectedEditorType, UpdateSourceTrigger=PropertyChanged}"
                                                      Width="280" HorizontalAlignment="Left" />
                                    <TextBlock Text="Loại UI component hiển thị field. Thay đổi sẽ cập nhật tab Control Props."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Order No -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Thứ tự hiển thị" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:TextEdit EditValue="{Binding OrderNo, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="100" HorizontalAlignment="Left" />
                                    <TextBlock Text="Thứ tự sắp xếp field trong section (Order_No)."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Col Span -->
                                <StackPanel Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Độ rộng (Col Span)" Style="{StaticResource FieldLabelStyle}" />
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Content="1/4"  GroupName="ColSpan"
                                                     IsChecked="{Binding ColSpan, Converter={StaticResource ColSpanConverter}, ConverterParameter=1}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="1/2"  GroupName="ColSpan"
                                                     IsChecked="{Binding ColSpan, Converter={StaticResource ColSpanConverter}, ConverterParameter=2}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="3/4"  GroupName="ColSpan"
                                                     IsChecked="{Binding ColSpan, Converter={StaticResource ColSpanConverter}, ConverterParameter=3}"
                                                     Margin="0,0,16,0" />
                                        <RadioButton Content="Full" GroupName="ColSpan"
                                                     IsChecked="{Binding ColSpan, Converter={StaticResource ColSpanConverter}, ConverterParameter=4}" />
                                    </StackPanel>
                                    <TextBlock Text="Độ rộng field trong grid 4-column (1=1/4, 2=half, 3=3/4, 4=full)."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                    </StackPanel>

                                <!-- ── Cột phải: diễn giải editor (khoang đỏ) ── -->
                                <Border Grid.Column="2" VerticalAlignment="Top"
                                        Visibility="{Binding HasEditorTypeGuide, Converter={StaticResource BoolToVis}}"
                                        Background="{DynamicResource AppInfoSoftBrush}"
                                        BorderBrush="{DynamicResource AppInfoBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="14,12"
                                        Margin="0,0,0,16">
                                    <StackPanel>
                                        <!-- Header: icon + title -->
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock Text="{Binding EditorTypeGuide.Icon}"
                                                       FontSize="20"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,10,0"
                                                       DockPanel.Dock="Left" />
                                            <TextBlock Text="{Binding EditorTypeGuide.Title}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppInfoBrush}"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>

                                        <!-- Khi nào dùng -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Khi nào dùng: "
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding EditorTypeGuide.WhenToUse}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <!-- Column type khuyến nghị -->
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Column type: "
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                            <TextBlock Text="{Binding EditorTypeGuide.ColumnType}"
                                                       FontSize="12"
                                                       FontFamily="Cascadia Code, Consolas"
                                                       Foreground="{DynamicResource AppInfoBrush}" />
                                        </StackPanel>

                                        <!-- Bảng Props đã chuyển sang tab Control Props (đặt cạnh các ô cấu hình) -->

                                        <!-- Footer hint: validation → tab Rules -->
                                        <Border Background="{DynamicResource AppWarningSoftBrush}" BorderBrush="{DynamicResource AppWarningLightBrush}"
                                                BorderThickness="1" CornerRadius="4"
                                                Padding="8,6" Margin="0,10,0,0">
                                            <TextBlock FontSize="11" Foreground="{DynamicResource AppWarningDarkBrush}" TextWrapping="Wrap">
                                                <Run Text="💡" />
                                                <Run Text=" Validation (bắt buộc, độ dài, regex, khoảng giá trị...) → cấu hình tại tab " />
                                                <Run Text="Rules" FontWeight="Bold" />
                                                <Run Text=" phía trên." />
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Card: Behavior ────────────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="Behavior" Style="{StaticResource SectionTitleStyle}"
                                           Margin="0,0,0,14" />

                                <!-- Grid 3×2: IsVisible / IsReadOnly / IsRequired / LockOnEdit (ADR-017) / IsVirtual -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- IsVisible -->
                                    <Border Grid.Column="0" Grid.Row="0"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding IsVisible}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock Text="Hiển thị" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center" />
                                            </DockPanel>
                                            <TextBlock Text="Field có hiển thị trên form."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- IsReadOnly -->
                                    <Border Grid.Column="2" Grid.Row="0"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding IsReadOnly}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="🔒" /><Run Text=" Chỉ đọc" />
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="Hiển thị nhưng không cho chỉnh sửa. Vẫn submit."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- IsRequired -->
                                    <Border Grid.Column="0" Grid.Row="2"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding IsRequired}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="✱" Foreground="{DynamicResource AppDangerBrush}" /><Run Text=" Bắt buộc" />
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="Không cho phép để trống khi submit."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- LockOnEdit (ADR-017): khoa field khi form mo o che do Edit -->
                                    <Border Grid.Column="2" Grid.Row="2"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding LockOnEdit}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="🔒" /><Run Text=" Khóa khi sửa" />
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="Cho nhập khi tạo, không cho đổi khi update (key/code/audit field)."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- ShowInList: hiển thị cột trong lưới danh sách Master Data -->
                                    <Border Grid.Column="2" Grid.Row="4"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding ShowInList}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="📋" /><Run Text=" Hiện trong danh sách" />
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="Hiển thị cột này trong lưới danh sách Master Data. Tắt = chỉ hiện trong form chi tiết."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <!-- IsVirtual: field UI-only, khong luu DB -->
                                    <Border Grid.Column="0" Grid.Row="4"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding IsVirtual}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="🔮" /><Run Text=" Field ảo" />
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="UI-only, không lưu DB. Dùng cho helper field cascading (ví dụ: TinhThanh lọc XaPhuong)."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />

                                            <!-- Field Code — hiện inline khi IsVirtual = true -->
                                            <StackPanel Margin="0,10,0,0"
                                                        Visibility="{Binding IsVirtual, Converter={StaticResource BoolToVis}}">
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text=" *"
                                                               Foreground="{DynamicResource AppDangerBrush}" FontWeight="Bold"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="Field Code" Style="{StaticResource FieldLabelStyle}"
                                                               Margin="0,0,0,4" />
                                                </DockPanel>
                                                <dxe:TextEdit EditValue="{Binding FieldCode, UpdateSourceTrigger=PropertyChanged}"
                                                              NullText="vd: NoiSinh_TinhThanh" />
                                                <TextBlock FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}"
                                                           Margin="0,4,0,0" TextWrapping="Wrap">
                                                    <Run Text="Mã dùng trong rules/events. Phải unique trong form." />
                                                    <Run Text=" Bắt buộc." Foreground="{DynamicResource AppDangerBrush}" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- IsUnique: chống trùng mã (backend check + nên kèm UNIQUE INDEX) -->
                                    <Border Grid.Column="0" Grid.Row="6"
                                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                        <StackPanel>
                                            <DockPanel>
                                                <dxe:ToggleSwitchEdit IsChecked="{Binding IsUnique}"
                                                                       DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                                <TextBlock FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                    <Run Text="🔑" /><Run Text=" Duy nhất (chống trùng)" />
                                                </TextBlock>
                                            </DockPanel>
                                            <TextBlock Text="Không cho phép trùng giá trị (vd: Mã). Backend kiểm tra trước khi lưu. Nên tạo thêm UNIQUE INDEX ở DB."
                                                       FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Làm mờ trong log (Sys_Column) — thuộc tính CẤP CỘT; chỉ field map cột thật -->
                                <Border Margin="0,12,0,0" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12,10"
                                        Visibility="{Binding CanConfigMasking, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <DockPanel>
                                            <dxe:ToggleSwitchEdit IsChecked="{Binding IsLogMasked}"
                                                                   DockPanel.Dock="Right" HorizontalAlignment="Right" />
                                            <TextBlock FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                                <Run Text="🕶" /><Run Text=" Làm mờ trong log" />
                                            </TextBlock>
                                        </DockPanel>
                                        <TextBlock Text="Ẩn giá trị cột này trong log import/audit (cấp cột — mọi form/view dùng cột này). KHÔNG ảnh hưởng dữ liệu thật."
                                                   FontSize="11" Foreground="{DynamicResource AppTextSubtleBrush}" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                                                    Visibility="{Binding IsLogMasked, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="Kiểu" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource AppTextMutedBrush}" />
                                            <dxe:ComboBoxEdit Width="160" Height="30"
                                                              ItemsSource="{Binding LogMaskModeOptions}"
                                                              EditValue="{Binding LogMaskMode, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="10"
                                                       Foreground="{DynamicResource AppTextSubtleBrush}"
                                                       Text="Full=*** · Partial=****1234 · Hash=sha256" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Cụm validation i18n: 2 cột (trái = để trống, phải = trùng) -->
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                <!-- ── Required Error Key (chỉ hiện khi IsRequired = true) ── -->
                                <Border Grid.Column="0" VerticalAlignment="Top" Margin="0" Padding="12,10"
                                        Background="{DynamicResource AppDangerSoftBrush}" CornerRadius="6"
                                        BorderBrush="{DynamicResource AppDangerLightBrush}" BorderThickness="1"
                                        Visibility="{Binding IsRequiredExpanded, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppDangerBrush}">
                                            <Run Text="✱" /><Run Text=" Thông báo lỗi khi để trống (i18n)" />
                                        </TextBlock>
                                        <!-- Nhập THẲNG thông báo lỗi (vi); key tự sinh ngầm -->
                                        <dxe:TextEdit EditValue="{Binding RequiredErrorKeyPreview, UpdateSourceTrigger=LostFocus}"
                                                      NullText="vd: Vui lòng nhập Họ và tên"
                                                      Margin="0,0,0,4" />
                                        <DockPanel Margin="0,0,0,2">
                                            <Button DockPanel.Dock="Right" Command="{Binding OpenI18nKeyCommand}" CommandParameter="requiredError"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    ToolTip="Nhập bản dịch các ngôn ngữ khác (EN, JA...)">
                                                <TextBlock Text="🌐 Dịch" FontSize="11" />
                                            </Button>
                                            <TextBlock Text="{Binding RequiredErrorKey}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="{DynamicResource AppDangerDarkBrush}"
                                                       FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding RequiredErrorKey}" />
                                        </DockPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ── Unique Error Key (chỉ hiện khi IsUnique = true) ── -->
                                <Border Grid.Column="2" VerticalAlignment="Top" Margin="0" Padding="12,10"
                                        Background="{DynamicResource AppInfoSoftBrush}" CornerRadius="6"
                                        BorderBrush="{DynamicResource AppInfoBorderBrush}" BorderThickness="1"
                                        Visibility="{Binding IsUniqueExpanded, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,8" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppInfoBrush}">
                                            <Run Text="🔑" /><Run Text=" Thông báo khi trùng (i18n)" />
                                        </TextBlock>
                                        <!-- Nhập THẲNG thông báo trùng (vi); key tự sinh ngầm -->
                                        <dxe:TextEdit EditValue="{Binding UniqueErrorKeyPreview, UpdateSourceTrigger=LostFocus}"
                                                      NullText="vd: Mã đã tồn tại" Margin="0,0,0,4" />
                                        <DockPanel Margin="0,0,0,2">
                                            <Button DockPanel.Dock="Right" Command="{Binding OpenI18nKeyCommand}" CommandParameter="unique"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    ToolTip="Nhập bản dịch các ngôn ngữ khác (EN, JA...)">
                                                <TextBlock Text="🌐 Dịch" FontSize="11" />
                                            </Button>
                                            <TextBlock Text="{Binding UniqueErrorKey}" VerticalAlignment="Center"
                                                       FontSize="10" Foreground="{DynamicResource AppInfoBrush}"
                                                       FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding UniqueErrorKey}" />
                                        </DockPanel>
                                        <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="{DynamicResource AppInfoBrush}"
                                                   FontFamily="Cascadia Code, Consolas" TextWrapping="Wrap"
                                                   Text="Pattern: {tableCode}.val.{fieldCode}.unique — tự tạo khi lưu field" />
                                    </StackPanel>
                                </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── Card: Display (i18n) ───────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,14">
                                    <TextBlock Text="Display (i18n)" Style="{StaticResource SectionTitleStyle}"
                                               DockPanel.Dock="Left" Margin="0" />
                                    <Button DockPanel.Dock="Right" Command="{Binding ManageI18nCommand}"
                                            HorizontalAlignment="Right"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="Mở quản lý i18n">
                                        <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                                            <Run Text="🌐" /><Run Text=" Manage i18n →" />
                                        </TextBlock>
                                    </Button>
                                </DockPanel>

                                <!-- 3 cột: Nhãn · Gợi ý nhập · Mô tả hover -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                <!-- Nhãn (Label) — nhập tiếng Việt; key i18n tự sinh ngầm -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Top" Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Nhãn hiển thị (tiếng Việt)" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:TextEdit EditValue="{Binding LabelPreview, UpdateSourceTrigger=LostFocus}"
                                                  NullText="vd: Họ và tên" Margin="0,0,0,4" />
                                    <DockPanel Margin="0,0,0,2">
                                        <Button DockPanel.Dock="Right" Command="{Binding OpenI18nKeyCommand}" CommandParameter="label"
                                                Style="{StaticResource SmallSecondaryButtonStyle}"
                                                ToolTip="Nhập bản dịch các ngôn ngữ khác (EN, JA...)">
                                            <TextBlock Text="🌐 Dịch" FontSize="11" />
                                        </Button>
                                        <TextBlock Text="{Binding LabelKey}" VerticalAlignment="Center"
                                                   FontSize="10" Foreground="{DynamicResource AppTextSubtleBrush}"
                                                   FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding LabelKey}" />
                                    </DockPanel>
                                    <TextBlock Text="Gõ thẳng nhãn tiếng Việt — key i18n tự sinh theo cột, bản dịch lưu khi Lưu field."
                                               Style="{StaticResource HelpTextStyle}" />
                                </StackPanel>

                                <!-- Gợi ý nhập (Placeholder) — nhập tiếng Việt; key tự sinh -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Top" Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Gợi ý nhập (tiếng Việt)" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:TextEdit EditValue="{Binding PlaceholderPreview, UpdateSourceTrigger=LostFocus}"
                                                  NullText="vd: Nhập họ và tên đầy đủ" Margin="0,0,0,4" />
                                    <DockPanel Margin="0,0,0,2">
                                        <Button DockPanel.Dock="Right" Command="{Binding OpenI18nKeyCommand}" CommandParameter="placeholder"
                                                Style="{StaticResource SmallSecondaryButtonStyle}"
                                                ToolTip="Nhập bản dịch các ngôn ngữ khác (EN, JA...)">
                                            <TextBlock Text="🌐 Dịch" FontSize="11" />
                                        </Button>
                                        <TextBlock Text="{Binding PlaceholderKey}" VerticalAlignment="Center"
                                                   FontSize="10" Foreground="{DynamicResource AppTextSubtleBrush}"
                                                   FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding PlaceholderKey}" />
                                    </DockPanel>
                                </StackPanel>

                                <!-- Mô tả (Tooltip) — nhập tiếng Việt; key tự sinh -->
                                <StackPanel Grid.Column="4" VerticalAlignment="Top" Style="{StaticResource FieldGroupStyle}">
                                    <TextBlock Text="Mô tả khi hover (tiếng Việt)" Style="{StaticResource FieldLabelStyle}" />
                                    <dxe:TextEdit EditValue="{Binding TooltipPreview, UpdateSourceTrigger=LostFocus}"
                                                  NullText="vd: Họ tên đầy đủ theo CMND/CCCD" Margin="0,0,0,4" />
                                    <DockPanel Margin="0,0,0,2">
                                        <Button DockPanel.Dock="Right" Command="{Binding OpenI18nKeyCommand}" CommandParameter="tooltip"
                                                Style="{StaticResource SmallSecondaryButtonStyle}"
                                                ToolTip="Nhập bản dịch các ngôn ngữ khác (EN, JA...)">
                                            <TextBlock Text="🌐 Dịch" FontSize="11" />
                                        </Button>
                                        <TextBlock Text="{Binding TooltipKey}" VerticalAlignment="Center"
                                                   FontSize="10" Foreground="{DynamicResource AppTextSubtleBrush}"
                                                   FontFamily="Cascadia Code, Consolas" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding TooltipKey}" />
                                    </DockPanel>
                                </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ TAB 2: Control Props ═══════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Control Props" VerticalAlignment="Center" />
                    </StackPanel>
                </TabItem.Header>

                <DockPanel>

                    <!-- ── Hướng dẫn GHIM đầu tab (không cuộn) — 2 cột cho gọn chiều dọc ── -->
                    <Border DockPanel.Dock="Top"
                            Visibility="{Binding EditorTypeGuide.HasProps, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource AppInfoSoftBrush}"
                            BorderBrush="{DynamicResource AppInfoBorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="14,10" Margin="0,12,0,8">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="{Binding EditorTypeGuide.Icon}" FontSize="15"
                                           VerticalAlignment="Center" Margin="0,0,8,0" DockPanel.Dock="Left" />
                                <TextBlock Text="{Binding EditorTypeGuide.Title}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppInfoBrush}" VerticalAlignment="Center" />
                            </DockPanel>
                            <ItemsControl ItemsSource="{Binding EditorTypeGuide.Props}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:PropHintRow}">
                                        <DockPanel Margin="0,2,16,2">
                                            <TextBlock Text="{Binding Name}" FontSize="11"
                                                       FontFamily="Cascadia Code, Consolas"
                                                       Foreground="{DynamicResource AppInfoBrush}"
                                                       Width="120" DockPanel.Dock="Left" VerticalAlignment="Top" />
                                            <TextBlock Text="{Binding Hint}" FontSize="11"
                                                       Foreground="{DynamicResource AppTextSecondaryBrush}" TextWrapping="Wrap" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="300" />
                    </Grid.ColumnDefinitions>

                    <!-- ── CỘT TRÁI: Form cấu hình ───────────────────────── -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,12,0,0">
                    <StackPanel>

                        <!-- Editor type badge -->
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <TextBlock Text="Cấu hình cho " FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextBrush}" VerticalAlignment="Center" />
                                    <Border Background="{StaticResource AccentLightBrush}"
                                            CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="{Binding SelectedEditorType}" FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AccentDarkBrush}" />
                                    </Border>
                                </StackPanel>

                                <!-- Dynamic props form -->
                                <ItemsControl ItemsSource="{Binding ControlProps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:ControlPropValue}">
                                            <ContentControl Content="{Binding}">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Setter Property="ContentTemplate" Value="{StaticResource StringPropTemplate}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Definition.PropType}" Value="Number">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource NumberPropTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Definition.PropType}" Value="Boolean">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource BooleanPropTemplate}" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Definition.PropType}" Value="Enum">
                                                                <Setter Property="ContentTemplate" Value="{StaticResource EnumPropTemplate}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Bảng Props hướng dẫn đã GHIM ở đầu tab (ngoài vùng cuộn) — xem DockPanel.Dock="Top" phía trên -->

                        <!-- ── Lookup Config — chỉ RadioGroup (Sys_Lookup đơn giản) ─── -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding IsRadioGroupEditor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Cấu hình Lookup — Sys_Lookup" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,12" />
                                <TextBlock Text="Lookup Code" FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3" />
                                <dxg:LookUpEdit Style="{StaticResource ScalarLookUpEditStyle}"
                                                ItemsSource="{Binding AvailableLookupCodes}"
                                                EditValue="{Binding LookupCode, UpdateSourceTrigger=PropertyChanged}"
                                                Margin="0,0,0,4" />
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12">
                                    <Run Text="Mã danh mục trong Sys_Lookup. VD: " />
                                    <Run Text="GENDER" FontFamily="Consolas" Foreground="{StaticResource AccentDarkBrush}" />
                                </TextBlock>
                                <TextBlock Text="Xem trước options:" FontSize="11"
                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,6"
                                           Visibility="{Binding LookupPreviewItems.Count, Converter={StaticResource BoolToVis}}" />
                                <ItemsControl ItemsSource="{Binding LookupPreviewItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                                <Border Background="{StaticResource AccentLightBrush}"
                                                        CornerRadius="3" Padding="5,2" Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding ItemCode}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               Foreground="{StaticResource AccentDarkBrush}" />
                                                </Border>
                                                <TextBlock Text="{Binding Label}" FontSize="12"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── ComboBoxPropsPanel — LookupComboBox (static) + ComboBox (dynamic) ── -->
                        <panels:ComboBoxPropsPanel
                            Visibility="{Binding IsLookupOrComboBoxEditor, Converter={StaticResource BoolToVis}}" />

                        <!-- ── LookupBoxPropsPanel — LookupBox (DxDropDownBox) ── -->
                        <!-- REPLACED: FK Lookup Config inline section → dedicated UserControl -->
                        <panels:LookupBoxPropsPanel
                            Visibility="{Binding IsFkLookupEditor, Converter={StaticResource BoolToVis}}" />

                        <!-- ── FK Lookup Config (LEGACY — hidden, kept for reference) ── -->
                        <Border Style="{StaticResource SectionCardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="Cấu hình FK Lookup" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextBrush}" Margin="0,0,0,14" />

                                <!-- ── Mode selector ──────────────────────────── -->
                                <TextBlock Text="Chế độ truy vấn" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <RadioButton Content="Bảng / View"
                                             IsChecked="{Binding IsTableMode, Mode=OneWay}"
                                             GroupName="QueryMode" Margin="0,0,16,0"
                                             Command="{Binding SetQueryModeCommand}"
                                             CommandParameter="table"/>
                                    <RadioButton Content="Function (TVF)"
                                             IsChecked="{Binding IsFunctionMode, Mode=OneWay}"
                                             GroupName="QueryMode" Margin="0,0,16,0"
                                             Command="{Binding SetQueryModeCommand}"
                                             CommandParameter="function"/>
                                    <RadioButton Content="SQL tùy chỉnh"
                                             IsChecked="{Binding IsSqlMode, Mode=OneWay}"
                                             GroupName="QueryMode"
                                             Command="{Binding SetQueryModeCommand}"
                                             CommandParameter="sql"/>
                                </StackPanel>

                                <!-- Cột Value + Display — chung 3 mode -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Cột Value (lưu vào DB)" FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                        <dxe:TextEdit Text="{Binding FkValueField, UpdateSourceTrigger=PropertyChanged}"
                                                      Height="32" NullText="VD: PhongBan_Id"/>
                                        <TextBlock Text="Alias SELECT hoặc cột FK int." FontSize="10"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Cột Display (hiển thị)" FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                        <dxe:TextEdit Text="{Binding FkDisplayField, UpdateSourceTrigger=PropertyChanged}"
                                                      Height="32" NullText="VD: Ten_PhongBan"/>
                                        <TextBlock Text="Alias SELECT hoặc cột text." FontSize="10"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ════ Panel: Bảng / View ════════════════ -->
                                <StackPanel Visibility="{Binding IsTableMode, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="Tên bảng hoặc View" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                    <dxe:TextEdit Text="{Binding FkTableName, UpdateSourceTrigger=PropertyChanged}"
                                                  Height="32" Margin="0,0,0,2"
                                                  NullText="VD: DM_PhongBan  hoặc  vw_PhongBan_Full"/>
                                    <TextBlock Text="Bảng hoặc View — View có thể chứa JOIN sẵn." FontSize="10"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10"/>
                                    <TextBlock Text="Filter SQL / WHERE (tùy chọn)" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                    <dxe:TextEdit Text="{Binding FkFilterSql, UpdateSourceTrigger=PropertyChanged}"
                                                  Height="32" Margin="0,0,0,2"
                                                  NullText="VD: Is_Active = 1 AND Tenant_Id = @TenantId"/>
                                    <TextBlock FontSize="10" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,8">
                                        <Run Text="Tham số hệ thống tự động: "/>
                                        <Run Text="@TenantId  @Today  @CurrentUser"
                                             FontFamily="Consolas" Foreground="{DynamicResource AppSuccessDarkBrush}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- ════ Panel: Function (TVF) ════════════ -->
                                <StackPanel Visibility="{Binding IsFunctionMode, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{DynamicResource AppWarningSoftBrush}" CornerRadius="6" Padding="10,6"
                                            Margin="0,0,0,10" BorderBrush="{DynamicResource AppWarningLightBrush}" BorderThickness="1">
                                        <TextBlock FontSize="10" Foreground="{DynamicResource AppWarningDarkBrush}" TextWrapping="Wrap">
                                            <Run Text="⚡ TVF: "/>
                                            <Run Text="SELECT ... FROM fn_Tên(@P1, @P2)" FontFamily="Consolas"/>
                                            <LineBreak/>
                                            <Run Text="Thứ tự tham số phải khớp định nghĩa hàm trong DB."/>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="Tên Function (TVF)" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                    <dxe:TextEdit Text="{Binding FkFunctionName, UpdateSourceTrigger=PropertyChanged}"
                                                  Height="32" Margin="0,0,0,12" FontFamily="Consolas"
                                                  NullText="VD: fn_GetPhongBanHieuLuc"/>
                                    <DockPanel Margin="0,0,0,8">
                                        <TextBlock Text="Tham số hàm (theo thứ tự)" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppTextSecondaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                        <Button Content="+ Thêm" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                Command="{Binding AddFunctionParamCommand}"
                                                Style="{StaticResource SmallSecondaryButtonStyle}"/>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding FkFunctionParams}"
                                                  AlternationCount="{Binding FkFunctionParams.Count}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource AppWarningSoftBrush}" CornerRadius="4"
                                                        BorderBrush="{DynamicResource AppWarningLightBrush}" BorderThickness="1"
                                                        Padding="10,8" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="28"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Tên param -->
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="@Tên tham số" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:TextEdit Height="28" FontFamily="Consolas" FontSize="11"
                                                                          Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                          NullText="VD: NgayHieuLuc"/>
                                                        </StackPanel>
                                                        <!-- Nguồn -->
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Nguồn giá trị" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:ComboBoxEdit Height="28"
                                                                              EditValue="{Binding SourceType, UpdateSourceTrigger=PropertyChanged}"
                                                                              ItemsSource="{Binding DataContext.FunctionParamSourceTypes,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                        </StackPanel>
                                                        <!-- FieldRef hoặc SystemKey -->
                                                        <StackPanel Grid.Column="4">
                                                            <StackPanel Visibility="{Binding IsFieldSource,
                                                                                    Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="FieldCode trong form" FontSize="10"
                                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                                <dxe:TextEdit Height="28"
                                                                              Text="{Binding FieldRef, UpdateSourceTrigger=PropertyChanged}"
                                                                              NullText="VD: NgayVaoLam"/>
                                                            </StackPanel>
                                                            <StackPanel Visibility="{Binding IsSystemSource,
                                                                                    Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Tham số hệ thống" FontSize="10"
                                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                                <dxe:ComboBoxEdit Height="28"
                                                                                  EditValue="{Binding SystemKey, UpdateSourceTrigger=PropertyChanged}"
                                                                                  ItemsSource="{Binding DataContext.SystemKeyOptions,
                                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <!-- Xóa -->
                                                        <Button Grid.Column="5" Content="×" FontSize="16" FontWeight="Bold"
                                                                Foreground="{DynamicResource AppDangerBrush}" Background="Transparent"
                                                                BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                                                                Command="{Binding DataContext.RemoveFunctionParamCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- ════ Panel: SQL tùy chỉnh ════════════ -->
                                <StackPanel Visibility="{Binding IsSqlMode, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{DynamicResource AppDangerSoftBrush}" CornerRadius="6" Padding="10,6"
                                            Margin="0,0,0,10" BorderBrush="{DynamicResource AppDangerLightBrush}" BorderThickness="1">
                                        <TextBlock FontSize="10" Foreground="{DynamicResource AppDangerDarkBrush}" TextWrapping="Wrap">
                                            <Run Text="⚠ Chỉ dùng @Param — tuyệt đối không string interpolation.  "/>
                                            <Run Text="Alias trong SELECT phải khớp Cột Value và Cột Display."/>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="Full SELECT SQL" FontSize="11"
                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                    <dxe:TextEdit Text="{Binding FkSelectSql, UpdateSourceTrigger=PropertyChanged}"
                                                  Height="90" AcceptsReturn="True"
                                                  FontFamily="Cascadia Code, Consolas" FontSize="11"
                                                  NullText="SELECT p.PhongBan_Id, p.Ten FROM DM_PhongBan p JOIN ... WHERE ..."/>
                                    <TextBlock FontSize="10" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8">
                                        <Run Text="Tham số hệ thống tự động: "/>
                                        <Run Text="@TenantId  @Today  @CurrentUser"
                                             FontFamily="Consolas" Foreground="{DynamicResource AppSuccessDarkBrush}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Filter Params — Table mode + SQL mode -->
                                <Border Background="{DynamicResource AppSuccessSoftBrush}" CornerRadius="6" Padding="12,10"
                                        Margin="0,0,0,12"
                                        BorderBrush="{DynamicResource AppSuccessLightBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8">
                                            <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AppSuccessDarkBrush}"
                                                       DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <Run Text="⚡ "/>
                                                <Run Text="Tham số từ field khác trong form"/>
                                            </TextBlock>
                                            <Button Content="+ Thêm" DockPanel.Dock="Right"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding AddFkFilterParamCommand}"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"/>
                                        </DockPanel>

                                        <!-- Danh sách params — mỗi param 1 card -->
                                        <ItemsControl ItemsSource="{Binding FkFilterParams}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="White" CornerRadius="4"
                                                            BorderBrush="{DynamicResource AppSuccessLightBrush}" BorderThickness="1"
                                                            Padding="10,8" Margin="0,0,0,6">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="10"/>
                                                                <ColumnDefinition Width="100"/>
                                                                <ColumnDefinition Width="28"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- @Param alias -->
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock FontSize="10" Margin="0,0,0,3"
                                                                           Foreground="{StaticResource MutedBrush}">
                                                                    <Run Text="Alias " FontWeight="SemiBold"/>
                                                                    <Run Text="(tên dùng sau @ trong SQL)"/>
                                                                </TextBlock>
                                                                <dxe:TextEdit Height="28"
                                                                              Text="{Binding Param, UpdateSourceTrigger=PropertyChanged}"
                                                                              NullText="VD: TuNgay"
                                                                              FontFamily="Consolas" FontSize="11"/>
                                                                <TextBlock FontSize="9" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,2,0,0">
                                                                    <Run Text="Dùng trong SQL: "/>
                                                                    <Run Text="@TuNgay" FontFamily="Consolas" Foreground="{StaticResource AccentDarkBrush}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                            <!-- FieldRef -->
                                                            <StackPanel Grid.Column="2">
                                                                <TextBlock FontSize="10" Margin="0,0,0,3"
                                                                           Foreground="{StaticResource MutedBrush}">
                                                                    <Run Text="Lấy giá trị từ field " FontWeight="SemiBold"/>
                                                                    <Run Text="(FieldCode trong form)"/>
                                                                </TextBlock>
                                                                <dxe:TextEdit Height="28"
                                                                              Text="{Binding FieldRef, UpdateSourceTrigger=PropertyChanged}"
                                                                              NullText="VD: NgayVaoLam"/>
                                                                <TextBlock FontSize="9" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,2,0,0"
                                                                           Text="Field trên form cung cấp giá trị lúc runtime"/>
                                                            </StackPanel>
                                                            <!-- Kiểu -->
                                                            <StackPanel Grid.Column="4">
                                                                <TextBlock Text="Kiểu dữ liệu" FontSize="10"
                                                                           Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                                                <dxe:ComboBoxEdit Height="28"
                                                                                  ItemsSource="{Binding DataContext.FkParamTypes,
                                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                  EditValue="{Binding Type, UpdateSourceTrigger=PropertyChanged}"
/>
                                                            </StackPanel>
                                                            <!-- Xóa -->
                                                            <Button Grid.Column="5" Content="×"
                                                                    FontSize="16" FontWeight="Bold"
                                                                    Foreground="{DynamicResource AppDangerBrush}" Background="Transparent"
                                                                    BorderThickness="0" Cursor="Hand"
                                                                    VerticalAlignment="Bottom" Margin="4,0,0,2"
                                                                    Command="{Binding DataContext.RemoveFkFilterParamCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Ghi chú -->
                                        <TextBlock FontSize="10" Foreground="{DynamicResource AppSuccessDarkBrush}" Margin="0,6,0,0">
                                            <Run Text="Dùng trong filterSql như: "/>
                                            <Run Text="Ngay_Hieu_Luc &lt;= @NgayVaoLam" FontFamily="Consolas"/>
                                            <LineBreak/>
                                            <Run Text="Khi field nguồn thay đổi → lookup tự reload."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- Order By + Search enabled — 2 cột ngang -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Sắp xếp (ORDER BY)" FontSize="11"
                                                   Foreground="{StaticResource MutedBrush}" Margin="0,0,0,3"/>
                                        <dxe:TextEdit Text="{Binding FkOrderBy, UpdateSourceTrigger=PropertyChanged}"
                                                      Height="32" NullText="VD: Ten_PhongBan ASC"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                        <dxe:CheckEdit Content="Cho phép tìm kiếm"
                                                       IsChecked="{Binding FkSearchEnabled}"
                                                       FontSize="12"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Cột popup -->
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Cột hiển thị trong popup" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                    <Button Content="+ Thêm cột" DockPanel.Dock="Right"
                                            Command="{Binding AddFkColumnCommand}"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource SmallSecondaryButtonStyle}"/>
                                </DockPanel>

                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="0" Margin="0,0,0,4">
                                    <dxg:GridControl ItemsSource="{Binding FkPopupColumns}"
                                                     MaxHeight="200" AutoPopulateColumns="False">
                                        <dxg:GridControl.View>
                                            <dxg:TableView ShowGroupPanel="False"
                                                           AllowEditing="True"
                                                           NavigationStyle="Cell"
                                                           ShowIndicator="False"
                                                           RowMinHeight="30"/>
                                        </dxg:GridControl.View>
                                        <dxg:GridControl.Columns>
                                            <dxg:GridColumn FieldName="FieldName" Header="Tên cột DB"    Width="150"/>
                                            <dxg:GridColumn FieldName="Caption"   Header="Tiêu đề"       Width="*"/>
                                            <dxg:GridColumn FieldName="Width"     Header="Rộng (px)"     Width="80"/>
                                            <dxg:GridColumn Header=" " Width="36" AllowEditing="False"
                                                            AllowSorting="False" AllowResizing="False">
                                                <dxg:GridColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <Button Content="×" FontSize="14" FontWeight="Bold"
                                                                Foreground="{DynamicResource AppDangerBrush}" Background="Transparent"
                                                                BorderThickness="0" Cursor="Hand"
                                                                Command="{Binding DataContext.RemoveFkColumnCommand,
                                                                          RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                                CommandParameter="{Binding Row}"/>
                                                    </DataTemplate>
                                                </dxg:GridColumn.CellTemplate>
                                            </dxg:GridColumn>
                                        </dxg:GridControl.Columns>
                                    </dxg:GridControl>
                                </Border>
                                <TextBlock Text="Các cột này hiển thị trong popup dropdown khi user click chọn."
                                           FontSize="10" Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Multi-Trigger reload (Migration 068) ──────────────────────────
                             Danh sách field cha → runtime reload khi BẤT KỲ field nào đổi. Lưu ở cột
                             Ui_Field_Lookup.Reload_Trigger_Fields. Bổ sung cho auto-dò @param Filter SQL:
                             dùng cho TVF/Full SQL hoặc field cha KHÔNG có trong Filter SQL. -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding IsFkLookupEditor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Left" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                        <Run Text="🔄 "/>
                                        <Run Text="Tự reload theo nhiều field cha (Multi-Trigger)"/>
                                    </TextBlock>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"
                                           Text="Khi bất kỳ field dưới đây đổi giá trị → lookup tự reload (giá trị đang chọn bị xoá nếu không còn hợp lệ). Table-mode đã tự dò @param trong Filter SQL — chỉ cần khai ở đây cho TVF/Full SQL hoặc field NGOÀI Filter SQL."/>

                                <!-- Tags hiện tại -->
                                <ItemsControl ItemsSource="{Binding ReloadOnChangeFields}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource AppAccentLightBrush}" CornerRadius="12" Padding="10,4"
                                                    Margin="0,0,6,6">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AppAccentDarkBrush}" FontFamily="Consolas"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="×" FontSize="12" FontWeight="Bold"
                                                            Foreground="{DynamicResource AppAccentDarkBrush}" Background="Transparent"
                                                            BorderThickness="0" Cursor="Hand" Margin="6,0,0,0"
                                                            Command="{Binding DataContext.RemoveReloadFieldCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Thêm field code mới -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <dxe:TextEdit Grid.Column="0" Height="28"
                                                  Text="{Binding ReloadOnChangeInput, UpdateSourceTrigger=PropertyChanged}"
                                                  NullText="Nhập FieldCode rồi bấm Thêm (VD: NgayVaoLam)">
                                        <dxe:TextEdit.InputBindings>
                                            <KeyBinding Key="Return" Command="{Binding AddReloadFieldCommand}"/>
                                        </dxe:TextEdit.InputBindings>
                                    </dxe:TextEdit>
                                    <Button Grid.Column="2" Content="+ Thêm"
                                            Command="{Binding AddReloadFieldCommand}"
                                            Style="{StaticResource SmallSecondaryButtonStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ── dataSourceConditions ───────────────────────── -->
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding IsFkLookupEditor, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Left" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                        <Run Text="🔀 "/>
                                        <Run Text="Điều kiện đổi bảng nguồn"/>
                                    </TextBlock>
                                    <Button Content="+ Thêm điều kiện" DockPanel.Dock="Right"
                                            HorizontalAlignment="Right"
                                            Command="{Binding AddDataSourceConditionCommand}"
                                            Style="{StaticResource SmallSecondaryButtonStyle}"/>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,10"
                                           Text="Khi field trong form thoả điều kiện → đổi sang bảng khác. Ưu tiên từ trên xuống, không match → dùng bảng mặc định."/>

                                <ItemsControl ItemsSource="{Binding DataSourceConditions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource AppWarningSoftBrush}" CornerRadius="6"
                                                    BorderBrush="{DynamicResource AppWarningLightBrush}" BorderThickness="1"
                                                    Padding="12,10" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <!-- Header: điều kiện -->
                                                    <DockPanel Margin="0,0,0,8">
                                                        <TextBlock DockPanel.Dock="Left"
                                                                   FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AppWarningDarkBrush}"
                                                                   VerticalAlignment="Center" Text="Nếu:"/>
                                                        <Button DockPanel.Dock="Right" Content="× Xoá"
                                                                FontSize="11" Foreground="{DynamicResource AppDangerBrush}"
                                                                Background="Transparent" BorderThickness="0"
                                                                Cursor="Hand"
                                                                Command="{Binding DataContext.RemoveDataSourceConditionCommand,
                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </DockPanel>

                                                    <!-- Dòng 1: when.field / when.op / when.value -->
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="110"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Field" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:TextEdit Height="28"
                                                                          Text="{Binding WhenField, UpdateSourceTrigger=PropertyChanged}"
                                                                          NullText="VD: LoaiNhanVien"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Phép so sánh" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:ComboBoxEdit Height="28"
                                                                              ItemsSource="{Binding DataContext.WhenOpOptions,
                                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                              EditValue="{Binding WhenOp, UpdateSourceTrigger=PropertyChanged}"
/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="Giá trị so sánh" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:TextEdit Height="28"
                                                                          Text="{Binding WhenValue, UpdateSourceTrigger=PropertyChanged}"
                                                                          NullText="VD: THUE_NGOAI"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Dòng 2: tableName / displayField -->
                                                    <TextBlock Text="→ Thì dùng:" FontSize="10" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AppWarningDarkBrush}" Margin="0,0,0,6"/>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Bảng nguồn thay thế" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:TextEdit Height="28"
                                                                          Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}"
                                                                          NullText="VD: DM_DonViThueNgoai"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Cột hiển thị" FontSize="10"
                                                                       Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                            <dxe:TextEdit Height="28"
                                                                          Text="{Binding DisplayField, UpdateSourceTrigger=PropertyChanged}"
                                                                          NullText="VD: Ten_Don_Vi"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Filter SQL riêng -->
                                                    <TextBlock Text="Filter SQL (tùy chọn)" FontSize="10"
                                                               Foreground="{StaticResource MutedBrush}" Margin="0,0,0,2"/>
                                                    <dxe:TextEdit Height="28"
                                                                  Text="{Binding FilterSql, UpdateSourceTrigger=PropertyChanged}"
                                                                  NullText="VD: Is_Active = 1 AND Tenant_Id = @TenantId"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ── Kiểm tra & Diễn giải (LEGACY — đã chuyển vào LookupBoxPropsPanel) ── -->
                        <Border Style="{StaticResource SectionCardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock DockPanel.Dock="Left" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextSecondaryBrush}" VerticalAlignment="Center">
                                        <Run Text="🔍 "/>
                                        <Run Text="Kiểm tra &amp; Diễn giải cấu hình"/>
                                    </TextBlock>
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                            Command="{Binding ExplainConfigCommand}"
                                            Style="{StaticResource SmallSecondaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▶ " FontSize="10"/>
                                            <TextBlock Text="Diễn giải"/>
                                        </StackPanel>
                                    </Button>
                                </DockPanel>
                                <TextBlock FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,8"
                                           Text="Bấm Diễn giải để kiểm tra toàn bộ cấu hình bằng tiếng Việt trước khi lưu."/>

                                <!-- Kết quả diễn giải -->
                                <Border Visibility="{Binding HasConfigExplanation, Converter={StaticResource BoolToVis}}"
                                        Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="6" Padding="12"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                    <TextBox Text="{Binding ConfigExplanation, Mode=OneWay}"
                                             IsReadOnly="True"
                                             FontFamily="Cascadia Code, Consolas" FontSize="11"
                                             Foreground="{DynamicResource AppTextBrush}"
                                             Background="Transparent" BorderThickness="0"
                                             TextWrapping="Wrap" AcceptsReturn="True"/>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                    </ScrollViewer>

                    <!-- ── CỘT PHẢI: JSON Preview Sidebar ────────────────── -->
                    <Border Grid.Column="2" Margin="0,12,0,0"
                            Background="{DynamicResource AppSurfaceMutedBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <DockPanel>
                            <!-- Header -->
                            <Border DockPanel.Dock="Top"
                                    Background="{DynamicResource AppAccentSoftBrush}" CornerRadius="8,8,0,0"
                                    Padding="12,8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Control_Props_Json"
                                               FontFamily="Cascadia Code, Consolas" FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentDarkBrush}"
                                               VerticalAlignment="Center" />
                                    <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                            Command="{Binding CopyJsonCommand}"
                                            Style="{StaticResource SmallSecondaryButtonStyle}"
                                            ToolTip="Copy JSON vào clipboard">
                                        <TextBlock Text="📋 Copy" FontSize="10" />
                                    </Button>
                                </DockPanel>
                            </Border>
                            <!-- JSON content -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding ControlPropsJson, Mode=OneWay}"
                                         IsReadOnly="True"
                                         FontFamily="Cascadia Code, Consolas" FontSize="11"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         Background="Transparent" BorderThickness="0"
                                         Padding="12,10"
                                         Foreground="{DynamicResource AppTextBrush}" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    </Grid>
                </DockPanel>
            </TabItem>

            <!-- ═══ TAB 3: Validation Rules ════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Rules" VerticalAlignment="Center" />
                        <Border Style="{StaticResource TabBadgeStyle}">
                            <TextBlock Text="{Binding LinkedRules.Count}" FontSize="10"
                                       FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel Margin="0,12,0,0">
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardStyle}"
                            Padding="12,8" Margin="0,0,0,8">
                        <DockPanel>
                            <dx:SimpleButton DockPanel.Dock="Left"
                                             Command="{Binding AddRuleCommand}"
                                             ToolTip="Thêm validation rule mới">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text=" Thêm Rule" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </dx:SimpleButton>

                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}">
                                <Run Text="Tổng: " />
                                <Run Text="{Binding LinkedRules.Count, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text=" rule" />
                            </TextBlock>
                        </DockPanel>
                    </Border>

                    <!-- Rules DataGrid -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                            Effect="{StaticResource CardShadow}">
                        <dxg:GridControl ItemsSource="{Binding LinkedRules}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                               AllowPerPixelScrolling="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="#" FieldName="OrderNo" Width="45" />
                                <dxg:GridColumn Header="Rule Type" FieldName="RuleTypeCode" Width="110" />
                                <dxg:GridColumn Header="Expression" FieldName="ExpressionPreview" Width="*" />
                                <dxg:GridColumn Header="Error Key" FieldName="ErrorKey" Width="130" />
                                <dxg:GridColumn Header="Active" FieldName="IsActive" Width="60" />
                                <dxg:GridColumn Header="" Width="70" AllowEditing="False" AllowSorting="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource IconBtnStyle}"
                                                        Width="28" Height="28" FontSize="13"
                                                        Command="{Binding DataContext.OpenRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Cấu hình rule" Content="⚙" />
                                                <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                                        Command="{Binding DataContext.DeleteRuleCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Xóa rule" Content="🗑" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ═══ TAB 4: Events ══════════════════════════════════ -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Events" VerticalAlignment="Center" />
                        <Border Style="{StaticResource TabBadgeStyle}">
                            <TextBlock Text="{Binding LinkedEvents.Count}" FontSize="10"
                                       FontWeight="Bold" Foreground="{StaticResource AccentDarkBrush}" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <DockPanel Margin="0,12,0,0">
                    <!-- Toolbar -->
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardStyle}"
                            Padding="12,8" Margin="0,0,0,8">
                        <DockPanel>
                            <dx:SimpleButton DockPanel.Dock="Left"
                                             Command="{Binding AddEventCommand}"
                                             ToolTip="Thêm event mới">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text=" Thêm Event" Margin="4,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </dx:SimpleButton>

                            <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource MutedBrush}">
                                <Run Text="Tổng: " />
                                <Run Text="{Binding LinkedEvents.Count, Mode=OneWay}" FontWeight="Bold" />
                                <Run Text=" event" />
                            </TextBlock>
                        </DockPanel>
                    </Border>

                    <!-- Events DataGrid -->
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Background="{StaticResource SurfaceBrush}"
                            Effect="{StaticResource CardShadow}">
                        <dxg:GridControl ItemsSource="{Binding LinkedEvents}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                               AllowPerPixelScrolling="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="ID" FieldName="EventId" Width="60" />
                                <dxg:GridColumn Header="Trigger" FieldName="TriggerCode" Width="110" />
                                <dxg:GridColumn Header="Condition" FieldName="ConditionPreview" Width="*" />
                                <dxg:GridColumn Header="Actions" FieldName="ActionsCount" Width="70" />
                                <dxg:GridColumn Header="Active" FieldName="IsActive" Width="60" />
                                <dxg:GridColumn Header="" Width="70" AllowEditing="False" AllowSorting="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource IconBtnStyle}"
                                                        Width="28" Height="28" FontSize="13"
                                                        Command="{Binding DataContext.OpenEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Cấu hình event" Content="⚙" />
                                                <Button Style="{StaticResource InlineDeleteBtnStyle}"
                                                        Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                        CommandParameter="{Binding Row}"
                                                        ToolTip="Xóa event" Content="🗑" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </Border>
                </DockPanel>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════════════════
             ROW 3: Footer — navigate links
             ═══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Command="{Binding AddRuleCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,16,0">
                    <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                        <Run Text="Validation Rules →" />
                    </TextBlock>
                </Button>
                <Button Command="{Binding AddEventCommand}"
                        Background="Transparent" BorderThickness="0" Cursor="Hand">
                    <TextBlock FontSize="12" Foreground="{StaticResource AccentBrush}">
                        <Run Text="Events →" />
                    </TextBlock>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>
