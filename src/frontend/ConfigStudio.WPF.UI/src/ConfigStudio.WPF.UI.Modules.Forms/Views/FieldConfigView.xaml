                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <dxe:TextEdit Grid.Column="0" Height="28"
                                                  Text="{Binding ReloadOnChangeInput, UpdateSourceTrigger=PropertyChanged}"
