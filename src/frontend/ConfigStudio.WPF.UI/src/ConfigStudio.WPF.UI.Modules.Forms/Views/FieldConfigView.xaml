                                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <!-- ════ Panel: SQL tùy chỉnh ════════════ -->
                                <StackPanel Visibility="{Binding IsSqlMode, Converter={StaticResource BoolToVis}}">
