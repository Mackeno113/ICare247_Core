                                                               Foreground="#1D4ED8" FontFamily="Consolas"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="×" FontSize="12" FontWeight="Bold"
                                                            Foreground="#1D4ED8" Background="Transparent"
                                                            BorderThickness="0" Cursor="Hand" Margin="6,0,0,0"
                                                            Command="{Binding DataContext.RemoveReloadFieldCommand,
                                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

