<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.FormManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:conv="clr-namespace:ConfigStudio.WPF.UI.Core.Converters;assembly=ConfigStudio.WPF.UI.Core"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1100"
             mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding CreateFormCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisConverter x:Key="InvBoolToVis" />

        <!-- Style dùng chung cho action button trong cell -->
        <Style x:Key="CellActionButtonStyle" TargetType="Button">
            <Setter Property="Width"           Value="30" />
            <Setter Property="Height"          Value="28" />
            <Setter Property="Margin"          Value="2,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="FontSize"        Value="14" />
            <Setter Property="Foreground"      Value="{DynamicResource AppTextSecondaryBrush}" />
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppBorderBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style nút Deactivate (cam khi hover) -->
        <Style x:Key="CellDeactivateButtonStyle" TargetType="Button"
               BasedOn="{StaticResource CellActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AppWarningBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppWarningSoftBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppWarningLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style nút Restore (xanh lá khi hover) -->
        <Style x:Key="CellRestoreButtonStyle" TargetType="Button"
               BasedOn="{StaticResource CellActionButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource AppSuccessBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSuccessLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSuccessLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: Header + Filter bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title + Create button -->
                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="Quản Lý Form"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                        <TextBlock Text="Danh sách tất cả form trong hệ thống"
                                   FontSize="12" Opacity="0.6" Margin="0,2,0,0"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <dx:SimpleButton Command="{Binding RefreshCommand}"
                                         ToolTip="Làm mới danh sách"
                                         Margin="0,0,8,0" Width="32" Height="32"
                                         Content="↻" FontSize="16" />
                        <dx:SimpleButton Command="{Binding CreateFormCommand}" Content="+ Tạo Form Mới" />
                    </StackPanel>
                </DockPanel>

                <!-- Filter bar -->
                <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <!-- Search box -->
                    <dxe:TextEdit x:Name="SearchBox"
                                  Width="260"
                                  NullText="Tìm theo mã hoặc tên form... (Ctrl+F)"
                                  EditValue="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,10,0" />

                    <!-- Filter Platform -->
                    <dxe:ComboBoxEdit Width="130"
                                      NullText="Platform"
                                      ItemsSource="{Binding PlatformOptions}"
                                      EditValue="{Binding PlatformFilter}"
                                      Margin="0,0,10,0" />

                    <!-- Filter Table -->
                    <dxg:LookUpEdit Style="{StaticResource ScalarLookUpEditStyle}"
                                    Width="160"
                                    NullText="Business Table"
                                    ItemsSource="{Binding TableOptions}"
                                    EditValue="{Binding TableFilter}"
                                    Margin="0,0,10,0" />

                    <!-- Show inactive toggle -->
                    <dxe:CheckEdit Content="Hiện form đã ẩn"
                                   IsChecked="{Binding ShowInactive}"
                                   VerticalAlignment="Center" />
                </WrapPanel>

                <!-- Error banner -->
                <Border Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10,8"
                        Background="{DynamicResource AppDangerSoftBrush}"
                        BorderBrush="{DynamicResource AppDangerLightBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding LoadErrorMessage}"
                               Foreground="{DynamicResource AppDangerDarkBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: GridControl
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="16,8,16,0"
                BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">

            <dxg:GridControl ItemsSource="{Binding FormsView}"
                             SelectedItem="{Binding SelectedForm, Mode=TwoWay}"
                             AutoPopulateColumns="False">
                <dxg:GridControl.View>
                    <dxg:TableView NavigationStyle="Row"
                                   ShowGroupPanel="False"
                                   AllowPerPixelScrolling="True"
                                   RowDoubleClick="OnRowDoubleClick">
                        <!-- NOTE: Row mờ khi IsActive = false + ContextMenu chuột phải -->
                        <dxg:TableView.RowStyle>
                            <Style TargetType="dxg:RowControl">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Row.IsActive}" Value="False">
                                        <Setter Property="Opacity" Value="0.45" />
                                    </DataTrigger>
                                </Style.Triggers>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <!-- PlacementTarget = RowControl; .DataContext.Row = FormSummaryDto; .View.DataControl.DataContext = VM -->
                                        <ContextMenu>
                                            <MenuItem Header="Mở Form Editor" InputGestureText="Enter"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.OpenFormCommand}"
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row}" />
                                            <MenuItem Header="Xem chi tiết"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.ViewDetailCommand}"
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row}" />
                                            <Separator />
                                            <MenuItem Header="Xem trước (Preview)" InputGestureText="Space"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.PreviewFormCommand}"
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row}" />
                                            <MenuItem Header="Sửa thông tin"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.EditFormCommand}" />
                                            <MenuItem Header="Nhân bản"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.DuplicateFormCommand}" />
                                            <Separator />
                                            <MenuItem Header="Vô hiệu hóa" InputGestureText="Delete"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.DeactivateFormCommand}"
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row}"
                                                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row.IsActive, Converter={StaticResource BoolToVis}}" />
                                            <MenuItem Header="Khôi phục"
                                                      Command="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.View.DataControl.DataContext.RestoreFormCommand}"
                                                      CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row}"
                                                      Visibility="{Binding RelativeSource={RelativeSource AncestorType=ContextMenu}, Path=PlacementTarget.DataContext.Row.IsActive, Converter={StaticResource InvBoolToVis}}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </dxg:TableView.RowStyle>
                    </dxg:TableView>
                </dxg:GridControl.View>

                <dxg:GridControl.Columns>

                    <!-- Mã Form — click → navigate FormDetail -->
                    <dxg:GridColumn Header="Mã Form" FieldName="FormCode" Width="160"
                                    AllowEditing="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock VerticalAlignment="Center" Cursor="Hand"
                                           FontWeight="Medium" Foreground="{DynamicResource AppAccentDarkBrush}"
                                           TextDecorations="Underline">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Row.FormCode}" />
                                        </Style>
                                    </TextBlock.Style>
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ViewDetailCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                      CommandParameter="{Binding Row}" />
                                    </TextBlock.InputBindings>
                                </TextBlock>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="Tên Form"  FieldName="FormName"  Width="*" />
                    <dxg:GridColumn Header="Table"     FieldName="TableName" Width="120" />

                    <!-- Platform — badge màu -->
                    <dxg:GridColumn Header="Platform" FieldName="Platform" Width="90"
                                    AllowEditing="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AppPageBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Row.Platform}" Value="web">
                                                    <Setter Property="Background" Value="{DynamicResource AppAccentLightBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Row.Platform}" Value="mobile">
                                                    <Setter Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Row.Platform}" Value="wpf">
                                                    <Setter Property="Background" Value="{DynamicResource AppWarningSoftBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="{Binding Row.Platform}" />
                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Row.Platform}" Value="web">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppAccentDarkBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Row.Platform}" Value="mobile">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Row.Platform}" Value="wpf">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppWarningDarkBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <dxg:GridColumn Header="Ver"      FieldName="Version"     Width="50" />
                    <dxg:GridColumn Header="Sections" FieldName="SectionCount" Width="70" />
                    <dxg:GridColumn Header="Fields"   FieldName="FieldCount"   Width="60" />
                    <dxg:GridColumn Header="Events"   FieldName="EventCount"   Width="60" />

                    <!-- Trạng thái — badge Active / Inactive -->
                    <dxg:GridColumn Header="Trạng thái" FieldName="IsActive" Width="100"
                                    AllowEditing="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,3"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AppPageBackgroundBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Row.IsActive}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource AppSuccessLightBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Inactive" />
                                                <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Row.IsActive}" Value="True">
                                                        <Setter Property="Text"       Value="Active" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AppSuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <!-- Cập nhật -->
                    <dxg:GridColumn Header="Cập nhật" FieldName="UpdatedAt" Width="120"
                                    AllowEditing="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Row.UpdatedAt, StringFormat='dd/MM/yyyy HH:mm'}"
                                           VerticalAlignment="Center" FontSize="12" Opacity="0.7" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                    <!-- Actions: Edit | Preview | Clone | Deactivate-or-Restore -->
                    <dxg:GridColumn Header="" Width="136" AllowEditing="False" AllowSorting="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            Margin="4,0">

                                    <!-- EditInfo — sửa thông tin Ui_Form (tên, code, version...) -->
                                    <Button Style="{StaticResource CellActionButtonStyle}"
                                            Command="{Binding DataContext.EditFormCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                            CommandParameter="{Binding Row}"
                                            ToolTip="Sửa thông tin form"
                                            Content="⚙" />

                                    <!-- Edit — mở Form Editor -->
                                    <Button Style="{StaticResource CellActionButtonStyle}"
                                            Command="{Binding DataContext.OpenFormCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                            CommandParameter="{Binding Row}"
                                            ToolTip="Mở Form Editor"
                                            Content="✎" />

                                    <!-- Preview — render form từ metadata -->
                                    <Button Style="{StaticResource CellActionButtonStyle}"
                                            Command="{Binding DataContext.PreviewFormCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                            CommandParameter="{Binding Row}"
                                            ToolTip="Xem trước form"
                                            Content="👁" />

                                    <!-- Clone — nhân bản -->
                                    <Button Style="{StaticResource CellActionButtonStyle}"
                                            Command="{Binding DataContext.DuplicateFormCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                            CommandParameter="{Binding Row}"
                                            ToolTip="Nhân bản form"
                                            Content="⧉" />

                                    <!-- Deactivate — chỉ hiện khi IsActive=true -->
                                    <Button Style="{StaticResource CellDeactivateButtonStyle}"
                                            Command="{Binding DataContext.DeactivateFormCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                            CommandParameter="{Binding Row}"
                                            ToolTip="Vô hiệu hóa form"
                                            Content="🔒"
                                            Visibility="{Binding Row.IsActive, Converter={StaticResource BoolToVis}}" />

                                    <!-- Restore — chỉ hiện khi IsActive=false -->
                                    <Button Style="{StaticResource CellRestoreButtonStyle}"
                                            Command="{Binding DataContext.RestoreFormCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                            CommandParameter="{Binding Row}"
                                            ToolTip="Khôi phục form"
                                            Content="🔓"
                                            Visibility="{Binding Row.IsActive, Converter={StaticResource InvBoolToVis}}" />

                                </StackPanel>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>

                </dxg:GridControl.Columns>
            </dxg:GridControl>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Summary bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,7"
                Background="{DynamicResource AppAccentSoftBrush}" CornerRadius="4">
            <DockPanel>
                <!-- Số liệu thống kê -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ℹ" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.5" />

                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Hiển thị {0} / Tổng {1}">
                                <Binding Path="FilteredCount" />
                                <Binding Path="TotalForms" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <Border Width="1" Height="14" Background="{DynamicResource AppTextSubtleBrush}" Margin="12,0" Opacity="0.4" />

                    <!-- Active count -->
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AppSuccessBrush}" Margin="0,0,5,0"
                             VerticalAlignment="Center" />
                    <TextBlock FontSize="12" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Active: {0}">
                                <Binding Path="ActiveCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <Border Width="1" Height="14" Background="{DynamicResource AppTextSubtleBrush}" Margin="12,0" Opacity="0.4" />

                    <!-- Inactive count -->
                    <Ellipse Width="8" Height="8" Fill="{DynamicResource AppTextSubtleBrush}" Margin="0,0,5,0"
                             VerticalAlignment="Center" />
                    <TextBlock FontSize="12" Opacity="0.7" VerticalAlignment="Center">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="Inactive: {0}">
                                <Binding Path="InactiveCount" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>

                <!-- Loading indicator -->
                <TextBlock DockPanel.Dock="Right" Text="⏳ Đang tải..."
                           FontSize="12" Opacity="0.6" VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
