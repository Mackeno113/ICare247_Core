<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.SysTableManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="680"
             d:DesignWidth="1200"
             mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}" />
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="Quản Trị Sys_Table"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                        <TextBlock Text="Nhập liệu và cập nhật metadata bảng theo tenant"
                                   FontSize="12" Opacity="0.6" Margin="0,2,0,0"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <dx:SimpleButton Command="{Binding RefreshCommand}"
                                         ToolTip="Làm mới dữ liệu"
                                         Width="32" Height="32"
                                         Content="↻" FontSize="16" />
                    </StackPanel>
                </DockPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <dxe:TextEdit Width="340"
                                  NullText="Tìm theo Table_Code, Table_Name, Schema_Name..."
                                  EditValue="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,12,0" />

                    <dxe:CheckEdit Content="Hiện cả bản ghi inactive"
                                   IsChecked="{Binding ShowInactive}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />

                    <Border Background="{DynamicResource AppAccentSoftBrush}"
                            BorderBrush="{DynamicResource AppAccentLightBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="10,5">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource AppAccentDarkBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding TenantId, Mode=OneWay, StringFormat=Tenant_Id: {0}}" />
                    </Border>
                </StackPanel>

                <Border Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10,8"
                        Background="{DynamicResource AppDangerSoftBrush}"
                        BorderBrush="{DynamicResource AppDangerLightBrush}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Visibility="{Binding HasLoadError, Converter={StaticResource BoolToVis}}">
                    <ScrollViewer MaxHeight="80" VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding LoadErrorMessage}"
               Foreground="{DynamicResource AppDangerDarkBrush}"
               FontSize="12"
               TextWrapping="Wrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6">
                <dxg:GridControl ItemsSource="{Binding TablesView}"
                                 SelectedItem="{Binding SelectedTable, Mode=TwoWay}"
                                 AutoGenerateColumns="None">
                    <dxg:GridControl.View>
                        <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                       AllowPerPixelScrolling="True" />
                    </dxg:GridControl.View>
                    <dxg:GridControl.Columns>
                        <dxg:GridColumn Header="Table_Id" FieldName="TableId" Width="80" AllowEditing="False" />
                        <dxg:GridColumn Header="Table_Code" FieldName="TableCode" Width="150" AllowEditing="False" />
                        <dxg:GridColumn Header="Table_Name" FieldName="TableName" Width="*" AllowEditing="False" />
                        <dxg:GridColumn Header="Schema" FieldName="SchemaName" Width="90" AllowEditing="False" />
                        <dxg:GridColumn Header="Is_Tenant" FieldName="IsTenant" Width="85" AllowEditing="False" />
                        <dxg:GridColumn Header="Active" FieldName="IsActive" Width="70" AllowEditing="False" />
                        <dxg:GridColumn Header="Updated_At" FieldName="UpdatedAt" Width="130" AllowEditing="False">
                            <dxg:GridColumn.EditSettings>
                                <dxe:TextEditSettings DisplayFormat="dd/MM/yyyy HH:mm" />
                            </dxg:GridColumn.EditSettings>
                        </dxg:GridColumn>
                    </dxg:GridControl.Columns>
                </dxg:GridControl>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="{DynamicResource AppAccentLightBrush}" BorderThickness="1" CornerRadius="6"
                    Background="{DynamicResource AppSurfaceBrush}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Tạo mới Sys_Table" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Text" Value="Cập nhật Sys_Table" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Grid.Row="1" Margin="0,2,0,12">
                        <TextBlock FontSize="12"
                                   Opacity="0.6"
                                   Text="{Binding EditTableId, StringFormat='Đang chỉnh sửa Table_Id={0}', TargetNullValue='Nhập thông tin và bấm Tạo mới để lưu.'}" />

                        <!-- Chọn nhanh bảng/view thật từ Target DB → tự điền Table_Code + Schema_Name. -->
                        <TextBlock Text="Chọn bảng / view có sẵn (Target DB)"
                                   FontSize="12" FontWeight="SemiBold" Opacity="0.75" Margin="0,12,0,2" />
                        <TextBlock Text="Chọn 1 bảng/view vật lý đang có trong Target DB — hệ thống tự điền Table_Code và Schema_Name. Để trống nếu muốn khai báo thủ công."
                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,6" />
                        <dxe:ComboBoxEdit ItemsSource="{Binding DbObjects}"
                                          EditValue="{Binding SelectedDbObject, UpdateSourceTrigger=PropertyChanged}"
                                          IsTextEditable="True"
                                          ImmediatePopup="True"
                                          IncrementalFiltering="True"
                                          FilterCondition="Contains"
                                          NullText="— Chọn để tự điền Code, hoặc gõ tay bên dưới —"
                                          Height="34" />
                    </StackPanel>

                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Table_Code *" FontSize="12" FontWeight="SemiBold" Opacity="0.75" Margin="0,0,0,2" />
                        <TextBlock Text="Mã định danh duy nhất của bảng metadata — dùng trong cấu hình và các engine. Nên viết HOA, không dấu, không khoảng trắng (VD: UI_CUSTOMER)."
                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,6" />
                    </StackPanel>
                    <dxe:TextEdit Grid.Row="3"
                                  EditValue="{Binding EditTableCode, UpdateSourceTrigger=PropertyChanged}"
                                  NullText="VD: UI_CUSTOMER, UI_INVOICE"
                                  Height="34"
                                  Margin="0,0,0,10" />

                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Table_Name *" FontSize="12" FontWeight="SemiBold" Opacity="0.75" Margin="0,0,0,2" />
                        <TextBlock Text="Tên hiển thị thân thiện cho người dùng — có thể là tiếng Việt có dấu (VD: Danh mục khách hàng)."
                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,6" />
                    </StackPanel>
                    <dxe:TextEdit Grid.Row="5"
                                  EditValue="{Binding EditTableName, UpdateSourceTrigger=PropertyChanged}"
                                  NullText="VD: Danh mục khách hàng"
                                  Height="34"
                                  Margin="0,0,0,10" />

                    <StackPanel Grid.Row="6" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Schema_Name *" FontSize="12" FontWeight="SemiBold" Opacity="0.75" Margin="0,0,0,2" />
                                <TextBlock Text="Schema chứa bảng/view vật lý trong Target DB (mặc định dbo)."
                                           FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,6" />
                                <dxe:TextEdit EditValue="{Binding EditSchemaName, UpdateSourceTrigger=PropertyChanged}"
                                              Height="34"
                                              NullText="dbo" />
                            </StackPanel>

                            <dxe:CheckEdit Grid.Column="2"
                                           Content="Is_Tenant"
                                           IsChecked="{Binding EditIsTenant}"
                                           ToolTip="Bật nếu bảng chứa dữ liệu riêng theo từng tenant (mỗi tenant một bộ dữ liệu); tắt nếu là bảng dùng chung."
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,6" />

                            <dxe:CheckEdit Grid.Column="4"
                                           Content="Is_Active"
                                           IsChecked="{Binding EditIsActive}"
                                           ToolTip="Bật = bản ghi đang hiệu lực và xuất hiện trong cấu hình; tắt = ẩn/vô hiệu khỏi hệ thống."
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,6" />
                        </Grid>

                        <TextBlock FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Is_Tenant: bảng có dữ liệu riêng theo từng tenant. • Is_Active: bản ghi đang hiệu lực (tắt để ẩn/vô hiệu)." />
                    </StackPanel>

                    <StackPanel Grid.Row="7">
                        <TextBlock Text="Description" FontSize="12" FontWeight="SemiBold" Opacity="0.75" Margin="0,0,0,2" />
                        <TextBlock Text="Ghi chú nội bộ mô tả mục đích/ý nghĩa của bảng (không bắt buộc)."
                                   FontSize="11" Opacity="0.5" TextWrapping="Wrap" Margin="0,0,0,6" />
                        <TextBox Text="{Binding EditDescription, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 MinHeight="120"
                                 Padding="8"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 BorderThickness="1" />
                    </StackPanel>

                    <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,12,0,0">
                        <dx:SimpleButton Command="{Binding SaveCommand}" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding SaveButtonText}" Margin="6,0,0,0" />
                            </StackPanel>
                        </dx:SimpleButton>

                        <dx:SimpleButton Command="{Binding NewCommand}" Content="Làm mới form nhập" Margin="0,0,8,0" />

                        <dx:SimpleButton Command="{Binding GenerateHookStoreCommand}"
                                         ToolTip="Tạo store skeleton (spc_Grid_/sp_AfterSave_Grid_) cho bảng đang chọn TRỰC TIẾP trên Target DB — hỏi xác nhận, chỉ tạo nếu chưa có (không đè proc đã sửa).">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" VerticalAlignment="Center" />
                                <TextBlock Text="Tạo store" Margin="6,0,0,0" />
                            </StackPanel>
                        </dx:SimpleButton>

                        <dx:SimpleButton Command="{Binding CheckAuditColumnsCommand}"
                                         Margin="8,0,0,0"
                                         ToolTip="Đối chiếu khối cột auto chuẩn (CreatedBy/CreatedAt/UpdatedBy/UpdatedAt/IsDeleted/Ver) của bảng đang chọn với Target DB. Thiếu → hỏi xác nhận rồi ALTER trực tiếp lên Target DB (idempotent).">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧩" VerticalAlignment="Center" />
                                <TextBlock Text="Kiểm tra cột chuẩn" Margin="6,0,0,0" />
                            </StackPanel>
                        </dx:SimpleButton>
                    </StackPanel>

                    <Border Grid.Row="9"
                            Margin="0,12,0,0"
                            Padding="10,8"
                            CornerRadius="6"
                            Visibility="{Binding HasSaveStatus, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource AppSuccessLightBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AppSuccessLightBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSaveStatusError}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AppDangerSoftBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource AppDangerLightBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding SaveStatusMessage}" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource AppSuccessDarkBrush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSaveStatusError}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource AppDangerDarkBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6"
                Background="{DynamicResource AppAccentSoftBrush}" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ℹ" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock FontSize="12" Opacity="0.6" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hiển thị {0} / {1} bản ghi Sys_Table">
                            <Binding Path="FilteredCount" />
                            <Binding Path="TotalTables" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
