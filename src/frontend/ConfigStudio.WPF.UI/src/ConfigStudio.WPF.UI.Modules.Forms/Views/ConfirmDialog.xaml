<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.ConfirmDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="440">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Padding="20,14"
                    Background="{DynamicResource AppDangerSoftBrush}"
                    BorderBrush="{DynamicResource AppDangerLightBrush}"
                    BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppDangerDarkBrush}" />
            </Border>
            <TextBlock Grid.Row="1" Margin="20,18" Text="{Binding Message}"
                       TextWrapping="Wrap" FontSize="13"
                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
            <Border Grid.Row="2" Padding="20,10"
                    Background="{DynamicResource AppSurfaceMutedBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding CancelText}" Command="{Binding CancelCommand}"
                            Style="{DynamicResource AppOutlineButtonStyle}" Margin="0,0,8,0" />
                    <Button Content="{Binding ConfirmText}" Command="{Binding ConfirmCommand}"
                            Style="{DynamicResource AppActionButtonStyle}"
                            Background="{DynamicResource AppDangerBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
