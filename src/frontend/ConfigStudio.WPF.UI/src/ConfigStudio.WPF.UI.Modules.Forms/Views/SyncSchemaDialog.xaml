<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Forms.Views.SyncSchemaDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="620" MinHeight="440" MaxHeight="700"
             mc:Ignorable="d"
             Background="#F8FAFC">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- ── Action button ─────────────────────────────────── -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="18,0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost button ──────────────────────────────────── -->
        <Style x:Key="GhostBtnStyle" TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#475569" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                BorderBrush="#CBD5E1" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Row item (warning/mismatch list) ─────────────── -->
        <Style x:Key="IssueRowStyle" TargetType="Border">
            <Setter Property="Background"      Value="White" />
            <Setter Property="BorderBrush"     Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding"         Value="14,10" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header     -->
            <RowDefinition Height="*"    />   <!-- Tab body   -->
            <RowDefinition Height="Auto" />   <!-- Section picker (tab 0 only) -->
            <RowDefinition Height="Auto" />   <!-- Footer buttons -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- HEADER                                              -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFF7ED" CornerRadius="8" Width="36" Height="36"
                            Margin="0,0,12,0" VerticalAlignment="Center">
                        <TextBlock Text="🔄" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Đồng bộ cấu trúc cột DB"
                                   FontSize="16" FontWeight="SemiBold" Foreground="#0F172A" />
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                            <!-- Cột cần thêm -->
                            <Border Background="#EFF6FF" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                    Visibility="{Binding AddCount, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="11" Foreground="#1D4ED8"
                                           Text="{Binding AddCount, StringFormat={}+{0} cột mới}" />
                            </Border>
                            <!-- Field cảnh báo -->
                            <Border Background="#FEF3C7" CornerRadius="4" Padding="7,2" Margin="0,0,6,0"
                                    Visibility="{Binding RemoveCount, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="11" Foreground="#92400E"
                                           Text="{Binding RemoveCount, StringFormat={}{0} field mồ côi}" />
                            </Border>
                            <!-- Type mismatch -->
                            <Border Background="#FEF2F2" CornerRadius="4" Padding="7,2"
                                    Visibility="{Binding MismatchCount, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="11" Foreground="#DC2626"
                                           Text="{Binding MismatchCount, StringFormat={}{0} type lỗi}" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB CONTROL                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveTab}"
                    Background="Transparent" BorderThickness="0">

            <!-- ── Tab 0: Có thể thêm ─────────────────────── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Có thể thêm" VerticalAlignment="Center" />
                        <Border Background="#DBEAFE" CornerRadius="10" Padding="6,1"
                                Margin="6,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ColumnsToAdd.Count}"
                                       FontSize="11" Foreground="#1D4ED8" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Select toolbar -->
                        <RowDefinition Height="*" />     <!-- List -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar: Select All / Deselect All -->
                    <Border Grid.Row="0" Background="#F8FAFC"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1"
                            Padding="14,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Chọn cột cần thêm field:"
                                       FontSize="12" FontWeight="SemiBold" Foreground="#475569"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                            <Button Content="Tất cả" Command="{Binding SelectAllAddCommand}"
                                    Style="{StaticResource GhostBtnStyle}"
                                    Height="26" Padding="10,0" FontSize="12" FontWeight="Normal"
                                    Margin="0,0,6,0" />
                            <Button Content="Bỏ chọn" Command="{Binding DeselectAllAddCommand}"
                                    Style="{StaticResource GhostBtnStyle}"
                                    Height="26" Padding="10,0" FontSize="12" FontWeight="Normal" />
                        </StackPanel>
                    </Border>

                    <!-- Column list -->
                    <Border Grid.Row="1" Background="White">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ColumnsToAdd}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource IssueRowStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Column.ColumnName}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#1E293B" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Column.DataType}"
                                                                   FontSize="11" Foreground="#64748B"
                                                                   FontFamily="Cascadia Code, Consolas" />
                                                        <TextBlock Text=" · " FontSize="11" Foreground="#CBD5E1" />
                                                        <TextBlock FontSize="11">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text"       Value="NOT NULL" />
                                                                    <Setter Property="Foreground" Value="#64748B" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Column.IsNullable}" Value="True">
                                                                            <Setter Property="Text"       Value="NULL" />
                                                                            <Setter Property="Foreground" Value="#94A3B8" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- EditorType badge -->
                                                <Border Grid.Column="2"
                                                        CornerRadius="4" Padding="7,2"
                                                        VerticalAlignment="Center">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#E0E7FF" Opacity="0.6" />
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Column.DefaultEditorType}"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding EditorTypeBadgeColor}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── Tab 1: Cảnh báo (field mồ côi) ────────── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ Cảnh báo" VerticalAlignment="Center"
                                   Foreground="#D97706" />
                        <Border Background="#FEF3C7" CornerRadius="10" Padding="6,1"
                                Margin="6,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding OrphanedFields.Count}"
                                       FontSize="11" Foreground="#92400E" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Border Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Hướng dẫn -->
                            <Border Margin="14,12,14,4" CornerRadius="6" Padding="12,8"
                                    Background="#FFFBEB" BorderBrush="#FDE68A" BorderThickness="1">
                                <TextBlock FontSize="12" Foreground="#78350F" TextWrapping="Wrap"
                                           Text="Các field sau đang tham chiếu cột không còn tồn tại trong Target DB. Tích chọn để xóa khỏi form." />
                            </Border>

                            <ItemsControl ItemsSource="{Binding OrphanedFields}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource IssueRowStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsMarkedForRemoval}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,12,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Field.Code}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#1E293B" />
                                                    <TextBlock Margin="0,2,0,0" FontSize="11"
                                                               Foreground="#94A3B8"
                                                               Text="{Binding SectionName,
                                                                      StringFormat={}Section: {0}}" />
                                                </StackPanel>

                                                <!-- Danger badge -->
                                                <Border Grid.Column="2"
                                                        Background="#FEE2E2" CornerRadius="4"
                                                        Padding="7,2" VerticalAlignment="Center">
                                                    <TextBlock Text="Mồ côi" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="#DC2626" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- ── Tab 2: Type Mismatch ───────────────────── -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Type Mismatch" VerticalAlignment="Center"
                                   Foreground="#DC2626" />
                        <Border Background="#FEE2E2" CornerRadius="10" Padding="6,1"
                                Margin="6,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding TypeMismatches.Count}"
                                       FontSize="11" Foreground="#DC2626" FontWeight="SemiBold" />
                        </Border>
                    </StackPanel>
                </TabItem.Header>

                <Border Background="White">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Hướng dẫn -->
                            <Border Margin="14,12,14,4" CornerRadius="6" Padding="12,8"
                                    Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1">
                                <TextBlock FontSize="12" Foreground="#7F1D1D" TextWrapping="Wrap"
                                           Text="Các field sau có EditorType không còn phù hợp với kiểu dữ liệu hiện tại. Vui lòng chỉnh thủ công trong FieldConfig." />
                            </Border>

                            <ItemsControl ItemsSource="{Binding TypeMismatches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource IssueRowStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Field.Code}"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           Foreground="#1E293B" />
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="11" Foreground="#64748B"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- SECTION PICKER (chỉ cho tab "Có thể thêm")         -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#F8FAFC"
                BorderBrush="#E2E8F0" BorderThickness="0,1,0,1"
                Padding="20,12"
                Visibility="{Binding ColumnsToAdd.Count, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Thêm vào Section:"
                           FontSize="12" FontWeight="SemiBold" Foreground="#475569"
                           VerticalAlignment="Center" Margin="0,0,12,0" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding AvailableSections}"
                          SelectedItem="{Binding SelectedSection}"
                          DisplayMemberPath="Label"
                          Height="34" FontSize="13" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- FOOTER BUTTONS                                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="White" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Hủy -->
                <Button Grid.Column="1"
                        Content="Đóng"
                        Command="{Binding CloseCommand}"
                        Style="{StaticResource GhostBtnStyle}" />

                <!-- Áp dụng -->
                <Button Grid.Column="3"
                        Command="{Binding ApplyCommand}"
                        Style="{StaticResource ActionBtnStyle}"
                        Background="#F59E0B" Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock VerticalAlignment="Center">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}Áp dụng ({0} thêm, {1} xóa)">
                                    <Binding Path="AddCount" />
                                    <Binding Path="RemoveCount" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
