<UserControl x:Class="ConfigStudio.WPF.UI.Modules.I18n.Views.I18nEditorDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Width="540" MinHeight="320" MaxHeight="640"
             mc:Ignorable="d"
             Background="{DynamicResource AppSurfaceMutedBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Action button (primary) -->
        <Style x:Key="ActionBtnStyle" TargetType="Button">
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="18,0" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ghost button (secondary) -->
        <Style x:Key="GhostBtnStyle" TargetType="Button" BasedOn="{StaticResource ActionBtnStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6"
                                BorderBrush="{DynamicResource AppBorderStrongBrush}" BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppPageBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Value TextBox với rounded border -->
        <Style x:Key="ValueBoxStyle" TargetType="TextBox">
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="BorderBrush"              Value="{DynamicResource AppBorderStrongBrush}" />
            <Setter Property="Background"               Value="White" />
            <Setter Property="MinHeight"                Value="34" />
            <Setter Property="Padding"                  Value="9,7" />
            <Setter Property="FontSize"                 Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextWrapping"             Value="Wrap" />
            <Setter Property="AcceptsReturn"            Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Header -->
            <RowDefinition Height="*"    />   <!-- Rows   -->
            <RowDefinition Height="Auto" />   <!-- Error  -->
            <RowDefinition Height="Auto" />   <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Border Background="{DynamicResource AppAccentSoftBrush}" CornerRadius="8" Width="36" Height="36"
                        Margin="0,0,12,0" VerticalAlignment="Center">
                    <TextBlock Text="🌐" FontSize="18"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Dịch đa ngôn ngữ"
                                   FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AppTextStrongBrush}" />
                        <Border Background="{DynamicResource AppPageBackgroundBrush}" CornerRadius="4" Padding="7,2"
                                Margin="10,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding HasContextLabel, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ContextLabel}" FontSize="11"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}" />
                        </Border>
                    </StackPanel>
                    <!-- Key (readonly — tự sinh từ caller) -->
                    <TextBox Text="{Binding ResourceKey}"
                             IsReadOnly="True"
                             BorderThickness="0" Background="Transparent"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="11" Foreground="{DynamicResource AppTextMutedBrush}" Margin="0,2,0,0"
                             ToolTip="{Binding ResourceKey}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ROWS -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Background="White" Padding="20,14">
            <ItemsControl ItemsSource="{Binding Rows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- Lang label -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBlock Text="{Binding DisplayLang}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                <TextBlock Text=" *" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource AppDangerBrush}"
                                           Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <!-- Value -->
                            <TextBox Grid.Row="1"
                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ValueBoxStyle}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ERROR -->
        <Border Grid.Row="2" Background="{DynamicResource AppDangerSoftBrush}"
                BorderBrush="{DynamicResource AppDangerLightBrush}" BorderThickness="0,1,0,0"
                Padding="20,10"
                Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="14" Margin="0,0,8,0"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource AppDangerBrush}"
                           FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <Border Grid.Row="3" Background="White"
                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Hủy"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource GhostBtnStyle}" />

                <Button Grid.Column="3"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource ActionBtnStyle}"
                        Background="{DynamicResource AppAccentBrush}" Foreground="White">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Lưu tất cả" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
