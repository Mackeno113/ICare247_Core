<UserControl x:Class="ConfigStudio.WPF.UI.Modules.I18n.Views.I18nManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: Header + Filter
             ═══════════════════════════════════════════════════════════ -->
        <md:Card Grid.Row="0" Margin="16,16,16,0" Padding="16"
                 md:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="i18n Manager"
                                   Style="{StaticResource MaterialDesignHeadline5TextBlock}" />
                        <TextBlock Text="Quản lý resource key đa ngôn ngữ"
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.6" Margin="0,2,0,0" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding ImportCommand}"
                                Margin="0,0,8,0" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Import" VerticalAlignment="Center" />
                                <TextBlock Text="Import" Margin="4,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding ExportCommand}"
                                Margin="0,0,8,0" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Export" VerticalAlignment="Center" />
                                <TextBlock Text="Export" Margin="4,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding RefreshCommand}" ToolTip="Làm mới">
                            <md:PackIcon Kind="Refresh" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                Command="{Binding AddEntryCommand}" Margin="8,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Plus" VerticalAlignment="Center" />
                                <TextBlock Text="Thêm Key" Margin="6,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>

                <!-- Filter bar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBox Width="280"
                             md:HintAssist.Hint="Tìm key, giá trị vi-VN hoặc en-US..."
                             md:HintAssist.IsFloating="False"
                             md:TextFieldAssist.HasClearButton="True"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,12,0" />

                    <ComboBox Width="130"
                              md:HintAssist.Hint="Module"
                              md:HintAssist.IsFloating="True"
                              ItemsSource="{Binding ModuleOptions}"
                              SelectedItem="{Binding ModuleFilter}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,12,0" />

                    <CheckBox Content="Chỉ hiện thiếu bản dịch"
                              IsChecked="{Binding ShowMissingOnly}"
                              VerticalAlignment="Center"
                              Style="{StaticResource MaterialDesignCheckBox}" />
                </StackPanel>
            </Grid>
        </md:Card>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: DataGrid — key/language matrix (editable)
             ═══════════════════════════════════════════════════════════ -->
        <md:Card Grid.Row="1" Margin="16,8,16,0" Padding="0"
                 md:ElevationAssist.Elevation="Dp1">
            <DataGrid ItemsSource="{Binding EntriesView}"
                      SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      BorderThickness="0"
                      Style="{StaticResource MaterialDesignDataGrid}">

                <DataGrid.Columns>
                    <!-- Key (read-only display) -->
                    <DataGridTextColumn Header="Resource Key"
                                        Binding="{Binding ResourceKey}"
                                        Width="180"
                                        IsReadOnly="True" />

                    <!-- Module -->
                    <DataGridTextColumn Header="Module"
                                        Binding="{Binding Module}"
                                        Width="80"
                                        IsReadOnly="True" />

                    <!-- vi-VN (editable) -->
                    <DataGridTextColumn Header="vi-VN"
                                        Binding="{Binding ViVn, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />

                    <!-- en-US (editable) -->
                    <DataGridTextColumn Header="en-US"
                                        Binding="{Binding EnUs, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />

                    <!-- ja-JP (editable) -->
                    <DataGridTextColumn Header="ja-JP"
                                        Binding="{Binding JaJp, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />

                    <!-- Missing indicator -->
                    <DataGridTemplateColumn Header="" Width="35">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <md:PackIcon Kind="AlertOutline"
                                             Foreground="Orange" Width="16" Height="16"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"
                                             Visibility="{Binding HasMissing, Converter={StaticResource BoolToVis}}"
                                             ToolTip="Thiếu bản dịch" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Delete -->
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                        Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                        ToolTip="Xóa key" Width="28" Height="28">
                                    <md:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                                </Button>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6"
                Background="{DynamicResource MaterialDesignToolBarBackground}" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="Translate" Width="14" Height="14"
                             VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.6" Margin="6,0,16,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hiển thị {0} / {1} keys · {2} thiếu bản dịch">
                            <Binding Path="FilteredCount" />
                            <Binding Path="TotalEntries" />
                            <Binding Path="MissingCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
