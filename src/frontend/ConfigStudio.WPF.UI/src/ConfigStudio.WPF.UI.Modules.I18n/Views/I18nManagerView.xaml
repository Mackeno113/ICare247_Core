<UserControl x:Class="ConfigStudio.WPF.UI.Modules.I18n.Views.I18nManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: Header + Filter
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Title -->
                <DockPanel Grid.Row="0">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <dx:SimpleButton Command="{Binding GoBackCommand}"
                                         Width="32" Height="32" Content="←" FontSize="16"
                                         Margin="0,0,10,0"
                                         ToolTip="Quay lại màn hình trước"
                                         Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVis}}" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="i18n Manager"
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                            <TextBlock Text="Quản lý resource key đa ngôn ngữ"
                                       FontSize="12" Opacity="0.6" Margin="0,2,0,0"
                                       Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <dx:SimpleButton Command="{Binding ImportCommand}"
                                         Margin="0,0,8,0" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Import" VerticalAlignment="Center" />
                            </StackPanel>
                        </dx:SimpleButton>
                        <dx:SimpleButton Command="{Binding ExportCommand}"
                                         Margin="0,0,8,0" Height="34">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Export" VerticalAlignment="Center" />
                            </StackPanel>
                        </dx:SimpleButton>
                        <dx:SimpleButton Command="{Binding RefreshCommand}" ToolTip="Làm mới"
                                         Width="32" Height="32" Content="↻" FontSize="16"
                                         Margin="0,0,8,0" />
                        <dx:SimpleButton Command="{Binding AddEntryCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" VerticalAlignment="Center" />
                                <TextBlock Text="Thêm Key" Margin="6,0,0,0" />
                            </StackPanel>
                        </dx:SimpleButton>
                    </StackPanel>
                </DockPanel>

                <!-- Filter bar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <dxe:TextEdit Width="280"
                                  NullText="Tìm key, giá trị vi-VN hoặc en-US..."
                                  EditValue="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                  Margin="0,0,12,0" />

                    <dxe:ComboBoxEdit Width="130"
                                      NullText="Module"
                                      ItemsSource="{Binding ModuleOptions}"
                                      EditValue="{Binding ModuleFilter}"
                                      Margin="0,0,12,0" />

                    <dxe:CheckEdit Content="Chỉ hiện thiếu bản dịch"
                                   IsChecked="{Binding ShowMissingOnly}"
                                   VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: GridControl — key/language matrix (editable)
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Margin="16,8,16,0"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <dxg:GridControl ItemsSource="{Binding EntriesView}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                             AutoPopulateColumns="False">
                <dxg:GridControl.View>
                    <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                   AllowPerPixelScrolling="True" />
                </dxg:GridControl.View>
                <dxg:GridControl.Columns>
                    <dxg:GridColumn Header="Resource Key" FieldName="ResourceKey" Width="180" AllowEditing="False" />
                    <dxg:GridColumn Header="Module" FieldName="Module" Width="80" AllowEditing="False" />
                    <dxg:GridColumn Header="vi-VN" FieldName="ViVn" Width="*" />
                    <dxg:GridColumn Header="en-US" FieldName="EnUs" Width="*" />
                    <dxg:GridColumn Header="ja-JP" FieldName="JaJp" Width="*" />
                    <dxg:GridColumn Header="" Width="35" AllowEditing="False" AllowSorting="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="⚠" FontSize="14" Foreground="Orange"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           Visibility="{Binding Row.HasMissing, Converter={StaticResource BoolToVis}}"
                                           ToolTip="Thiếu bản dịch" />
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                    <dxg:GridColumn Header="" Width="40" AllowEditing="False" AllowSorting="False">
                        <dxg:GridColumn.CellTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.DeleteEntryCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                        CommandParameter="{Binding Row}"
                                        Foreground="#EF4444"
                                        ToolTip="Xóa key" Width="28" Height="28"
                                        Background="Transparent" BorderBrush="Transparent">
                                    <TextBlock Text="🗑" />
                                </Button>
                            </DataTemplate>
                        </dxg:GridColumn.CellTemplate>
                    </dxg:GridColumn>
                </dxg:GridControl.Columns>
            </dxg:GridControl>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6"
                Background="#EEF5FF" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🌐" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock FontSize="12" Opacity="0.6" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="Hiển thị {0} / {1} keys · {2} thiếu bản dịch">
                            <Binding Path="FilteredCount" />
                            <Binding Path="TotalEntries" />
                            <Binding Path="MissingCount" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
