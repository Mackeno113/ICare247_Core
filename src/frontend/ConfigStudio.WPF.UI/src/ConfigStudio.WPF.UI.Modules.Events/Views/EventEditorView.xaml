<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Events.Views.EventEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: Header + Toolbar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Command="{Binding BackCommand}" ToolTip="Quay lại Field Config"
                            Width="30" Height="30" Background="Transparent" BorderBrush="Transparent">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" />
                    </Button>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Events — {0}">
                                    <Binding Path="FieldCode" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="12" Opacity="0.6"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Field #{0} · {1} events">
                                    <Binding Path="FieldId" />
                                    <Binding Path="Events.Count" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="•" Foreground="Orange" FontSize="20"
                               Margin="12,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <dx:SimpleButton Command="{Binding AddEventCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="+" VerticalAlignment="Center" />
                            <TextBlock Text="Thêm Event" Margin="6,0,0,0" />
                        </StackPanel>
                    </dx:SimpleButton>
                    <dx:SimpleButton Command="{Binding SaveAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" VerticalAlignment="Center" />
                            <TextBlock Text="Lưu" Margin="6,0,0,0" />
                        </StackPanel>
                    </dx:SimpleButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: Events GridControl (left) + Actions panel (right)
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- Events GridControl -->
            <Border Grid.Column="0" BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Events" Margin="12,12,12,8"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                    <dxg:GridControl ItemsSource="{Binding Events}"
                                     SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                                     AutoPopulateColumns="False">
                        <dxg:GridControl.View>
                            <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                           AllowPerPixelScrolling="True" />
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn Header="#" FieldName="OrderNo" Width="40" />
                            <dxg:GridColumn Header="Trigger" FieldName="TriggerCode" Width="100" />
                            <dxg:GridColumn Header="Condition" FieldName="ConditionPreview" Width="*" />
                            <dxg:GridColumn Header="Actions" FieldName="ActionsCount" Width="70" />
                            <dxg:GridColumn Header="Active" FieldName="IsActive" Width="60" />
                            <dxg:GridColumn Header="" Width="70" AllowEditing="False" AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Command="{Binding DataContext.EditConditionCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    ToolTip="Sửa condition" Width="30" Height="30"
                                                    Background="Transparent" BorderBrush="Transparent">
                                                <TextBlock Text="{}{ }" />
                                            </Button>
                                            <Button Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    Foreground="#EF4444"
                                                    ToolTip="Xóa event" Width="30" Height="30"
                                                    Background="Transparent" BorderBrush="Transparent">
                                                <TextBlock Text="🗑" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Actions panel -->
            <Border Grid.Column="2" BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="12,12,12,8">
                        <TextBlock Text="Actions" DockPanel.Dock="Left"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellSidebarItemTextBrush}"
                                   VerticalAlignment="Center" />
                        <dx:SimpleButton DockPanel.Dock="Right" HorizontalAlignment="Right"
                                         Command="{Binding AddActionCommand}"
                                         Height="28" Padding="8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="Thêm" Margin="4,0,0,0" FontSize="12" />
                            </StackPanel>
                        </dx:SimpleButton>
                    </DockPanel>

                    <!-- Actions GridControl -->
                    <dxg:GridControl ItemsSource="{Binding Actions}"
                                     SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                                     AutoPopulateColumns="False">
                        <dxg:GridControl.View>
                            <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                           AllowPerPixelScrolling="True" />
                        </dxg:GridControl.View>
                        <dxg:GridControl.Columns>
                            <dxg:GridColumn Header="#" FieldName="OrderNo" Width="35" />
                            <dxg:GridColumn Header="Action" FieldName="ActionType" Width="110" />
                            <dxg:GridColumn Header="Target" FieldName="TargetField" Width="*" />
                            <dxg:GridColumn Header="" Width="35" AllowEditing="False" AllowSorting="False">
                                <dxg:GridColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.DeleteActionCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                CommandParameter="{Binding Row}"
                                                Foreground="#EF4444"
                                                ToolTip="Xóa action" Width="28" Height="28"
                                                Background="Transparent" BorderBrush="Transparent">
                                            <TextBlock Text="✕" />
                                        </Button>
                                    </DataTemplate>
                                </dxg:GridColumn.CellTemplate>
                            </dxg:GridColumn>
                        </dxg:GridControl.Columns>
                    </dxg:GridControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6"
                Background="#EEF5FF" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚡" Margin="0,0,6,0" VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock FontSize="12" Opacity="0.6" VerticalAlignment="Center">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} events · Field: {1}">
                            <Binding Path="Events.Count" />
                            <Binding Path="FieldCode" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
