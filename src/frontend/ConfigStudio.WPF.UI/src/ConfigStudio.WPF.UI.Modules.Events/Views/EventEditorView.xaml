<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Events.Views.EventEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 0: Header + Toolbar
             ═══════════════════════════════════════════════════════════ -->
        <md:Card Grid.Row="0" Margin="16,16,16,0" Padding="16"
                 md:ElevationAssist.Elevation="Dp2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding BackCommand}" ToolTip="Quay lại Field Config">
                        <md:PackIcon Kind="ArrowLeft" />
                    </Button>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource MaterialDesignHeadline6TextBlock}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Events — {0}">
                                    <Binding Path="FieldCode" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}" Opacity="0.6">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="Field #{0} · {1} events">
                                    <Binding Path="FieldId" />
                                    <Binding Path="Events.Count" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                    <md:PackIcon Kind="CircleSmall" Foreground="Orange" Margin="12,0,0,0"
                                 VerticalAlignment="Center"
                                 Visibility="{Binding IsDirty, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding AddEventCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Plus" VerticalAlignment="Center" />
                            <TextBlock Text="Thêm Event" Margin="6,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                            Command="{Binding SaveAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ContentSave" VerticalAlignment="Center" />
                            <TextBlock Text="Lưu" Margin="6,0,0,0" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </md:Card>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 1: Events DataGrid (left) + Actions panel (right)
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="16,8,16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- Events DataGrid -->
            <md:Card Grid.Column="0" Padding="0" md:ElevationAssist.Elevation="Dp1">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Events" Margin="12,12,12,8"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}" />
                    <DataGrid ItemsSource="{Binding Events}"
                              SelectedItem="{Binding SelectedEvent, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding OrderNo}" Width="40" />
                            <DataGridTextColumn Header="Trigger" Binding="{Binding TriggerCode}" Width="100" />
                            <DataGridTextColumn Header="Condition" Binding="{Binding ConditionPreview}" Width="*" />
                            <DataGridTextColumn Header="Actions" Binding="{Binding ActionsCount}" Width="70" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="60" />
                            <DataGridTemplateColumn Header="" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Command="{Binding DataContext.EditConditionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    ToolTip="Sửa condition" Width="30" Height="30">
                                                <md:PackIcon Kind="CodeBraces" Width="16" Height="16" />
                                            </Button>
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Command="{Binding DataContext.DeleteEventCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                    ToolTip="Xóa event" Width="30" Height="30">
                                                <md:PackIcon Kind="DeleteOutline" Width="16" Height="16" />
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </md:Card>

            <GridSplitter Grid.Column="1" Width="4" Background="Transparent"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <!-- Actions panel -->
            <md:Card Grid.Column="2" Padding="0" md:ElevationAssist.Elevation="Dp1">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="12,12,12,8">
                        <TextBlock Text="Actions" DockPanel.Dock="Left"
                                   Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                                   VerticalAlignment="Center" />
                        <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Command="{Binding AddActionCommand}"
                                Height="28" Padding="8,0">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center" />
                                <TextBlock Text="Thêm" Margin="4,0,0,0" FontSize="12" />
                            </StackPanel>
                        </Button>
                    </DockPanel>

                    <!-- Actions list -->
                    <DataGrid ItemsSource="{Binding Actions}"
                              SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Style="{StaticResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding OrderNo}" Width="35" />
                            <DataGridTextColumn Header="Action" Binding="{Binding ActionType}" Width="110" />
                            <DataGridTextColumn Header="Target" Binding="{Binding TargetField}" Width="*" />
                            <DataGridTemplateColumn Header="" Width="35">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Command="{Binding DataContext.DeleteActionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                ToolTip="Xóa action" Width="28" Height="28">
                                            <md:PackIcon Kind="Close" Width="14" Height="14" />
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </md:Card>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             ROW 2: Status bar
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Margin="16,8,16,16" Padding="12,6"
                Background="{DynamicResource MaterialDesignToolBarBackground}" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="LightningBolt" Width="14" Height="14"
                             VerticalAlignment="Center" Opacity="0.5" />
                <TextBlock Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.6" Margin="6,0,0,0">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0} events · Field: {1}">
                            <Binding Path="Events.Count" />
                            <Binding Path="FieldCode" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
