<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Grammar.Views.GrammarLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Grammar Library"
                               FontSize="24" FontWeight="SemiBold"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                    <TextBlock Text="Whitelist functions và operators cho AST engine"
                               FontSize="12" Opacity="0.6" Margin="0,2,0,0"
                               Foreground="{DynamicResource ShellSidebarItemTextBrush}" />
                </StackPanel>
                <dx:SimpleButton DockPanel.Dock="Right" HorizontalAlignment="Right"
                                 Command="{Binding RefreshCommand}" ToolTip="Làm mới"
                                 Width="32" Height="32" Content="↻" FontSize="16" />
            </DockPanel>
        </Border>

        <!-- TabControl: Functions + Operators -->
        <Border Grid.Row="1" Margin="16,8,16,16"
                BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}">

                <!-- Tab 1: Functions -->
                <TabItem Header="f() Functions">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="12,12,12,8">
                            <dxe:TextEdit Width="250"
                                          NullText="Tìm function..."
                                          EditValue="{Binding FunctionSearch, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,12,0" />

                            <dxe:ComboBoxEdit Width="140"
                                              NullText="Category"
                                              ItemsSource="{Binding FunctionCategories}"
                                              EditValue="{Binding FunctionCategoryFilter}"
                                              Margin="0,0,12,0" />

                            <dx:SimpleButton Command="{Binding AddFunctionCommand}" Height="36">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" VerticalAlignment="Center" />
                                    <TextBlock Text="Thêm" Margin="4,0,0,0" />
                                </StackPanel>
                            </dx:SimpleButton>
                        </StackPanel>

                        <dxg:GridControl ItemsSource="{Binding FunctionsView}"
                                         SelectedItem="{Binding SelectedFunction, Mode=TwoWay}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                               AllowPerPixelScrolling="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="Tên" FieldName="FunctionName" Width="120" />
                                <dxg:GridColumn Header="Category" FieldName="Category" Width="100" />
                                <dxg:GridColumn Header="Params" FieldName="ParamText" Width="70" />
                                <dxg:GridColumn Header="Return" FieldName="ReturnType" Width="80" />
                                <dxg:GridColumn Header="Mô tả" FieldName="Description" Width="*" />
                                <dxg:GridColumn Header="Ví dụ" FieldName="Example" Width="180" />
                                <dxg:GridColumn Header="" Width="40" AllowEditing="False" AllowSorting="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.DeleteFunctionCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    Foreground="#EF4444"
                                                    ToolTip="Xóa" Width="28" Height="28"
                                                    Background="Transparent" BorderBrush="Transparent">
                                                <TextBlock Text="🗑" />
                                            </Button>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </DockPanel>
                </TabItem>

                <!-- Tab 2: Operators -->
                <TabItem Header="{}{ } Operators">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="12,12,12,8">
                            <dxe:TextEdit Width="250"
                                          NullText="Tìm operator..."
                                          EditValue="{Binding OperatorSearch, UpdateSourceTrigger=PropertyChanged}"
                                          Margin="0,0,12,0" />

                            <dx:SimpleButton Command="{Binding AddOperatorCommand}" Height="36">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" VerticalAlignment="Center" />
                                    <TextBlock Text="Thêm" Margin="4,0,0,0" />
                                </StackPanel>
                            </dx:SimpleButton>
                        </StackPanel>

                        <dxg:GridControl ItemsSource="{Binding OperatorsView}"
                                         SelectedItem="{Binding SelectedOperator, Mode=TwoWay}"
                                         AutoPopulateColumns="False">
                            <dxg:GridControl.View>
                                <dxg:TableView NavigationStyle="Row" ShowGroupPanel="False"
                                               AllowPerPixelScrolling="True" />
                            </dxg:GridControl.View>
                            <dxg:GridControl.Columns>
                                <dxg:GridColumn Header="Symbol" FieldName="Symbol" Width="80" />
                                <dxg:GridColumn Header="Tên" FieldName="OperatorName" Width="140" />
                                <dxg:GridColumn Header="Category" FieldName="Category" Width="110" />
                                <dxg:GridColumn Header="Precedence" FieldName="Precedence" Width="90" />
                                <dxg:GridColumn Header="Mô tả" FieldName="Description" Width="*" />
                                <dxg:GridColumn Header="" Width="40" AllowEditing="False" AllowSorting="False">
                                    <dxg:GridColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.DeleteOperatorCommand, RelativeSource={RelativeSource AncestorType=dxg:GridControl}}"
                                                    CommandParameter="{Binding Row}"
                                                    Foreground="#EF4444"
                                                    ToolTip="Xóa" Width="28" Height="28"
                                                    Background="Transparent" BorderBrush="Transparent">
                                                <TextBlock Text="🗑" />
                                            </Button>
                                        </DataTemplate>
                                    </dxg:GridColumn.CellTemplate>
                                </dxg:GridColumn>
                            </dxg:GridControl.Columns>
                        </dxg:GridControl>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
