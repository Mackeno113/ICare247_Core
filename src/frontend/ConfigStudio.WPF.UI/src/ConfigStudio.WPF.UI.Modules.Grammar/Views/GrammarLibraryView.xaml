<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Grammar.Views.GrammarLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600"
             d:DesignWidth="1000"
             mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <md:Card Grid.Row="0" Margin="16,16,16,0" Padding="16"
                 md:ElevationAssist.Elevation="Dp2">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="Grammar Library"
                               Style="{StaticResource MaterialDesignHeadline5TextBlock}" />
                    <TextBlock Text="Whitelist functions và operators cho AST engine"
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               Opacity="0.6" Margin="0,2,0,0" />
                </StackPanel>
                <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding RefreshCommand}" ToolTip="Làm mới">
                    <md:PackIcon Kind="Refresh" />
                </Button>
            </DockPanel>
        </md:Card>

        <!-- TabControl: Functions + Operators -->
        <md:Card Grid.Row="1" Margin="16,8,16,16" Padding="0"
                 md:ElevationAssist.Elevation="Dp1">
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Style="{StaticResource MaterialDesignNavigationRailTabControl}">

                <!-- Tab 1: Functions -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Function" VerticalAlignment="Center" />
                            <TextBlock Text="Functions" Margin="6,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="12,12,12,8">
                            <TextBox Width="250"
                                     md:HintAssist.Hint="Tìm function..."
                                     md:HintAssist.IsFloating="False"
                                     md:TextFieldAssist.HasClearButton="True"
                                     Text="{Binding FunctionSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,12,0" />

                            <ComboBox Width="140"
                                      md:HintAssist.Hint="Category"
                                      md:HintAssist.IsFloating="True"
                                      ItemsSource="{Binding FunctionCategories}"
                                      SelectedItem="{Binding FunctionCategoryFilter}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Margin="0,0,12,0" />

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding AddFunctionCommand}" Height="36">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" VerticalAlignment="Center" />
                                    <TextBlock Text="Thêm" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding FunctionsView}"
                                  SelectedItem="{Binding SelectedFunction, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" SelectionMode="Single"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên" Binding="{Binding FunctionName}" Width="120" />
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                                <DataGridTextColumn Header="Params" Binding="{Binding ParamText}" Width="70" />
                                <DataGridTextColumn Header="Return" Binding="{Binding ReturnType}" Width="80" />
                                <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*" />
                                <DataGridTextColumn Header="Ví dụ" Binding="{Binding Example}" Width="180" />
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Command="{Binding DataContext.DeleteFunctionCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                    ToolTip="Xóa" Width="28" Height="28">
                                                <md:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <!-- Tab 2: Operators -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CodeBraces" VerticalAlignment="Center" />
                            <TextBlock Text="Operators" Margin="6,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                    Margin="12,12,12,8">
                            <TextBox Width="250"
                                     md:HintAssist.Hint="Tìm operator..."
                                     md:HintAssist.IsFloating="False"
                                     md:TextFieldAssist.HasClearButton="True"
                                     Text="{Binding OperatorSearch, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,12,0" />

                            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding AddOperatorCommand}" Height="36">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Plus" VerticalAlignment="Center" />
                                    <TextBlock Text="Thêm" Margin="4,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <DataGrid ItemsSource="{Binding OperatorsView}"
                                  SelectedItem="{Binding SelectedOperator, Mode=TwoWay}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" SelectionMode="Single"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Style="{StaticResource MaterialDesignDataGrid}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="80" />
                                <DataGridTextColumn Header="Tên" Binding="{Binding OperatorName}" Width="140" />
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110" />
                                <DataGridTextColumn Header="Precedence" Binding="{Binding Precedence}" Width="90" />
                                <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="*" />
                                <DataGridTemplateColumn Header="" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                    Command="{Binding DataContext.DeleteOperatorCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    Foreground="{DynamicResource MaterialDesignValidationErrorBrush}"
                                                    ToolTip="Xóa" Width="28" Height="28">
                                                <md:PackIcon Kind="DeleteOutline" Width="14" Height="14" />
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>
            </TabControl>
        </md:Card>
    </Grid>
</UserControl>
