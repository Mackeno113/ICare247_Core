<UserControl x:Class="ConfigStudio.WPF.UI.Modules.Grammar.Views.ExpressionBuilderDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
             xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:models="clr-namespace:ConfigStudio.WPF.UI.Modules.Grammar.Models"
             prism:ViewModelLocator.AutoWireViewModel="True"
             MinWidth="800" MinHeight="600"
             d:DesignWidth="900" d:DesignHeight="650"
             mc:Ignorable="d">

    <prism:Dialog.WindowStyle>
        <Style TargetType="Window">
            <Setter Property="Width" Value="900" />
            <Setter Property="Height" Value="650" />
            <Setter Property="ResizeMode" Value="CanResize" />
            <Setter Property="Title" Value="Expression Builder" />
        </Style>
    </prism:Dialog.WindowStyle>

    <DockPanel>
        <!-- ── TitleBar / Context ─────────────────────────────── -->
        <Border DockPanel.Dock="Top" Height="44"
                Background="{DynamicResource ShellTitleBarBackgroundBrush}"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <TextBlock Text="f()" FontSize="18" Foreground="White"
                           VerticalAlignment="Center" />
                <TextBlock Text="Expression Builder" Margin="8,0,0,0"
                           Foreground="White" FontSize="16" FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right" Margin="16,0,0,0"
                           Foreground="#90CAF9" FontSize="12" VerticalAlignment="Center">
                    <Run Text="Expected: " />
                    <Run Text="{Binding ExpectedReturnType, Mode=OneWay}" FontWeight="Bold" />
                    <Run Text="  " />
                    <Run Text="{Binding ContextInfo, Mode=OneWay}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ── Footer ─────────────────────────────────────────── -->
        <Border DockPanel.Dock="Bottom" Height="52"
                Background="{DynamicResource ShellContentBackgroundBrush}"
                BorderBrush="#D0E4FF" BorderThickness="0,1,0,0"
                Padding="16,0">
            <DockPanel VerticalAlignment="Center">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <dx:SimpleButton Command="{Binding ApplyCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" VerticalAlignment="Center" />
                            <TextBlock Text="Apply Expression" Margin="6,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </dx:SimpleButton>
                    <dx:SimpleButton Command="{Binding CancelCommand}"
                                     Content="Cancel" Margin="0,0,8,0" />
                    <Button Command="{Binding ResetCommand}"
                            ToolTip="Xóa toàn bộ expression"
                            Background="Transparent" BorderBrush="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↻" VerticalAlignment="Center" />
                            <TextBlock Text="Reset" Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <Button DockPanel.Dock="Right" Command="{Binding CopyJsonCommand}"
                        ToolTip="Copy JSON to clipboard"
                        Background="Transparent" BorderBrush="Transparent">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⧉" VerticalAlignment="Center" />
                        <TextBlock Text="Copy JSON" Margin="4,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </DockPanel>
        </Border>

        <!-- ── Main: 2 Columns ────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ═══ COL 1: Palette ═════════════════════════════ -->
            <Border Grid.Column="0"
                    Background="{DynamicResource ShellContentBackgroundBrush}"
                    BorderBrush="#D0E4FF" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">

                        <!-- Operators -->
                        <TextBlock Text="TOÁN TỬ" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                   Margin="4,8,0,8" />
                        <ItemsControl ItemsSource="{Binding OperatorItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PaletteItem}">
                                    <dx:SimpleButton Content="{Binding DisplayName}"
                                                     Command="{Binding DataContext.InsertOperatorCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                     CommandParameter="{Binding}"
                                                     ToolTip="{Binding Description}"
                                                     Padding="8,4" Margin="2"
                                                     FontFamily="Consolas" FontSize="13"
                                                     MinWidth="36" Height="32" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Margin="0,12" />

                        <!-- Functions -->
                        <TextBlock Text="HÀM" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                   Margin="4,0,0,8" />
                        <dxe:TextEdit EditValue="{Binding FunctionSearch, UpdateSourceTrigger=PropertyChanged}"
                                      NullText="Tìm hàm..."
                                      Margin="0,0,0,8" FontSize="12" />
                        <ListBox ItemsSource="{Binding FilteredFunctions}"
                                 MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PaletteItem}">
                                    <Border Padding="4,2" Cursor="Hand"
                                            Background="Transparent"
                                            ToolTip="{Binding Description}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                          Command="{Binding DataContext.InsertFunctionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="f()" Width="14" FontSize="11"
                                                       Foreground="#0891B2"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding DisplayName}" FontFamily="Consolas" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Margin="0,12" />

                        <!-- Fields -->
                        <TextBlock Text="FIELD (Form Context)" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                   Margin="4,0,0,8" />
                        <ListBox ItemsSource="{Binding FieldItems}"
                                 MaxHeight="200">
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:PaletteItem}">
                                    <Border Padding="4,2" Cursor="Hand"
                                            Background="Transparent"
                                            ToolTip="{Binding Description}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftDoubleClick"
                                                          Command="{Binding DataContext.InsertFieldCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="●" Width="14" FontSize="11"
                                                       Foreground="#66BB6A"
                                                       VerticalAlignment="Center" Margin="0,0,6,0" />
                                            <TextBlock Text="{Binding Code}" FontWeight="SemiBold" FontSize="12" />
                                            <TextBlock Text="{Binding NetType, StringFormat=' ({0})'}"
                                                       FontSize="11" Opacity="0.6" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#D0E4FF" />

            <!-- ═══ COL 3: Right Panel ═════════════════════════ -->
            <Grid Grid.Column="2" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- AST Tree -->
                <Border Grid.Row="0" Padding="8" Margin="0,0,0,8"
                        BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="AST Tree" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                       VerticalAlignment="Center" />
                            <Button Command="{Binding DeleteSelectedNodeCommand}"
                                    ToolTip="Delete selected node" Padding="4" Margin="12,0,0,0"
                                    Background="Transparent" BorderBrush="Transparent">
                                <TextBlock Text="🗑" FontSize="14" />
                            </Button>
                            <Button Command="{Binding WrapInBinaryCommand}"
                                    ToolTip="Wrap in Binary (&amp;&amp;)" Padding="4"
                                    Background="Transparent" BorderBrush="Transparent">
                                <TextBlock Text="[ ]" FontSize="14" />
                            </Button>
                            <Button Command="{Binding WrapInUnaryCommand}"
                                    ToolTip="Wrap in Unary (!)" Padding="4"
                                    Background="Transparent" BorderBrush="Transparent">
                                <TextBlock Text="!" FontSize="14" />
                            </Button>
                        </StackPanel>

                        <TreeView ItemsSource="{Binding RootNodes}">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate DataType="{x:Type models:AstNodeViewModel}"
                                                          ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal" Margin="2">
                                        <TextBlock Text="{Binding IconText}"
                                                   Width="18" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   Foreground="#0891B2" />
                                        <TextBlock Text="{Binding DisplayText}" Margin="6,0,0,0"
                                                   FontSize="13" VerticalAlignment="Center" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <!-- Preview & Validation -->
                <Border Grid.Row="1" Padding="12" Margin="0,0,0,8"
                        BorderBrush="#D0E4FF" BorderThickness="1" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Preview &amp; Validation" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource ShellTitleBarBackgroundBrush}"
                                   Margin="0,0,0,8" />

                        <!-- Natural Language -->
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="🌐" Width="16"
                                       VerticalAlignment="Center" Margin="0,0,6,0" Opacity="0.6" />
                            <TextBlock Text="{Binding NaturalLanguagePreview}"
                                       TextWrapping="Wrap" FontSize="13" />
                        </DockPanel>

                        <!-- Validation status -->
                        <WrapPanel Margin="0,4,0,0">
                            <!-- Return type -->
                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,4"
                                    Background="{DynamicResource ShellTitleBarBackgroundBrush}">
                                <TextBlock FontSize="11" Foreground="White">
                                    <Run Text="Return: " />
                                    <Run Text="{Binding ValidationResult.ActualReturnType, Mode=OneWay, FallbackValue='?'}" />
                                </TextBlock>
                            </Border>
                            <!-- Depth -->
                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,4"
                                    Background="{DynamicResource ShellTitleBarBackgroundBrush}">
                                <TextBlock FontSize="11" Foreground="White">
                                    <Run Text="Depth: " />
                                    <Run Text="{Binding ValidationResult.Depth, Mode=OneWay, FallbackValue='0'}" />
                                    <Run Text="/20" />
                                </TextBlock>
                            </Border>
                            <!-- Valid/Invalid -->
                            <Border CornerRadius="4" Padding="6,2" Margin="0,0,0,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#C62828" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                <Setter Property="Background" Value="#2E7D32" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="11" Foreground="White" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✕ Invalid" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsValid}" Value="True">
                                                        <Setter Property="Text" Value="✓ Valid" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Errors list -->
                        <ItemsControl ItemsSource="{Binding ValidationResult.Errors}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                        <TextBlock Text="⚠" Width="14" FontSize="11"
                                                   Foreground="#EF5350" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding}" Margin="6,0,0,0" FontSize="12"
                                                   Foreground="#EF5350" TextWrapping="Wrap" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- JSON Output (collapsed) -->
                <Expander Grid.Row="2" Header="JSON Output" IsExpanded="False">
                    <TextBox Text="{Binding JsonOutput, Mode=OneWay}"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MaxHeight="150" />
                </Expander>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
