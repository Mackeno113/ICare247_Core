<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Fonts ──────────────────────────────────────────────────── -->
    <FontFamily x:Key="ShellFontFamily">Bahnschrift</FontFamily>

    <!-- ── Window / Background Brushes ───────────────────────────── -->
    <SolidColorBrush x:Key="ShellWindowBackgroundBrush"    Color="#F4F8FF" />
    <SolidColorBrush x:Key="ShellWindowBorderBrush"        Color="#D6E2F3" />

    <LinearGradientBrush x:Key="ShellContentBackgroundBrush"
                         StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FBFF" Offset="0" />
        <GradientStop Color="#EEF5FF" Offset="1" />
    </LinearGradientBrush>

    <!-- ── Title Bar Brushes ──────────────────────────────────────── -->
    <LinearGradientBrush x:Key="ShellTitleBarBackgroundBrush"
                         StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2563EB" Offset="0" />
        <GradientStop Color="#0891B2" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ShellTitleBarTextBrush"          Color="#FFFFFF" />

    <!-- ── Status Bar Brushes ────────────────────────────────────── -->
    <SolidColorBrush x:Key="ShellStatusBarBackgroundBrush"   Color="#E6F0FF" />
    <SolidColorBrush x:Key="ShellStatusBarTextBrush"         Color="#334155" />
    <SolidColorBrush x:Key="ShellStatusBarSeparatorBrush"    Color="#94A3B8" />

    <!-- ── Tenant Badge Brushes ───────────────────────────────────── -->
    <SolidColorBrush x:Key="ShellTenantBadgeBackgroundBrush" Color="#DBEAFE" />
    <SolidColorBrush x:Key="ShellTenantBadgeBorderBrush"     Color="#93C5FD" />
    <SolidColorBrush x:Key="ShellTenantBadgeTextBrush"       Color="#1E40AF" />

    <!-- ── Sidebar Brushes ───────────────────────────────────────── -->
    <LinearGradientBrush x:Key="ShellSidebarBackgroundBrush"
                         StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F3F8FF" Offset="0" />
        <GradientStop Color="#EAF2FF" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ShellSidebarItemTextBrush"          Color="#1E293B" />
    <SolidColorBrush x:Key="ShellSidebarIconBrush"              Color="#2563EB" />
    <SolidColorBrush x:Key="ShellSidebarHoverBackgroundBrush"   Color="#E1ECFF" />
    <SolidColorBrush x:Key="ShellSidebarSelectedBackgroundBrush" Color="#D8E8FF" />
    <SolidColorBrush x:Key="ShellSidebarSelectionBorderBrush"   Color="#0284C7" />
    <SolidColorBrush x:Key="ShellSidebarDividerBrush"           Color="#C7D7F2" />

    <!-- ── Shadow Effect ─────────────────────────────────────────── -->
    <DropShadowEffect x:Key="ShellCardShadowEffect"
                      BlurRadius="16"
                      ShadowDepth="0"
                      Color="#406B8FC2"
                      Opacity="0.22" />

    <!-- ── Status Text Style ─────────────────────────────────────── -->
    <Style x:Key="ShellStatusTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground"  Value="{DynamicResource ShellStatusBarTextBrush}" />
        <Setter Property="FontSize"    Value="12" />
        <Setter Property="FontWeight"  Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
