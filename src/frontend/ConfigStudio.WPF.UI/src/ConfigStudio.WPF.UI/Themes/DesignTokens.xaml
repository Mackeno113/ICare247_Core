<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <FontFamily x:Key="AppFontFamily">Segoe UI</FontFamily>
    <FontFamily x:Key="AppMonoFontFamily">Cascadia Code, Consolas</FontFamily>

    <Color x:Key="AppPageBackgroundColor">#F1F5F9</Color>
    <Color x:Key="AppSurfaceColor">#FFFFFF</Color>
    <Color x:Key="AppSurfaceMutedColor">#F8FAFC</Color>
    <Color x:Key="AppBorderColor">#E2E8F0</Color>
    <Color x:Key="AppBorderStrongColor">#CBD5E1</Color>

    <Color x:Key="AppTextColor">#1E293B</Color>
    <Color x:Key="AppTextMutedColor">#64748B</Color>
    <Color x:Key="AppTextSubtleColor">#94A3B8</Color>

    <Color x:Key="AppAccentColor">#2563EB</Color>
    <Color x:Key="AppAccentDarkColor">#1D4ED8</Color>
    <Color x:Key="AppAccentLightColor">#DBEAFE</Color>
    <Color x:Key="AppAccentSoftColor">#EFF6FF</Color>

    <Color x:Key="AppSuccessColor">#16A34A</Color>
    <Color x:Key="AppSuccessDarkColor">#059669</Color>
    <Color x:Key="AppSuccessLightColor">#D1FAE5</Color>
    <Color x:Key="AppSuccessSoftColor">#F0FDF4</Color>

    <Color x:Key="AppWarningColor">#D97706</Color>
    <Color x:Key="AppWarningDarkColor">#92400E</Color>
    <Color x:Key="AppWarningSoftColor">#FEF3C7</Color>

    <Color x:Key="AppDangerColor">#DC2626</Color>
    <Color x:Key="AppDangerLightColor">#FCA5A5</Color>
    <Color x:Key="AppDangerSoftColor">#FEF2F2</Color>

    <SolidColorBrush x:Key="AppPageBackgroundBrush" Color="{StaticResource AppPageBackgroundColor}" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
    <SolidColorBrush x:Key="AppSurfaceMutedBrush" Color="{StaticResource AppSurfaceMutedColor}" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
    <SolidColorBrush x:Key="AppBorderStrongBrush" Color="{StaticResource AppBorderStrongColor}" />

    <SolidColorBrush x:Key="AppTextBrush" Color="{StaticResource AppTextColor}" />
    <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMutedColor}" />
    <SolidColorBrush x:Key="AppTextSubtleBrush" Color="{StaticResource AppTextSubtleColor}" />

    <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
    <SolidColorBrush x:Key="AppAccentDarkBrush" Color="{StaticResource AppAccentDarkColor}" />
    <SolidColorBrush x:Key="AppAccentLightBrush" Color="{StaticResource AppAccentLightColor}" />
    <SolidColorBrush x:Key="AppAccentSoftBrush" Color="{StaticResource AppAccentSoftColor}" />

    <SolidColorBrush x:Key="AppSuccessBrush" Color="{StaticResource AppSuccessColor}" />
    <SolidColorBrush x:Key="AppSuccessDarkBrush" Color="{StaticResource AppSuccessDarkColor}" />
    <SolidColorBrush x:Key="AppSuccessLightBrush" Color="{StaticResource AppSuccessLightColor}" />
    <SolidColorBrush x:Key="AppSuccessSoftBrush" Color="{StaticResource AppSuccessSoftColor}" />

    <SolidColorBrush x:Key="AppWarningBrush" Color="{StaticResource AppWarningColor}" />
    <SolidColorBrush x:Key="AppWarningDarkBrush" Color="{StaticResource AppWarningDarkColor}" />
    <SolidColorBrush x:Key="AppWarningSoftBrush" Color="{StaticResource AppWarningSoftColor}" />

    <SolidColorBrush x:Key="AppDangerBrush" Color="{StaticResource AppDangerColor}" />
    <SolidColorBrush x:Key="AppDangerLightBrush" Color="{StaticResource AppDangerLightColor}" />
    <SolidColorBrush x:Key="AppDangerSoftBrush" Color="{StaticResource AppDangerSoftColor}" />

    <!-- ── Màu mở rộng (gom các hex rải rác về token) ────────────────────── -->
    <!-- Text đậm/phụ (slate-900 / slate-600); slate-700, gray-700 gộp vào Secondary. -->
    <Color x:Key="AppTextStrongColor">#0F172A</Color>
    <Color x:Key="AppTextSecondaryColor">#475569</Color>
    <!-- Info (sky) — dùng cho intro panel, badge thông tin, help nhấn mạnh. -->
    <Color x:Key="AppInfoColor">#0369A1</Color>
    <Color x:Key="AppInfoDarkColor">#0C4A6E</Color>
    <Color x:Key="AppInfoBorderColor">#BAE6FD</Color>
    <Color x:Key="AppInfoSoftColor">#F0F9FF</Color>

    <SolidColorBrush x:Key="AppTextStrongBrush"    Color="{StaticResource AppTextStrongColor}" />
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource AppTextSecondaryColor}" />
    <SolidColorBrush x:Key="AppInfoBrush"          Color="{StaticResource AppInfoColor}" />
    <SolidColorBrush x:Key="AppInfoDarkBrush"      Color="{StaticResource AppInfoDarkColor}" />
    <SolidColorBrush x:Key="AppInfoBorderBrush"    Color="{StaticResource AppInfoBorderColor}" />
    <SolidColorBrush x:Key="AppInfoSoftBrush"      Color="{StaticResource AppInfoSoftColor}" />

    <!-- Warning sáng (amber-200) + Danger đậm (red-800) — gom họ cam/đỏ rải rác. -->
    <Color x:Key="AppWarningLightColor">#FDE68A</Color>
    <Color x:Key="AppDangerDarkColor">#991B1B</Color>
    <SolidColorBrush x:Key="AppWarningLightBrush" Color="{StaticResource AppWarningLightColor}" />
    <SolidColorBrush x:Key="AppDangerDarkBrush"   Color="{StaticResource AppDangerDarkColor}" />

    <!-- ── Token kích thước / hình khối (sửa 1 nơi → đổi toàn app) ────────── -->
    <!-- Cỡ chữ -->
    <sys:Double x:Key="AppFontSizeXs">11</sys:Double>
    <sys:Double x:Key="AppFontSizeSm">12</sys:Double>
    <sys:Double x:Key="AppFontSizeBase">13</sys:Double>
    <sys:Double x:Key="AppFontSizeMd">14</sys:Double>
    <sys:Double x:Key="AppFontSizeLg">16</sys:Double>
    <!-- Bo góc -->
    <CornerRadius x:Key="AppRadiusSm">4</CornerRadius>
    <CornerRadius x:Key="AppRadiusMd">6</CornerRadius>
    <CornerRadius x:Key="AppRadiusLg">8</CornerRadius>
    <!-- Chiều cao control nhập liệu / nút -->
    <sys:Double x:Key="AppInputHeight">36</sys:Double>
    <sys:Double x:Key="AppInputHeightSm">28</sys:Double>
    <sys:Double x:Key="AppButtonHeight">38</sys:Double>
    <!-- Padding / viền chuẩn -->
    <Thickness x:Key="AppInputPadding">10,0</Thickness>
    <Thickness x:Key="AppBorderThin">1</Thickness>

    <DropShadowEffect x:Key="AppCardShadowEffect"
                      BlurRadius="10"
                      ShadowDepth="0"
                      Color="#406B8FC2"
                      Opacity="0.10" />

    <DropShadowEffect x:Key="AppElevatedShadowEffect"
                      BlurRadius="16"
                      ShadowDepth="2"
                      Direction="270"
                      Color="#40000000"
                      Opacity="0.12" />
</ResourceDictionary>
