<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid"
                    xmlns:dxe="http://schemas.devexpress.com/winfx/2008/xaml/editors"
                    xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
                    xmlns:behaviors="clr-namespace:ConfigStudio.WPF.UI.Infrastructure.Behaviors">
    <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,5" />
    </Style>

    <Style x:Key="HelpTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        <Setter Property="Opacity" Value="0.75" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FieldGroupStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="FieldInputStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppAccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FieldPasswordStyle" TargetType="{x:Type PasswordBox}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
    </Style>

    <Style x:Key="CardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Effect" Value="{DynamicResource AppCardShadowEffect}" />
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource AppAccentBrush}"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SuccessOutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppSuccessDarkBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource AppSuccessDarkBrush}"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSuccessSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSuccessLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource OutlineButtonStyle}" />
    <Style x:Key="TargetTestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SuccessOutlineButtonStyle}" />

    <Style x:Key="AppFieldLabelStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource FieldLabelStyle}" />
    <Style x:Key="AppHelpTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HelpTextStyle}" />
    <Style x:Key="AppFieldGroupStyle" TargetType="{x:Type StackPanel}" BasedOn="{StaticResource FieldGroupStyle}" />
    <Style x:Key="AppFieldInputStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource FieldInputStyle}" />
    <Style x:Key="AppFieldPasswordStyle" TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource FieldPasswordStyle}" />
    <Style x:Key="AppCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}" />
    <Style x:Key="AppSectionCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource SectionCardStyle}" />
    <Style x:Key="AppSectionTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SectionTitleStyle}" />
    <Style x:Key="AppActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}" />
    <Style x:Key="AppOutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource OutlineButtonStyle}" />
    <Style x:Key="AppSuccessOutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SuccessOutlineButtonStyle}" />
    <Style x:Key="AppTestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TestButtonStyle}" />
    <Style x:Key="AppTargetTestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TargetTestButtonStyle}" />

    <Style x:Key="IconBtnStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarSeparatorStyle" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="6,6" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CommandBarHostStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,6" />
    </Style>

    <Style x:Key="DirtyIndicatorPillStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#FEF3C7" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StateBannerStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#FFF7ED" />
        <Setter Property="BorderBrush" Value="#FED7AA" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <Style x:Key="ErrorBannerStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#FEF2F2" />
        <Setter Property="BorderBrush" Value="#FECACA" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <!-- MỌI lưới trong app đều: có hàng lọc "chứa" dưới header, kéo giãn + đổi vị trí cột,
         và tự nhớ format lưới (độ rộng / thứ tự / ẩn-hiện / sắp xếp) ra file local.
         Chi tiết cơ chế + gotcha: xem GridLayoutBehavior và .claude-rules/wpf-configstudio.md §12. -->
    <Style TargetType="{x:Type dxg:TableView}">
        <Setter Property="ShowGroupPanel" Value="False" />
        <Setter Property="ShowIndicator" Value="False" />
        <Setter Property="NavigationStyle" Value="Row" />
        <!-- AutoWidth=False: cột giữ ĐÚNG pixel, kéo giãn tự do, có cuộn ngang khi tổng vượt khung.
             (AutoWidth=True ép mọi cột co vừa khung → lưới nhiều cột không kéo giãn được.) -->
        <Setter Property="AutoWidth" Value="False" />
        <Setter Property="RowMinHeight" Value="30" />
        <Setter Property="AllowPerPixelScrolling" Value="True" />
        <!-- Người dùng tự sắp lưới: kéo giãn độ rộng + kéo đổi vị trí cột. -->
        <Setter Property="AllowResizing" Value="True" />
        <Setter Property="AllowColumnMoving" Value="True" />
        <!-- Lọc: hàng filter ngay dưới header, mỗi cột 1 ô, gõ tới đâu lọc tới đó.
             Điều kiện "chứa" cho cột text do GridLayoutBehavior gán theo FieldType
             (không set AutoFilterCondition ở style vì cột số/ngày không dùng Contains). -->
        <Setter Property="AllowColumnFiltering" Value="True" />
        <Setter Property="ShowAutoFilterRow" Value="True" />
        <!-- Tự lưu/phục hồi format lưới ra file local + ép lại chính sách lọc sau khi phục hồi. -->
        <Setter Property="behaviors:GridLayoutBehavior.Persist" Value="True" />
    </Style>

    <Style TargetType="{x:Type dxg:GridColumn}">
        <Setter Property="MinWidth" Value="80" />
        <!-- Gõ tới đâu lọc tới đó (không phải nhấn Enter). -->
        <Setter Property="ImmediateUpdateAutoFilter" Value="True" />
        <Setter Property="AllowMoving" Value="True" />
        <Setter Property="AllowResizing" Value="True" />
    </Style>

    <!-- ════════════════════════════════════════════════════════════════════
         BỘ THEME CONTROL — style IMPLICIT dùng chung, đọc token DesignTokens.xaml.
         Đổi diện mạo control = sửa token (DesignTokens) hoặc setter ở đây, 1 nơi.
         Chỉ đặt giá trị MẶC ĐỊNH → value inline tại view vẫn thắng (không vỡ layout cũ).
         Mọi thuộc tính DevExpress đã xác minh qua reflection trên v25.2 (DP thật).
         ════════════════════════════════════════════════════════════════════ -->

    <!-- Setter nền dùng chung cho mọi editor nhập liệu (BaseEdit) -->
    <Style x:Key="AppEditBaseStyle" TargetType="{x:Type dxe:BaseEdit}">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSizeBase}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
        <Setter Property="CornerRadius" Value="{DynamicResource AppRadiusMd}" />
        <Setter Property="Padding" Value="{DynamicResource AppInputPadding}" />
    </Style>

    <!-- TextEdit / MemoEdit / SpinEdit -->
    <Style TargetType="{x:Type dxe:TextEdit}" BasedOn="{StaticResource AppEditBaseStyle}">
        <Setter Property="Height" Value="{DynamicResource AppInputHeight}" />
        <Setter Property="NullTextForeground" Value="{DynamicResource AppTextSubtleBrush}" />
    </Style>
    <Style TargetType="{x:Type dxe:MemoEdit}" BasedOn="{StaticResource AppEditBaseStyle}" />
    <Style TargetType="{x:Type dxe:SpinEdit}" BasedOn="{StaticResource AppEditBaseStyle}">
        <Setter Property="Height" Value="{DynamicResource AppInputHeight}" />
    </Style>

    <!-- ComboBoxEdit: nền editor + gõ-để-lọc (Contains, không phân biệt hoa thường).
         Combo nào ép IsTextEditable=False tại chỗ sẽ không lọc được → đã gỡ toàn bộ. -->
    <Style TargetType="{x:Type dxe:ComboBoxEdit}" BasedOn="{StaticResource AppEditBaseStyle}">
        <Setter Property="Height" Value="{DynamicResource AppInputHeight}" />
        <Setter Property="IsTextEditable" Value="True" />
        <Setter Property="ImmediatePopup" Value="True" />
        <Setter Property="IncrementalFiltering" Value="True" />
        <Setter Property="FilterCondition" Value="Contains" />
        <Setter Property="IsCaseSensitiveFilter" Value="False" />
    </Style>

    <!-- ComboBoxEditSettings (combo nhúng cột lưới) — chỉ hành vi lọc (không visual). -->
    <Style TargetType="{x:Type dxe:ComboBoxEditSettings}">
        <Setter Property="IsTextEditable" Value="True" />
        <Setter Property="ImmediatePopup" Value="True" />
        <Setter Property="IncrementalFiltering" Value="True" />
        <Setter Property="FilterCondition" Value="Contains" />
        <Setter Property="IsCaseSensitiveFilter" Value="False" />
    </Style>

    <!-- Popup lưới DÙNG CHUNG cho mọi LookUpEdit: tự sinh đủ cột (AutoPopulateColumns) + hàng
         auto-filter (mỗi cột 1 ô lọc → người dùng lọc theo cột tùy ý). Style="{x:Null}" để KHÔNG
         dính style implicit TableView (tránh GridLayoutBehavior lưu layout cho lưới popup). -->
    <ControlTemplate x:Key="LookUpGridPopup">
        <dxg:GridControl x:Name="PART_GridControl">
            <dxg:GridControl.View>
                <dxg:TableView Style="{x:Null}" ShowAutoFilterRow="True"
                               AutoWidth="True" ShowGroupPanel="False"
                               ShowIndicator="False" NavigationStyle="Row" />
            </dxg:GridControl.View>
        </dxg:GridControl>
    </ControlTemplate>

    <!-- LookUpEdit: lookup có lưới (DevExpress WPF — tương đương GridLookUpEdit bên WinForms).
         Dùng cho danh sách OBJECT. Toàn bộ popup (lưới nhiều cột + lọc theo cột) lấy từ template
         dùng chung ở trên → view chỉ cần ItemsSource/DisplayMember/EditValue, không khai báo cột. -->
    <Style TargetType="{x:Type dxg:LookUpEdit}" BasedOn="{StaticResource AppEditBaseStyle}">
        <Setter Property="Height" Value="{DynamicResource AppInputHeight}" />
        <Setter Property="IsTextEditable" Value="True" />
        <Setter Property="ImmediatePopup" Value="True" />
        <!-- Gõ ở ô editor để lọc nhanh theo DisplayMember (Contains, không phân biệt hoa/dấu).
             Hàng auto-filter trong lưới cho phép lọc chi tiết theo từng cột. -->
        <Setter Property="IncrementalFiltering" Value="True" />
        <Setter Property="FilterCondition" Value="Contains" />
        <Setter Property="IsCaseSensitiveFilter" Value="False" />
        <Setter Property="AutoPopulateColumns" Value="True" />
        <Setter Property="PopupContentTemplate" Value="{StaticResource LookUpGridPopup}" />
        <Setter Property="NullTextForeground" Value="{DynamicResource AppTextSubtleBrush}" />
    </Style>

    <!-- Popup cho LookUpEdit nguồn list SCALAR (List<string>): AutoPopulateColumns KHÔNG sinh
         được cột cho kiểu nguyên thủy (chuỗi không có business property) → khai báo 1 cột
         Binding="{Binding}" trỏ thẳng vào item (giá trị chuỗi của từng hàng). -->
    <ControlTemplate x:Key="LookUpScalarPopup">
        <dxg:GridControl x:Name="PART_GridControl">
            <dxg:GridControl.Columns>
                <dxg:GridColumn Header="Giá trị" Binding="{Binding}" />
            </dxg:GridControl.Columns>
            <dxg:GridControl.View>
                <dxg:TableView Style="{x:Null}" ShowAutoFilterRow="True"
                               AutoWidth="True" ShowGroupPanel="False"
                               ShowIndicator="False" NavigationStyle="Row" />
            </dxg:GridControl.View>
        </dxg:GridControl>
    </ControlTemplate>

    <!-- LookUpEdit cho danh sách SCALAR (chuỗi): cột bảng, mã lookup, form code… Dùng qua
         Style="{StaticResource ScalarLookUpEditStyle}" — hành vi/visual vẫn tập trung 1 nơi,
         chỉ khác: tắt AutoPopulateColumns + dùng popup 1 cột scalar ở trên. -->
    <Style x:Key="ScalarLookUpEditStyle" TargetType="{x:Type dxg:LookUpEdit}" BasedOn="{StaticResource AppEditBaseStyle}">
        <Setter Property="Height" Value="{DynamicResource AppInputHeight}" />
        <Setter Property="IsTextEditable" Value="True" />
        <Setter Property="ImmediatePopup" Value="True" />
        <Setter Property="IncrementalFiltering" Value="True" />
        <Setter Property="FilterCondition" Value="Contains" />
        <Setter Property="IsCaseSensitiveFilter" Value="False" />
        <Setter Property="AutoPopulateColumns" Value="False" />
        <Setter Property="PopupContentTemplate" Value="{StaticResource LookUpScalarPopup}" />
        <Setter Property="NullTextForeground" Value="{DynamicResource AppTextSubtleBrush}" />
    </Style>

    <!-- CheckEdit / ToggleSwitchEdit — đồng bộ chữ -->
    <Style TargetType="{x:Type dxe:CheckEdit}">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSizeBase}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
    </Style>
    <Style TargetType="{x:Type dxe:ToggleSwitchEdit}">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSizeBase}" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
    </Style>

    <!-- SimpleButton — bo góc + cỡ chữ chuẩn (giữ màu theo từng nút để đa dạng) -->
    <Style TargetType="{x:Type dx:SimpleButton}">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource AppFontSizeBase}" />
        <Setter Property="CornerRadius" Value="{DynamicResource AppRadiusMd}" />
        <Setter Property="MinHeight" Value="{DynamicResource AppInputHeightSm}" />
    </Style>

    <!-- GridControl — viền + nền chuẩn (TableView đã có style implicit riêng phía trên) -->
    <Style TargetType="{x:Type dxg:GridControl}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource AppBorderThin}" />
    </Style>

    <Style x:Key="AppIconBtnStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource IconBtnStyle}" />
    <Style x:Key="AppToolbarSeparatorStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ToolbarSeparatorStyle}" />
    <Style x:Key="AppCommandBarHostStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CommandBarHostStyle}" />
    <Style x:Key="AppDirtyIndicatorPillStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource DirtyIndicatorPillStyle}" />
    <Style x:Key="AppStateBannerStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource StateBannerStyle}" />
    <Style x:Key="AppErrorBannerStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ErrorBannerStyle}" />
</ResourceDictionary>
