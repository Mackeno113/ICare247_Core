<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:dxg="http://schemas.devexpress.com/winfx/2008/xaml/grid">
    <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        <Setter Property="Margin" Value="0,0,0,5" />
    </Style>

    <Style x:Key="HelpTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        <Setter Property="Opacity" Value="0.75" />
        <Setter Property="Margin" Value="0,4,0,0" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="FieldGroupStyle" TargetType="{x:Type StackPanel}">
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="FieldInputStyle" TargetType="{x:Type TextBox}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        <Setter Property="CaretBrush" Value="{DynamicResource AppAccentBrush}" />
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.65" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FieldPasswordStyle" TargetType="{x:Type PasswordBox}">
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
    </Style>

    <Style x:Key="CardStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Effect" Value="{DynamicResource AppCardShadowEffect}" />
    </Style>

    <Style x:Key="SectionCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        <Setter Property="Margin" Value="0,0,0,14" />
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Height" Value="38" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.88" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource AppAccentBrush}"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppAccentLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SuccessOutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppSuccessDarkBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource AppSuccessDarkBrush}"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSuccessSoftBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSuccessLightBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource OutlineButtonStyle}" />
    <Style x:Key="TargetTestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SuccessOutlineButtonStyle}" />

    <Style x:Key="AppFieldLabelStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource FieldLabelStyle}" />
    <Style x:Key="AppHelpTextStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource HelpTextStyle}" />
    <Style x:Key="AppFieldGroupStyle" TargetType="{x:Type StackPanel}" BasedOn="{StaticResource FieldGroupStyle}" />
    <Style x:Key="AppFieldInputStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource FieldInputStyle}" />
    <Style x:Key="AppFieldPasswordStyle" TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource FieldPasswordStyle}" />
    <Style x:Key="AppCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CardStyle}" />
    <Style x:Key="AppSectionCardStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource SectionCardStyle}" />
    <Style x:Key="AppSectionTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource SectionTitleStyle}" />
    <Style x:Key="AppActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}" />
    <Style x:Key="AppOutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource OutlineButtonStyle}" />
    <Style x:Key="AppSuccessOutlineButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SuccessOutlineButtonStyle}" />
    <Style x:Key="AppTestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TestButtonStyle}" />
    <Style x:Key="AppTargetTestButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource TargetTestButtonStyle}" />

    <Style x:Key="IconBtnStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource AppTextMutedBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ToolbarSeparatorStyle" TargetType="{x:Type Border}">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="Margin" Value="6,6" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CommandBarHostStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,6" />
    </Style>

    <Style x:Key="DirtyIndicatorPillStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#FEF3C7" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="StateBannerStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#FFF7ED" />
        <Setter Property="BorderBrush" Value="#FED7AA" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <Style x:Key="ErrorBannerStyle" TargetType="{x:Type Border}">
        <Setter Property="Background" Value="#FEF2F2" />
        <Setter Property="BorderBrush" Value="#FECACA" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="16,8" />
    </Style>

    <Style TargetType="{x:Type dxg:TableView}">
        <Setter Property="ShowGroupPanel" Value="False" />
        <Setter Property="ShowIndicator" Value="False" />
        <Setter Property="NavigationStyle" Value="Row" />
        <Setter Property="AutoWidth" Value="True" />
        <Setter Property="RowMinHeight" Value="30" />
        <Setter Property="AllowPerPixelScrolling" Value="True" />
    </Style>

    <Style TargetType="{x:Type dxg:GridColumn}">
        <Setter Property="MinWidth" Value="80" />
    </Style>

    <Style x:Key="AppIconBtnStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource IconBtnStyle}" />
    <Style x:Key="AppToolbarSeparatorStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ToolbarSeparatorStyle}" />
    <Style x:Key="AppCommandBarHostStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource CommandBarHostStyle}" />
    <Style x:Key="AppDirtyIndicatorPillStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource DirtyIndicatorPillStyle}" />
    <Style x:Key="AppStateBannerStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource StateBannerStyle}" />
    <Style x:Key="AppErrorBannerStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ErrorBannerStyle}" />
</ResourceDictionary>
