<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <FontFamily x:Key="ShellFontFamily">Bahnschrift</FontFamily>

    <SolidColorBrush x:Key="ShellWindowBackgroundBrush" Color="#0F172A" />
    <SolidColorBrush x:Key="ShellWindowBorderBrush" Color="#1E293B" />

    <LinearGradientBrush x:Key="ShellContentBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,1">
        <GradientStop Color="#111B2E" Offset="0" />
        <GradientStop Color="#0B1528" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ShellTitleBarBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="1,0">
        <GradientStop Color="#1D4ED8" Offset="0" />
        <GradientStop Color="#0F766E" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ShellStatusBarBackgroundBrush" Color="#122033" />

    <LinearGradientBrush x:Key="ShellSidebarBackgroundBrush"
                         StartPoint="0,0"
                         EndPoint="0,1">
        <GradientStop Color="#16243A" Offset="0" />
        <GradientStop Color="#101D30" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ShellTitleBarTextBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ShellStatusBarTextBrush" Color="#CBD5E1" />
    <SolidColorBrush x:Key="ShellStatusBarSeparatorBrush" Color="#475569" />

    <SolidColorBrush x:Key="ShellTenantBadgeBackgroundBrush" Color="#1E3A8A" />
    <SolidColorBrush x:Key="ShellTenantBadgeBorderBrush" Color="#3B82F6" />
    <SolidColorBrush x:Key="ShellTenantBadgeTextBrush" Color="#DBEAFE" />

    <SolidColorBrush x:Key="ShellTitleBarButtonHoverBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="ShellTitleBarCloseHoverBrush" Color="#DC2626" />

    <SolidColorBrush x:Key="ShellSidebarItemTextBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="ShellSidebarIconBrush" Color="#93C5FD" />
    <SolidColorBrush x:Key="ShellSidebarHoverBackgroundBrush" Color="#22324C" />
    <SolidColorBrush x:Key="ShellSidebarSelectedBackgroundBrush" Color="#1E3A5F" />
    <SolidColorBrush x:Key="ShellSidebarSelectionBorderBrush" Color="#38BDF8" />
    <SolidColorBrush x:Key="ShellSidebarDividerBrush" Color="#2C3D56" />

    <SolidColorBrush x:Key="ShellThemeSwitchBackgroundBrush" Color="#1E293B" />
    <SolidColorBrush x:Key="ShellThemeSwitchForegroundBrush" Color="#E2E8F0" />
    <SolidColorBrush x:Key="ShellThemeSwitchBorderBrush" Color="#334155" />
    <SolidColorBrush x:Key="ShellThemeSwitchHoverBackgroundBrush" Color="#334155" />

    <DropShadowEffect x:Key="ShellCardShadowEffect"
                      BlurRadius="20"
                      ShadowDepth="0"
                      Color="#66000000"
                      Opacity="0.5" />

    <Style x:Key="ShellTitleBarButtonStyle" TargetType="{x:Type Button}">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Margin" Value="2,0,0,0" />
        <Setter Property="Foreground" Value="{DynamicResource ShellTitleBarTextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ShellTitleBarButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.8" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ShellCloseButtonStyle"
           TargetType="{x:Type Button}"
           BasedOn="{StaticResource ShellTitleBarButtonStyle}">
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ShellTitleBarCloseHoverBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ShellStatusTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{DynamicResource ShellStatusBarTextBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="ShellThemeSwitchButtonStyle"
           TargetType="{x:Type Button}">
        <Setter Property="Padding" Value="10,4" />
        <Setter Property="Margin" Value="0,0,6,0" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{DynamicResource ShellThemeSwitchBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ShellThemeSwitchForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ShellThemeSwitchBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource ShellThemeSwitchHoverBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Opacity" Value="0.85" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
