<Window x:Class="ConfigStudio.WPF.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ConfigStudio.WPF.UI.Core.Constants;assembly=ConfigStudio.WPF.UI.Core"
        xmlns:corevc="clr-namespace:ConfigStudio.WPF.UI.Core.Converters;assembly=ConfigStudio.WPF.UI.Core"
        xmlns:dx="http://schemas.devexpress.com/winfx/2008/xaml/core"
        xmlns:local="clr-namespace:ConfigStudio.WPF.UI"
        xmlns:prism="http://prismlibrary.com/"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="ICare247 Config Studio"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="640"
        FontFamily="{DynamicResource ShellFontFamily}"
        Background="{DynamicResource ShellWindowBackgroundBrush}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False"
        WindowStartupLocation="CenterScreen">

    <!-- Global keyboard shortcuts shell -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="B" Command="{Binding ToggleSidebarCommand}" />
        <KeyBinding Key="F1" Command="{Binding NavigateByViewNameCommand}" CommandParameter="Settings" />
        <KeyBinding Modifiers="Alt" Key="D1" Command="{Binding NavigateByViewNameCommand}" CommandParameter="Dashboard" />
        <KeyBinding Modifiers="Alt" Key="D2" Command="{Binding NavigateByViewNameCommand}" CommandParameter="SysTableManager" />
        <KeyBinding Modifiers="Alt" Key="D3" Command="{Binding NavigateByViewNameCommand}" CommandParameter="SysLookupManager" />
        <KeyBinding Modifiers="Alt" Key="D4" Command="{Binding NavigateByViewNameCommand}" CommandParameter="FormManager" />
        <KeyBinding Modifiers="Alt" Key="D5" Command="{Binding NavigateByViewNameCommand}" CommandParameter="ValidationRuleEditor" />
        <KeyBinding Modifiers="Alt" Key="D6" Command="{Binding NavigateByViewNameCommand}" CommandParameter="EventEditor" />
        <KeyBinding Modifiers="Alt" Key="D7" Command="{Binding NavigateByViewNameCommand}" CommandParameter="GrammarLibrary" />
        <KeyBinding Modifiers="Alt" Key="D8" Command="{Binding NavigateByViewNameCommand}" CommandParameter="I18nManager" />
        <KeyBinding Modifiers="Alt" Key="D9" Command="{Binding NavigateByViewNameCommand}" CommandParameter="Settings" />
        <KeyBinding Modifiers="Alt" Key="Left" Command="{Binding GoBackCommand}" />
        <KeyBinding Modifiers="Alt" Key="Right" Command="{Binding GoForwardCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border BorderBrush="{DynamicResource ShellWindowBorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource ShellWindowBackgroundBrush}">
        <Border.Effect>
            <DynamicResource ResourceKey="ShellCardShadowEffect" />
        </Border.Effect>

        <Border.Style>
            <Style TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="14" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}" Value="Maximized">
                        <Setter Property="CornerRadius" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <DockPanel>
            <!-- ── Title Bar ─────────────────────────────────────────── -->
            <Grid DockPanel.Dock="Top"
                  Height="52"
                  Background="{DynamicResource ShellTitleBarBackgroundBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Toggle Sidebar -->
                <Button Grid.Column="0"
                        Width="36" Height="32" Margin="4,0,0,0"
                        Foreground="White" Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="0"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip="Toggle sidebar"
                        Cursor="Hand">
                    <TextBlock Text="≡" FontSize="18" VerticalAlignment="Center" Foreground="White" />
                </Button>

                <!-- Title -->
                <TextBlock Grid.Column="1"
                           Margin="10,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ShellTitleBarTextBrush}"
                           Text="ICare247 Config Studio" />

                <!-- Tenant Badge -->
                <Border Grid.Column="2"
                        Margin="0,0,10,0"
                        Padding="10,4"
                        VerticalAlignment="Center"
                        Background="{DynamicResource ShellTenantBadgeBackgroundBrush}"
                        BorderBrush="{DynamicResource ShellTenantBadgeBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <TextBlock Foreground="{DynamicResource ShellTenantBadgeTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="{Binding TenantName}" />
                </Border>

                <!-- User -->
                <TextBlock Grid.Column="3"
                           Margin="0,0,14,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource ShellTitleBarTextBrush}"
                           Text="{Binding CurrentUser}" />

                <!-- Theme switcher -->
                <StackPanel Grid.Column="4"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource ShellTitleBarTextBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentThemeDisplayName}" />

                    <dx:SimpleButton Content="Light Ocean"
                                     Command="{Binding ChangeThemeCommand}"
                                     CommandParameter="light"
                                     Margin="0,0,6,0"
                                     Padding="10,4"
                                     FontSize="11"
                                     ToolTip="Theme: Light Ocean" />

                    <dx:SimpleButton Content="Slate Pro"
                                     Command="{Binding ChangeThemeCommand}"
                                     CommandParameter="slate"
                                     Padding="10,4"
                                     FontSize="11"
                                     ToolTip="Theme: Slate Professional" />
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" Margin="0,0,6,0">
                    <Button Width="36" Height="32" Margin="2,0,0,0"
                            Foreground="White" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="0"
                            Command="{Binding WindowMinimizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Minimize" Cursor="Hand">
                        <TextBlock Text="─" FontSize="14" VerticalAlignment="Center" Foreground="White" />
                    </Button>

                    <Button Width="36" Height="32" Margin="2,0,0,0"
                            Foreground="White" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="0"
                            Command="{Binding WindowMaximizeCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Maximize" Cursor="Hand">
                        <TextBlock Text="□" FontSize="14" VerticalAlignment="Center" Foreground="White" />
                    </Button>

                    <Button Width="36" Height="32" Margin="2,0,0,0"
                            Foreground="White" Background="Transparent"
                            BorderBrush="Transparent" BorderThickness="0"
                            Command="{Binding WindowCloseCommand}"
                            CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Close" Cursor="Hand">
                        <TextBlock Text="✕" FontSize="14" VerticalAlignment="Center" Foreground="White" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ── Breadcrumb Bar ─────────────────────────────────────── -->
            <Border DockPanel.Dock="Top"
                    Height="36"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding HasBreadcrumbs, Converter={StaticResource BoolToVis}}">
                <DockPanel LastChildFill="True">
                    <!-- Back / Forward buttons -->
                    <Button DockPanel.Dock="Left"
                            Width="32" Height="28" Margin="6,0,2,0"
                            Command="{Binding GoBackCommand}"
                            ToolTip="Quay lại (Alt+←)"
                            Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                        <TextBlock Text="←" FontSize="16" VerticalAlignment="Center" />
                    </Button>
                    <Button DockPanel.Dock="Left"
                            Width="32" Height="28" Margin="2,0,8,0"
                            Command="{Binding GoForwardCommand}"
                            ToolTip="Tiến tới (Alt+→)"
                            Background="Transparent" BorderBrush="Transparent" Cursor="Hand">
                        <TextBlock Text="→" FontSize="16" VerticalAlignment="Center" />
                    </Button>

                    <!-- Crumbs -->
                    <ItemsControl ItemsSource="{Binding Breadcrumbs}"
                                  VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Command="{Binding DataContext.JumpToCrumbCommand,
                                                     RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent" BorderBrush="Transparent"
                                            Cursor="Hand" Padding="6,2"
                                            ToolTip="{Binding ViewName}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" FontSize="13"
                                                       VerticalAlignment="Center" Margin="0,0,4,0" />
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="#1E3A8A" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <TextBlock Text="›" FontSize="14" Margin="6,0"
                                               Opacity="0.45" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- ── Status Bar ─────────────────────────────────────────── -->
            <Grid DockPanel.Dock="Bottom"
                  Height="28"
                  Background="{DynamicResource ShellStatusBarBackgroundBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Margin="12,0,0,0" Style="{StaticResource ShellStatusTextStyle}" Text="{Binding ConnectionStatus, StringFormat=DB: {0}}" />
                <TextBlock Grid.Column="1" Margin="10,0,10,0" Style="{StaticResource ShellStatusTextStyle}" Foreground="{DynamicResource ShellStatusBarSeparatorBrush}" Text="|" />
                <TextBlock Grid.Column="2" Style="{StaticResource ShellStatusTextStyle}" Text="{Binding CacheStatus, StringFormat=Cache: {0}}" />
                <TextBlock Grid.Column="3" Margin="10,0,10,0" Style="{StaticResource ShellStatusTextStyle}" Foreground="{DynamicResource ShellStatusBarSeparatorBrush}" Text="|" />
                <TextBlock Grid.Column="4" Style="{StaticResource ShellStatusTextStyle}" Text="{Binding TenantName, StringFormat=Tenant: {0}}" />
                <TextBlock Grid.Column="5" Margin="0,0,12,0" Style="{StaticResource ShellStatusTextStyle}" Text="{Binding AppVersion}" />
                <TextBlock Grid.Column="6" Margin="0,0,12,0" Style="{StaticResource ShellStatusTextStyle}" Text="Ready" />
            </Grid>

            <!-- ── Main Content Area ──────────────────────────────────── -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ── Custom Sidebar ─────────────────────────────────── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource ShellSidebarBackgroundBrush}"
                        ClipToBounds="True">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Width" Value="240" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarCollapsed}" Value="True">
                                    <Setter Property="Width" Value="52" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding SidebarEntries}"
                                      Margin="6,10,6,10"
                                      Focusable="False">
                            <ItemsControl.ItemTemplateSelector>
                                <local:SidebarTemplateSelector>

                                    <!-- Section header -->
                                    <local:SidebarTemplateSelector.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,10,0,2">
                                                <TextBlock FontSize="10" FontWeight="Bold"
                                                           Opacity="0.45"
                                                           Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="{Binding Title}" />
                                                            <Setter Property="Margin" Value="10,0,4,0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed,
                                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                             Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </local:SidebarTemplateSelector.HeaderTemplate>

                                    <!-- Divider -->
                                    <local:SidebarTemplateSelector.DividerTemplate>
                                        <DataTemplate>
                                            <Separator Margin="8,6" Opacity="0.15" />
                                        </DataTemplate>
                                    </local:SidebarTemplateSelector.DividerTemplate>

                                    <!-- Nav item: icon + text -->
                                    <local:SidebarTemplateSelector.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding DataContext.NavigateCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding NavItem}"
                                                    HorizontalContentAlignment="Stretch"
                                                    Padding="0" Margin="0,1"
                                                    ToolTip="{Binding Title}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background"      Value="Transparent" />
                                                        <Setter Property="BorderBrush"     Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Cursor"          Value="Hand" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bd"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="7"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0">
                                                                        <ContentPresenter
                                                                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                            VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background"
                                                                                    Value="{DynamicResource ShellSidebarHoverBackgroundBrush}" />
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Setter TargetName="Bd" Property="Background"
                                                                                    Value="{DynamicResource ShellSidebarSelectedBackgroundBrush}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <!-- Selected state — bind đến NavItem.IsSelected -->
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding NavItem.IsSelected}" Value="True">
                                                                <Setter Property="Background"
                                                                        Value="{DynamicResource ShellSidebarSelectedBackgroundBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <Grid Margin="4,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="34" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Icon — đổi màu xanh khi selected -->
                                                    <TextBlock Grid.Column="0"
                                                               Text="{Binding Icon}"
                                                               FontSize="15"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground"
                                                                        Value="{DynamicResource ShellSidebarItemTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding NavItem.IsSelected}" Value="True">
                                                                        <Setter Property="Foreground"
                                                                                Value="{DynamicResource ShellSidebarIconBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Title (ẩn khi collapsed) -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Title}"
                                                               VerticalAlignment="Center"
                                                               FontSize="13"
                                                               Foreground="{DynamicResource ShellSidebarItemTextBrush}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DataContext.IsSidebarCollapsed,
                                                                                 RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                 Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </local:SidebarTemplateSelector.ItemTemplate>

                                </local:SidebarTemplateSelector>
                            </ItemsControl.ItemTemplateSelector>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Content Area -->
                <Grid Grid.Column="1" Margin="12">
                    <Border CornerRadius="8"
                            Background="{DynamicResource ShellContentBackgroundBrush}"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ShellContentHostBorderBrush}">
                        <ContentControl Margin="8"
                                        prism:RegionManager.RegionName="{x:Static core:RegionNames.Content}" />
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>
    </Border>
</Window>
