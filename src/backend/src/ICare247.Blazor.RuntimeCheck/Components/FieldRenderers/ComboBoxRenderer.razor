@* File    : ComboBoxRenderer.razor
   Purpose : Render DxComboBox cho dynamic lookup — gọi API lấy rows từ Table/TVF/SQL.
             Dùng cho Editor_Type = ComboBox + LookupSource = dynamic.
             Rows được map sang LookupItem (Value/Label) để DxComboBox bind được.
             Reload tự động khi ReloadTriggerField thay đổi giá trị. *@

@using DevExpress.Blazor
@using ICare247.Blazor.RuntimeCheck.Models

@inject ILookupQueryService LookupQuerySvc

<div @onfocusout="HandleLostFocus">
    @if (_loading)
    {
        <span class="lookup-loading">⏳ Đang tải...</span>
    }
    else if (_loadError is not null)
    {
        <span class="lookup-error" title="@_loadError">⚠ Lỗi tải dữ liệu</span>
    }
    else if (State is not null)
    {
        <DxComboBox Data="@_items"
                    @bind-Value="BoundValue"
                    TextField="@nameof(LookupItem.Label)"
                    ValueField="@nameof(LookupItem.Value)"
                    SearchMode="ListSearchMode.AutoSearch"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"

                    NullText="@NullTextValue"
                    CssClass="@CssClassValue"
                    Width="100%"
                    InputId="@($"field_{State!.FieldCode}")"

                    Enabled="@(State?.IsEnabled ?? true)"
                    ReadOnly="@(State?.IsReadOnly ?? false)" />
    }
</div>

@code {
    [Parameter, EditorRequired] public FieldState?                                 State    { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange { get; set; }
    [Parameter]                 public EventCallback<string>                       OnBlur   { get; set; }
    /// <summary>Context snapshot toàn form — truyền vào query để hỗ trợ cascading filter.</summary>
    [Parameter]                 public Dictionary<string, object?>                 Context  { get; set; } = [];

    private bool             _loading;
    private string?          _loadError;
    private string?          _localValue;
    // Snapshot giá trị tất cả trigger fields — hỗ trợ multi-trigger (Migration 016)
    private List<object?>    _lastTriggerSnapshot = [];
    private List<LookupItem> _items = [];

    /// <summary>Backing property cho @bind-Value — phát event async khi giá trị thay đổi.</summary>
    private string? BoundValue
    {
        get => _localValue;
        set => _ = HandleValueChangedAsync(value);
    }

    private string NullTextValue => State?.Label is { Length: > 0 } lbl ? "-- " + lbl + " --" : "-- Chọn --";
    private string CssClassValue => State?.Errors.Count > 0 ? "field-dx dx-has-error" : "field-dx";

    protected override async Task OnParametersSetAsync()
    {
        if (State is null) return;

        // Đồng bộ giá trị hiển thị từ State
        _localValue = State.ValueString is { Length: > 0 } v ? v : null;

        // Lấy danh sách trigger fields — ưu tiên ReloadTriggerFields (multi), fallback ReloadTriggerField (đơn)
        var triggerFields   = State.LookupConfig?.ReloadTriggerFields ?? [];
        var currentSnapshot = triggerFields
            .Select(f => Context.TryGetValue(f, out var v) ? v : null)
            .ToList();

        var needsLoad = _items.Count == 0
            || (triggerFields.Count > 0 && !SnapshotEquals(_lastTriggerSnapshot, currentSnapshot));

        if (needsLoad)
        {
            _lastTriggerSnapshot = currentSnapshot;
            await LoadDataAsync();
        }
    }

    // So sánh hai snapshot bằng Equals từng phần tử
    private static bool SnapshotEquals(List<object?> a, List<object?> b)
    {
        if (a.Count != b.Count) return false;
        for (var i = 0; i < a.Count; i++)
            if (!Equals(a[i], b[i])) return false;
        return true;
    }

    private async Task LoadDataAsync()
    {
        if (State is null) return;

        _loading   = true;
        _loadError = null;

        try
        {
            State.DynamicRows = await LookupQuerySvc.QueryAsync(State.FieldId, Context);

            // Map Dictionary rows → typed LookupItem để DxComboBox bind được
            var valCol = State.LookupConfig?.ValueColumn   ?? "";
            var lblCol = State.LookupConfig?.DisplayColumn ?? "";
            _items = State.DynamicRows
                .Select(row => new LookupItem(
                    Value: GetColValue(row, valCol),
                    Label: GetColValue(row, lblCol)))
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError        = ex.Message;
            State.DynamicRows = [];
            _items            = [];
        }
        finally { _loading = false; }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string GetColValue(Dictionary<string, object?> row, string col)
    {
        if (string.IsNullOrWhiteSpace(col)) return "";
        // Case-insensitive lookup theo tên cột
        var kv = row.FirstOrDefault(p => p.Key.Equals(col, StringComparison.OrdinalIgnoreCase));
        return kv.Value?.ToString() ?? "";
    }

    // ── Event handlers ────────────────────────────────────────────────────────

    private async Task HandleValueChangedAsync(string? value)
    {
        if (State is null) return;
        _localValue  = value;
        State.Value  = value;
        await OnChange.InvokeAsync((State.FieldCode, (object?)value));
    }

    private async Task HandleLostFocus(FocusEventArgs _)
    {
        if (State is null) return;
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    // ── Inner types ───────────────────────────────────────────────────────────

    /// <summary>Typed wrapper cho một row lookup — cần thiết để DxComboBox reflection bind được TextField/ValueField.</summary>
    private sealed record LookupItem(string Value, string Label);
}
