@* File    : TextBoxRenderer.razor
   Purpose : Render DxTextBox từ FieldState + ControlPropsJson.
             DxTextBox và DxMemo là 2 control riêng biệt — user tự chọn EditorType.
             TextBoxRenderer chỉ render DxTextBox (EditorType = "TextBox").
             Props: maxLength, isPassword, bindValueMode, inputDelay, clearButtonMode. *@

@using System.Text.Json
@using System.Text.Json.Serialization
@using DevExpress.Blazor

<div @onfocusout="HandleLostFocus">
    <DxTextBox Text="@_localValue"
               TextChanged="@HandleTextChanged"
               BindValueMode="@_bindMode"
               InputDelay="@(_bindMode == BindValueMode.OnInput ? _props.InputDelay : 0)"

               NullText="@NullTextValue"
               CssClass="@CssClassValue"
               Width="100%"
               InputId="@($"field_{State!.FieldCode}")"

               Enabled="true"
               ReadOnly="@State.IsReadOnly"

               Password="@_props.IsPassword"
               MaxLength="@_props.MaxLength"
               AutoComplete="@_props.AutoComplete"

               ClearButtonDisplayMode="@_clearButtonMode" />
</div>

@code {
    // ── Parameters ───────────────────────────────────────────────────────────────
    [Parameter, EditorRequired]
    public FieldState? State { get; set; }

    [Parameter]
    public EventCallback<(string Code, object? Value)> OnChange { get; set; }

    [Parameter]
    public EventCallback<string> OnBlur { get; set; }

    // ── Private state ────────────────────────────────────────────────────────────
    private TextBoxProps _props = new();
    private string _localValue = "";
    private BindValueMode _bindMode;
    private DataEditorClearButtonDisplayMode _clearButtonMode;

    // ── Computed ─────────────────────────────────────────────────────────────────

    /// <summary>NullText: dùng Label field làm placeholder fallback.</summary>
    private string NullTextValue => State?.Label is { Length: > 0 } lbl ? lbl + "..." : "";

    /// <summary>CSS class thêm dx-has-error khi field có lỗi validation.</summary>
    private string CssClassValue => State?.Errors.Count > 0 ? "field-dx dx-has-error" : "field-dx";

    // ── Lifecycle ────────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        _props      = TextBoxProps.Parse(State?.ControlPropsJson);
        _localValue = State?.ValueString ?? "";

        _bindMode = _props.BindValueMode == "OnInput"
            ? BindValueMode.OnInput
            : BindValueMode.OnLostFocus;

        _clearButtonMode = _props.ClearButtonMode == "Never"
            ? DataEditorClearButtonDisplayMode.Never
            : DataEditorClearButtonDisplayMode.Auto;
    }

    // ── Handlers ─────────────────────────────────────────────────────────────────

    private async Task HandleTextChanged(string value)
    {
        if (State is null) return;
        _localValue = value;
        State.Value = value;
        await OnChange.InvokeAsync((State.FieldCode, value));
    }

    private async Task HandleLostFocus(FocusEventArgs _)
    {
        if (State is null) return;
        await OnBlur.InvokeAsync(State.FieldCode);
    }

    // ── Inner types ──────────────────────────────────────────────────────────────

    private sealed class TextBoxProps
    {
        [JsonPropertyName("maxLength")]
        public int MaxLength { get; set; } = 255;

        [JsonPropertyName("isPassword")]
        public bool IsPassword { get; set; }

        /// <summary>"off" (default) | "on" | "new-password"</summary>
        [JsonPropertyName("autoComplete")]
        public string AutoComplete { get; set; } = "off";

        /// <summary>"OnLostFocus" (default) | "OnInput"</summary>
        [JsonPropertyName("bindValueMode")]
        public string BindValueMode { get; set; } = "OnLostFocus";

        [JsonPropertyName("inputDelay")]
        public int InputDelay { get; set; } = 300;

        /// <summary>"Auto" (default) | "Never"</summary>
        [JsonPropertyName("clearButtonMode")]
        public string ClearButtonMode { get; set; } = "Auto";

        public static TextBoxProps Parse(string? json)
        {
            if (string.IsNullOrWhiteSpace(json)) return new();
            try
            {
                return JsonSerializer.Deserialize<TextBoxProps>(json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new();
            }
            catch { return new(); }
        }
    }
}
