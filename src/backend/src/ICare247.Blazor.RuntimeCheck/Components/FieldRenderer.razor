@* File    : FieldRenderer.razor
   Purpose : Render một field dựa vào FieldType + FieldState.
             Hỗ trợ: text, number, date, datetime, bool, textarea, select, fklookup.
             Phát event OnChange khi user thay đổi giá trị. *@

@if (State is not null && State.IsVisible)
{
    <div class="field-wrapper @(State.Errors.Count > 0 ? "has-error" : "")"
         style="grid-column: span @State.ColSpan">
        <label class="field-label">
            @State.Label
            @if (State.IsRequired)
            {
                <span class="required-mark"> *</span>
            }
        </label>

        @* DEBUG — xóa dòng này sau khi verify xong *@
        @if (DebugMode)
        {
            <span style="font-size:10px;color:#888;font-style:italic">
                [@State.FieldCode | type: @State.FieldType | visible: @State.IsVisible | ro: @State.IsReadOnly
                @if (State.FieldType == "select")
                {
                    <text> | options: @State.Options.Count</text>
                }]
            </span>
        }

        @* id="field_{FieldCode}" dùng để JS focus khi submit có lỗi *@
        @switch (State.FieldType.ToLower())
        {
            case "textarea":
                <textarea id="field_@State.FieldCode"
                          class="field-input"
                          value="@State.ValueString"
                          disabled="@State.IsReadOnly"
                          rows="3"
                          @onchange="HandleChange"
                          @onblur="HandleBlur" />
                break;

            case "number":
                <input id="field_@State.FieldCode"
                       type="number" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;

            case "date":
                <input id="field_@State.FieldCode"
                       type="date" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;

            case "datetime":
                <input id="field_@State.FieldCode"
                       type="datetime-local" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;

            case "bool":
                <div class="bool-wrapper">
                    <input id="field_@State.FieldCode"
                           type="checkbox"
                           checked="@(State.ValueString == "true" || State.ValueString == "True")"
                           disabled="@State.IsReadOnly"
                           @onchange="HandleBoolChange" />
                    <label for="field_@State.FieldCode" class="bool-label">@State.Label</label>
                </div>
                break;

            case "select":
                @if (State.Options.Count > 0)
                {
                    @* Static lookup — render <select> với options từ Sys_Lookup *@
                    <select id="field_@State.FieldCode"
                            class="field-input"
                            disabled="@State.IsReadOnly"
                            @onchange="HandleChange"
                            @onblur="HandleBlur">
                        <option value="">-- Chọn --</option>
                        @foreach (var opt in State.Options)
                        {
                            @if (State.ValueString == opt.ItemCode)
                            {
                                <option value="@opt.ItemCode" selected>@opt.Label</option>
                            }
                            else
                            {
                                <option value="@opt.ItemCode">@opt.Label</option>
                            }
                        }
                    </select>
                }
                else
                {
                    @* Options chưa load hoặc LookupCode không tồn tại → fallback text *@
                    <input id="field_@State.FieldCode"
                           type="text" class="field-input"
                           value="@State.ValueString"
                           disabled="@State.IsReadOnly"
                           placeholder="(lookup options not loaded)"
                           @onchange="HandleChange"
                           @onblur="HandleBlur" />
                }
                break;

            case "combobox":
                @* Dynamic ComboBox — lấy data từ Table/TVF/SQL qua API *@
                <ComboBoxRenderer State="State"
                                  OnChange="OnChange"
                                  OnBlur="OnBlur"
                                  Context="Context" />
                break;

            case "fklookup":
                @* FK LookupBox — popup grid chọn từ data source động *@
                <LookupBoxRenderer State="State"
                                   OnChange="OnChange"
                                   OnBlur="OnBlur"
                                   Context="Context" />
                break;

            default:
                @* text và các type không nhận dạng được → text input *@
                <input id="field_@State.FieldCode"
                       type="text" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;
        }

        @if (State.Errors.Count > 0)
        {
            <div class="field-errors">
                @foreach (var err in State.Errors)
                {
                    <span class="field-error">@err</span>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public FieldState?                                State     { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange  { get; set; }
    [Parameter]                 public EventCallback<string>                       OnBlur    { get; set; }
    /// <summary>Context snapshot toàn form — cần thiết cho ComboBoxRenderer / LookupBoxRenderer (cascading).</summary>
    [Parameter]                 public Dictionary<string, object?>                 Context   { get; set; } = [];
    /// <summary>Bật để hiển thị debug badge: FieldCode | FieldType | IsVisible | IsReadOnly.</summary>
    [Parameter]                 public bool                                        DebugMode { get; set; }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (State is null) return;
        State.Value = e.Value;
        await OnChange.InvokeAsync((State.FieldCode, e.Value));
    }

    private async Task HandleBoolChange(ChangeEventArgs e)
    {
        if (State is null) return;
        var val = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var r) && r;
        State.Value = val;
        await OnChange.InvokeAsync((State.FieldCode, val));
    }

    private async Task HandleBlur(FocusEventArgs _)
    {
        if (State is null) return;
        await OnBlur.InvokeAsync(State.FieldCode);
    }
}
