@* File    : LookupAddDialog.razor
   Purpose : Dialog "thêm mới" entity cho LookupBox. Render Ui_Form (AddFormCode) trong modal,
             thu thập giá trị field → POST /api/v1/lookups/insert → trả (value, display) cho LookupBox.
             Tái dùng FieldRenderer + FormApiService giống FormRunner. *@

@inject FormApiService      FormApi
@inject LookupApiService    LookupApi
@inject ILookupQueryService LookupQuerySvc

<div class="lookupadd-backdrop" @onclick="OnCancel">
    <div class="lookupadd-dialog" @onclick:stopPropagation>
        <div class="lookupadd-header">
            <span>➕ Thêm mới</span>
            <button class="lookupadd-close" @onclick="OnCancel" title="Đóng">✕</button>
        </div>

        <div class="lookupadd-body">
            @if (_loading)
            {
                <div class="lookupadd-loading">⏳ Đang tải form...</div>
            }
            else if (_error is not null)
            {
                <div class="lookupadd-error">⚠ @_error</div>
            }
            else
            {
                @foreach (var fs in _fieldStates.Where(f => f.IsVisible && !f.IsVirtual))
                {
                    <div class="lookupadd-field">
                        <label class="lookupadd-label">
                            @fs.Label
                            @if (fs.IsRequired)
                            {
                                <span class="lookupadd-req">*</span>
                            }
                        </label>
                        <FieldRenderer State="fs"
                                       Context="BuildContext()"
                                       OnChange="OnFieldChanged"
                                       OnBlur="@(_ => Task.CompletedTask)" />
                    </div>
                }
            }
        </div>

        <div class="lookupadd-footer">
            @if (_saveError is not null)
            {
                <div class="lookupadd-error" style="flex:1">⚠ @_saveError</div>
            }
            <button class="btn btn-secondary" @onclick="OnCancel" disabled="@_saving">Hủy</button>
            <button class="btn btn-primary" @onclick="Save" disabled="@(_saving || _loading || _error is not null)">
                @(_saving ? "Đang lưu..." : "Lưu")
            </button>
        </div>
    </div>
</div>

@code {
    /// <summary>Form_Code của Ui_Form dùng render dialog (AddFormCode trong cấu hình lookup).</summary>
    [Parameter, EditorRequired] public string FormCode { get; set; } = "";

    /// <summary>Field_Id của LookupBox — backend dùng để biết bảng đích khi insert.</summary>
    [Parameter, EditorRequired] public int FieldId { get; set; }

    /// <summary>Callback khi lưu thành công — trả (value, display) của bản ghi mới.</summary>
    [Parameter] public EventCallback<(string? Value, string? Display)> OnSaved { get; set; }

    /// <summary>Callback khi đóng/hủy dialog.</summary>
    [Parameter] public EventCallback OnClose { get; set; }

    private List<FieldState> _fieldStates = [];
    private bool    _loading = true;
    private bool    _saving;
    private string? _error;
    private string? _saveError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var form = await FormApi.GetFormAsync(FormCode);
            if (form is null)
            {
                _error = $"Form '{FormCode}' không tồn tại trong tenant.";
                return;
            }

            _fieldStates = form.Fields.Select(f => new FieldState
            {
                FieldId      = f.FieldId,
                FieldCode    = f.FieldCode.Length > 0 ? f.FieldCode : $"field_{f.FieldId}",
                FieldType    = NormalizeFieldType(f.FieldType, f.LookupSource),
                Label        = f.Label.Length > 0 ? f.Label : f.FieldCode,
                IsVisible    = f.IsVisible,
                IsReadOnly   = f.IsReadOnly,
                IsRequired   = f.IsRequired,
                IsVirtual    = f.IsVirtual,
                IsEditMode   = false,   // dialog luôn ở chế độ thêm mới
                Value        = null,
                ColSpan      = f.ColSpan > 0 ? f.ColSpan : (byte)1,
                LookupSource = f.LookupSource,
                LookupCode   = f.LookupSource == "static"  ? f.LookupCode   : null,
                LookupConfig = f.LookupSource == "dynamic" ? f.LookupConfig : null,
                ControlPropsJson = f.ControlPropsJson,
            }).ToList();

            await LoadStaticOptionsAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally { _loading = false; }
    }

    private async Task LoadStaticOptionsAsync()
    {
        var codes = _fieldStates
            .Where(fs => !string.IsNullOrWhiteSpace(fs.LookupCode))
            .Select(fs => fs.LookupCode!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        if (codes.Count == 0) return;

        var optionsMap = await LookupApi.GetOptionsBatchAsync(codes);
        foreach (var fs in _fieldStates)
            if (!string.IsNullOrWhiteSpace(fs.LookupCode)
                && optionsMap.TryGetValue(fs.LookupCode, out var opts))
                fs.Options = opts;
    }

    /// <summary>Snapshot giá trị hiện tại — cho cascading lookup giữa các field trong dialog.</summary>
    private Dictionary<string, object?> BuildContext()
        => _fieldStates.ToDictionary(fs => fs.FieldCode, fs => fs.Value);

    private void OnFieldChanged((string Code, object? Value) args)
    {
        var fs = _fieldStates.FirstOrDefault(f => f.FieldCode == args.Code);
        if (fs is not null)
        {
            fs.Value = args.Value;
            fs.Errors.Clear();
        }
        StateHasChanged();
    }

    /// <summary>
    /// Thu thập giá trị field (key = FieldCode = tên cột DB) rồi gọi API insert.
    /// Sự kiện theo sau: thành công → OnSaved((value, display)) + đóng dialog; lỗi → hiện _saveError.
    /// </summary>
    private async Task Save()
    {
        _saving    = true;
        _saveError = null;
        try
        {
            // Validate required tối thiểu trên client
            var missing = _fieldStates
                .Where(fs => fs.IsVisible && !fs.IsVirtual && fs.IsRequired
                          && (fs.Value is null || string.IsNullOrWhiteSpace(fs.Value.ToString())))
                .Select(fs => fs.Label)
                .ToList();
            if (missing.Count > 0)
            {
                _saveError = $"Vui lòng nhập: {string.Join(", ", missing)}";
                return;
            }

            // Chỉ gửi field có giá trị + không phải virtual (cột DB thật)
            var values = _fieldStates
                .Where(fs => !fs.IsVirtual && fs.Value is not null
                          && !string.IsNullOrWhiteSpace(fs.Value.ToString()))
                .ToDictionary(fs => fs.FieldCode, fs => (object?)fs.Value);

            if (values.Count == 0)
            {
                _saveError = "Chưa có dữ liệu để lưu.";
                return;
            }

            var result = await LookupQuerySvc.InsertAsync(FieldId, values);
            if (!result.Success)
            {
                _saveError = result.Error ?? "Lưu thất bại.";
                return;
            }

            await OnSaved.InvokeAsync((result.Value, result.Display));
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }
        finally { _saving = false; }
    }

    private async Task OnCancel() => await OnClose.InvokeAsync();

    /// <summary>Chuyển Editor_Type DB → type lowercase cho FieldRenderer (đồng bộ FormRunner).</summary>
    private static string NormalizeFieldType(string dbType, string? lookupSource)
        => dbType.ToLower() switch
    {
        "textbox"      or "text"                              => "text",
        "textarea"     or "memo"                              => "textarea",
        "numberedit"   or "number" or "numericbox"            => "number",
        "dateedit"     or "date"   or "datepicker"            => "date",
        "datetimeedit" or "datetime" or "datetimepicker"      => "datetime",
        "checkbox"     or "bool"                              => "bool",
        "toggleswitch" or "toggle"                            => "switch",
        "combobox"     => lookupSource == "dynamic" ? "combobox" : "select",
        "select" or "lookupedit" or "dropdown" or "multiselect"
            or "radiogroup" or "lookupcombobox"               => "select",
        "lookupbox"                                           => "fklookup",
        "treelookupbox" or "treelookup"                       => "treelookup",
        _                                                     => "text"
    };
}
