@* File    : ViewPage.razor
   Purpose : Màn hiển thị danh sách metadata-driven từ Ui_View (route /view/{ViewCode}).
             Gọi api/v1/views/{code}/info + /data; render DataView (Grid/TreeList). *@

@page "/view/{ViewCode}"
@using ICare247.Blazor.RuntimeCheck.Services
@using ICare247.Blazor.RuntimeCheck.Components.View
@inject ViewApiService ViewApi
@inject NavigationManager Nav

<PageTitle>@(_view?.Title ?? _view?.ViewCode ?? ViewCode) — View</PageTitle>

<div class="page-container">
    @if (_loading)
    {
        <div class="md-form-loading"><div class="spinner"></div><span>Đang tải View…</span></div>
    }
    else if (_error is not null)
    {
        <div class="error-banner"><strong>⚠ Lỗi:</strong> @_error</div>
    }
    else if (_view is not null)
    {
        <div class="md-list-header">
            <div>
                <h2>@(_view.Title ?? _view.ViewCode)</h2>
                <span class="md-list-sub">Bảng @_view.TableCode · @_view.ViewType</span>
            </div>
            @if (_view.AllowAdd && !string.IsNullOrWhiteSpace(_view.EditFormCode))
            {
                <button class="btn btn-primary" @onclick="OpenAdd">+ Thêm mới</button>
            }
        </div>

        @if (_view.ShowSearchBox)
        {
            <div class="md-list-toolbar">
                <input class="md-search" placeholder="🔍 Tìm kiếm…" value="@_search"
                       @onchange="OnSearchChanged" />
            </div>
        }

        <DataView View="_view" Items="_items" OnEdit="OpenEdit" OnDelete="OpenDelete"
                  OnAdd="OpenAdd" OnRefresh="ReloadDataAsync" OnUnhandledAction="OnUnhandledAction" />

        @if (_notice is not null)
        {
            <div class="md-list-notice">@_notice</div>
        }

        <div class="md-list-footer">Hiển thị @_items.Count / @_total bản ghi</div>
    }
</div>

@code {
    [Parameter] public string ViewCode { get; set; } = "";

    private ViewMetadataDto? _view;
    private List<Dictionary<string, object?>> _items = [];
    private int _total;
    private bool _loading = true;
    private string? _error;
    private string? _search;
    private string? _notice;

    protected override async Task OnParametersSetAsync() => await InitAsync();

    private async Task InitAsync()
    {
        _loading = true; _error = null;
        try
        {
            _view = await ViewApi.GetInfoAsync(ViewCode);
            if (_view is null) { _error = $"Không tìm thấy View '{ViewCode}'."; return; }
            await ReloadDataAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task ReloadDataAsync()
    {
        var pageSize = _view!.PageSize < 1 ? 50 : _view.PageSize;
        var result = await ViewApi.GetDataAsync(ViewCode, _search, page: 1, pageSize: pageSize);
        _items = result?.Items ?? [];
        _total = result?.TotalCount ?? 0;
    }

    private async Task OnSearchChanged(ChangeEventArgs e)
    {
        _search = e.Value?.ToString();
        await ReloadDataAsync();
    }

    /// <summary>Mở form Thêm của Edit_Form gắn với View (tab edit route).</summary>
    private void OpenAdd()
    {
        if (string.IsNullOrWhiteSpace(_view?.EditFormCode)) return;
        Nav.NavigateTo($"/master/{Uri.EscapeDataString(_view.EditFormCode)}/edit");
    }

    private void OpenEdit(object? id)
    {
        if (string.IsNullOrWhiteSpace(_view?.EditFormCode) || id is null) return;
        Nav.NavigateTo($"/master/{Uri.EscapeDataString(_view.EditFormCode)}/edit/{Uri.EscapeDataString(id.ToString() ?? "")}");
    }

    /// <summary>Xóa: điều hướng sang màn danh mục của Edit_Form (có dialog xác nhận xóa).</summary>
    private void OpenDelete(object? id)
    {
        if (string.IsNullOrWhiteSpace(_view?.EditFormCode)) return;
        Nav.NavigateTo($"/master/{Uri.EscapeDataString(_view.EditFormCode)}");
    }

    /// <summary>Action chưa hỗ trợ client (print/event/api/export server-side) → hiện thông báo.</summary>
    private void OnUnhandledAction(ViewActionDto a)
    {
        _notice = a.ActionType.Equals("Export", StringComparison.OrdinalIgnoreCase)
            ? $"Xuất {a.ExportFormat} server-side (pdf/docx) chưa hỗ trợ — sẽ bổ sung sau."
            : $"Action '{a.ActionType}' ({a.ActionCode}) chưa được hỗ trợ ở runtime.";
    }
}
