<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="DevExpress 25.2 Local" value="C:\Program Files\DevExpress 25.2\Components\System\Components\Packages" />
  </packageSources>
  <!-- Xóa fallbackPackageFolders kế thừa từ machine-level config (DevExpress 24.2 installer để lại) -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>
</configuration>
