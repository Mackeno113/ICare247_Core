@* File    : FieldRenderer.razor
   Purpose : Render một field dựa vào FieldType + FieldState.
             Hỗ trợ: text, number, date, datetime, bool, textarea, select.
             Phát event OnChange khi user thay đổi giá trị. *@

@if (State is not null && State.IsVisible)
{
    <div class="field-wrapper @(State.Errors.Count > 0 ? "has-error" : "")">
        <label class="field-label">
            @State.Label
            @if (State.IsRequired)
            {
                <span class="required-mark"> *</span>
            }
        </label>

        @switch (State.FieldType.ToLower())
        {
            case "textarea":
                <textarea class="field-input"
                          value="@State.ValueString"
                          disabled="@State.IsReadOnly"
                          rows="3"
                          @onchange="HandleChange"
                          @onblur="HandleBlur" />
                break;

            case "number":
                <input type="number" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;

            case "date":
                <input type="date" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;

            case "datetime":
                <input type="datetime-local" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;

            case "bool":
                <div class="bool-wrapper">
                    <input type="checkbox" id="@($"chk_{State.FieldCode}")"
                           checked="@(State.ValueString == "true" || State.ValueString == "True")"
                           disabled="@State.IsReadOnly"
                           @onchange="HandleBoolChange" />
                    <label for="@($"chk_{State.FieldCode}")" class="bool-label">@State.Label</label>
                </div>
                break;

            default:
                @* text, select (fallback về text input) *@
                <input type="text" class="field-input"
                       value="@State.ValueString"
                       disabled="@State.IsReadOnly"
                       @onchange="HandleChange"
                       @onblur="HandleBlur" />
                break;
        }

        @if (State.Errors.Count > 0)
        {
            <div class="field-errors">
                @foreach (var err in State.Errors)
                {
                    <span class="field-error">@err</span>
                }
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public FieldState?                           State    { get; set; }
    [Parameter]                 public EventCallback<(string Code, object? Value)> OnChange { get; set; }
    [Parameter]                 public EventCallback<string>                  OnBlur   { get; set; }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (State is null) return;
        State.Value = e.Value;
        await OnChange.InvokeAsync((State.FieldCode, e.Value));
    }

    private async Task HandleBoolChange(ChangeEventArgs e)
    {
        if (State is null) return;
        var val = e.Value is bool b ? b : bool.TryParse(e.Value?.ToString(), out var r) && r;
        State.Value = val;
        await OnChange.InvokeAsync((State.FieldCode, val));
    }

    private async Task HandleBlur(FocusEventArgs _)
    {
        if (State is null) return;
        await OnBlur.InvokeAsync(State.FieldCode);
    }
}
